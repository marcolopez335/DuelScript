// ミラァと燐寸之仔
// Mira Match
// Transpiled from c44201739.lua

card "Mira Match" {
    id: 44201739
    type: Effect Monster
    attribute: FIRE
    race: Spellcaster
    level: 1
    atk: 0
    def: 0

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        activate_from: [hand]
        on_resolve {
            reveal (1+, card, opponent controls)
            special_summon (1, monster) from gy
            shuffle_hand
            shuffle_deck
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        cost {
            send self to gy
        }
        on_resolve {
            send (1+, card, you controls, hand) to gy
            negate activation
        }
    }

}
