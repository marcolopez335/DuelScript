card "Light Dragon @Ignister" {
    id: 61399402
    type: Xyz Monster
    attribute: LIGHT
    race: Cyberse
    rank: 4
    atk: 2300
    def: 1500

    summon {
        cannot_normal_summon
        xyz materials: (2, monster, where level == 4)
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        mandatory
        cost {
            detach 1 from self
        }
        resolve {
            destroy (all, card, either controls)
        }
    }

    effect "Effect 3" {
        speed: 1
        once_per_turn: soft
        timing: when
        trigger: destroyed_by_battle
        resolve {
            special_summon (all, card, either controls)
        }
    }

    replacement "Effect 1" {
        instead_of: destroyed
        do {
            banish self
        }
    }
}
