// 竜の闘志
// Dragon's Fighting Spirit
// Transpiled from c95697223.lua

card "Dragon's Fighting Spirit" {
    id: 95697223
    type: Quick-Play Spell

    effect "Effect 1" {
        speed: spell_speed_1
        damage_step: false
        on_activate {
            select (1+, monster, opponent controls, where { is_face_up and race == Dragon }) as target
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
