// 猿魔王ゼーマン
// Zeman the Ape King
// Transpiled from c22858242.lua

card "Zeman the Ape King" {
    id: 22858242
    type: Synchro Monster
    attribute: EARTH
    race: Beast
    level: 7
    atk: 2500
    def: 1800

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    summon_condition {
        cannot_normal_summon: true
    }

    continuous_effect "Effect 1" {
        scope: field
        grant: cannot_activate_effects
    }

    effect "Effect 2" {
        speed: spell_speed_1
        optional: true
        timing: when
        damage_step: false
        trigger: when attack_declared
        on_activate {
            select (1+, monster, you controls, where { is_monster }) as target
        }
        cost {
            send self to gy
        }
        on_resolve {
            negate attack
        }
    }

}
