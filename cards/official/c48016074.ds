card "Charmers of the Grand Circle" {
    id: 48016074
    type: Fusion Monster
    attribute: LIGHT
    race: Spellcaster
    level: 6
    atk: 1850
    def: 1500

    summon {
        cannot_normal_summon
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            add_to_hand (1, card, where archetype == "Possessed" and not is_monster) from deck
            add_to_hand (1, card, where archetype == "Possessed" and not is_monster) from deck
            special_summon (all, card, either controls)
        }
    }
}
