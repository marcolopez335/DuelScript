card "Raidraptor - Readiness" {
    id: 21648584
    type: Normal Trap

    effect "Effect 1" {
        speed: 2
        mandatory
        resolve {
            grant (all, card, you control, from monster_zone, where archetype == "Raidraptor") cannot_be_destroyed by battle until end_of_turn
        }
    }

    effect "Effect 2" {
        speed: 2
        cost {
            banish self
        }
        resolve {
            damage_rule you no_damage end_of_turn
        }
    }
}
