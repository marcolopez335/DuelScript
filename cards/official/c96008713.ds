// マジックアーム・シールド
// Magical Arm Shield
// Transpiled from c96008713.lua

card "Magical Arm Shield" {
    id: 96008713
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        damage_step: false
        trigger: when attack_declared
        on_activate {
            select (1+, card, either_player controls, where { is_face_up }) as target
        }
        on_resolve {
            take_control of (1, monster, opponent controls)
        }
    }

}
