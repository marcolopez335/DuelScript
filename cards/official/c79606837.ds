// 虹光の宣告者
// Herald of the Arc Light
// Transpiled from c79606837.lua

card "Herald of the Arc Light" {
    id: 79606837
    type: Synchro Monster
    attribute: LIGHT
    race: Fairy
    level: 4
    atk: 600
    def: 1000

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    summon_condition {
        cannot_normal_summon: true
    }

    redirect_effect "Effect 1" {
        when_going_to: gy
        redirect_to: banished
    }

    effect "Effect 2" {
        speed: spell_speed_2
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        cost {
            tribute self
        }
        on_resolve {
            negate activation
            destroy (1+, monster, you controls, deck)
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        optional: true
        timing: if
        trigger: on_custom_event "chain_end"
        on_resolve {
            add_to_hand (1+, monster, you controls) from deck
            reveal (1+, card, opponent controls)
        }
    }

}
