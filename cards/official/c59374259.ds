// 空牙団の奥義
// Furtive Techniques Fur Hire, Fur All Your Ultimate Moves
// Transpiled from c59374259.lua

card "Furtive Techniques Fur Hire, Fur All Your Ultimate Moves" {
    id: 59374259
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, monster, you controls) as target
        }
        on_resolve {
            banish (1+, monster, you controls)
            destroy (1+, monster, you controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        timing: when
        trigger: when_summoned by_special_summon
        activate_from: [gy]
        on_resolve {
            return (1+, monster, you controls) to hand
        }
    }

}
