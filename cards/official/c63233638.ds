card "Megalith Phaleg" {
    id: 63233638
    type: Ritual Monster
    attribute: EARTH
    race: Rock
    level: 8
    atk: 2500
    def: 1200

    summon {
        cannot_normal_summon
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        mandatory
        cost {
            discard (all, card, either controls)
        }
        resolve {
            ritual_summon (1, ritual monster, where archetype == "Megalith")
        }
    }


    passive "Passive 2" {
        scope: field
        target: (all, monster, you control)
        modifier: atk + count((all, ritual monster, you control, from gy)) * 300
    }


    passive "Passive 3" {
        scope: field
        target: (all, monster, you control)
        modifier: def + count((all, ritual monster, you control, from gy)) * 300
    }
}
