card "Delta Tri" {
    id: 12079734
    type: Effect Monster
    attribute: LIGHT
    race: Machine
    level: 4
    atk: 1200
    def: 1000

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        timing: when
        damage_step: false
        trigger: when_battle_damage
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            equip (1, card) to (1, monster)
            return (1+, card, either_player controls) to deck shuffle
            shuffle_deck
            draw 1
        }
    }

}
