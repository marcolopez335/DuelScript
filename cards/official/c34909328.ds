// ライゼオル・デッドネーダー
// Ryzeal Detonator
// Transpiled from c34909328.lua

card "Ryzeal Detonator" {
    id: 34909328
    type: Xyz Monster
    attribute: LIGHT
    race: Pyro
    rank: 4
    atk: 3000
    def: 2500

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        same_level: true
        method: xyz
    }

    effect "Effect 1" {
        speed: spell_speed_2
        optional: true
        timing: when
        damage_step: false
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        cost {
            detach 1 overlay_unit from self
        }
        on_resolve {
            destroy (1+, monster, you controls, gy)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        on_resolve {
            attach (1, card) to self as_material
        }
    }

    replacement_effect "Effect 3" {
        instead_of: destroyed_by_any
        do: {
            banish self
        }
    }

}
