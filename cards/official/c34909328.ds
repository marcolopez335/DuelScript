card "Ryzeal Detonator" {
    id: 34909328
    type: Xyz Monster
    attribute: LIGHT
    race: Pyro
    rank: 4
    atk: 3000
    def: 2500

    summon {
        cannot_normal_summon
        xyz materials: (2, monster, where level == 4 and archetype == "Ryzeal")
    }

    effect "Effect 1" {
        speed: 2
        timing: when
        trigger: opponent_activates [activate_spell, activate_trap, activate_spell]
        target (1, card, either controls, from field)
        cost {
            detach 1 from self
        }
        resolve {
            destroy (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            destroy target
        }
    }

    replacement "Effect 3" {
        instead_of: destroyed
        do {
            banish self
        }
    }
}
