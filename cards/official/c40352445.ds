// 凶導の白騎士
// White Knight of Dogmatika
// Transpiled from c40352445.lua

card "White Knight of Dogmatika" {
    id: 40352445
    type: Ritual Monster
    attribute: LIGHT
    race: Spellcaster
    level: 8
    atk: 500
    def: 2500

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 1+ monster
        method: ritual
    }

    raw_effect "Effect 1" {
        effect_type: Field
        code: CannotDisable
        property: InitialValue
        range: MonsterZone
        on_resolve {
            register_effect on self { grant: cannot_be_used_as_material duration: until_end_of_turn }
        }
    }

    raw_effect "Effect 2" {
        effect_type: Field + Trigger
        category: ToGrave + SynchroSummon
        code: Chaining
        property: Delay
        range: MonsterZone
        count_limit: (1, 40352445)
        on_resolve {
            send (1+, card, either_player controls) to gy
            reveal (1+, card, opponent controls)
            send (1+, card, either_player controls) to gy
            shuffle_deck
        }
    }

    raw_effect "Effect 3" {
        effect_type: Single
        code: UpdateAttack
        on_resolve {
            modifier: atk + 0
        }
    }

}
