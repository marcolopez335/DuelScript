// ヴァレット・バラージュ
// Rokket Barrage
// Transpiled from c53481938.lua

card "Rokket Barrage" {
    id: 53481938
    type: Effect Monster
    attribute: DARK
    race: Dragon
    level: 5
    atk: 1500
    def: 1600

    summon_condition {
        tributes_required: 1
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        activate_from: [hand]
        cost {
            send self to gy
        }
        on_resolve {
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            destroy (1+, card, you controls, hand)
            special_summon (1, monster) from gy
        }
    }

}
