card "Arms of Genex Return Zero" {
    password: 61775475
    type: Synchro Monster
    attribute: DARK
    race: Machine
    level: 10
    atk: 3100
    def: 2950

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    raw_effect "Effect 1" {
        effect_type: QuickEffect
