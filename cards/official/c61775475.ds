// Ａ・Ｏ・Ｇ リターンゼロ
// Arms of Genex Return Zero
// Transpiled from c61775475.lua

card "Arms of Genex Return Zero" {
    id: 61775475
    type: Synchro Monster
    attribute: DARK
    race: Machine
    level: 10
    atk: 3100
    def: 2950

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    effect "Effect 1" {
        speed: spell_speed_2
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        cost {
            banish self
        }
        on_resolve {
            negate activation
            destroy (1+, card, you controls, gy)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_activate {
            select (1+, card, you controls) as target
        }
        on_resolve {
            return (1+, card, you controls) to deck shuffle
            destroy (1+, card, you controls, gy)
        }
    }

}
