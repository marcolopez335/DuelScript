    raw_effect "Effect 2" {
        effect_type: Ignition
        category: Destroy + ToDeck
        property: 16
        range: MonsterZone
        count_limit: (1, 0)
        on_resolve {
            return (1+, card, you controls) to deck shuffle
            destroy (1+, card, you controls, gy)
        }
    }

