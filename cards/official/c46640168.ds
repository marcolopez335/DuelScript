card "Fiendsmith's Lacrima" {
    id: 46640168
    type: Fusion Monster
    attribute: LIGHT
    race: Fiend
    level: 6
    atk: 2400
    def: 2400

    summon {
        cannot_normal_summon
        special_summon_procedure {
            from: extra_deck
            to: your_field
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            add_to_hand (all, card, either controls)
            special_summon (all, card, either controls)
        }
    }

    effect "Effect 3" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: custom "chain_end"
        resolve {
            damage opponent 1000
        }
    }
}
