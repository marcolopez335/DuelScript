// ビッグウェルカム・ラビュリンス
// Big Welcome Labrynth
// Transpiled from c92714517.lua

card "Big Welcome Labrynth" {
    id: 92714517
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        on_resolve {
            special_summon (1, monster) from gy
            add_to_hand (1+, card, you controls, where { is_face_up and race == Fiend }) from gy
            destroy (1, monster, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        damage_step: false
        activate_from: [gy]
        on_activate {
            select (1+, card, you controls, where { is_face_up and race == Fiend }) as target
        }
        cost {
            banish self
        }
        on_resolve {
            add_to_hand (1+, card, you controls, where { is_face_up and race == Fiend }) from gy
        }
    }

}
