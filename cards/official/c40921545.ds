card "Evilswarm Ketos" {
    id: 40921545
    type: Effect Monster
    attribute: DARK
    race: Aqua
    level: 4
    atk: 1750
    def: 1050

    effect "Effect 1" {
        speed: spell_speed_1
        damage_step: false
        on_activate {
            select (1+, spell, either_player controls, where { is_spell }) as target
        }
        cost {
            tribute self
        }
        on_resolve {
            destroy (1+, spell, either_player controls, where { is_spell })
        }
    }

}
