card "Branded Opening" {
    id: 36637374
    type: Quick-Play Spell

    effect "Effect 1" {
        speed: 2
        once_per_turn: hard
        mandatory
        resolve {
            discard (all, card, either controls)
            add_to_hand (all, card, either controls)
            special_summon (all, card, either controls)
        }
    }

    replacement "Effect 2" {
        instead_of: destroyed
        do {
            banish self
        }
    }
}
