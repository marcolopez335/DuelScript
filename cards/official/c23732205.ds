// デリンジャラス・ドラゴン
// Dillingerous Dragon
// Transpiled from c23732205.lua

card "Dillingerous Dragon" {
    id: 23732205
    type: Link Monster
    attribute: DARK
    race: Dragon
    link: 2
    link_arrows: [top, bottom]
    atk: 1600

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ effect monster
        method: link
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: when
        damage_step: false
        trigger: during_end_phase
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            destroy (1+, card, either_player controls)
            deal_damage to opponent: 1000
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: when
        trigger: when_summoned by_special_summon
        activate_from: [gy]
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
