// アヌビスの裁き
// Judgment of Anubis
// Transpiled from c55256016.lua

card "Judgment of Anubis" {
    id: 55256016
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            negate activation
            destroy (1+, spell, opponent controls)
            destroy (1+, spell, opponent controls)
            deal_damage to opponent: 1000
        }
    }

}
