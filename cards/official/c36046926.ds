card "Sylvan Marshalleaf" {
    id: 36046926
    type: Effect Monster
    attribute: WATER
    race: Plant
    level: 3
    atk: 1500
    def: 1200

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        timing: when
        trigger: when_summoned
        on_resolve {
            reveal (1, card, opponent controls, deck)
            send (1+, card, either_player controls) to gy
            send_to_deck (1+, card, you controls) bottom
            send_to_deck (1+, card, you controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        optional: true
        timing: if
        damage_step: false
        trigger: on_custom_event "chain_end"
        on_resolve {
            destroy (1+, card, either_player controls)
        }
    }

}
