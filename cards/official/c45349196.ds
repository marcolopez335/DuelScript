// Archfiend Black Skull Dragon
// Transpiled from c45349196.lua

card "Archfiend Black Skull Dragon" {
    id: 45349196
    type: Fusion Monster
    attribute: DARK
    race: Dragon
    level: 9
    atk: 3200
    def: 2500

    materials {
        require: 2+ monster
        method: fusion
    }

    summon_condition {
        cannot_normal_summon: true
    }

    raw_effect "Effect 1" {
        effect_type: Field
        code: CannotChangeControl
        property: InitialValue
        range: MonsterZone
        on_resolve {
            register_effect on self { grant: cannot_activate_effects duration: until_end_of_turn }
        }
    }

    raw_effect "Effect 2" {
        effect_type: Field + Trigger
        category: ToDeck + Damage
        code: PhaseBattleStep
        property: CardTarget
        range: MonsterZone
        count_limit: (1, 0)
        on_resolve {
            deal_damage to opponent: 1000
            return (1+, card, either_player controls) to deck shuffle
        }
    }

}
