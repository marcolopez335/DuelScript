// 『焔聖剣－アルマス』
// 'Infernoble Arms - Almace'
// Transpiled from c98319530.lua

card "'Infernoble Arms - Almace'" {
    id: 98319530
    type: Equip Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [spell_trap_zone]
        on_resolve {
            equip (1, card) to (1, monster)
            destroy (1+, monster, you controls, where { is_face_up and attribute == FIRE and race == Warrior })
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        damage_step: false
        trigger: on_custom_event "chain_end"
        on_activate {
            select (1+, monster, you controls, where { is_face_up and attribute == FIRE and race == Warrior }) as target
        }
        on_resolve {
            return (1+, monster, you controls, where { is_face_up and attribute == FIRE and race == Warrior }) to hand
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        on_resolve {
            equip self to (1, monster, you controls)
        }
    }

}
