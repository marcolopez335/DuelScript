card "Ghostrick Siren" {
    id: 64804316
    type: Effect Monster
    attribute: DARK
    race: Fairy
    level: 4
    atk: 800
    def: 1500

    continuous_effect "Effect 1" {
        scope: self
        grant: cannot_attack
    }

    effect "Effect 2" {
        speed: spell_speed_1
        on_resolve {
            change_battle_position (1, monster)
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        trigger: when_summoned
        on_resolve {
            mill 2
            add_to_hand (1+, spell, you controls) from deck
            reveal (1+, card, opponent controls)
            change_battle_position (1, monster)
        }
    }

    effect "Effect 4" {
        speed: spell_speed_1
        trigger: on_custom_event "chain_active"
        on_resolve {
            mill 2
            add_to_hand (1+, spell, you controls) from deck
            reveal (1+, card, opponent controls)
            change_battle_position (1, monster)
        }
    }

}
