card "Luce the Dusk's Dark" {
    id: 45409943
    type: Fusion Monster
    attribute: DARK
    race: Fiend
    level: 8
    atk: 3500
    def: 3000

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        method: fusion
    }

    continuous_effect "Effect 1" {
        scope: field
        grant: cannot_be_destroyed_by_effect
