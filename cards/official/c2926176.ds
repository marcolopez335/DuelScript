// 王家の呪い
// Curse of Royal
// Transpiled from c2926176.lua

card "Curse of Royal" {
    id: 2926176
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            negate activation
            destroy (1+, spell, either_player controls, where { is_spell })
        }
    }

}
