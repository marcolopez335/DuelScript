// ペンギン魚雷
// Penguin Torpedo
// Transpiled from c17679043.lua

card "Penguin Torpedo" {
    id: 17679043
    type: Effect Monster
    attribute: WATER
    race: Aqua
    level: 3
    atk: 550
    def: 300

    continuous_effect "Effect 1" {
        scope: self
        grant: direct_attack
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: when
        damage_step: false
        trigger: when_battle_destroyed
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            take_control of (1, monster, opponent controls)
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    raw_effect "Effect 3" {
        effect_type: Single + MandatoryTrigger
        category: Destroy
        code: BattleDestroyed
        on_resolve {
            destroy (1+, card, either_player controls)
        }
    }

    continuous_effect "Effect 4" {
        scope: self
        grant: cannot_attack
    }

}
