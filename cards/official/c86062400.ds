// エクシーズ・アヴェンジャー
// Xyz Avenger
// Transpiled from c86062400.lua

card "Xyz Avenger" {
    id: 86062400
    type: Effect Monster
    attribute: DARK
    race: Fiend
    level: 4
    atk: 1800
    def: 700

    raw_effect "Effect 1" {
        effect_type: Single
        code: ImmuneEffect
        property: SingleRange
        range: MonsterZone
        on_resolve {
            register_effect on self { grant: unaffected_by_card_effects duration: until_end_of_turn }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        trigger: when_battle_damage
        on_resolve {
            reveal (1+, card, opponent controls)
            send (1+, card, either_player controls) to gy
            shuffle_deck
        }
    }

}
