// 未み界かい域いきのワーウルフ
// Danger! Dogman!
// Transpiled from c26302107.lua

card "Danger! Dogman!" {
    id: 26302107
    type: Effect Monster
    attribute: DARK
    race: Beast-Warrior
    level: 7
    atk: 2400
    def: 1000

    summon_condition {
        tributes_required: 2
    }

    effect "Effect 1" {
        speed: spell_speed_1
        activate_from: [hand]
        on_resolve {
            shuffle_hand
            send (1+, monster, opponent controls) to gy
            special_summon (1, monster) from gy
            draw 1
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: on_custom_event "chain_end"
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    raw_effect "Effect 3" {
        effect_type: Single + Trigger
        category: AtkChange
        code: TurnEnd
        property: Delay
        count_limit: (1, 26302107)
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
