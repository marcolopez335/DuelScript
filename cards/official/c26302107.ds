card "Danger! Dogman!" {
    id: 26302107
    type: Effect Monster
    attribute: DARK
    race: Beast-Warrior
    level: 7
    atk: 2400
    def: 1000

    summon {
        tributes: 2
    }

    effect "Effect 1" {
        speed: 1
        mandatory
        resolve {
            send (all, card, either controls) to gy
            special_summon (all, card, either controls)
            draw 1
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: custom "chain_end"
        condition: previous_location == hand and reason includes discard
        resolve {
            send target to gy
            draw 1
        }
    }
}
