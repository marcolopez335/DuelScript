card "Draco Masters of the Tenyi" {
    id: 23935886
    type: Link Monster
    attribute: LIGHT
    race: Wyrm
    link: 3
    link_arrows: [bottom_left, bottom, bottom_right]
    atk: 2600

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ effect monster
        method: link
    }

    raw_effect "Effect 1" {
        effect_type: Single
        code: CannotBeEffectTarget
        on_resolve {
            register_effect on self { grant: cannot_be_destroyed_by_battle duration: until_end_of_turn }
