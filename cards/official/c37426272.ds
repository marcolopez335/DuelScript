// マテリアクトル・エクサレプト
// Materiactor Exareptor
// Transpiled from c37426272.lua

card "Materiactor Exareptor" {
    id: 37426272
    type: Effect Monster
    attribute: WATER
    race: Dragon
    level: 3
    atk: 1500
    def: 1500

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [hand]
        on_resolve {
            add_to_hand (1+, card, you controls, where { level == 3 and is_monster }) from hand
            reveal (1+, card, opponent controls)
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        optional: true
        damage_step: false
        activate_from: [hand]
        on_activate {
            select (1+, card, you controls, where { level == 3 and is_monster }) as target
        }
        cost {
            discard (1, card, you controls)
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    raw_effect "Effect 3" {
        effect_type: Single
        code: UpdateAttack
        property: BothSide
        on_resolve {
            modifier: atk + 1500
        }
    }

}
