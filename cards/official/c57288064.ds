// 刀神－不知火
// Shiranui Samuraisaga
// Transpiled from c57288064.lua

card "Shiranui Samuraisaga" {
    id: 57288064
    type: Synchro Monster
    attribute: FIRE
    race: Zombie
    level: 6
    atk: 2500
    def: 0

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        damage_step: false
        on_activate {
            select (1+, monster, opponent controls, where { is_face_up and race == Zombie }) as target
        }
        on_resolve {
            return (1+, monster, opponent controls, where { is_face_up and race == Zombie }) to deck shuffle
            change_battle_position (1, monster)
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single + Trigger
        code: TurnEnd
        property: CardTarget + Oath + Delay
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
