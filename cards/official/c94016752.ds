// 深淵の宣告者
// Herald of the Abyss
// Transpiled from c94016752.lua

card "Herald of the Abyss" {
    id: 94016752
    type: Normal Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        cost {
            pay_lp 1500
        }
        on_resolve {
            send (1+, monster, opponent controls, where { is_face_up }) to gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    continuous_effect "Effect 2" {
        scope: field
        grant: cannot_activate_effects
    }

}
