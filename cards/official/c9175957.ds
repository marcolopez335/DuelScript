card "Tally-ho! Springans" {
    id: 9175957
    type: Quick-Play Spell

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        cost {
            detach 1 overlay_unit from self
        }
        on_resolve {
            add_to_hand (1+, monster, you controls, where { is_face_up and is_xyz }) from gy
            reveal (1+, card, opponent controls)
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: hard
        damage_step: false
        activate_from: [gy]
        on_activate {
            select (1+, monster, you controls, where { is_face_up and is_xyz }) as target
        }
        on_resolve {
            add_to_hand (1+, monster, you controls, where { is_face_up and is_xyz }) from gy
            reveal (1+, card, opponent controls)
        }
    }

}
