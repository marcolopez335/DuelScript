// ラッシュ・ウォリアー
// Rush Warrior
// Transpiled from c36736723.lua

card "Rush Warrior" {
    id: 36736723
    type: Effect Monster
    attribute: WIND
    race: Warrior
    level: 2
    atk: 300
    def: 1200

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        timing: when
        trigger: when attack_declared
        activate_from: [hand]
        cost {
            send self to gy
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        activate_from: [gy]
        on_activate {
            select (1+, monster, either_player controls) as target
        }
        cost {
            banish self
        }
        on_resolve {
            add_to_hand (1+, monster, either_player controls) from gy
        }
    }

}
