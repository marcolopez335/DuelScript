// ラッシュ・ウォリアー
// Rush Warrior
// Transpiled from c36736723.lua

card "Rush Warrior" {
    id: 36736723
    type: Effect Monster
    attribute: WIND
    race: Warrior
    level: 2
    atk: 300
    def: 1200

    raw_effect "Effect 1" {
        effect_type: QuickEffect
        code: AttackEnd
        range: Hand
        count_limit: (1, 36736723)
        cost {
            send self to gy
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        activate_from: [gy]
        cost {
            banish self
        }
        on_resolve {
            add_to_hand (1+, monster, either_player controls) from gy
        }
    }

}
