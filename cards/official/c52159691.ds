card "Raider's Wing" {
    id: 52159691
    type: Effect Monster
    attribute: DARK
    race: Winged Beast
    level: 4
    atk: 0
    def: 2000

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [hand, gy]
        cost {
            send self to gy
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
