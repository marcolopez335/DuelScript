// 転生炎獣の超転生
// Salamangreat Transcendence
// Transpiled from c54529134.lua

card "Salamangreat Transcendence" {
    id: 54529134
    type: Quick-Play Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            send (1+, card, either_player controls) to gy
            special_summon (1, monster) from gy
        }
    }

}
