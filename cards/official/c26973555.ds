card "Number F0: Utopic Draco Future" {
    id: 26973555
    type: Xyz Monster
    attribute: LIGHT
    race: Warrior
    rank: 1
    atk: 3000
    def: 2000

    summon {
        cannot_normal_summon
        special_summon_procedure {
            from: extra_deck
            to: your_field
        }
    }

    passive "Effect 1" {
        scope: self
        grant: cannot_be_destroyed by battle
    }

    passive "Effect 2" {
        scope: self
        grant: cannot_be_destroyed by effect
    }

    effect "Effect 3" {
        speed: 2
        once_per_turn: soft
        timing: when
        trigger: opponent_activates [activate_spell, activate_trap, activate_spell]
        cost {
            detach 1 from self
        }
        resolve {
            negate
            take_control (all, card, either controls)
        }
    }
}
