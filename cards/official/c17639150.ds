card "Saqlifice" {
    id: 17639150
    type: Equip Spell

    passive "Effect 2" {
        scope: self
        grant: cannot_be_destroyed by battle
    }

    effect "Effect 4" {
        speed: 1
        timing: if
        trigger: custom "chain_end"
        condition: previous_location == field
        resolve {
            add_to_hand (all, card, either controls)
        }
    }

    effect "Effect 5" {
        speed: 1
        mandatory
        resolve {
            add_to_hand target
        }
    }


    passive "Passive 6" {
        target: equipped_card
        modifier: atk + 300
    }
}
