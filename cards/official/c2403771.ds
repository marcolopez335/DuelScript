card "Power Tool Dragon" {
    id: 2403771
    type: Synchro Monster
    attribute: EARTH
    race: Machine
    level: 7
    atk: 2300
    def: 2500

    summon {
        cannot_normal_summon
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: soft
        mandatory
        resolve {
            add_to_hand (all, card, either controls)
        }
    }

    replacement "Effect 2" {
        instead_of: destroyed
        do {
            banish self
        }
    }
}
