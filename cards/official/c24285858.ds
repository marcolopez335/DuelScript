// グラディアル・リターン
// Gladiator's Return
// Transpiled from c24285858.lua

card "Gladiator's Return" {
    id: 24285858
    type: Normal Spell

    effect "Effect 1" {
        speed: spell_speed_1
        damage_step: false
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            return (1+, card, either_player controls) to deck shuffle
            shuffle_deck
            draw 1
        }
    }

}
