// 幻獣サンダーペガス
// Phantom Beast Thunder-Pegasus
// Transpiled from c34961968.lua

card "Phantom Beast Thunder-Pegasus" {
    id: 34961968
    type: Effect Monster
    attribute: LIGHT
    race: Beast-Warrior
    level: 4
    atk: 700
    def: 2000

    effect "Effect 1" {
        speed: spell_speed_2
        optional: true
        timing: when
        damage_step: false
        trigger: when attack_declared
        activate_from: [gy]
        on_activate {
            select (1+, card, either_player controls) as target
        }
        cost {
            banish self
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
