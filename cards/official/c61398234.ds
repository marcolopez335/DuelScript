card "Gate Guardian of Wind and Water" {
    id: 61398234
    type: Fusion Monster
    attribute: WIND
    race: Spellcaster
    level: 9
    atk: 2450
    def: 2300

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        method: fusion
    }

    effect "Effect 1" {
        speed: spell_speed_2
        twice_per_turn
