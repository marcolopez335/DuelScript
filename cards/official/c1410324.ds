// トリックスター・フーディ
// Trickstar Hoody
// Transpiled from c1410324.lua

card "Trickstar Hoody" {
    id: 1410324
    type: Effect Monster
    attribute: LIGHT
    race: Fairy
    level: 2
    atk: 600
    def: 1800

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [hand]
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        trigger: when_flipped
        on_resolve {
            return (1+, monster, you controls) to hand
            reveal (1+, card, opponent controls)
        }
    }

}
