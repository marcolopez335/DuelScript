card "Do a Barrel Roll" {
    id: 6260554
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        cost {
            tribute self
        }
        on_resolve {
            negate activation
            destroy (1+, monster, you controls)
        }
    }

