// 絶望と希望の逆転
// Exchange of Despair and Hope
// Transpiled from c25209168.lua

card "Exchange of Despair and Hope" {
    id: 25209168
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        on_resolve {
            send (1+, trap, either_player controls) to gy
            special_summon (1, monster) from gy
            special_summon (1, monster) from gy
            set (1, card)
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
