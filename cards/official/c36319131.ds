card "Fighting Flame Dragon" {
    id: 36319131
    type: Fusion Monster
    attribute: FIRE
    race: Dragon
    level: 5
    atk: 1700
    def: 1600

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        method: fusion
    }

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        damage_step: false
        activate_from: [monster_zone, gy]
        on_activate {
            select (1+, card, either_player controls, where { race == Warrior and is_fusion and is_face_up }) as target
        }
        on_resolve {
            equip (1, card) to (1, monster)
        }
    }

    raw_effect "Effect 2" {
        effect_type: Equip
        code: UpdateAttack
        on_resolve {
            modifier: atk + 700
        }
    }

    raw_effect "Effect 3" {
        effect_type: Equip
        code: 194
        on_resolve {
        }
    }

}
