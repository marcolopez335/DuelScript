// クロス・ポーター
// Cross Porter
// Transpiled from c73146473.lua

card "Cross Porter" {
    id: 73146473
    type: Effect Monster
    attribute: DARK
    race: Warrior
    level: 2
    atk: 400
    def: 400

    effect "Effect 1" {
        speed: spell_speed_1
        damage_step: false
        on_activate {
            select (1+, monster, you controls) as target
        }
        on_resolve {
            send (1+, monster, you controls, hand) to gy
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        optional: true
        timing: when
        trigger: on_custom_event "chain_end"
        on_resolve {
            add_to_hand (1+, monster, you controls) from hand
            reveal (1+, card, opponent controls)
        }
    }

}
