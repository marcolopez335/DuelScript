card "Bravo, Fighter Fur Hire" {
    id: 66740005
    type: Effect Monster
    attribute: FIRE
    race: Reptile
    level: 4
    atk: 1900
    def: 200

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        mandatory
        resolve {
            special_summon (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: summoned by special
        resolve {
            modify_atk (all, card, either controls, from monster_zone, where is_face_up and archetype == "Fur Hire") + 500 until end_of_turn
            modify_def (all, card, either controls, from monster_zone, where is_face_up and archetype == "Fur Hire") + 500 until end_of_turn
        }
    }
}
