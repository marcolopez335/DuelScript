card "S-Force Edge Razor" {
    id: 91864689
    type: Effect Monster
    attribute: DARK
    race: Cyberse
    level: 4
    atk: 1500
    def: 1300

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned
        resolve {
            special_summon (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            special_summon (1, monster, where archetype == "S-Force") from hand in attack_position
        }
    }
}
