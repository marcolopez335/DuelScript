// RR－フォース・ストリクス
// Raidraptor - Force Strix
// Transpiled from c73347079.lua

card "Raidraptor - Force Strix" {
    id: 73347079
    type: Xyz Monster
    attribute: DARK
    race: Winged Beast
    rank: 4
    atk: 100
    def: 2000

    materials {
        require: 2+ monster
        same_level: true
        method: xyz
    }

    summon_condition {
        cannot_normal_summon: true
    }

    raw_effect "Effect 1" {
        effect_type: Single
        code: UpdateAttack
        property: SingleRange
        range: MonsterZone
        on_resolve {
            modifier: atk + count((1+, monster, you controls)) * 500
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single
        code: UpdateDefense
        property: SingleRange
        range: MonsterZone
        on_resolve {
            modifier: def + count((1+, monster, you controls)) * 500
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        cost {
            detach 1 overlay_unit from self
        }
        on_resolve {
            add_to_hand (1+, card, you controls, where { attribute == DARK }) from deck
            reveal (1+, card, opponent controls)
        }
    }

}
