card "Wind-Up Snail" {
    id: 58475908
    type: Effect Monster
    attribute: WATER
    race: Aqua
    level: 2
    atk: 100
    def: 2000

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
