// 道化鳥ラフィンパフィン
// Laughing Puffin
// Transpiled from c80275707.lua

card "Laughing Puffin" {
    id: 80275707
    type: Effect Monster
    attribute: DARK
    race: Winged Beast
    level: 4
    atk: 1000
    def: 1700

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [hand]
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_activate {
            select (1+, spell, either_player controls) as target
        }
        cost {
            tribute self
        }
        on_resolve {
            return (1+, spell, either_player controls) to hand
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 3" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        damage_step: false
        on_activate {
            select (1+, spell, either_player controls) as target
        }
        cost {
            tribute self
        }
        on_resolve {
            return (1+, spell, either_player controls) to hand
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
