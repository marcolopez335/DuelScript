// サイバース・アクセラレーター
// Cyberse Accelerator
// Transpiled from c89238128.lua

card "Cyberse Accelerator" {
    id: 89238128
    type: Link Monster
    attribute: LIGHT
    race: Cyberse
    link: 3
    link_arrows: [left, right, bottom]
    atk: 2000

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ effect monster
        method: link
    }

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        damage_step: false
        on_activate {
            select (1+, card, either_player controls, where { is_face_up and race == Cyberse }) as target
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        damage_step: false
        on_activate {
            select (1+, card, either_player controls, where { is_face_up and race == Cyberse }) as target
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
