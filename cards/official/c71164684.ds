card "Mannadium Breakheart" {
    id: 71164684
    type: Normal Trap

    effect "Effect 1" {
        speed: 2
        once_per_turn: hard
        mandatory
        resolve {
            special_summon (all, card, either controls)
            destroy (all, card, either controls)
        }
