        range: MonsterZone
        count_limit: (1, 0)
        cost {
            banish self
        }
        on_resolve {
            banish (1+, card, you controls, hand)
        }
    }

    raw_effect "Effect 3" {
        effect_type: Field + MandatoryTrigger
        category: SpecialSummon
        code: PhaseStandby
        range: Banished
        count_limit: (1, 0)
        on_resolve {
