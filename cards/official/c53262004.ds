// オッドアイズ・ボルテックス・ドラゴン
// Odd-Eyes Vortex Dragon
// Transpiled from c53262004.lua

card "Odd-Eyes Vortex Dragon" {
    id: 53262004
    type: Fusion Monster
    attribute: WIND
    race: Dragon
    level: 7
    atk: 2500
    def: 3000

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        method: fusion
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: when
        damage_step: false
        trigger: when_summoned by_special_summon
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            add_to_hand (1+, card, either_player controls) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            return (1+, card, either_player controls) to deck shuffle
            negate activation
            destroy (1+, card, either_player controls)
        }
    }

}
