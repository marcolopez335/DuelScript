// Odd-Eyes Vortex Dragon
// Transpiled from c53262004.lua

card "Odd-Eyes Vortex Dragon" {
    password: 53262004
    type: Fusion Monster
    attribute: WIND
    race: Dragon
    level: 7
    atk: 2500
    def: 3000

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        trigger: when_summoned by_special_summon
        on_resolve {
            add_to_hand (1, card) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        damage_step: true
        trigger: opponent_activates [search | special_summon | send_to_gy | draw]
        on_resolve {
            return (1, card) to deck shuffle
            negate activation
            destroy (1+, card, either_player controls)
        }
    }

}
