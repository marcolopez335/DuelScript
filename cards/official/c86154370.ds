// HSR/CWライダー
// Hi-Speedroid Clear Wing Rider
// Transpiled from c86154370.lua

card "Hi-Speedroid Clear Wing Rider" {
    id: 86154370
    type: Synchro Monster
    attribute: WIND
    race: Machine
    level: 11
    atk: 3500
    def: 2000

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        on_resolve {
            flip_coin { heads { draw 1 } tails { draw 1 } }
            return (1+, card, either_player controls) to deck shuffle
            destroy (1+, card, either_player controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        optional: true
        cost {
            tribute self
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
