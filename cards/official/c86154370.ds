// HSR/CWライダー
// Hi-Speedroid Clear Wing Rider
// Transpiled from c86154370.lua

card "Hi-Speedroid Clear Wing Rider" {
    id: 86154370
    type: Synchro Monster
    attribute: WIND
    race: Machine
    level: 11
    atk: 3500
    def: 2000

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    raw_effect "Effect 1" {
        effect_type: Ignition
        category: Destroy + ToDeck + AtkChange
        range: MonsterZone
        count_limit: (1, 0)
        on_resolve {
            flip_coin { heads { draw 1 } tails { draw 1 } }
            return (1+, card, either_player controls) to deck shuffle
            destroy (1+, card, either_player controls)
        }
    }

    raw_effect "Effect 2" {
        effect_type: QuickEffect
        category: SpecialSummon
        code: FreeChain
        range: MonsterZone
        cost {
            tribute self
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
