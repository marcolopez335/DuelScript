// 一回休み
// Lose 1 Turn
// Transpiled from c24348804.lua

card "Lose 1 Turn" {
    id: 24348804
    type: Continuous Trap

    effect "Effect 1" {
        speed: spell_speed_2
        on_resolve {
            change_battle_position (1, monster)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        trigger: when_summoned by_special_summon
        activate_from: [spell_trap_zone]
        on_resolve {
            change_battle_position (1, monster)
        }
    }

    raw_effect "Effect 3" {
        effect_type: Field
        code: Disable
        range: SpellTrapZone
        on_resolve {
            register_effect on self { grant: cannot_activate_effects duration: until_end_of_turn }
        }
    }

}
