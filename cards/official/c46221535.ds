// ドリル・アームド・ドラゴン
// Drill Armed Dragon
// Transpiled from c46221535.lua

card "Drill Armed Dragon" {
    id: 46221535
    type: Effect Monster
    attribute: WIND
    race: Dragon
    level: 3
    atk: 1100
    def: 400

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [hand]
        cost {
            send self to gy
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        cost {
            banish self
        }
        on_resolve {
            add_to_hand (1+, monster, you controls) from gy
            reveal (1+, card, opponent controls)
        }
    }

}
