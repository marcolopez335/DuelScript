// 炎帝近衛兵
// Royal Firestorm Guards
// Transpiled from c54040221.lua

card "Royal Firestorm Guards" {
    id: 54040221
    type: Effect Monster
    attribute: FIRE
    race: Pyro
    level: 4
    atk: 1700
    def: 1200

    effect "Effect 1" {
        speed: spell_speed_1
        damage_step: false
        trigger: when_summoned
        on_activate {
            select (1+, card, either_player controls, where { race == Pyro }) as target
        }
        on_resolve {
            return (1+, card, either_player controls, where { race == Pyro }) to deck shuffle
            shuffle_deck
            draw 2
        }
    }

}
