card "Stardust Assault Warrior" {
    id: 97792247
    type: Synchro Monster
    attribute: WIND
    race: Warrior
    level: 6
    atk: 2100
    def: 1200

    summon {
        cannot_normal_summon
        synchro materials {
            tuner: (1, tuner monster)
            non_tuner: (1+, non-tuner monster)
        }
    }

    passive "Effect 2" {
        scope: self
        grant: piercing
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        timing: when
        trigger: summoned by special
        resolve {
            special_summon (all, card, either controls)
        }
    }
}
