// 死者転生
// Monster Reincarnation
// Transpiled from c74848038.lua

card "Monster Reincarnation" {
    id: 74848038
    type: Normal Spell

    effect "Effect 1" {
        speed: spell_speed_1
        damage_step: false
        on_activate {
            select (1+, monster, you controls, where { is_monster }) as target
        }
        on_resolve {
            add_to_hand (1+, monster, you controls, where { is_monster }) from hand
        }
    }

}
