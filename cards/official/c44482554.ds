// 星辰竜パーン
// Dracotail Pan
// Transpiled from c44482554.lua

card "Dracotail Pan" {
    id: 44482554
    type: Effect Monster
    attribute: WIND
    race: Dragon
    level: 7
    atk: 2700
    def: 1700

    summon_condition {
        tributes_required: 2
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: when_flipped
        on_resolve {
            set (1, card)
            shuffle_deck
            destroy (1+, spell, either_player controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: when
        trigger: when_destroyed
        activate_from: [gy]
        on_resolve {
            return (1+, spell, either_player controls) to deck shuffle
            special_summon (1, monster) from gy
        }
    }

}
