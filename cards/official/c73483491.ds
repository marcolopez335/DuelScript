// レアル・ジェネクス・ヴィンディカイト
// Vindikite R-Genex
// Transpiled from c73483491.lua

card "Vindikite R-Genex" {
    id: 73483491
    type: Synchro Monster
    attribute: WIND
    race: Machine
    level: 8
    atk: 2400
    def: 1000

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    summon_condition {
        cannot_normal_summon: true
    }

    continuous_effect "Effect 1" {
        scope: self
        grant: cannot_be_targeted_by_card_effects
    }

    effect "Effect 2" {
        speed: spell_speed_1
        optional: true
        timing: when
        trigger: when_battle_damage
        on_resolve {
            add_to_hand (1+, card, you controls) from deck
            reveal (1+, card, opponent controls)
        }
    }

}
