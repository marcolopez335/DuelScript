// レアル・ジェネクス・ヴィンディカイト
// Vindikite R-Genex
// Transpiled from c73483491.lua

card "Vindikite R-Genex" {
    id: 73483491
    type: Synchro Monster
    attribute: WIND
    race: Machine
    level: 8
    atk: 2400
    def: 1000

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    summon_condition {
        cannot_normal_summon: true
    }

    raw_effect "Effect 1" {
        effect_type: Single
        code: AttackDisabled
        property: SingleRange
        range: MonsterZone
        on_resolve {
            register_effect on self { grant: cannot_be_targeted_by_card_effects duration: until_end_of_turn }
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single + Trigger
        category: ToHand + Search
        code: BattleConfirmed
        on_resolve {
            add_to_hand (1+, card, you controls) from deck
            reveal (1+, card, opponent controls)
        }
    }

}
