card "Gouki Jet Ogre" {
    id: 59644128
    type: Link Monster
    attribute: EARTH
    race: Warrior
    link: 2
    link_arrows: [left, bottom]
    atk: 2000

    summon {
        cannot_normal_summon
        link materials: (2, monster, where archetype == "Gouki")
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: soft
        mandatory
        resolve {
            destroy (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: custom "chain_end"
        resolve {
            modify_atk (all, card, you control, from monster_zone, where is_face_up and archetype == "Gouki") + 500 until end_of_turn
        }
    }
}
