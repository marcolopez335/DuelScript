// 溟界の大蛟
// Ogdoadic Serpent Strike
// Transpiled from c96203584.lua

card "Ogdoadic Serpent Strike" {
    id: 96203584
    type: Continuous Spell

    effect "Effect 1" {
        speed: spell_speed_1
        on_resolve {
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        activate_from: [spell_trap_zone]
        on_activate {
            select (1+, monster, you controls, where { is_monster and race == Reptile }) as target
        }
        cost {
            send self to gy
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        trigger: on_custom_event "chain_end"
        activate_from: [spell_trap_zone]
        on_resolve {
            send (1+, monster, you controls, hand) to gy
        }
    }

}
