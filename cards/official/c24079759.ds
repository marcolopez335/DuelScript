card "Goblin Biker Dugg Charger" {
    id: 24079759
    type: Effect Monster
    attribute: EARTH
    race: Warrior
    level: 3
    atk: 1600
    def: 0

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        mandatory
        resolve {
            special_summon (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: summoned
        resolve {
            add_to_hand (1, card, where archetype == "Goblin Biker" and not is_monster) from deck
        }
    }

    effect "Effect 3" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: summoned by special
        resolve {
            add_to_hand (1, card, where archetype == "Goblin Biker" and not is_monster) from deck
        }
    }
}
