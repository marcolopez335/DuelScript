// 炎魔刃レーヴァテイン
// Laevateinn the Burning Blade
// Transpiled from c6260560.lua

card "Laevateinn the Burning Blade" {
    id: 6260560
    type: Link Monster
    attribute: FIRE
    race: Warrior
    link: 2
    link_arrows: [bottom_left, bottom_right]
    atk: 1000

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ effect monster
        method: link
    }

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        damage_step: false
        on_activate {
            select (1+, card, either_player controls, where { attribute == FIRE and level >= 1 }) as target
        }
        cost {
            tribute self
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    replacement_effect "Effect 2" {
        instead_of: destroyed_by_any
        do: {
            banish self
        }
    }

}
