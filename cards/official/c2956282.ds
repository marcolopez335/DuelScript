card "Naturia Barkion" {
    id: 2956282
    type: Synchro Monster
    attribute: EARTH
    race: Dragon
    level: 6
    atk: 2500
    def: 1800

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_2
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        cost {
            banish self
        }
        on_resolve {
            negate activation
            destroy (1+, monster, you controls, gy)
        }
    }

