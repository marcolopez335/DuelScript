// ミスト・ウォーム
// Mist Wurm
// Transpiled from c27315304.lua

card "Mist Wurm" {
    id: 27315304
    type: Synchro Monster
    attribute: WIND
    race: Thunder
    level: 9
    atk: 2500
    def: 1500

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        damage_step: false
        trigger: when_summoned by_special_summon
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            add_to_hand (1+, card, either_player controls) from gy
        }
    }

}
