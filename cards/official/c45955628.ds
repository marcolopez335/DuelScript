// 呪眼の眷属 カトブレパス
// Catoblepas, Familiar of the Evil Eye
// Transpiled from c45955628.lua

card "Catoblepas, Familiar of the Evil Eye" {
    id: 45955628
    type: Effect Monster
    attribute: DARK
    race: Fiend
    level: 3
    atk: 600
    def: 1900

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, monster, you controls) as target
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        activate_from: [gy]
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
