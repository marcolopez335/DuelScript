card "Cyber Angel Idaten" {
    id: 3629090
    type: Ritual Monster
    attribute: LIGHT
    race: Fairy
    level: 6
    atk: 1600
    def: 2000

    summon {
        cannot_normal_summon
    }

    effect "Effect 1" {
        speed: 1
        timing: if
        trigger: summoned by special
        resolve {
            return (all, card, either controls) to hand
        }
    }

    effect "Effect 2" {
        speed: 1
        timing: if
        trigger: sent_to gy
        resolve {
            modify_atk (all, card, you control, from monster_zone, where is_face_up and is_monster and is_ritual) + 1000 until while_face_up
            modify_def (all, card, you control, from monster_zone, where is_face_up and is_monster and is_ritual) + 1000 until while_face_up
        }
    }
}
