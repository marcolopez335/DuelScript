card "Aquarium Stage" {
    id: 29047353
    type: Continuous Spell

    effect "Effect 1" {
        speed: spell_speed_1
        on_resolve {
        }
    }

    continuous_effect "Effect 2" {
        scope: field
        grant: cannot_be_destroyed_by_battle
    }

    continuous_effect "Effect 3" {
        scope: field
        grant: unaffected_by_card_effects
