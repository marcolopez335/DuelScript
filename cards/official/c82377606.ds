card "Ally of Justice Unlimiter" {
    id: 82377606
    type: Effect Monster
    attribute: DARK
    race: Machine
    level: 2
    atk: 600
    def: 200

    effect "Effect 1" {
        speed: spell_speed_1
        damage_step: false
        on_activate {
            select (1+, card, either_player controls) as target
        }
        cost {
            tribute self
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
