card "Metalfoes Vanisher" {
    id: 56518311
    type: Effect Monster | Pendulum Monster
    attribute: FIRE
    race: Psychic
    level: 9
    scale: 1
    atk: 2900
    def: 1900

    summon_condition {
        tributes_required: 2
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: when_destroyed
        on_resolve {
            return (1+, monster, you controls, where { is_monster }) to hand
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        activate_from: [hand]
        on_resolve {
            destroy (1+, monster, you controls, where { is_monster })
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        damage_step: false
        trigger: when_summoned by_special_summon
        on_resolve {
            banish (1+, monster, you controls, where { is_monster })
        }
    }

}
