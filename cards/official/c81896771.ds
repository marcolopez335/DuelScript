// エレキジ
// Wattpheasant
// Transpiled from c81896771.lua

card "Wattpheasant" {
    id: 81896771
    type: Effect Monster
    attribute: LIGHT
    race: Thunder
    level: 4
    atk: 1000
    def: 800

    continuous_effect "Effect 1" {
        scope: self
        grant: direct_attack
    }

    effect "Effect 2" {
        speed: spell_speed_1
        damage_step: false
        trigger: when_battle_destroyed
        on_activate {
            select (1+, card, either_player controls, where { is_face_up }) as target
        }
        on_resolve {
            banish (1+, card, either_player controls, where { is_face_up })
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
