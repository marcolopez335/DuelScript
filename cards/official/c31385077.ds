    level: 8
    atk: 2500
    def: 1800

    summon {
        cannot_normal_summon
        synchro materials {
            tuner: (1, tuner monster, where attribute == LIGHT)
            non_tuner: (2+, non-tuner monster, where attribute == DARK)
        }
