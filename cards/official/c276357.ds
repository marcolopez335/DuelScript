// Shinobird Salvation
// Transpiled from c276357.lua

card "Shinobird Salvation" {
    password: 276357
    type: Continuous Trap

    effect "Effect 1" {
        speed: spell_speed_1
        on_resolve {
            reveal self
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        trigger: when attack_declared
        cost {
            banish self
        }
        on_resolve {
            negate attack
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        on_resolve {
            destroy (1+, card, either_player controls)
        }
    }

}
