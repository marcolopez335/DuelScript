card "Salamangreat Mole" {
    id: 89484053
    type: Effect Monster
    attribute: FIRE
    race: Cyberse
    level: 1
    atk: 0
    def: 0

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [hand]
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        activate_from: [gy]
        on_activate {
            select (1+, card, either_player controls) as target
        }
        cost {
            banish self
        }
        on_resolve {
            return (1+, card, either_player controls) to deck shuffle
            shuffle_deck
            draw 2
        }
    }

