// サイバー・エンジェル－美朱濡－
// Cyber Angel Vrash
// Transpiled from c78316184.lua

card "Cyber Angel Vrash" {
    id: 78316184
    type: Ritual Monster
    attribute: LIGHT
    race: Fairy
    level: 10
    atk: 3000
    def: 2000

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 1+ monster
        method: ritual
    }

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        on_resolve {
            destroy (1+, monster, opponent controls)
            deal_damage to opponent: 1000
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            negate activation
            destroy (1+, monster, opponent controls)
        }
    }

}
