// クロスロードランナー
// Crossroad Sonic Chick
// Transpiled from c80054655.lua

card "Crossroad Sonic Chick" {
    id: 80054655
    type: Effect Monster
    attribute: EARTH
    race: Winged Beast
    level: 1
    atk: 300
    def: 300

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: on_custom_event "chain_end"
        activate_from: [hand, gy]
        on_resolve {
            special_summon (1, monster) from gy
            change_battle_position (1, monster)
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
