// 極限への衝動
// Limit Impulse
// Transpiled from c82324105.lua

card "Limit Impulse" {
    id: 82324105
    type: Normal Trap

    raw_effect "Effect 1" {
        effect_type: Activate
        category: SpecialSummon + Token
        code: FreeChain
        cost {
            send self to gy
        }
        on_resolve {
            create_token { atk: 0 def: 0 }
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
