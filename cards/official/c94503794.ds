// 漆梏の喰獣 ケルゼブス
// Kerzebs, the Gaoled Glutton
// Transpiled from c94503794.lua

card "Kerzebs, the Gaoled Glutton" {
    id: 94503794
    type: Xyz Monster
    attribute: DARK
    race: Beast
    rank: 7
    atk: 700
    def: 2500

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        same_level: true
        method: xyz
    }

    raw_effect "Effect 1" {
        effect_type: Single
        code: UpdateAttack
        property: SingleRange
        range: MonsterZone
        on_resolve {
            modifier: atk + 0
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            attach (1, card) to self as_material
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: when
        trigger: during_end_phase
        on_resolve {
            set (1, card)
        }
    }

    continuous_effect "Effect 4" {
        scope: self
        grant: unaffected_by_card_effects
    }

}
