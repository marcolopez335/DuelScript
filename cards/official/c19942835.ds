// アンデット・リボーン
// Zombie Reborn
// Transpiled from c19942835.lua

card "Zombie Reborn" {
    id: 19942835
    type: Normal Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, card, you controls) as target
        }
        on_resolve {
            banish (1+, card, you controls, deck)
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [gy]
        on_resolve {
            return (1+, card, you controls) to deck shuffle
            set (1, card)
        }
    }

}
