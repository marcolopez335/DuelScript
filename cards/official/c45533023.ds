card "Raidraptor - Blaze Falcon" {
    id: 45533023
    type: Xyz Monster
    attribute: DARK
    race: Winged Beast
    rank: 5
    atk: 1000
    def: 2000

    materials {
        require: 2+ monster
        same_level: true
        method: xyz
    }

    summon_condition {
        cannot_normal_summon: true
    }

    raw_effect "Effect 1" {
        effect_type: Single
        code: DefenseDisabled
        on_resolve {
            register_effect on self { grant: direct_attack duration: until_end_of_turn }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        optional: true
        timing: when
        damage_step: false
        trigger: when_battle_destroyed
        on_resolve {
            destroy (1+, monster, opponent controls)
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        cost {
            detach 1 overlay_unit from self
        }
        on_resolve {
            destroy (1+, monster, opponent controls)
            deal_damage to opponent: 1000
        }
    }

}
