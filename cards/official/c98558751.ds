// TG ワンダー・マジシャン
// T.G. Wonder Magician
// Transpiled from c98558751.lua

card "T.G. Wonder Magician" {
    id: 98558751
    type: Synchro Monster | Tuner
    attribute: LIGHT
    race: Spellcaster
    level: 5
    atk: 1900
    def: 0

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        damage_step: false
        trigger: when_summoned by_special_summon
        on_activate {
            select (1+, spell, either_player controls, where { is_spell }) as target
        }
        on_resolve {
            destroy (1+, spell, either_player controls, where { is_spell })
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single + MandatoryTrigger
        category: Draw
        code: ChainNegated
        property: InitialValue
        on_resolve {
            draw 1
        }
    }

    effect "Effect 3" {
        speed: spell_speed_2
        optional: true
        on_resolve {
            synchro_summon (1, synchro monster) using (1+, monster, you controls)
        }
    }

}
