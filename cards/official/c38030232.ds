// 天威龍-サハスラーラ
// Tenyi Spirit - Sahasrara
// Transpiled from c38030232.lua

card "Tenyi Spirit - Sahasrara" {
    id: 38030232
    type: Link Monster
    attribute: LIGHT
    race: Wyrm
    link: 4
    link_arrows: [top, top_right, bottom, bottom_right]
    atk: 3000

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ effect monster
        method: link
    }

    continuous_effect "Effect 1" {
        scope: field
        grant: cannot_be_targeted_by_card_effects
    }

    continuous_effect "Effect 2" {
        scope: field
        grant: cannot_be_targeted_by_card_effects
    }

    effect "Effect 3" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        damage_step: false
        on_activate {
            select (1+, monster, you controls, where { is_face_up }) as target
        }
        on_resolve {
            create_token { atk: 0 def: 0 }
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
