card "Vivid Knight" {
    id: 52575195
    type: Effect Monster
    attribute: LIGHT
    race: Beast-Warrior
    level: 4
    atk: 1700
    def: 800

    effect "Effect 1" {
        speed: 2
        timing: when
        trigger: opponent_activates [activate_spell, activate_trap, activate_spell]
        resolve {
            banish (all, card, either controls)
            special_summon (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 2
        timing: when
        trigger: summoned
        resolve {
            banish (all, card, either controls)
            special_summon (all, card, either controls)
        }
    }
}
