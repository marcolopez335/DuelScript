// 生存競争
// Survival of the Fittest
// Transpiled from c58272005.lua

card "Survival of the Fittest" {
    id: 58272005
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        damage_step: false
        on_activate {
            select (1+, monster, either_player controls, where { is_face_up and race == Dinosaur }) as target
        }
        on_resolve {
            equip (1, card) to (1, monster)
        }
    }

}
