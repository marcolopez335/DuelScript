// Super Quantal Mech Sword - Magnaslayer
// Transpiled from c47819246.lua

card "Super Quantal Mech Sword - Magnaslayer" {
    id: 47819246
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        damage_step: false
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            equip (1, card) to (1, monster)
        }
    }

    raw_effect "Effect 2" {
        effect_type: Equip
        code: UpdateAttack
        on_resolve {
            modifier: atk + 0
        }
    }

    continuous_effect "Effect 3" {
        scope: self
        grant: piercing
    }

    effect "Effect 4" {
        speed: spell_speed_2
        optional: true
        activate_from: [spell_trap_zone]
        cost {
            send self to gy
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
