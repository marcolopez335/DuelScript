// 覇王の逆鱗
// Supreme Rage
// Transpiled from c84869738.lua

card "Supreme Rage" {
    id: 84869738
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        on_resolve {
            destroy (1+, monster, you controls)
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        optional: true
        damage_step: false
        activate_from: [gy]
        on_activate {
            select (1+, monster, you controls) as target
        }
        cost {
            banish self
        }
        on_resolve {
            attach (1, card) to self as_material
        }
    }

}
