card "Greedy Venom Fusion Dragon" {
    id: 51570882
    type: Fusion Monster
    attribute: DARK
    race: Dragon
    level: 10
    atk: 3300
    def: 2500

    summon {
        cannot_normal_summon
        special_summon_procedure {
            from: extra_deck
            to: your_field
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        mandatory
        resolve {
            banish target
            special_summon target
        }
    }

    effect "Effect 3" {
        speed: 1
        mandatory
        trigger: custom "chain_end"
        resolve {
            destroy (all, card, either controls)
            banish (all, card, either controls)
            special_summon (all, card, either controls)
        }
    }
}
