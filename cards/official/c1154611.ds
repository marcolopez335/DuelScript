// バージェストマ・レアンコイリア
// Paleozoic Leanchoilia
// Transpiled from c1154611.lua

card "Paleozoic Leanchoilia" {
    id: 1154611
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        damage_step: false
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            send (1+, card, either_player controls) to gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        activate_from: [gy]
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
