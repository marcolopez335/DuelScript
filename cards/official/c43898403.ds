card "Twin Twisters" {
    id: 43898403
    type: Quick-Play Spell

    effect "Effect 1" {
        speed: spell_speed_2
        damage_step: false
        on_activate {
            select (1+, spell, you controls, where { is_spell }) as target
        }
        on_resolve {
            destroy (1+, spell, you controls, hand)
        }
    }

}
