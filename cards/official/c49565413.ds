card "Chaos Beast" {
    id: 49565413
    type: Synchro Monster
    attribute: DARK
    race: Fiend
    level: 6
    atk: 2000
    def: 1800

    summon {
        cannot_normal_summon
        synchro materials {
            tuner: (1, tuner monster, where attribute == LIGHT)
            non_tuner: (1+, non-tuner monster, where attribute == DARK)
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        mandatory
        resolve {
            add_to_hand (all, card, either controls)
        }
    }

    effect "Effect 3" {
        speed: 1
        once_per_turn: soft
        mandatory
        cost {
            banish self
        }
        resolve {
            special_summon (all, card, either controls)
        }
    }
}
