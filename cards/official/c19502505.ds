// 沈黙の魔導剣士－サイレント・パラディン
// Silent Paladin
// Transpiled from c19502505.lua

card "Silent Paladin" {
    id: 19502505
    type: Effect Monster
    attribute: LIGHT
    race: Fairy
    level: 4
    atk: 500
    def: 1500

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        timing: when
        trigger: when_summoned
        on_resolve {
            add_to_hand (1+, card, you controls) from deck
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            negate activation
            send (1+, card, you controls, deck) to gy
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        optional: true
        timing: if
        damage_step: false
        trigger: when_destroyed
        on_activate {
            select (1+, card, you controls) as target
        }
        on_resolve {
            add_to_hand (1+, card, you controls) from deck
        }
    }

}
