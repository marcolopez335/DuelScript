card "Angelica, Princess of Noble Arms" {
    id: 36320744
    type: Synchro Monster
    attribute: FIRE
    race: Warrior
    level: 5
    atk: 1200
    def: 2400

    summon {
        cannot_normal_summon
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            add_to_hand (all, card, either controls)
        }
    }

    effect "Effect 3" {
        speed: 2
        once_per_turn: soft
        timing: when
        trigger: attacked
        resolve {
            send (all, card, either controls) to gy
            banish (all, card, either controls)
            special_summon (all, card, either controls)
        }
    }
}
