card "U.A. Stadium" {
    id: 19814508
    type: Field Spell

    effect "Effect 1" {
        speed: 1
        mandatory
        resolve {
            add_to_hand (1, card, you control, from deck)
        }
    }

    effect "Effect 2" {
        speed: 1
        timing: if
        trigger: summoned
        resolve {
            return (all, card, either controls) to hand
        }
    }

    effect "Effect 3" {
        speed: 1
        once_per_turn: soft
        mandatory
        trigger: summoned by special
        resolve {
            modify_atk (all, card, you control, from monster_zone, where is_face_up) + 500 until end_of_turn
        }
    }
}
