card "Performage Fire Dancer" {
    id: 7934362
    type: Effect Monster | Pendulum Monster
    attribute: FIRE
    race: Spellcaster
    level: 4
    scale: 6
    atk: 1400
    def: 1200

    passive "Effect 5" {
        scope: self
        grant: piercing
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: soft
        mandatory
        resolve {
            add_to_hand target
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned
        resolve {
            add_to_hand (1, monster, where archetype == "Performage") from deck
        }
    }

    effect "Effect 3" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            add_to_hand (1, monster, where archetype == "Performage") from deck
        }
    }

    effect "Effect 4" {
        speed: 1
        timing: if
        trigger: destroyed
        resolve {
        }
    }
}
