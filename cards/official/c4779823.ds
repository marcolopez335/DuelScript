        property: CardTarget
        range: MonsterZone
        count_limit: (1, 0)
        cost {
            pay_lp 1000
        }
        on_resolve {
            banish (1+, monster, either_player controls)
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single + Trigger
        category: ToDeck + Recover
        code: Destroyed
        property: CardTarget + Oath
        on_resolve {
            return (1+, monster, either_player controls) to deck shuffle
            gain_lp: 1000
        }
    }

    raw_effect "Effect 3" {
        effect_type: Field + MandatoryTrigger
        category: DeckDestroy
        code: PhaseEnd
        range: MonsterZone
        count_limit: (1, 0)
        on_resolve {
