card "Michael, the Arch-Lightsworn" {
    id: 4779823
    type: Synchro Monster
    attribute: LIGHT
    race: Dragon
    level: 7
    atk: 2600
    def: 2000

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    summon_condition {
        cannot_normal_summon: true
    }

    raw_effect "Effect 1" {
        effect_type: Ignition
