// ラスト・カウンター
// Last Counter
// Transpiled from c86049351.lua

card "Last Counter" {
    id: 86049351
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        trigger: when attack_declared
        on_resolve {
            negate attack
            send (1+, monster, you controls) to gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            deal_damage to opponent: 1000
        }
    }

}
