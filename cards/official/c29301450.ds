        category: Banish
        code: Chaining
        property: CardTarget
        range: MonsterZone
        count_limit: (1, 0)
        on_resolve {
            banish (1+, monster, opponent controls)
        }
    }

    raw_effect "Effect 4" {
        effect_type: Field
        code: CannotAttackAnnounce
        on_resolve {
            register_effect on self { grant: cannot_attack_directly duration: until_end_of_turn }
        }
    }

