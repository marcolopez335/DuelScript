card "S:P Little Knight" {
    id: 29301450
    type: Link Monster
    attribute: DARK
    race: Warrior
    link: 2
    link_arrows: [left, right]
    atk: 1600

    summon {
        cannot_normal_summon
    }

    passive "Effect 4" {
        scope: self
        grant: cannot_attack_directly
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            banish (all, card, either controls)
        }
    }

    effect "Effect 3" {
        speed: 2
        once_per_turn: soft
        timing: when
        trigger: opponent_activates [activate_spell, activate_trap, activate_spell]
        resolve {
            banish (all, card, either controls)
        }
    }
}
