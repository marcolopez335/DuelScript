card "Time Thief Redoer" {
    id: 55285840
    type: Xyz Monster
    attribute: DARK
    race: Psychic
    rank: 4
    atk: 2400
    def: 2000

    summon {
        cannot_normal_summon
        xyz materials: (2, monster, where level == 4)
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: soft
        timing: when
        trigger: standby_phase
        resolve {
            send target to gy
            banish target
            draw 1
            send target to deck
        }
    }

    effect "Effect 2" {
        speed: 2
        once_per_turn: hard
        resolve {
            send (all, card, either controls) to gy
            banish (all, card, either controls)
            draw 1
            return (all, card, either controls) to deck
        }
    }
}
