card "The Suppression Pluto" {
    id: 24413299
    type: Effect Monster
    attribute: DARK
    race: Fiend
    level: 8
    atk: 2600
    def: 2000

    summon_condition {
        tributes_required: 2
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        on_resolve {
            reveal (1+, card, opponent controls)
            take_control of (1, monster, opponent controls)
            destroy (1+, spell, opponent controls, where { is_spell })
            set (1, card)
            shuffle_hand
        }
    }

}
