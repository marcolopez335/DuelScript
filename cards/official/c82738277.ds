// ランカの蟲惑魔
// Traptrix Mantis
// Transpiled from c82738277.lua

card "Traptrix Mantis" {
    id: 82738277
    type: Effect Monster
    attribute: EARTH
    race: Insect
    level: 4
    atk: 1500
    def: 1300

    continuous_effect "Effect 1" {
        scope: self
        grant: unaffected_by_card_effects
    }

    effect "Effect 2" {
        speed: spell_speed_1
        optional: true
        timing: when
        trigger: when_summoned
        on_resolve {
            add_to_hand (1+, monster, you controls) from hand
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 3" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        damage_step: false
        on_activate {
            select (1+, monster, you controls) as target
        }
        on_resolve {
            add_to_hand (1+, monster, you controls) from hand
            shuffle_hand
            set (1, card)
        }
    }

}
