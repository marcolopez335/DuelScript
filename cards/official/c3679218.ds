card "Knightmare Mermaid" {
    id: 3679218
    type: Link Monster
    attribute: WATER
    race: Fiend
    link: 1
    link_arrows: [bottom]
    atk: 1000

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ effect monster
        method: link
    }

    effect "Effect 1" {
        speed: spell_speed_1
