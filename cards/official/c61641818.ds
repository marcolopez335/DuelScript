card "Virtual World Dragon - Longlong" {
    id: 61641818
    type: Xyz Monster
    attribute: EARTH
    race: Wyrm
    rank: 3
    atk: 2400
    def: 2000

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        same_level: true
        method: xyz
    }

    raw_effect "Effect 1" {
        effect_type: Single
