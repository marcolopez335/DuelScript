// スカーレッド・カーペット
// Red Carpet
// Transpiled from c41197012.lua

card "Red Carpet" {
    id: 41197012
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        damage_step: false
        on_activate {
            select (1+, monster, either_player controls, where { is_face_up and is_synchro and race == Dragon }) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
            special_summon (1, monster) from gy
        }
    }

}
