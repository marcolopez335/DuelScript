// 闇魔界の竜騎士 ダークソード
// Dark Blade the Dragon Knight
// Transpiled from c86805855.lua

card "Dark Blade the Dragon Knight" {
    id: 86805855
    type: Fusion Monster
    attribute: DARK
    race: Warrior
    level: 6
    atk: 2200
    def: 1500

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        method: fusion
    }

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        timing: when
        damage_step: false
        trigger: when_battle_destroyed
        on_activate {
            select (1+, monster, either_player controls, where { is_monster }) as target
        }
        on_resolve {
            banish (1+, monster, either_player controls, where { is_monster })
        }
    }

}
