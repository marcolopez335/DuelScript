// ゼノ・メテオロス
// Xeno Meteorus
// Transpiled from c5852388.lua

card "Xeno Meteorus" {
    id: 5852388
    type: Effect Monster | Tuner
    attribute: FIRE
    race: Dinosaur
    level: 6
    atk: 2000
    def: 200

    summon_condition {
        tributes_required: 1
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: when_destroyed
        activate_from: [hand]
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            destroy (1+, monster, you controls, hand)
            special_summon (1, monster) from gy
        }
    }

}
