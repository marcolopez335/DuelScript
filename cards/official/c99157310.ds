// ティンダングル・ドロネー
// Tindangle Delaunay
// Transpiled from c99157310.lua

card "Tindangle Delaunay" {
    id: 99157310
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        trigger: when_battle_destroyed
        on_resolve {
            destroy (1+, monster, you controls, gy)
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        optional: true
        damage_step: false
        activate_from: [gy]
        on_activate {
            select (1+, monster, you controls) as target
        }
        cost {
            banish self
        }
        on_resolve {
            special_summon (1, monster) from gy
            reveal (1+, card, opponent controls)
            special_summon (1, monster) from gy
            reveal (1+, card, opponent controls)
        }
    }

}
