card "Rubysapphirus, the Adamant Jewel" {
    id: 6906306
    type: Xyz Monster
    attribute: EARTH
    race: Rock
    rank: 9
    atk: 2700
    def: 1600

    summon {
        cannot_normal_summon
        xyz materials: (2, monster, where level == 9)
    }

    effect "Effect 2" {
        speed: 1
        timing: when
        trigger: summoned
        resolve {
            set_atk self self.atk * 2 until end_of_damage_step
        }
    }

    effect "Effect 3" {
        speed: 2
        once_per_turn: soft
        target (1, card, you control, from field)
        resolve {
            set_atk self self.atk * 2 until end_of_turn
        }
    }

    replacement "Effect 1" {
        instead_of: destroyed
        do {
            banish self
        }
    }
}
