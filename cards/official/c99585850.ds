card "Red Supernova Dragon" {
    id: 99585850
    type: Synchro Monster
    attribute: DARK
    race: Dragon
    level: 12
    atk: 4000
    def: 3000

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    raw_effect "Effect 1" {
        effect_type: Single
        code: SpsummonCondition
        property: BothSide + SingleRange + Uncopyable
        range: Deck
        on_resolve {
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single
        code: UpdateAttack
        property: SingleRange
        range: MonsterZone
        on_resolve {
            modifier: atk + count((1+, card, you controls, gy)) * 500
        }
    }

    continuous_effect "Effect 3" {
        scope: self
        grant: cannot_be_destroyed_by_effect
    }

    effect "Effect 4" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        timing: when
        trigger: when attack_declared
        on_resolve {
            banish (1+, card, opponent controls)
        }
    }

    effect "Effect 5" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            banish (1+, card, opponent controls)
        }
    }

    effect "Effect 6" {
        speed: spell_speed_1
        once_per_turn: soft
        trigger: during_end_phase
        activate_from: [banished]
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    raw_effect "Effect 7" {
        effect_type: Single
        code: 21142671
        property: BothSide + Uncopyable
        on_resolve {
        }
    }

