// 壱世壊に澄み渡る残響
// Tearlaments Cryme
// Transpiled from c1329620.lua

card "Tearlaments Cryme" {
    id: 1329620
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            negate activation
            return (1+, monster, you controls) to deck shuffle
            send (1+, monster, you controls) to gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        timing: if
        damage_step: false
        trigger: on_custom_event "chain_end"
        on_resolve {
            return (1+, monster, you controls) to hand
        }
    }

}
