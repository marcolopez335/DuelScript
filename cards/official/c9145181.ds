// 儀式降臨封印の書
// Ritual Sealing
// Transpiled from c9145181.lua

card "Ritual Sealing" {
    id: 9145181
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        damage_step: false
        on_activate {
            select (1+, card, either_player controls, where { is_face_up and is_ritual }) as target
        }
        on_resolve {
            destroy (1+, card, either_player controls, where { is_face_up and is_ritual })
        }
    }

}
