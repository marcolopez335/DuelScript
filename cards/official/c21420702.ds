card "Tri-Blaze Accelerator" {
    id: 21420702
    type: Continuous Spell

    effect "Effect 1" {
        speed: spell_speed_1
        cost {
            send self to gy
        }
        on_resolve {
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        damage_step: false
        activate_from: [spell_trap_zone]
        on_activate {
            select (1+, spell, you controls) as target
        }
        on_resolve {
            send (1+, spell, you controls) to gy
            destroy (1+, spell, you controls)
            deal_damage to opponent: 500
        }
    }

}
