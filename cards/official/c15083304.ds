card "Danger! Zone" {
    id: 15083304
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        on_resolve {
            draw 1
            shuffle_hand
            send (1+, card, either_player controls) to gy
            reveal (1+, card, opponent controls)
            return (1+, card, either_player controls) to deck shuffle
        }
    }

