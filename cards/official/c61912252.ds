// 無限起動トレンチャー
// Infinitrack Trencher
// Transpiled from c61912252.lua

card "Infinitrack Trencher" {
    id: 61912252
    type: Effect Monster
    attribute: EARTH
    race: Machine
    level: 5
    atk: 500
    def: 2400

    summon_condition {
        tributes_required: 1
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [hand]
        cost {
            tribute self
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        activate_from: [gy]
        on_activate {
            select (1+, card, either_player controls, where { race == Machine and attribute == EARTH }) as target
        }
        cost {
            banish self
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
