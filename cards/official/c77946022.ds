// 天威無窮の境地
// Tenyinfinity
// Transpiled from c77946022.lua

card "Tenyinfinity" {
    id: 77946022
    type: Field Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        on_resolve {
            return (1+, monster, either_player controls) to hand
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        activate_from: [field_zone]
        on_activate {
            select (1+, monster, either_player controls) as target
        }
        cost {
            tribute self
        }
        on_resolve {
            destroy (1+, monster, either_player controls)
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: when
        trigger: during_end_phase
        activate_from: [field_zone]
        on_resolve {
            send (1+, monster, either_player controls) to gy
            send (1+, monster, either_player controls) to gy
            special_summon (1, monster) from gy
        }
    }

}
