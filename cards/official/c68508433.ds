card "Master Spirit Tech Force - Pendulum Ruler" {
    id: 68508433
    type: Fusion Monster | Pendulum Monster
    attribute: LIGHT
    race: Machine
    level: 12
    scale: 1
    atk: 3500
    def: 3000

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        method: fusion
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        on_resolve {
            return (1+, card, you controls, where { level == 7 and is_face_up }) to deck shuffle
            add_to_hand (1+, card, you controls, where { level == 7 and is_face_up }) from deck
            reveal (1+, card, opponent controls)
        }
    }

    continuous_effect "Effect 2" {
        scope: self
        grant: cannot_be_destroyed_by_effect
    }

    continuous_effect "Effect 3" {
        scope: field
        grant: cannot_attack
    }

    effect "Effect 4" {
        speed: spell_speed_1
        twice_per_turn
        damage_step: false
        cost {
            tribute self
        }
        on_resolve {
            destroy (1+, card, you controls, deck)
            deal_damage to opponent: 1600
        }
    }

    effect "Effect 5" {
        speed: spell_speed_1
        once_per_turn: soft
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
