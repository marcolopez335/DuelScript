card "Master Spirit Tech Force - Pendulum Ruler" {
    id: 68508433
    type: Fusion Monster | Pendulum Monster
    attribute: LIGHT
    race: Machine
    level: 12
    scale: 1
    atk: 3500
    def: 3000

    summon {
        cannot_normal_summon
        special_summon_procedure {
            from: extra_deck
            to: your_field
        }
    }

    passive "Effect 2" {
        scope: self
        grant: cannot_be_destroyed by effect
    }

    passive "Effect 3" {
        scope: self
        grant: cannot_attack
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: soft
        mandatory
        resolve {
            return (all, card, either controls) to deck
            add_to_hand (all, card, either controls)
        }
    }

    effect "Effect 4" {
        speed: 1
        twice_per_turn
        mandatory
        target (1, card, opponent controls, from field)
        cost {
            tribute self
        }
        resolve {
            destroy (all, card, either controls)
            damage opponent 1600
        }
    }

    effect "Effect 5" {
        speed: 1
        once_per_turn: soft
        mandatory
        resolve {
            special_summon (all, card, either controls)
        }
    }
}
