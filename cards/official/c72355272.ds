card "Metaphys Nephthys" {
    id: 72355272
    type: Effect Monster
    attribute: LIGHT
    race: Wyrm
    level: 8
    atk: 2400
    def: 1600

    summon_condition {
        tributes_required: 2
    }

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        on_resolve {
            banish (1+, spell, either_player controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: when
        trigger: during_standby_phase
        activate_from: [banished]
        cost {
            send self to deck
        }
        on_resolve {
            return (1+, spell, either_player controls) to hand
            reveal (1+, card, opponent controls)
        }
    }

}
