card "Light and Darkness Dragonlord" {
    id: 19652159
    type: Fusion Monster
    attribute: LIGHT
    race: Dragon
    level: 10
    atk: 3400
    def: 3000

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        method: fusion
    }

    raw_effect "Effect 1" {
        effect_type: Single
        code: AddType
        property: SingleRange
        range: MonsterZone
        on_resolve {
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            negate activation
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        optional: true
        timing: if
        damage_step: false
        trigger: when_destroyed
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    raw_effect "Effect 4" {
        effect_type: Single
        code: UpdateAttack
        property: 8192
        on_resolve {
            modifier: atk - 1000
        }
    }

    raw_effect "Effect 5" {
        effect_type: Single
        code: UpdateDefense
        property: 8192
        on_resolve {
            modifier: def - 1000
        }
    }

}
