card "Stardust Dragon/Assault Mode" {
    id: 61257789
    type: Effect Monster | Effect Monster
    attribute: WIND
    race: Dragon
    level: 10
    atk: 3000
    def: 2500

    summon {
        cannot_normal_summon
    }

    effect "Effect 2" {
        speed: 2
        timing: when
        trigger: opponent_activates [activate_spell, activate_trap, activate_spell]
        resolve {
            negate
            destroy (all, card, either controls)
        }
    }

    effect "Effect 3" {
        speed: 1
        once_per_turn: soft
        timing: when
        trigger: end_phase
        resolve {
            special_summon (all, card, either controls)
        }
    }

    effect "Effect 4" {
        speed: 1
        timing: when
        trigger: destroyed
        resolve {
            special_summon (all, card, either controls)
        }
    }
}
