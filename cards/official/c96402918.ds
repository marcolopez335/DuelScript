card "Lancea, Ancestral Dragon of the Ice Mountain" {
    id: 96402918
    type: Synchro Monster
    attribute: WATER
    race: Dragon
    level: 10
    atk: 3300
    def: 2700

    summon {
        cannot_normal_summon
        synchro materials {
            tuner: (1, tuner monster, where attribute == WATER)
            non_tuner: (1+, non-tuner monster)
        }
    }

    effect "Effect 1" {
        speed: 1
        twice_per_turn
        timing: if
        trigger: summoned by special
        resolve {
            special_summon (1, monster, where archetype == "Ice Barrier") from hand in attack_position
        }
    }
}
