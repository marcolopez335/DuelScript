// アドヴェンデット・セイヴァー
// Avendread Savior
// Transpiled from c91420202.lua

card "Avendread Savior" {
    id: 91420202
    type: Link Monster
    attribute: DARK
    race: Zombie
    link: 2
    link_arrows: [bottom_left, bottom_right]
    atk: 1600

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ effect monster
        method: link
    }

    raw_effect "Effect 1" {
        effect_type: Single
        code: 114
        property: SingleRange
        range: MonsterZone
        on_resolve {
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, card, you controls) as target
        }
        on_resolve {
            add_to_hand (1+, card, you controls) from deck
        }
    }

    effect "Effect 3" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        timing: when
        trigger: when attack_declared
        cost {
            send self to gy
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
