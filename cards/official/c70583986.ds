card "Dewloren, Tiger King of the Ice Barrier" {
    id: 70583986
    type: Synchro Monster
    attribute: WATER
    race: Beast
    level: 6
    atk: 2000
    def: 1400

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, card, either_player controls, where { is_face_up }) as target
        }
        on_resolve {
            add_to_hand (1+, card, either_player controls, where { is_face_up }) from gy
        }
    }

}
