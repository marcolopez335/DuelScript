card "Daigusto Falcos" {
    id: 34109611
    type: Synchro Monster
    attribute: WIND
    race: Psychic
    level: 4
    atk: 1400
    def: 1200

    summon {
        cannot_normal_summon
        synchro materials {
            tuner: (1, tuner monster)
            non_tuner: (1+, non-tuner monster, where archetype == "Gusto")
        }
    }

    effect "Effect 1" {
        speed: 1
        mandatory
        trigger: summoned by special
        resolve {
            modify_atk (all, card, either controls, from monster_zone) + 600 until end_of_turn
        }
    }
}
