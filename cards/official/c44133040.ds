// セレンの呪眼
// Evil Eye of Selene
// Transpiled from c44133040.lua

card "Evil Eye of Selene" {
    id: 44133040
    type: Equip Spell

    raw_effect "Effect 1" {
        effect_type: Equip
        code: CannotBeEffectTarget
        on_resolve {
            register_effect on self { grant: cannot_be_destroyed_by_battle duration: until_end_of_turn }
        }
    }

    raw_effect "Effect 2" {
        effect_type: Equip
        code: CannotDirectAttack2
        property: SetAvailable
        on_resolve {
            register_effect on self { grant: cannot_be_targeted_by_card_effects duration: until_end_of_turn }
        }
    }

    raw_effect "Effect 3" {
        effect_type: Equip
        code: IndestructableEffect
        on_resolve {
            register_effect on self { grant: cannot_be_destroyed_by_effect duration: until_end_of_turn }
        }
    }

    effect "Effect 4" {
        speed: spell_speed_1
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        activate_from: [spell_trap_zone]
        on_resolve {
            gain_lp: 0
        }
    }

    effect "Effect 5" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [gy]
        cost {
            banish self
            pay_lp your_lp / 2
        }
        on_resolve {
            set (1, card)
        }
    }

    effect "Effect 6" {
        speed: spell_speed_1
        on_resolve {
            equip self to (1, monster, you controls)
        }
    }

}
