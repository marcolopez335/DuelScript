// トライポッド・フィッシュ
// Tripod Fish
// Transpiled from c61254509.lua

card "Tripod Fish" {
    id: 61254509
    type: Effect Monster
    attribute: WATER
    race: Fish
    level: 3
    atk: 300
    def: 1300

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        timing: when
        damage_step: false
        trigger: when_summoned by_special_summon
        on_activate {
            select (1+, card, either_player controls, where { is_face_up and level >= 1 }) as target
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
