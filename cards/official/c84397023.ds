// レベル変換実験室
// Level Conversion Lab
// Transpiled from c84397023.lua

card "Level Conversion Lab" {
    id: 84397023
    type: Normal Trap

    raw_effect "Effect 1" {
        effect_type: Activate
        code: FreeChain
        on_resolve {
            reveal (1+, card, opponent controls)
            flip_coin { heads { draw 1 } tails { draw 1 } }
            send (1+, card, you controls, hand) to gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            shuffle_hand
        }
    }

}
