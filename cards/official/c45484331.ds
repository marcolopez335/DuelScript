        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        on_resolve {
            add_to_hand (1+, spell, you controls) from gy
            reveal (1+, card, opponent controls)
            shuffle_hand
            shuffle_deck
            return (1+, spell, you controls) to deck shuffle
