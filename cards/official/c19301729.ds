card "Digital Bug Registrider" {
    id: 19301729
    type: Effect Monster
    attribute: LIGHT
    race: Insect
    level: 3
    atk: 1000
    def: 1000

    effect "Effect 2" {
        speed: 1
        timing: when
        trigger: summoned
        resolve {
            special_summon (all, card, either controls)
        }
    }

    effect "Effect 3" {
        speed: 1
        timing: if
        trigger: summoned by special
        condition: previous_location == hand
        resolve {
            change_position target to defense_position
        }
    }
}
