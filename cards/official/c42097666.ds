// 青き眼の精霊
// Spirit with Eyes of Blue
// Transpiled from c42097666.lua

card "Spirit with Eyes of Blue" {
    id: 42097666
    type: Link Monster
    attribute: LIGHT
    race: Dragon
    link: 1
    link_arrows: [bottom_left]
    atk: 300

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ effect monster
        method: link
    }

    continuous_effect "Effect 1" {
        scope: field
        grant: cannot_be_used_as_material
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        on_resolve {
            add_to_hand (1, card, you controls) from gy
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        cost {
            tribute self
        }
        on_resolve {
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    continuous_effect "Effect 4" {
        scope: self
        grant: cannot_attack
    }

}
