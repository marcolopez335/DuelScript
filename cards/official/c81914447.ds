    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        activate_from: [hand, monster_zone]
        cost {
            send self to gy
        }
        on_resolve {
            add_to_hand (1+, monster, you controls) from deck
            reveal (1+, card, opponent controls)
        }
