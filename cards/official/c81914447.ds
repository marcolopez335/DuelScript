card "Noh-P.U.N.K. Ogre Dance" {
    id: 81914447
    type: Effect Monster
    attribute: DARK
    race: Fiend
    level: 8
    atk: 2500
    def: 2000

    summon_condition {
        tributes_required: 2
    }

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
        }
