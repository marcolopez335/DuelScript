// 熾天の騎士ガイアプロミネンス
// Gaia Prominence, the Fierce Force
// Transpiled from c95095116.lua

card "Gaia Prominence, the Fierce Force" {
    id: 95095116
    type: Fusion Monster
    attribute: FIRE
    race: Pyro
    level: 11
    atk: 3500
    def: 3100

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        method: fusion
    }

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            negate effect
            destroy (1+, monster, you controls, hand)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: when
        damage_step: false
        trigger: when_battle_damage
        on_activate {
            select (1+, monster, you controls, where { is_monster }) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
