// 墓穴の指名者
// Called by the Grave
// Transpiled from c24224830.lua

card "Called by the Grave" {
    id: 24224830
    type: Quick-Play Spell

    effect "Effect 1" {
        speed: spell_speed_1
        damage_step: false
        on_activate {
            select (1+, monster, either_player controls, where { is_monster }) as target
        }
        on_resolve {
            banish (1+, monster, either_player controls, where { is_monster })
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
