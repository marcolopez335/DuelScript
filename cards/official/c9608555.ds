// 転生炎獣ブレイズ・ドラゴン
// Salamangreat Blaze Dragon
// Transpiled from c9608555.lua

card "Salamangreat Blaze Dragon" {
    id: 9608555
    type: Xyz Monster
    attribute: FIRE
    race: Cyberse
    rank: 4
    atk: 2300
    def: 1200

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        same_level: true
        method: xyz
    }

    replacement_effect "Effect 1" {
        instead_of: destroyed_by_any
        do: {
            banish self
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        on_resolve {
            attach (1, card) to self as_material
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        on_resolve {
            destroy (1+, monster, opponent controls)
        }
    }

}
