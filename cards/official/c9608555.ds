card "Salamangreat Blaze Dragon" {
    id: 9608555
    type: Xyz Monster
    attribute: FIRE
    race: Cyberse
    rank: 4
    atk: 2300
    def: 1200

    summon {
        cannot_normal_summon
        xyz materials: (2, monster, where level == 4)
    }

    effect "Effect 2" {
        speed: 2
        once_per_turn: hard
        resolve {
            special_summon (all, card, either controls)
        }
    }

    effect "Effect 3" {
        speed: 1
        timing: if
        trigger: summoned by special
        resolve {
            destroy (1, monster, opponent controls)
        }
    }

    replacement "Effect 1" {
        instead_of: destroyed
        do {
            banish self
        }
    }
}
