card "Scrap-Iron Signal" {
    id: 50947142
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            negate activation
            change_battle_position (1, monster)
            emit_event "custom"
        }
    }

}
