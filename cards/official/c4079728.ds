card "Gung-Ho! Springans!" {
    id: 4079728
    type: Xyz Monster
    attribute: FIRE
    race: Machine
    rank: 4
    atk: 2500
    def: 1600

    summon {
        cannot_normal_summon
        xyz materials: (2, monster, where level == 4 and archetype == "Springans")
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: custom "chain_end"
        resolve {
            special_summon (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            special_summon (all, card, either controls)
        }
    }

    effect "Effect 3" {
        speed: 1
        once_per_turn: hard
        mandatory
        cost {
            detach 2 from self
        }
        resolve {
            add_to_hand (all, card, either controls)
            special_summon (all, card, either controls)
        }
    }
}
