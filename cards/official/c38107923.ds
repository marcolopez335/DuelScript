// ダーク・ネフティス
// Dark Nephthys
// Transpiled from c38107923.lua

card "Dark Nephthys" {
    id: 38107923
    type: Effect Monster
    attribute: DARK
    race: Winged Beast
    level: 8
    atk: 2400
    def: 1600

    summon_condition {
        tributes_required: 2
    }

    effect "Effect 1" {
        speed: spell_speed_1
        activate_from: [hand]
        cost {
            banish self
        }
        on_resolve {
            send (1+, spell, you controls, gy) to gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        trigger: during_standby_phase
        activate_from: [gy]
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        damage_step: false
        trigger: when_summoned by_special_summon
        on_resolve {
            destroy (1+, spell, you controls, gy)
        }
    }

}
