// ネメシス・コリドー
// Nemeses Corridor
// Transpiled from c72090076.lua

card "Nemeses Corridor" {
    id: 72090076
    type: Effect Monster
    attribute: WIND
    race: Thunder
    level: 4
    atk: 1900
    def: 600

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        activate_from: [hand]
        on_activate {
            select (1+, monster, either_player controls) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
            return (1+, monster, either_player controls) to deck shuffle
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_activate {
            select (1+, monster, either_player controls) as target
        }
        on_resolve {
            add_to_hand (1+, monster, either_player controls) from gy
        }
    }

}
