card "Fabled Miztoji" {
    id: 8316661
    type: Effect Monster | Tuner
    attribute: LIGHT
    race: Fiend
    level: 2
    atk: 400
    def: 200

    effect "Effect 1" {
        speed: spell_speed_1
        damage_step: false
        activate_from: [hand]
        on_activate {
            select (1+, monster, either_player controls) as target
        }
        cost {
            send self to gy
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
