card "Gouki Guts" {
    id: 7540107
    type: Effect Monster
    attribute: EARTH
    race: Warrior
    level: 1
    atk: 800
    def: 0

    passive "Effect 1" {
        scope: self
        grant: cannot_be_destroyed by battle
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        mandatory
        resolve {
            modify_atk (all, card, you control, from monster_zone, where is_face_up and archetype == "Gouki" and is_monster) + 200 until while_face_up
        }
    }

    effect "Effect 3" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: custom "chain_end"
        condition: previous_location == field
        resolve {
            return (all, card, either controls) to hand
        }
    }
}
