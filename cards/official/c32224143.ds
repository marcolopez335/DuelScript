card "Ghostrick Socuteboss" {
    id: 32224143
    type: Xyz Monster
    attribute: DARK
    race: Spellcaster
    rank: 2
    atk: 1400
    def: 1200

    materials {
        require: 2+ monster
        same_level: true
        method: xyz
