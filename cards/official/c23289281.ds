card "Karate Man" {
    id: 23289281
    type: Effect Monster
    attribute: EARTH
    race: Warrior
    level: 3
    atk: 1000
    def: 1000

    effect "Effect 1" {
        speed: 1
        once_per_turn: soft
        mandatory
        resolve {
            set_atk self self.atk * 2 until end_of_turn
            install_watcher "desop" { event: end_phase duration: end_of_turn check { destroy self } }
        }
    }
}
