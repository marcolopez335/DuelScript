// 魔救の奇縁
// Adamancipator Friends
// Transpiled from c99927991.lua

card "Adamancipator Friends" {
    id: 99927991
    type: Normal Spell

    effect "Effect 1" {
        speed: spell_speed_1
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            reveal (1, card, opponent controls, deck)
            return (1+, monster, you controls) to hand
            reveal (1+, card, opponent controls)
            shuffle_hand
            send_to_deck (1+, card, you controls) bottom
            send_to_deck (1+, card, you controls)
        }
    }

}
