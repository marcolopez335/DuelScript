// 白き森のいいつたえ
// Tales of the White Forest
// Transpiled from c99289828.lua

card "Tales of the White Forest" {
    id: 99289828
    type: Normal Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        on_resolve {
            return (1+, monster, you controls) to hand
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        trigger: on_custom_event "chain_end"
        on_resolve {
            set (1, card)
        }
    }

}
