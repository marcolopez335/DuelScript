card "Azamina Moa Regina" {
    id: 46174776
    type: Fusion Monster
    attribute: DARK
    race: Warrior
    level: 8
    atk: 3000
    def: 2000

    summon {
        cannot_normal_summon
        special_summon_procedure {
            from: extra_deck
            to: your_field
        }
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        mandatory
        resolve {
            special_summon (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 2
        once_per_turn: soft
        timing: when
        trigger: opponent_activates [activate_spell, activate_trap, activate_spell]
        target (1+, card, either controls, from field)
        resolve {
            destroy (all, card, either controls)
        }
    }
}
