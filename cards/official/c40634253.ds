// BM-4 ボムスパイダー
// BM-4 Blast Spider
// Transpiled from c40634253.lua

card "BM-4 Blast Spider" {
    id: 40634253
    type: Effect Monster
    attribute: DARK
    race: Machine
    level: 4
    atk: 1400
    def: 2200

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_activate {
            select (1+, monster, either_player controls, where { is_face_up and race == Machine and attribute == DARK }) as target
        }
        on_resolve {
            destroy (1+, monster, either_player controls, where { is_face_up and race == Machine and attribute == DARK })
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: when_battle_damage
        on_resolve {
            deal_damage to opponent: 1000
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: on_custom_event "chain_end"
        on_resolve {
            deal_damage to opponent: 1000
        }
    }

}
