card "Spellbook of Fate" {
    id: 97997309
    type: Quick-Play Spell

    effect "Effect 1" {
        speed: 2
        once_per_turn: hard
        mandatory
        resolve {
            return (all, card, either controls) to hand
        }
    }

    effect "Effect 2" {
        speed: 2
        once_per_turn: hard
        mandatory
        resolve {
            change_position (1, card, either controls, from monster_zone) to face_down_defense
            change_position (1, card, either controls, from monster_zone)
        }
    }

    effect "Effect 3" {
        speed: 2
        once_per_turn: hard
        mandatory
        resolve {
            banish (all, card, either controls)
        }
    }
}
