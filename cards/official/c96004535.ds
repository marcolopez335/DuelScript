// エクシーズ・アンブレイカブル・バリア
// Unbreakable Xyz Barrier
// Transpiled from c96004535.lua

card "Unbreakable Xyz Barrier" {
    id: 96004535
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            negate activation
            detach 1 overlay_unit from self
            destroy (1+, monster, you controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        damage_step: false
        activate_from: [gy]
        on_activate {
            select (1+, monster, you controls) as target
        }
        cost {
            banish self
        }
        on_resolve {
            attach (1, card) to self as_material
        }
    }

}
