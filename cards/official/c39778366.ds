// スクランブル・ユニオン
// Union Scramble
// Transpiled from c39778366.lua

card "Union Scramble" {
    id: 39778366
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, card, either_player controls, where { attribute == LIGHT and race == Machine and is_monster and is_face_up }) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
            special_summon (1, monster) from gy
            send (1+, card, either_player controls, where { attribute == LIGHT and race == Machine and is_monster and is_face_up }) to gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        optional: true
        damage_step: false
        activate_from: [gy]
        on_activate {
            select (1+, card, either_player controls, where { attribute == LIGHT and race == Machine and is_monster and is_face_up }) as target
        }
        cost {
            banish self
        }
        on_resolve {
            add_to_hand (1+, card, either_player controls, where { attribute == LIGHT and race == Machine and is_monster and is_face_up }) from gy
            reveal (1+, card, opponent controls)
        }
    }

}
