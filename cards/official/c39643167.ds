card "Bunny Ear Enthusiast" {
    id: 39643167
    type: Effect Monster
    attribute: EARTH
    race: Beast-Warrior
    level: 1
    atk: 200
    def: 100

    effect "Effect 1" {
        speed: spell_speed_2
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        damage_step: false
        on_resolve {
            banish (1+, monster, opponent controls)
        }
    }

