// BF－陽炎のカーム
// Blackwing - Calima the Haze
// Transpiled from c88305978.lua

card "Blackwing - Calima the Haze" {
    id: 88305978
    type: Effect Monster
    attribute: DARK
    race: Winged Beast
    level: 4
    atk: 600
    def: 1800

    effect "Effect 1" {
        speed: spell_speed_2
        optional: true
        damage_step: false
        activate_from: [gy]
        on_activate {
            select (1+, card, either_player controls) as target
        }
        cost {
            banish self
        }
        on_resolve {
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
