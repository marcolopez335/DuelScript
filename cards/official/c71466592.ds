card "Maryokutai" {
    id: 71466592
    type: Effect Monster
    attribute: WATER
    race: Aqua
    level: 3
    atk: 900
    def: 900

    effect "Effect 1" {
        speed: spell_speed_2
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        cost {
            tribute self
        }
        on_resolve {
            negate activation
            destroy (1+, card, either_player controls)
        }
    }

}
