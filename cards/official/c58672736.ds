card "Dinowrestler Giga Spinosavate" {
    id: 58672736
    type: Synchro Monster
    attribute: EARTH
    race: Dinosaur
    level: 8
    atk: 3000
    def: 0

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    summon_condition {
        cannot_normal_summon: true
    }

    continuous_effect "Effect 1" {
        scope: field
