card "Psychic Rover" {
    id: 53154400
    type: Effect Monster
    attribute: DARK
    race: Psychic
    level: 2
    atk: 0
    def: 700

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        on_resolve {
            flip_coin { heads { draw 1 } tails { draw 1 } }
            destroy (1+, card, either_player controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        optional: true
        timing: if
        trigger: on_custom_event "chain_end"
        on_resolve {
            flip_coin { heads { draw 1 } tails { draw 1 } }
            special_summon (1, monster) from gy
        }
    }

}
