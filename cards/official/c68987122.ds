// ヴァレルガード・ドラゴン
// Borrelguard Dragon
// Transpiled from c68987122.lua

card "Borrelguard Dragon" {
    id: 68987122
    type: Link Monster
    attribute: DARK
    race: Dragon
    link: 4
    link_arrows: [top, right, bottom, bottom_right]
    atk: 3000

    materials {
        require: 2+ effect monster
        method: link
    }

    summon_condition {
        cannot_normal_summon: true
    }

    continuous_effect "Effect 1" {
        scope: self
        grant: cannot_be_destroyed_by_effect
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        cost {
            send self to gy
        }
        on_resolve {
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 3" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        damage_step: false
        on_activate {
            select (1+, spell, you controls) as target
        }
        on_resolve {
            change_battle_position (1, monster)
        }
    }

}
