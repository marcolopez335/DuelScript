    }

    raw_effect "Effect 3" {
        effect_type: Field + Trigger
        category: ToHand
        code: BattleDamage
        property: Delay
        range: Graveyard
        cost {
            banish self
        }
        on_resolve {
            add_to_hand (1+, card, you controls) from deck
            reveal (1+, card, opponent controls)
        }
    }

    raw_effect "Effect 4" {
        effect_type: Field + Trigger
        category: ToHand
        code: ChainEnd
        property: Delay
        range: Graveyard
        cost {
            banish self
        }
        on_resolve {
            add_to_hand (1+, card, you controls) from deck
            reveal (1+, card, opponent controls)
        }
    }

