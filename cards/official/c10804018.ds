// Saffira, Divine Dragon of the Voiceless Voice
// Transpiled from c10804018.lua

card "Saffira, Divine Dragon of the Voiceless Voice" {
    password: 10804018
    type: Ritual Monster
    attribute: LIGHT
    race: Dragon
    level: 7
    atk: 2550
    def: 2450

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        trigger: when_summoned by_special_summon
        on_resolve {
            draw 2
            shuffle deck
            discard (1, card)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        trigger: when attack_declared
        on_resolve {
            send (1, card) to gy
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        trigger: during_end_phase
        on_resolve {
            add_to_hand (1, card) from gy
        }
    }

}
