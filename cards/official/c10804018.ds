// 粛声なる竜神サフィラ
// Saffira, Divine Dragon of the Voiceless Voice
// Transpiled from c10804018.lua

card "Saffira, Divine Dragon of the Voiceless Voice" {
    id: 10804018
    type: Ritual Monster
    attribute: LIGHT
    race: Dragon
    level: 7
    atk: 2550
    def: 2450

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 1+ monster
        method: ritual
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        on_resolve {
            draw 2
            shuffle_hand
            discard (1, card)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: when
        trigger: when attack_declared
        on_resolve {
            send (1+, card, you controls, gy) to gy
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: when
        trigger: during_end_phase
        on_resolve {
            add_to_hand (1+, card, you controls) from gy
            reveal (1+, card, opponent controls)
        }
    }

}
