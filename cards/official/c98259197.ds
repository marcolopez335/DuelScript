// おジャマッスル
// Ojamuscle
// Transpiled from c98259197.lua

card "Ojamuscle" {
    id: 98259197
    type: Normal Spell

    effect "Effect 1" {
        speed: spell_speed_1
        damage_step: false
        on_activate {
            select (1+, monster, either_player controls, where { is_face_up and card_id == 90140980 }) as target
        }
        on_resolve {
            destroy (1+, monster, either_player controls, where { is_face_up and card_id == 90140980 })
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
