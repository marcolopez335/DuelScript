// サブテラーの激闘
// Subterror Cave Clash
// Transpiled from c68001309.lua

card "Subterror Cave Clash" {
    id: 68001309
    type: Continuous Spell

    effect "Effect 1" {
        speed: spell_speed_1
        on_resolve {
        }
    }

    raw_effect "Effect 2" {
        effect_type: Field
        code: UpdateAttack
        range: SpellTrapZone
        on_resolve {
            modifier: atk + count((1+, monster, you controls)) * 500
        }
    }

    raw_effect "Effect 3" {
        effect_type: Field
        code: UpdateDefense
        range: SpellTrapZone
        on_resolve {
            modifier: def + count((1+, monster, you controls)) * 500
        }
    }

    effect "Effect 4" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: when
        damage_step: false
        trigger: when_battle_destroyed
        activate_from: [spell_trap_zone]
        on_activate {
            select (1+, monster, either_player controls) as target
        }
        on_resolve {
            return (1+, monster, either_player controls) to hand
        }
    }

}
