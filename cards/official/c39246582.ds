card "Fluffal Dog" {
    id: 39246582
    type: Effect Monster
    attribute: EARTH
    race: Fairy
    level: 4
    atk: 1700
    def: 1000

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        timing: when
        trigger: summoned
        condition: previous_location == hand
        resolve {
            add_to_hand (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        timing: when
        trigger: summoned by special
        resolve {
            add_to_hand (all, card, either controls)
        }
    }
}
