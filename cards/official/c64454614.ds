// アルカナ エクストラジョーカー
// Arcana Extra Joker
// Transpiled from c64454614.lua

card "Arcana Extra Joker" {
    id: 64454614
    type: Link Monster
    attribute: LIGHT
    race: Warrior
    link: 3
    link_arrows: [top, bottom_left, bottom_right]
    atk: 2800

    materials {
        require: 2+ effect monster
        method: link
    }

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            negate activation
            send (1+, card, you controls, hand) to gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        optional: true
        timing: when
        trigger: when_battle_damage
        on_resolve {
            special_summon (1, monster) from gy
            reveal (1+, card, opponent controls)
            add_to_hand (1+, card, you controls) from hand
        }
    }

}
