// 久遠の神徒フリムニル
// Hrimnir the Divine Follower
// Transpiled from c49904658.lua

card "Hrimnir the Divine Follower" {
    id: 49904658
    type: Effect Monster
    attribute: LIGHT
    race: Fairy
    level: 9
    atk: 2200
    def: 2200

    summon_condition {
        tributes_required: 2
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        cost {
            tribute self
        }
        on_resolve {
            set (1, card)
            destroy (1+, monster, opponent controls)
            send (1+, card, you controls, deck) to gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        trigger: on_custom_event "chain_end"
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    redirect_effect "Effect 3" {
        when_going_to: field
        redirect_to: banished
    }

}
