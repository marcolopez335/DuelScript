// Sunset Beat
// Transpiled from c42510430.lua

card "Sunset Beat" {
    password: 42510430
    type: Continuous Spell

    effect "Effect 1" {
        speed: spell_speed_1
        on_resolve {
            reveal self
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        on_resolve {
            destroy (1+, card, either_player controls)
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        damage_step: true
        trigger: when_flipped
        on_resolve {
            deal_damage to opponent: 1000
        }
    }

}
