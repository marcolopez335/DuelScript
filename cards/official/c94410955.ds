card "Hecahands Xeno" {
    id: 94410955
    type: Fusion Monster
    attribute: DARK
    race: Unknown
    level: 9
    atk: 3400
    def: 3500

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        method: fusion
    }

    raw_effect "Effect 1" {
        effect_type: Field
        code: CannotBeEffectTarget
        range: MonsterZone
        on_resolve {
            register_effect on self { grant: cannot_be_destroyed_by_battle duration: until_end_of_turn }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        on_resolve {
            reveal (1+, card, opponent controls)
            special_summon (1, monster) from gy
            shuffle_deck
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        trigger: when_destroyed
        on_resolve {
            take_control of (1, monster, opponent controls)
        }
    }

}
