// スマイル・アクション
// Smile Action
// Transpiled from c47870325.lua

card "Smile Action" {
    id: 47870325
    type: Field Spell

    effect "Effect 1" {
        speed: spell_speed_1
        on_resolve {
            banish (1+, spell, either_player controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        trigger: when attack_declared
        activate_from: [field_zone]
        on_resolve {
            add_to_hand (1+, spell, either_player controls) from gy
            send (1+, spell, either_player controls) to gy
            negate attack
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
