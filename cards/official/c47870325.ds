// スマイル・アクション
// Smile Action
// Transpiled from c47870325.lua

card "Smile Action" {
    id: 47870325
    type: Field Spell

    raw_effect "Effect 1" {
        effect_type: Activate
        category: Banish
        code: FreeChain
        on_resolve {
            banish (1+, spell, either_player controls)
        }
    }

    raw_effect "Effect 2" {
        effect_type: Field + MandatoryTrigger
        category: ToHand + DefChange
        code: AttackAnnounce
        range: FieldZone
        on_resolve {
            add_to_hand (1+, spell, either_player controls) from gy
            send (1+, spell, either_player controls) to gy
            negate attack
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
