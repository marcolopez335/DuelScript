// 精霊の世界
// World of Spirits
// Transpiled from c5414777.lua

card "World of Spirits" {
    id: 5414777
    type: Field Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        on_resolve {
            return (1+, monster, you controls, where { is_monster }) to hand
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        trigger: when_summoned by_special_summon
        activate_from: [field_zone]
        on_resolve {
            change_battle_position (1, monster)
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        trigger: during_end_phase
        activate_from: [field_zone]
        on_resolve {
            destroy (1+, monster, you controls, where { is_monster })
        }
    }

}
