card "XY-Dragon Cannon" {
    id: 2111707
    type: Fusion Monster
    attribute: LIGHT
    race: Machine
    level: 6
    atk: 2200
    def: 1900

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        method: fusion
    }

    effect "Effect 1" {
        speed: spell_speed_1
        damage_step: false
        on_activate {
            select (1+, spell, you controls, where { is_face_up and is_spell }) as target
        }
        on_resolve {
            destroy (1+, spell, you controls, where { is_face_up and is_spell })
        }
    }

}
