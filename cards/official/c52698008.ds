// サイバース・ウィキッド
// Cyberse Wicckid
// Transpiled from c52698008.lua

card "Cyberse Wicckid" {
    id: 52698008
    type: Link Monster
    attribute: DARK
    race: Cyberse
    link: 2
    link_arrows: [bottom, bottom_right]
    atk: 800

    materials {
        require: 2+ effect monster
        method: link
    }

    summon_condition {
        cannot_normal_summon: true
    }

    continuous_effect "Effect 1" {
        scope: self
        grant: cannot_be_destroyed_by_battle
    }

    continuous_effect "Effect 2" {
        scope: self
        grant: cannot_be_destroyed_by_effect
    }

    continuous_effect "Effect 3" {
        scope: field
        grant: cannot_be_destroyed_by_effect
    }

    effect "Effect 4" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        cost {
            banish self
        }
        on_resolve {
            add_to_hand (1+, card, you controls, where { race == Cyberse and is_tuner }) from gy
            reveal (1+, card, opponent controls)
        }
    }

}
