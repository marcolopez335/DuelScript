// 破壊剣－アームズバスターブレード
// Robot Buster Destruction Sword
// Transpiled from c38601126.lua

card "Robot Buster Destruction Sword" {
    id: 38601126
    type: Effect Monster
    attribute: DARK
    race: Machine
    level: 4
    atk: 1600
    def: 1200

    effect "Effect 1" {
        speed: spell_speed_1
        damage_step: false
        activate_from: [hand, monster_zone]
        on_activate {
            select (1+, card, either_player controls, where { is_face_up }) as target
        }
        on_resolve {
            send (1+, card, either_player controls, where { is_face_up }) to gy
            equip (1, card) to (1, monster)
        }
    }

    continuous_effect "Effect 2" {
        scope: field
        grant: cannot_activate_effects
    }

    effect "Effect 3" {
        speed: spell_speed_1
        activate_from: [spell_trap_zone]
        cost {
            send self to gy
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    raw_effect "Effect 4" {
        effect_type: Single
        code: CannotAttack2
        on_resolve {
        }
    }

    raw_effect "Effect 5" {
        effect_type: Single
        code: UpdateAttack
        on_resolve {
            modifier: atk + 1000
        }
    }

}
