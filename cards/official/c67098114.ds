// 極神皇ロキ
// Loki, Lord of the Aesir
// Transpiled from c67098114.lua

card "Loki, Lord of the Aesir" {
    id: 67098114
    type: Synchro Monster
    attribute: DARK
    race: Spellcaster
    level: 10
    atk: 3300
    def: 3000

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            negate activation
            destroy (1+, trap, you controls, gy)
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single + Continuous
        code: ChainEnd
        property: BothSide
        on_resolve {
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: when
        trigger: during_end_phase
        activate_from: [gy]
        cost {
            banish self
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 4" {
        speed: spell_speed_1
        optional: true
        timing: when
        damage_step: false
        trigger: when_summoned by_special_summon
        on_activate {
            select (1+, trap, you controls, where { is_trap }) as target
        }
        on_resolve {
            add_to_hand (1+, trap, you controls, where { is_trap }) from gy
            reveal (1+, card, opponent controls)
        }
    }

}
