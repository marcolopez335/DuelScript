// 混沌魔龍カオス・ルーラー
// Chaos Ruler, the Chaotic Magical Dragon
// Transpiled from c3040496.lua

card "Chaos Ruler, the Chaotic Magical Dragon" {
    id: 3040496
    type: Synchro Monster
    attribute: DARK
    race: Dragon
    level: 8
    atk: 3000
    def: 2500

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        on_resolve {
            reveal (1, card, opponent controls, deck)
            add_to_hand (1+, monster, you controls) from gy
            reveal (1+, card, opponent controls)
            shuffle_hand
            send (1+, monster, you controls, gy) to gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        activate_from: [gy]
        cost {
            banish self
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
