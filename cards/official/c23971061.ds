card "Doublebyte Dragon" {
    id: 23971061
    type: Link Monster
    attribute: DARK
    race: Cyberse
    link: 2
    link_arrows: [top, bottom]
    atk: 1500

    summon {
        cannot_normal_summon
        special_summon_procedure {
            from: extra_deck
            to: your_field
        }
