card "Puppet Shark" {
    id: 53323475
    type: Normal Trap

    raw_effect "Effect 1" {
        effect_type: Activate
        category: ToHand + Search
        code: FreeChain
        count_limit: (1, 53323475)
        on_resolve {
            detach 1 overlay_unit from self
            reveal (1, card, opponent controls, deck)
