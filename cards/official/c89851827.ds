card "Secreterion Dragon" {
    id: 89851827
    type: Fusion Monster
    attribute: LIGHT
    race: Dragon
    level: 8
    atk: 3000
    def: 1500

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        method: fusion
    }

    raw_effect "Effect 1" {
        effect_type: Single
        code: UpdateAttack
        property: SingleRange
        range: MonsterZone
        on_resolve {
            modifier: atk + 0
        }
    }

    raw_effect "Effect 2" {
        effect_type: Field
        code: CannotChangeControl
        property: InitialValue
        range: MonsterZone
        on_resolve {
            register_effect on self { grant: cannot_activate_effects duration: until_end_of_turn }
        }
    }

    raw_effect "Effect 3" {
        effect_type: Ignition
        category: ToDeck + SpecialSummon
        property: CardTarget
        range: MonsterZone
        count_limit: (1, 89851827)
        on_resolve {
            special_summon (1, monster) from gy
            return (1+, card, you controls) to deck shuffle
        }
    }

}
