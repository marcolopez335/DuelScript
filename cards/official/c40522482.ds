card "Skydive Scorcher" {
    id: 40522482
    type: Normal Spell

    effect "Effect 1" {
        speed: spell_speed_1
        damage_step: false
        on_activate {
            select (1+, monster, opponent controls, where { is_face_up }) as target
        }
        on_resolve {
            destroy (1+, monster, opponent controls, where { is_face_up })
            deal_damage to opponent: 1000
        }
    }

}
