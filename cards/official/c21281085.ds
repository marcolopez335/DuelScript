// 魔轟神レヴェルゼブル
// Fabled Levilazebul
// Transpiled from c21281085.lua

card "Fabled Levilazebul" {
    id: 21281085
    type: Synchro Monster
    attribute: LIGHT
    race: Fiend
    level: 10
    atk: 3050
    def: 1950

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        on_resolve {
            tribute (1, monster, you controls)
            take_control of (1, monster, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        activate_from: [gy]
        on_activate {
            select (1+, monster, opponent controls) as target
        }
        on_resolve {
            return (1+, monster, opponent controls) to deck shuffle
            return (1+, monster, opponent controls) to hand
        }
    }

}
