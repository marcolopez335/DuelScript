card "Fabled Levilazebul" {
    id: 21281085
    type: Synchro Monster
    attribute: LIGHT
    race: Fiend
    level: 10
    atk: 3050
    def: 1950

    summon {
        cannot_normal_summon
        synchro materials {
            tuner: (1, tuner monster)
            non_tuner: (1+, non-tuner monster)
        }
    }

    effect "Effect 1" {
        speed: 2
        once_per_turn: soft
        resolve {
            take_control (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        mandatory
        resolve {
            return (all, card, either controls) to deck
            return (all, card, either controls) to hand
        }
    }
}
