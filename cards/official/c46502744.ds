// 応戦するG
// Retaliating 'C'
// Transpiled from c46502744.lua

card "Retaliating 'C'" {
    id: 46502744
    type: Effect Monster
    attribute: EARTH
    race: Insect
    level: 4
    atk: 1400
    def: 1400

    effect "Effect 1" {
        speed: spell_speed_2
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        activate_from: [hand]
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    redirect_effect "Effect 2" {
        when_going_to: gy
        redirect_to: banished
    }

    effect "Effect 3" {
        speed: spell_speed_1
        optional: true
        timing: if
        trigger: on_custom_event "chain_end"
        on_resolve {
            add_to_hand (1+, card, you controls) from deck
            reveal (1+, card, opponent controls)
        }
    }

}
