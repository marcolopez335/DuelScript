card "Retaliating 'C'" {
    id: 46502744
    type: Effect Monster
    attribute: EARTH
    race: Insect
    level: 4
    atk: 1400
    def: 1400

    effect "Effect 1" {
        speed: 2
        timing: when
        trigger: opponent_activates [activate_spell, activate_trap, activate_spell]
        resolve {
            special_summon (all, card, either controls)
        }
    }

    effect "Effect 3" {
        speed: 1
        timing: if
        trigger: custom "chain_end"
        condition: previous_location == field
        resolve {
            add_to_hand (all, card, either controls)
        }
    }
}
