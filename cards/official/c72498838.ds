        trigger: summoned by special
        resolve {
            add_to_hand (1, card, where archetype == "Magistus" and not is_monster) from deck
            send (all, card, either controls) to gy
        }
    }

    effect "Effect 3" {
        speed: 1
        once_per_turn: soft
        mandatory
        cost {
