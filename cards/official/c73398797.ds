card "Paladin of White Dragon" {
    id: 73398797
    type: Ritual Monster
    attribute: LIGHT
    race: Dragon
    level: 4
    atk: 1900
    def: 1200

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 1+ monster
        method: ritual
    }

    raw_effect "Effect 1" {
        effect_type: Single + MandatoryTrigger
        category: Destroy
