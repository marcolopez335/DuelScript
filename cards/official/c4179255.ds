// 妖精竜 エンシェント
// Ancient Pixie Dragon
// Transpiled from c4179255.lua

card "Ancient Pixie Dragon" {
    id: 4179255
    type: Synchro Monster
    attribute: DARK
    race: Dragon
    level: 7
    atk: 2100
    def: 3000

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            draw 1
        }
    }

    raw_effect "Effect 2" {
        effect_type: Field + MandatoryTrigger
        category: Draw
        code: 4179255
        property: InitialValue
        range: MonsterZone
        count_limit: (1, 4179255)
        on_resolve {
            draw 1
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            destroy (1+, card, either_player controls)
        }
    }

}
