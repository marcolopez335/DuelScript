card "Fish Lamp" {
    id: 35834119
    type: Synchro Monster | Tuner
    attribute: FIRE
    race: Fish
    level: 4
    atk: 1200
    def: 400

    summon {
        cannot_normal_summon
        synchro materials {
            tuner: (1, tuner monster)
            non_tuner: (1+, non-tuner monster)
        }
    }

    passive "Effect 3" {
        scope: self
        grant: cannot_attack
