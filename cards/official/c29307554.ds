card "Lineage of Destruction" {
    id: 29307554
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        damage_step: false
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    raw_effect "Effect 2" {
        effect_type: Field + Continuous
        code: Destroyed
        on_resolve {
            set_flag "tracked" on self
            set_flag "tracked" on self
        }
    }

}
