// 毘龍之謙
// Ken the Warrior Dragon
// Transpiled from c25131968.lua

card "Ken the Warrior Dragon" {
    id: 25131968
    type: Effect Monster
    attribute: LIGHT
    race: Warrior
    level: 3
    atk: 1300
    def: 1550

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        trigger: during battle_phase
        on_resolve {
            add_to_hand (1+, card, you controls) from hand
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        trigger: when_summoned by_special_summon
        on_resolve {
            draw 1
            shuffle_hand
            discard (1, card)
        }
    }

}
