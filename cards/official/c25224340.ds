// 幻惑の操手
// Nightmare Hands
// Transpiled from c25224340.lua

card "Nightmare Hands" {
    id: 25224340
    type: Quick-Play Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        on_resolve {
            send (1+, card, you controls, deck) to gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        activate_from: [gy]
        on_activate {
            select (1+, card, you controls, where { race == Illusion }) as target
        }
        cost {
            banish self
        }
        on_resolve {
            special_summon (1, monster) from gy
            destroy (1+, monster, opponent controls)
            banish (1+, card, you controls, deck)
        }
    }

}
