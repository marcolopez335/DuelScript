card "Ultimate Great Insect" {
    id: 87804747
    type: Fusion Monster
    attribute: EARTH
    race: Insect
    level: 9
    atk: 3000
    def: 2600

    summon {
        cannot_normal_summon
        special_summon_procedure {
            from: extra_deck
            to: your_field
        }
