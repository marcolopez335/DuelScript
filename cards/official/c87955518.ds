// Chef's Special Recipe
// Transpiled from c87955518.lua

card "Chef's Special Recipe" {
    password: 87955518
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        trigger: opponent_activates [search | special_summon | send_to_gy | draw]
        on_resolve {
            negate activation
            destroy (1+, card, either_player controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        trigger: when_summoned by_special_summon
        cost {
            banish self
        }
        on_resolve {
            tribute (1, monster, you controls)
        }
    }

}
