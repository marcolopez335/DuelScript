// 先史遺産技術
// Chronomaly Technology
// Transpiled from c90951921.lua

card "Chronomaly Technology" {
    id: 90951921
    type: Normal Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, monster, either_player controls) as target
        }
        on_resolve {
            banish (1+, monster, either_player controls)
            reveal (1+, card, opponent controls)
            add_to_hand (1+, monster, either_player controls) from gy
            send (1+, monster, either_player controls) to gy
        }
    }

}
