card "Ukiyoe-P.U.N.K. Amazing Dragon" {
    id: 44708154
    type: Synchro Monster
    attribute: WIND
    race: Sea Serpent
    level: 11
    atk: 3000
    def: 2800

    summon {
        cannot_normal_summon
        synchro materials {
            tuner: (1, tuner monster)
            non_tuner: (1+, non-tuner monster)
        }
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            add_to_hand (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        mandatory
        resolve {
            special_summon (all, card, either controls)
        }
    }
}
