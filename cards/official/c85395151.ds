// 洗脳解放
// Release Brainwashing
// Transpiled from c85395151.lua

card "Release Brainwashing" {
    id: 85395151
    type: Quick-Play Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        trigger: when_tributed
        on_activate {
            select (1+, monster, either_player controls) as target
        }
        on_resolve {
            take_control of (1, monster, opponent controls)
            add_to_hand (1+, monster, either_player controls) from gy
            destroy (1+, monster, opponent controls)
        }
    }

}
