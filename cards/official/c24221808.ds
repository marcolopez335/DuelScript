card "Overmind Archfiend" {
    id: 24221808
    type: Synchro Monster
    attribute: DARK
    race: Psychic
    level: 9
    atk: 3300
    def: 3000

    summon {
        cannot_normal_summon
        synchro materials {
            tuner: (1, tuner monster, where race == Psychic)
            non_tuner: (2+, non-tuner monster, where race == Psychic)
        }
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: soft
        mandatory
        resolve {
            banish (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        mandatory
        trigger: custom "chain_end"
        resolve {
            special_summon (all, card, either controls)
        }
    }
}
