// マジェスペクター・テンペスト
// Majespecter Tempest
// Transpiled from c2572890.lua

card "Majespecter Tempest" {
    id: 2572890
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        cost {
            tribute self
        }
        on_resolve {
            negate summon
            destroy (1+, card, either_player controls, where { race == Spellcaster and attribute == WIND })
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        cost {
            tribute self
        }
        on_resolve {
            negate activation
            destroy (1+, card, either_player controls, where { race == Spellcaster and attribute == WIND })
        }
    }

}
