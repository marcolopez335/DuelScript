// ジャンク・デストロイヤー
// Junk Destroyer
// Transpiled from c74860293.lua

card "Junk Destroyer" {
    id: 74860293
    type: Synchro Monster
    attribute: EARTH
    race: Warrior
    level: 8
    atk: 2600
    def: 2500

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        timing: when
        damage_step: false
        trigger: when_summoned by_special_summon
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            destroy (1+, card, either_player controls)
        }
    }

}
