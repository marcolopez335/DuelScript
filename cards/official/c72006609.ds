// 明星の機械騎士
// Mekk-Knight of the Morning Star
// Transpiled from c72006609.lua

card "Mekk-Knight of the Morning Star" {
    id: 72006609
    type: Link Monster
    attribute: LIGHT
    race: Machine
    link: 2
    link_arrows: [bottom_left, bottom_right]
    atk: 2000

    materials {
        require: 2+ effect monster
        method: link
    }

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        on_resolve {
            add_to_hand (1+, monster, you controls) from hand
            reveal (1+, card, opponent controls)
        }
    }

    continuous_effect "Effect 2" {
        scope: field
        grant: cannot_be_destroyed_by_battle
    }

    continuous_effect "Effect 3" {
        scope: field
        grant: cannot_be_destroyed_by_battle
    }

}
