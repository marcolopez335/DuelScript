card "Horn of Olifant" {
    id: 55749927
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        on_resolve {
            banish (1+, spell, either_player controls, where { is_spell })
            destroy (1+, spell, either_player controls, where { is_spell })
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
