card "Stellarknight Triverr" {
    id: 42589641
    type: Xyz Monster
    attribute: LIGHT
    race: Warrior
    rank: 4
    atk: 2100
    def: 2500

    summon {
        cannot_normal_summon
    }

    effect "Effect 3" {
        speed: 1
        mandatory
        trigger: summoned by special
        resolve {
            return (all, card, either controls) to hand
        }
    }

    effect "Effect 4" {
        speed: 1
        once_per_turn: soft
        mandatory
        cost {
            detach 1 from self
        }
        resolve {
            send (all, card, either controls) to gy
        }
    }

    effect "Effect 5" {
        speed: 1
        timing: if
        trigger: custom "chain_end"
        resolve {
            special_summon (all, card, either controls)
        }
    }
}
