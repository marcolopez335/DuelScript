// 転生炎獣の炎軍
// Salamangreat Charge
// Transpiled from c83533296.lua

card "Salamangreat Charge" {
    id: 83533296
    type: Quick-Play Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        on_resolve {
            return (1+, card, you controls) to deck shuffle
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            destroy (1+, card, you controls, gy)
        }
    }

}
