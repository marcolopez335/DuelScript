card "Gergonne's End" {
    id: 59490397
    type: Normal Trap

    effect "Effect 1" {
        speed: 2
        mandatory
        resolve {
            equip self to target
            grant equipped_card cannot_be_destroyed by battle until while_equipped
            grant equipped_card cannot_be_destroyed by effect until while_equipped
            grant equipped_card cannot_be_targeted until while_equipped
        }
    }

    effect "Effect 2" {
        speed: 2
        once_per_turn: soft
        resolve {
            destroy (all, card, either controls)
            damage opponent 1000
        }
    }
}
