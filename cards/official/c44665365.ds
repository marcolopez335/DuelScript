card "Herald of Perfection" {
    password: 44665365
    type: Ritual Monster
    attribute: LIGHT
    race: Fairy
    level: 6
    atk: 1800
    def: 2800

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_2
        optional: true
        damage_step: true
