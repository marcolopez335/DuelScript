card "Clockwork Knight" {
    id: 41739381
    type: Link Monster
    attribute: EARTH
    race: Machine
    link: 1
    link_arrows: [left]
    atk: 500

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ effect monster
        method: link
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        cost {
            send self to gy
        }
        on_resolve {
            return (1+, card, you controls, where { card_id == 84797028 }) to hand
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_activate {
            select (1+, card, you controls, where { card_id == 84797028 }) as target
        }
        on_resolve {
            tribute (1, monster, you controls)
            special_summon (1, monster) from gy
        }
    }

}
