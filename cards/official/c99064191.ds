// エクシーズ・パニッシュ
// Xyz Wrath
// Transpiled from c99064191.lua

card "Xyz Wrath" {
    id: 99064191
    type: Continuous Trap

    effect "Effect 1" {
        speed: spell_speed_2
        on_resolve {
            negate effect
            destroy (1+, monster, you controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        activate_from: [spell_trap_zone]
        on_resolve {
            negate effect
            destroy (1+, monster, you controls)
        }
    }

}
