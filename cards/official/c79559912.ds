// ＤＤＤ怒涛大王エグゼクティブ・シーザー
// D/D/D Wave High King Caesar
// Transpiled from c79559912.lua

card "D/D/D Wave High King Caesar" {
    id: 79559912
    type: Xyz Monster
    attribute: WATER
    race: Fiend
    rank: 6
    atk: 2800
    def: 1800

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        same_level: true
        method: xyz
    }

    raw_effect "Effect 1" {
        effect_type: QuickEffect
        category: Destroy + AtkChange + Negate
        code: Chaining
        property: Oath + CountCodeDuel
        range: MonsterZone
        cost {
            detach 1 overlay_unit from self
        }
        on_resolve {
            negate activation
            destroy (1+, monster, you controls)
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single + Trigger
        category: ToHand + Search
        code: ChainEnd
        property: Delay
        on_resolve {
            return (1+, monster, you controls) to hand
            reveal (1+, card, opponent controls)
        }
    }

}
