card "Number C104: Umbral Horror Masquerade" {
    id: 49456901
    type: Xyz Monster
    attribute: DARK
    race: Spellcaster
    rank: 5
    atk: 3000
    def: 1500

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
