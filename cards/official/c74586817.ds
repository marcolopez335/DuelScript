card "PSY-Framelord Omega" {
    id: 74586817
    type: Synchro Monster
    attribute: LIGHT
    race: Psychic
    level: 8
    atk: 2800
    def: 2200

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        on_resolve {
            banish (1+, card, opponent controls, hand)
            destroy (1+, monster, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: when
        damage_step: false
        trigger: during_standby_phase
        on_resolve {
            send (1+, card, opponent controls, hand) to gy
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        damage_step: false
        activate_from: [gy]
        on_resolve {
            return (1+, card, opponent controls) to deck shuffle
        }
    }

}
