card "Maliss in the Mirror" {
    id: 93453053
    type: Quick-Play Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, monster, you controls) as target
        }
        on_resolve {
            banish (1+, monster, you controls, hand)
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single + Trigger
        category: Banish + ToHand + Search
        code: TurnEnd
        property: CardTarget + Delay
        count_limit: (1, 0)
        on_resolve {
            banish (1+, monster, you controls, hand)
            add_to_hand (1+, monster, you controls) from hand
            reveal (1+, card, opponent controls)
        }
    }

