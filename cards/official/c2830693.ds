// 虹クリボー
// Rainbow Kuriboh
// Transpiled from c2830693.lua

card "Rainbow Kuriboh" {
    id: 2830693
    type: Effect Monster
    attribute: LIGHT
    race: Fiend
    level: 1
    atk: 100
    def: 100

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: when
        damage_step: false
        trigger: when attack_declared
        activate_from: [hand]
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            send (1+, card, either_player controls) to gy
            equip (1, card) to (1, monster)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: when
        trigger: when attack_declared
        activate_from: [gy]
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
