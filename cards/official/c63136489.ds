// 合成獣融合
// Chimera Fusion
// Transpiled from c63136489.lua

card "Chimera Fusion" {
    id: 63136489
    type: Quick-Play Spell

    effect "Effect 1" {
        speed: spell_speed_1
        on_resolve {
            fusion_summon (1, fusion monster) using (1+, monster, you controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [gy]
        on_resolve {
            add_to_hand (1+, card, you controls) from gy
            reveal (1+, card, opponent controls)
            banish (1+, card, you controls, gy)
            special_summon (1, monster) from gy
        }
    }

}
