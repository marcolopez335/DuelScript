card "Chaos Archfiend" {
    id: 13076804
    type: Synchro Monster
    attribute: DARK
    race: Fiend
    level: 8
    atk: 2500
    def: 1800

    summon {
        cannot_normal_summon
        synchro materials {
            tuner: (1, tuner monster, where attribute == LIGHT)
            non_tuner: (1+, non-tuner monster, where attribute == DARK)
        }
    }

    passive "Effect 2" {
        scope: self
        grant: attack_all_monsters
    }
}
