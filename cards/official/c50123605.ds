card "Heavy Cavalry of the Indestructible Insects" {
    id: 50123605
    type: Fusion Monster
    attribute: EARTH
    race: Insect
    level: 7
    atk: 2500
    def: 1800

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        method: fusion
    }

    raw_effect "Effect 1" {
        effect_type: Single
        code: IndestructableEffect
        property: SingleRange
        range: MonsterZone
        on_resolve {
            register_effect on self { grant: cannot_be_destroyed_by_effect duration: until_end_of_turn }
        }
    }

    raw_effect "Effect 2" {
        effect_type: QuickEffect
        category: Banish
        code: FreeChain
        property: CardTarget
        range: MonsterZone
        count_limit: (1, 50123605)
        on_resolve {
            banish (1+, monster, you controls)
        }
    }

