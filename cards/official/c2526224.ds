// 炎王神獣 キリン
// Fire King High Avatar Kirin
// Transpiled from c2526224.lua

card "Fire King High Avatar Kirin" {
    id: 2526224
    type: Effect Monster
    attribute: FIRE
    race: Beast
    level: 8
    atk: 2400
    def: 200

    summon_condition {
        tributes_required: 2
    }

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        activate_from: [hand]
        on_resolve {
            destroy (1+, card, either_player controls, where { attribute == FIRE and is_face_up })
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        trigger: on_custom_event "chain_end"
        on_resolve {
            special_summon (1, monster) from gy
            destroy (1+, card, either_player controls, where { attribute == FIRE and is_face_up })
        }
    }

}
