// ゴーストリックの妖精
// Ghostrick Fairy
// Transpiled from c36239585.lua

card "Ghostrick Fairy" {
    id: 36239585
    type: Effect Monster
    attribute: DARK
    race: Spellcaster
    level: 2
    atk: 900
    def: 1000

    continuous_effect "Effect 1" {
        scope: self
        grant: cannot_attack
    }

    effect "Effect 2" {
        speed: spell_speed_1
        on_resolve {
            change_battle_position (1, monster)
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        optional: true
        timing: when
        damage_step: false
        trigger: on_custom_event "chain_active"
        on_activate {
            select (1+, monster, you controls) as target
        }
        on_resolve {
            send (1+, monster, you controls) to gy
            set (1, card)
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            change_battle_position (1, monster)
        }
    }

}
