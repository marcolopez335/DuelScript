// 落消しのパズロミノ
// Puzzlomino, the Drop-n-Deleter
// Transpiled from c84271823.lua

card "Puzzlomino, the Drop-n-Deleter" {
    id: 84271823
    type: Link Monster
    attribute: LIGHT
    race: Spellcaster
    link: 2
    link_arrows: [right, bottom]
    atk: 1300

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ effect monster
        method: link
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_resolve {
            destroy (1+, monster, either_player controls, where { level >= 1 and is_face_up })
        }
    }

}
