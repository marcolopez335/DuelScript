// 落消しのパズロミノ
// Puzzlomino, the Drop-n-Deleter
// Transpiled from c84271823.lua

card "Puzzlomino, the Drop-n-Deleter" {
    id: 84271823
    type: Link Monster
    attribute: LIGHT
    race: Spellcaster
    link: 2
    link_arrows: [right, bottom]
    atk: 1300

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ effect monster
        method: link
    }

    raw_effect "Effect 1" {
        effect_type: Field + Trigger
        category: LevelChange
        code: SpecialSummonSuccess
        property: Delay
        range: MonsterZone
        count_limit: (1, 84271823)
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    raw_effect "Effect 2" {
        effect_type: Ignition
        category: Destroy
        property: CardTarget
        range: MonsterZone
        count_limit: (1, 0)
        on_resolve {
            destroy (1+, monster, either_player controls)
        }
    }

}
