// 海造賊－黒翼の水先人
// Blackeyes, the Plunder Patroll Seaguide
// Transpiled from c91642007.lua

card "Blackeyes, the Plunder Patroll Seaguide" {
    id: 91642007
    type: Effect Monster
    attribute: WATER
    race: Fiend
    level: 4
    atk: 1000
    def: 1000

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        activate_from: [hand]
        on_resolve {
            special_summon (1, monster) from gy
            add_to_hand (1+, monster, either_player controls) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        damage_step: false
        trigger: on_custom_event "chain_end"
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
