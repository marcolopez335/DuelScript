card "Fiendsmith in Paradise" {
    id: 99989863
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, monster, either_player controls) as target
        }
        on_resolve {
            send (1+, monster, either_player controls) to gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        timing: when
        trigger: when_summoned by_special_summon
        activate_from: [gy]
        cost {
            banish self
        }
        on_resolve {
            send (1+, monster, either_player controls) to gy
        }
    }

}
