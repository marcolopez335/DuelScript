card "Cynet Backdoor" {
    id: 43839002
    type: Quick-Play Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        on_resolve {
            banish (1+, card, you controls, deck)
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            add_to_hand (1+, card, you controls, where { race == Cyberse }) from deck
            reveal (1+, card, opponent controls)
        }
    }

}
