card "Cynet Backdoor" {
    id: 43839002
    type: Quick-Play Spell

    raw_effect "Effect 1" {
        effect_type: Activate
        category: Banish + ToHand + Search
        code: FreeChain
        property: CardTarget
        count_limit: (1, 43839002)
        on_resolve {
            banish (1+, card, you controls, deck)
