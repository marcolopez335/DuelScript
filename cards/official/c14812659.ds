// 覚星師ライズベルト
// Risebell the Star Psycher
// Transpiled from c14812659.lua

card "Risebell the Star Psycher" {
    id: 14812659
    type: Effect Monster
    attribute: WIND
    race: Psychic
    level: 4
    atk: 1500
    def: 1500

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        damage_step: false
        on_activate {
            select (1+, card, either_player controls, where { is_face_up and level >= 1 }) as target
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
