// PSY-Framelord Zeta
// Transpiled from c37192109.lua

card "PSY-Framelord Zeta" {
    id: 37192109
    type: Synchro Monster
    attribute: LIGHT
    race: Psychic
    level: 7
    atk: 2500
    def: 1800

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    summon_condition {
        cannot_normal_summon: true
    }

    raw_effect "Effect 1" {
        effect_type: QuickEffect
        category: Banish
        code: FreeChain
        property: CardTarget
        range: MonsterZone
        count_limit: (1, 0)
        on_resolve {
            banish (1+, card, either_player controls)
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    raw_effect "Effect 2" {
        effect_type: Ignition
        category: ToHand + ToDeck
        property: CardTarget
        range: Graveyard
        on_resolve {
            return (1+, card, either_player controls) to deck shuffle
            add_to_hand (1+, card, either_player controls) from gy
        }
    }

}
