// ホーンテッド・アンデット
// Haunted Zombies
// Transpiled from c32335697.lua

card "Haunted Zombies" {
    id: 32335697
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        on_resolve {
            banish (1+, monster, either_player controls, gy)
            create_token { atk: 0 def: 0 }
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        activate_from: [gy]
        on_resolve {
            return (1+, monster, either_player controls) to deck shuffle
            set (1, card)
        }
    }

}
