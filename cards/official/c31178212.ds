// マジェスペクター・ユニコーン
// Majespecter Unicorn - Kirin
// Transpiled from c31178212.lua

card "Majespecter Unicorn - Kirin" {
    id: 31178212
    type: Effect Monster | Pendulum Monster
    attribute: WIND
    race: Spellcaster
    level: 6
    scale: 2
    atk: 2000
    def: 2000

    summon_condition {
        tributes_required: 1
    }

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        damage_step: false
        on_activate {
            select (1+, card, either_player controls, where { is_face_up and is_pendulum }) as target
        }
        on_resolve {
            add_to_hand (1+, card, either_player controls, where { is_face_up and is_pendulum }) from gy
        }
    }

    continuous_effect "Effect 2" {
        scope: self
        grant: cannot_be_targeted_by_card_effects
    }

    continuous_effect "Effect 3" {
        scope: self
        grant: cannot_be_destroyed_by_effect
    }

}
