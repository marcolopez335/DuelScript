card "Hugin the Runick Wings" {
    id: 55990317
    type: Fusion Monster
    attribute: LIGHT
    race: Fairy
    level: 2
    atk: 0
    def: 0

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        method: fusion
    }

    raw_effect "Effect 1" {
        effect_type: Single + Trigger
        category: ToHand + Search
        code: SpecialSummonSuccess
        property: Delay
        on_resolve {
            add_to_hand (1+, card, you controls) from hand
            reveal (1+, card, opponent controls)
        }
    }

    replacement_effect "Effect 2" {
        instead_of: destroyed_by_any
        do: {
            banish self
        }
    }

    raw_effect "Effect 3" {
        effect_type: Single + MandatoryTrigger
        category: ToDeck
        code: Destroyed
        property: Delay
        on_resolve {
            return (1+, card, you controls) to deck shuffle
        }
    }

}
