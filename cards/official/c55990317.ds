// 神碑の翼フギン
// Hugin the Runick Wings
// Transpiled from c55990317.lua

card "Hugin the Runick Wings" {
    id: 55990317
    type: Fusion Monster
    attribute: LIGHT
    race: Fairy
    level: 2
    atk: 0
    def: 0

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        method: fusion
    }

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        on_resolve {
            add_to_hand (1+, card, you controls) from hand
            reveal (1+, card, opponent controls)
        }
    }

    replacement_effect "Effect 2" {
        instead_of: destroyed_by_any
        do: {
            banish self
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        trigger: when_destroyed
        on_resolve {
            return (1+, card, you controls) to deck shuffle
        }
    }

}
