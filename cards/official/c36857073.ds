card "Hot Red Dragon Archfiend Bane" {
    id: 36857073
    type: Synchro Monster
    attribute: DARK
    race: Dragon
    level: 10
    atk: 3500
    def: 3000

    summon {
        cannot_normal_summon
        special_summon_procedure {
            from: extra_deck
            to: your_field
        }
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        mandatory
        cost {
            tribute self
        }
        resolve {
            special_summon (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        timing: when
        trigger: destroyed_by_battle
        resolve {
            special_summon (all, card, either controls)
        }
    }
