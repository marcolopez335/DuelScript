// アンデット・ネクロナイズ
// Zombie Necronize
// Transpiled from c38363525.lua

card "Zombie Necronize" {
    id: 38363525
    type: Normal Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, monster, either_player controls, where { is_face_up and level >= 5 and race == Zombie }) as target
        }
        on_resolve {
            take_control of (1, monster, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [gy]
        on_resolve {
            return (1+, monster, either_player controls, where { is_face_up and level >= 5 and race == Zombie }) to deck shuffle
            set (1, card)
        }
    }

}
