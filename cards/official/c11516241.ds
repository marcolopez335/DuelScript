card "Gouki The Powerload Ogre" {
    id: 11516241
    type: Link Monster
    attribute: EARTH
    race: Warrior
    link: 4
    link_arrows: [right, bottom_left, bottom, bottom_right]
    atk: 2800

    materials {
        require: 2+ effect monster
        method: link
    }

    summon_condition {
        cannot_normal_summon: true
    }

    raw_effect "Effect 1" {
        effect_type: Single
        code: ImmuneEffect
        property: SingleRange
        range: MonsterZone
        on_resolve {
            register_effect on self { grant: unaffected_by_card_effects duration: until_end_of_turn }
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single
        code: UpdateAttack
        property: SingleRange
        range: MonsterZone
        on_resolve {
            modifier: atk + 0
        }
    }

    raw_effect "Effect 3" {
        effect_type: Ignition
        category: Destroy
        property: CardTarget
        range: MonsterZone
        count_limit: (1, 11516241)
        on_resolve {
            destroy (1+, monster, you controls)
        }
    }

}
