card "Naturia Camellia" {
    id: 29942771
    type: Effect Monster | Tuner
    attribute: EARTH
    race: Plant
    level: 4
    atk: 1400
    def: 700

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned
        resolve {
            send (all, card, either controls) to gy
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            send (all, card, either controls) to gy
        }
    }

    effect "Effect 4" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: summoned
        resolve {
            special_summon (1, monster, where archetype == "Naturia") from gy in attack_position
        }
    }

    effect "Effect 5" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: summoned by special
        resolve {
            special_summon (1, monster, where archetype == "Naturia") from gy in attack_position
        }
    }
}
