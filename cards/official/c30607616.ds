// 轍の魔妖-朧車
// Oboro-Guruma, the Wheeled Mayakashi
// Transpiled from c30607616.lua

card "Oboro-Guruma, the Wheeled Mayakashi" {
    id: 30607616
    type: Synchro Monster
    attribute: EARTH
    race: Zombie
    level: 3
    atk: 800
    def: 2100

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        trigger: when_destroyed
        activate_from: [gy]
        on_resolve {
            banish (1+, card, you controls, gy)
            special_summon (1, monster) from gy
        }
    }

}
