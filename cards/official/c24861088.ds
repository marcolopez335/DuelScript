card "Chronomaly Nebra Disk" {
    id: 24861088
    type: Effect Monster
    attribute: LIGHT
    race: Machine
    level: 4
    atk: 1800
    def: 1500

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
