// 破壊剣士の揺籃
// Prologue of the Destruction Swordsman
// Transpiled from c33280639.lua

card "Prologue of the Destruction Swordsman" {
    id: 33280639
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        cost {
            send self to gy
        }
        on_resolve {
            special_summon (1, monster) from gy
            destroy (1+, monster, opponent controls)
            destroy (1+, monster, you controls, deck)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        optional: true
        activate_from: [gy]
        cost {
            banish self
        }
        on_resolve {
            set_flag "tracked" on self
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    continuous_effect "Effect 3" {
        scope: field
        grant: cannot_be_destroyed_by_effect
    }

    continuous_effect "Effect 4" {
        scope: field
        grant: cannot_be_destroyed_by_battle
    }

}
