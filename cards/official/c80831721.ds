card "Sabatiel - The Philosopher's Stone" {
    id: 80831721
    type: Normal Spell

    effect "Effect 1" {
        speed: spell_speed_1
        cost {
            pay_lp your_lp / 2
        }
        on_resolve {
            return (1+, spell, either_player controls) to hand
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        damage_step: false
        activate_from: [gy]
        cost {
            banish self
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
