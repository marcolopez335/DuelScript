// リターン・オブ・アンデット
// Return of the Zombies
// Transpiled from c91742238.lua

card "Return of the Zombies" {
    id: 91742238
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        on_resolve {
            banish (1+, card, you controls, gy)
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        activate_from: [gy]
        on_resolve {
            return (1+, card, you controls) to deck shuffle
            set (1, card)
        }
    }

}
