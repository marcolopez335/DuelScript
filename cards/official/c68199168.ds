card "Harr, Generaider Boss of Storms" {
    id: 68199168
    type: Effect Monster
    attribute: DARK
    race: Spellcaster
    level: 9
    atk: 3000
    def: 3000

    summon_condition {
        tributes_required: 2
    }

    raw_effect "Effect 1" {
        effect_type: Field + Trigger
        category: ToGrave
        code: ChainSolving
        property: Delay
        range: MonsterZone
        count_limit: (1, 0)
        on_resolve {
            send (1+, monster, opponent controls, hand) to gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        cost {
            tribute self
        }
        on_resolve {
            negate activation
            destroy (1+, monster, opponent controls, hand)
        }
    }

}
