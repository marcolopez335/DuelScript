card "Altergeist Primebanshee" {
    id: 93503294
    type: Link Monster
    attribute: DARK
    race: Spellcaster
    link: 3
    link_arrows: [right, bottom, bottom_right]
    atk: 2100

    summon {
        cannot_normal_summon
        link materials: (2+, monster, where archetype == "Altergeist")
    }

    effect "Effect 1" {
        speed: 2
        once_per_turn: hard
        cost {
            tribute self
        }
        resolve {
            special_summon (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: custom "chain_end"
        resolve {
            add_to_hand (all, card, either controls)
        }
    }
}
