// 水晶機巧－シストバーン
// Crystron Thystvern
// Transpiled from c29838323.lua

card "Crystron Thystvern" {
    id: 29838323
    type: Effect Monster
    attribute: WATER
    race: Machine
    level: 3
    atk: 1500
    def: 1500

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, monster, you controls, where { is_face_up }) as target
        }
        on_resolve {
            destroy (1+, monster, you controls, deck)
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [gy]
        cost {
            banish self
        }
        on_resolve {
            add_to_hand (1+, monster, you controls, where { is_face_up }) from deck
            reveal (1+, card, opponent controls)
        }
    }

}
