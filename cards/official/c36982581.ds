// リチュアの氷魔鏡
// Gishki Nekromirror
// Transpiled from c36982581.lua

card "Gishki Nekromirror" {
    id: 36982581
    type: Ritual Spell

    effect "Effect 1" {
        speed: spell_speed_1
        on_resolve {
            special_summon (1, monster) from gy
            gain_lp: 0
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        damage_step: false
        activate_from: [gy]
        on_activate {
            select (1+, monster, opponent controls) as target
        }
        on_resolve {
            return (1+, monster, opponent controls) to deck shuffle
            reveal (1, card, opponent controls, deck)
            return (1+, monster, opponent controls) to deck shuffle
        }
    }

}
