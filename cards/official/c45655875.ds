card "Magikey Beast - Ansyalabolas" {
    id: 45655875
    type: Fusion Monster | Tuner
    attribute: DARK
    race: Beast
    level: 4
    atk: 2200
    def: 2000

    summon {
        cannot_normal_summon
        special_summon_procedure {
            from: extra_deck
            to: your_field
        }
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            add_to_hand (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        mandatory
        resolve {
            change_position target to defense_position
            modify_def target - 1000 until end_of_turn
        }
    }
}
