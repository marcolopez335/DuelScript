card "Expurrely Noir" {
    id: 83827392
    type: Xyz Monster
    attribute: DARK
    race: Fairy
    rank: 7
    atk: 1100
    def: 2800

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        same_level: true
        method: xyz
    }

    continuous_effect "Effect 1" {
        scope: self
        grant: unaffected_by_card_effects
    }

    effect "Effect 2" {
        speed: spell_speed_1
        damage_step: false
        on_activate {
            select (1+, card, either_player controls) as target
        }
        cost {
            detach 2 overlay_unit from self
        }
        on_resolve {
            return (1+, card, either_player controls) to deck shuffle
        }
    }

    effect "Effect 3" {
        speed: spell_speed_2
        optional: true
        damage_step: false
        on_activate {
            select (1+, card, either_player controls) as target
        }
        cost {
            detach 2 overlay_unit from self
        }
        on_resolve {
            return (1+, card, either_player controls) to deck shuffle
        }
    }

}
