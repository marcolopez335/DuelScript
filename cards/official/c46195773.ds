// ターボ・ウォリアー
// Turbo Warrior
// Transpiled from c46195773.lua

card "Turbo Warrior" {
    id: 46195773
    type: Synchro Monster
    attribute: WIND
    race: Warrior
    level: 6
    atk: 2500
    def: 1500

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        trigger: when attack_declared
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    continuous_effect "Effect 2" {
        scope: self
        grant: cannot_be_targeted_by_card_effects
    }

}
