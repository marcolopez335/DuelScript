card "Metalfoes Combination" {
    id: 69711728
    type: Continuous Trap

    effect "Effect 1" {
        speed: spell_speed_2
        on_resolve {
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        timing: if
        damage_step: false
        trigger: when_summoned by_special_summon
        activate_from: [spell_trap_zone]
        on_activate {
            select (1+, monster, you controls, where { is_face_up and is_fusion }) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
