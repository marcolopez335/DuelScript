    effect "Effect 3" {
        speed: spell_speed_2
        optional: true
        timing: if
        trigger: on_custom_event "chain_end"
        on_resolve {
            add_to_hand (1+, monster, you controls, where { is_face_up and is_fusion }) from deck
            reveal (1+, card, opponent controls)
        }
    }

