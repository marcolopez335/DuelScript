// 神樹獣ハイペリュトン
// Sacred Tree Beast, Hyperyton
// Transpiled from c9349094.lua

card "Sacred Tree Beast, Hyperyton" {
    id: 9349094
    type: Xyz Monster
    attribute: EARTH
    race: Plant
    rank: 9
    atk: 2600
    def: 1900

    materials {
        require: 2+ monster
        same_level: true
        method: xyz
    }

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        timing: when
        damage_step: false
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            attach (1, card) to self as_material
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            send (1+, card, either_player controls) to gy
            emit_event "custom"
            negate activation
            destroy (1+, card, either_player controls)
        }
    }

}
