card "Aquarium Lighting" {
    id: 91831066
    type: Continuous Spell

    effect "Effect 1" {
        speed: 1
        mandatory
        resolve {
            set_atk target target.atk * 2 until end_of_turn
            set_def target target.def * 2 until end_of_turn
        }
    }

    effect "Effect 2" {
        speed: 1
        mandatory
        trigger: summoned
        condition: previous_location == field
        resolve {
            special_summon target
        }
    }

    effect "Effect 3" {
        speed: 1
        timing: if
        trigger: custom "chain_end"
        resolve {
            special_summon (all, card, either controls)
        }
    }
}
