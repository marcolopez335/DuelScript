// ジェット・ウォリアー
// Jet Warrior
// Transpiled from c286392.lua

card "Jet Warrior" {
    id: 286392
    type: Synchro Monster
    attribute: FIRE
    race: Warrior
    level: 5
    atk: 2100
    def: 1200

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        damage_step: false
        trigger: when_summoned by_special_summon
        on_resolve {
            add_to_hand (1+, card, either_player controls, where { level <= 2 }) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        activate_from: [gy]
        cost {
            tribute self
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
