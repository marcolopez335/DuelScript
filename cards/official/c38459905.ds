// F.A. Test Run
// Transpiled from c38459905.lua

card "F.A. Test Run" {
    id: 38459905
    type: Quick-Play Spell

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: soft
        damage_step: false
        on_activate {
            select (1+, card, either_player controls, where { is_face_up }) as target
        }
        on_resolve {
            change_battle_position (1, monster)
            destroy (1+, card, either_player controls, where { is_face_up })
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        damage_step: false
        activate_from: [gy]
        on_activate {
            select (1+, card, either_player controls, where { is_face_up }) as target
        }
        cost {
            banish self
        }
        on_resolve {
            destroy (1+, card, either_player controls, where { is_face_up })
            special_summon (1, monster) from gy
        }
    }

}
