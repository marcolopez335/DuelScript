// 魔王超龍 ベエルゼウス
// Beelzeus of the Diabolic Dragons
// Transpiled from c8763963.lua

card "Beelzeus of the Diabolic Dragons" {
    id: 8763963
    type: Synchro Monster
    attribute: DARK
    race: Dragon
    level: 10
    atk: 4000
    def: 4000

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    summon_condition {
        cannot_normal_summon: true
    }

    continuous_effect "Effect 1" {
        scope: self
        grant: cannot_be_destroyed_by_battle
    }

    continuous_effect "Effect 2" {
        scope: self
        grant: cannot_be_destroyed_by_effect
    }

    continuous_effect "Effect 3" {
        scope: field
        grant: cannot_attack
    }

    effect "Effect 4" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            gain_lp: 1000
            deal_damage to opponent: 0
        }
    }

}
