card "WAKE CUP! Mocha" {
    id: 91818544
    type: Effect Monster
    attribute: WIND
    race: Aqua
    level: 3
    atk: 1000
    def: 100

    raw_effect "Effect 1" {
        effect_type: Single + Trigger
        category: ToGrave + AtkChange
        code: ChainActive
        property: CardTarget + Delay
        count_limit: (1, 91818544)
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            destroy (1+, monster, opponent controls)
            send (1+, card, either_player controls) to gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        activate_from: [hand]
        on_resolve {
            special_summon (1, monster) from gy
            change_battle_position (1, monster)
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: when
        trigger: during_end_phase
        on_resolve {
            change_battle_position (1, monster)
        }
    }

    raw_effect "Effect 4" {
        effect_type: Single
        code: UpdateAttack
        property: BothSide
        on_resolve {
            modifier: atk + 1000
        }
    }

}
