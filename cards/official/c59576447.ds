// アヌビスの審判
// Verdict of Anubis
// Transpiled from c59576447.lua

card "Verdict of Anubis" {
    id: 59576447
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            negate activation
            destroy (1+, spell, opponent controls)
            deal_damage to opponent: 1000
        }
    }

}
