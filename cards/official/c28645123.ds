card "A.I. Challenge You" {
    id: 28645123
    type: Continuous Trap

    passive "Effect 3" {
        scope: self
        grant: cannot_activate effects
    }


    passive "Passive 1" {
        scope: field
        target: (all, monster, opponent controls)
        modifier: atk - count((all, card, you control, from field)) * 100
    }
}
