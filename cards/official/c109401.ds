// 闇次元の戦士
// Dark Dimension Soldier
// Transpiled from c109401.lua

card "Dark Dimension Soldier" {
    id: 109401
    type: Synchro Monster
    attribute: DARK
    race: Warrior
    level: 5
    atk: 1200
    def: 2400

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_activate {
            select (1+, monster, you controls, where { is_face_up and is_monster and attribute == DARK }) as target
        }
        cost {
            banish self
        }
        on_resolve {
            special_summon (1, monster) from gy
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        trigger: during_end_phase
        on_resolve {
            deal_damage to opponent: 1000
        }
    }

}
