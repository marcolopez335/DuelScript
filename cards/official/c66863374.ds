card "Test Panther" {
    id: 66863374
    type: Link Monster
    attribute: EARTH
    race: Beast
    link: 2
    link_arrows: [bottom_left, bottom]
    atk: 800

    summon {
        cannot_normal_summon
        link materials: (2, monster)
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            add_to_hand (1, card, where archetype == "Gladiator Beast") from deck
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        mandatory
        resolve {
            return (all, card, either controls) to deck
            special_summon (all, card, either controls)
        }
    }
}
