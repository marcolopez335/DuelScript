card "Ritual Sanctuary" {
    id: 95658967
    type: Field Spell

    effect "Effect 1" {
        speed: spell_speed_1
        on_resolve {
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [spell_trap_zone]
        on_resolve {
            add_to_hand (1+, monster, you controls, where { is_monster and attribute == LIGHT }) from hand
            reveal (1+, card, opponent controls)
        }
