    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        activate_from: [spell_trap_zone]
        on_activate {
            select (1+, monster, you controls, where { is_monster and attribute == LIGHT }) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
