// 未界域の歓待
// You're in Danger!
// Transpiled from c10312660.lua

card "You're in Danger!" {
    id: 10312660
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        on_resolve {
            reveal (1+, card, opponent controls)
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
