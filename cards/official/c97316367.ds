card "Infinitrack Tunneller" {
    id: 97316367
    type: Effect Monster
    attribute: EARTH
    race: Machine
    level: 5
    atk: 2200
    def: 500

    summon {
        tributes: 1
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        mandatory
        cost {
            tribute self
        }
        resolve {
            special_summon (all, card, either controls)
        }
