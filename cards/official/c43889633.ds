card "Forgotten Temple of the Deep" {
    id: 43889633
    type: Continuous Trap

    effect "Effect 1" {
        speed: 2
        mandatory
        resolve {
            banish target
            install_watcher "spop" { event: end_phase duration: end_of_turn check { special_summon target } }
