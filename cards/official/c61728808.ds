card "Heavymetalfoes Amalgam" {
    id: 61728808
    type: Link Monster
    attribute: FIRE
    race: Psychic
    link: 2
    link_arrows: [left, right]
    atk: 2000

    summon {
        cannot_normal_summon
        link materials: (2, monster, where archetype == "Metalfoes")
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: custom "chain_end"
        condition: previous_location == field and reason == effect
        resolve {
            destroy (all, card, either controls)
            special_summon (all, card, either controls)
        }
    }
}
