// SPYRAL Sleeper
// Transpiled from c35699.lua

card "SPYRAL Sleeper" {
    password: 35699
    type: Effect Monster | Spirit
    attribute: LIGHT
    race: Fiend
    level: 8
    atk: 2800
    def: 1200

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        on_resolve {
            reveal self
        }
    }

    effect "Effect 3" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        on_resolve {
            destroy (1+, card, either_player controls)
        }
    }

    effect "Effect 4" {
        speed: spell_speed_1
        trigger: when_sent_to gy
        on_resolve {
            destroy (1+, card, either_player controls)
            special_summon (1, monster) from gy
        }
    }

}
