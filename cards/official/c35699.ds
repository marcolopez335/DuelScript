card "SPYRAL Sleeper" {
    id: 35699
    type: Effect Monster | Spirit
    attribute: LIGHT
    race: Fiend
    level: 8
    atk: 2800
    def: 1200

    summon_condition {
        cannot_normal_summon: true
    }

    raw_effect "Effect 1" {
        effect_type: Single
        code: SpsummonCondition
        property: BothSide + Uncopyable
        on_resolve {
        }
    }

    raw_effect "Effect 2" {
        effect_type: Field
        code: CannotSummon
        property: BothSide + Uncopyable
        range: Hand
        on_resolve {
            banish (1+, monster, you controls, gy)
        }
    }

    effect "Effect 3" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        damage_step: false
        on_activate {
            select (1+, monster, you controls) as target
        }
        on_resolve {
            destroy (1+, monster, you controls, gy)
        }
    }

    effect "Effect 4" {
        speed: spell_speed_1
        trigger: on_custom_event "chain_end"
        on_resolve {
            destroy (1+, monster, you controls, gy)
            special_summon (1, monster) from gy
        }
    }

}
