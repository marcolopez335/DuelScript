// 深海のミンストレル
// Deep Sea Minstrel
// Transpiled from c71978434.lua

card "Deep Sea Minstrel" {
    id: 71978434
    type: Effect Monster | Tuner
    attribute: WATER
    race: Sea Serpent
    level: 3
    atk: 1200
    def: 1500

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [hand]
        cost {
            send self to gy
        }
        on_resolve {
            reveal (1+, card, opponent controls)
            banish (1+, card, you controls, hand)
            shuffle_hand
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        damage_step: false
        trigger: when_summoned by_special_summon
        on_resolve {
            return (1+, card, you controls) to deck shuffle
            return (1+, card, you controls) to deck shuffle
        }
    }

}
