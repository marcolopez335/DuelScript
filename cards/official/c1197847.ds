// 幻煌龍の螺旋波
// Phantasm Spiral Wave
// Transpiled from c1197847.lua

card "Phantasm Spiral Wave" {
    id: 1197847
    type: Equip Spell

    continuous_effect "Effect 1" {
        scope: self
        grant: cannot_be_destroyed
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: when
        trigger: during battle_phase
        activate_from: [spell_trap_zone]
        on_resolve {
            special_summon (1, monster) from gy
            equip (1, card) to (1, monster)
            discard (1, card)
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        on_resolve {
            equip self to (1, monster, you controls)
        }
    }

}
