// アームド・チェンジャー
// Armed Changer
// Transpiled from c90374791.lua

card "Armed Changer" {
    id: 90374791
    type: Equip Spell

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        timing: when
        damage_step: false
        trigger: when_battle_damage
        activate_from: [spell_trap_zone]
        on_resolve {
            add_to_hand (1+, monster, you controls, where { is_monster }) from hand
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        on_resolve {
            equip self to (1, monster, you controls)
        }
    }

}
