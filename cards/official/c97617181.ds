// 銀河零式
// Galaxy Zero
// Transpiled from c97617181.lua

card "Galaxy Zero" {
    id: 97617181
    type: Equip Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
            equip (1, card) to (1, monster)
        }
    }

    continuous_effect "Effect 2" {
        scope: self
        grant: cannot_attack
    }

    continuous_effect "Effect 3" {
        scope: self
        grant: cannot_activate_effects
    }

    replacement_effect "Effect 4" {
        instead_of: destroyed_by_any
        do: {
            banish self
        }
    }

    raw_effect "Effect 5" {
        effect_type: Single + MandatoryTrigger
        code: ChainNegated
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
