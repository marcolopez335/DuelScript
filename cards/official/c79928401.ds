// 勇気の天使ヴィクトリカ
// Victorica, Angel of Bravery
// Transpiled from c79928401.lua

card "Victorica, Angel of Bravery" {
    id: 79928401
    type: Effect Monster
    attribute: LIGHT
    race: Fairy
    level: 4
    atk: 1400
    def: 800

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        on_resolve {
            special_summon (1, monster) from gy
            gain_lp: 0
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        trigger: when_destroyed
        cost {
            banish self
        }
        on_resolve {
            add_to_hand (1+, monster, you controls, where { race == Fairy and is_monster }) from hand
            reveal (1+, card, opponent controls)
        }
    }

}
