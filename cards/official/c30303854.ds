// ラヴァル・アーチャー
// Laval Archer
// Transpiled from c30303854.lua

card "Laval Archer" {
    id: 30303854
    type: Effect Monster
    attribute: FIRE
    race: Pyro
    level: 4
    atk: 1000
    def: 200

    effect "Effect 1" {
        speed: spell_speed_1
        trigger: when_summoned
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        activate_from: [gy]
        on_activate {
            select (1+, monster, either_player controls, where { is_face_up and is_monster and attribute == FIRE }) as target
        }
        on_resolve {
            destroy (1+, monster, either_player controls, where { is_face_up and is_monster and attribute == FIRE })
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
