card "A Shattered, Colorless Realm" {
    id: 44553392
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        damage_step: false
        on_resolve {
            destroy (1+, card, either_player controls)
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single
        code: UpdateAttack
        on_resolve {
            modifier: atk + 1500
        }
    }

}
