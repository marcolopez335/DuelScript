card "Trap Reclamation" {
    id: 2122975
    type: Normal Trap

    effect "Effect 1" {
        speed: 2
        mandatory
        trigger: opponent_activates [activate_spell, activate_trap, activate_spell]
        cost {
            discard (1, card, you control, from hand)
        }
        resolve {
            install_watcher "thop" { event: sent_to gy duration: end_of_turn check { add_to_hand self } }
        }
    }
}
