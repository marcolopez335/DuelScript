card "Radiant Typhoon Krosea" {
    id: 16922142
    type: Effect Monster
    attribute: WIND
    race: Winged Beast
    level: 6
    atk: 2200
    def: 1200

    summon {
        tributes: 1
    }

    passive "Effect 1" {
        scope: self
        grant: cannot_be_destroyed by battle
    }

    passive "Effect 2" {
        scope: self
        grant: cannot_be_destroyed by effect
    }

    passive "Effect 6" {
        scope: self
        grant: cannot_attack
    }

    effect "Effect 3" {
        speed: 1
