card "Soul of Silvermountain" {
    id: 91895091
    type: Xyz Monster
    attribute: EARTH
    race: Rock
    rank: 3
    atk: 1800
    def: 2200

    materials {
        require: 2+ monster
        same_level: true
        method: xyz
    }

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        cost {
            detach 1 overlay_unit from self
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single + Trigger
        category: SpecialSummon
        code: BattleConfirmed
        property: CardTarget
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
