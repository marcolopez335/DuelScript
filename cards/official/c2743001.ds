// 水晶機巧－フェニキシオン
// Crystron Phoenix
// Transpiled from c2743001.lua

card "Crystron Phoenix" {
    id: 2743001
    type: Synchro Monster
    attribute: WATER
    race: Machine
    level: 9
    atk: 2800
    def: 2000

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        on_resolve {
            banish (1+, spell, opponent controls, gy)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        optional: true
        timing: if
        damage_step: false
        trigger: when_destroyed
        on_activate {
            select (1+, spell, opponent controls, where { is_spell }) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
