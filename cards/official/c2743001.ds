card "Crystron Phoenix" {
    id: 2743001
    type: Synchro Monster
    attribute: WATER
    race: Machine
    level: 9
    atk: 2800
    def: 2000

    summon {
        cannot_normal_summon
        synchro materials {
            tuner: (1, tuner monster, where is_synchro)
            non_tuner: (1+, non-tuner monster, where is_synchro)
        }
    }

    effect "Effect 1" {
        speed: 1
        timing: if
        trigger: summoned by special
        resolve {
            banish (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        timing: if
        trigger: destroyed
        resolve {
            special_summon (all, card, either controls)
        }
    }
}
