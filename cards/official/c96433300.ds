card "Ogdoadic Hollow" {
    id: 96433300
    type: Continuous Trap

    effect "Effect 1" {
        speed: 2
        mandatory
        resolve {
            special_summon target
            install_watcher "tgop" { event: end_phase duration: end_of_turn check { send target to gy } }
        }
    }

    effect "Effect 2" {
        speed: 2
        once_per_turn: hard
        cost {
            tribute self
        }
        resolve {
            special_summon (all, card, either controls)
        }
    }

    effect "Effect 3" {
        speed: 2
        mandatory
        trigger: custom "chain_end"
        resolve {
            send (all, card, either controls) to gy
        }
    }
}
