card "Verre, the Maid of Endymion" {
    id: 22623509
    type: Effect Monster
    attribute: LIGHT
    race: Spellcaster
    level: 4
    atk: 500
    def: 1400

    raw_effect "Effect 1" {
        effect_type: Single
        code: UpdateAttack
        property: SingleRange
        range: MonsterZone
        on_resolve {
            modifier: atk + 2300
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        activate_from: [hand]
        on_resolve {
            special_summon (1, monster) from gy
        }
