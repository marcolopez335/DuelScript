card "Bramble Rose Dragon" {
    id: 6560411
    type: Synchro Monster
    attribute: FIRE
    race: Plant
    level: 7
    atk: 2400
    def: 1800

    summon {
        cannot_normal_summon
        synchro materials {
            tuner: (1, tuner monster, where race == Plant)
            non_tuner: (1+, non-tuner monster)
        }
    }

    effect "Effect 3" {
        speed: 2
        once_per_turn: soft
        cost {
            tribute self
        }
        resolve {
            special_summon (all, card, either controls)
        }
    }

    effect "Effect 4" {
        speed: 1
        once_per_turn: soft
        mandatory
        cost {
            banish self
        }
        resolve {
            special_summon (all, card, either controls)
        }
    }
}
