// 滅亡き闇 ヴェイドス
// Veidos the Dragon of Endless Darkness
// Transpiled from c8540986.lua

card "Veidos the Dragon of Endless Darkness" {
    id: 8540986
    type: Fusion Monster
    attribute: DARK
    race: Pyro
    level: 10
    atk: 3000
    def: 1700

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        method: fusion
    }

    continuous_effect "Effect 1" {
        scope: self
        grant: cannot_be_destroyed_by_effect
    }

    continuous_effect "Effect 2" {
        scope: self
        grant: cannot_be_targeted_by_card_effects
    }

    effect "Effect 3" {
        speed: spell_speed_1
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        on_resolve {
            destroy (1+, spell, opponent controls)
        }
    }

    effect "Effect 4" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        cost {
            send self to gy
        }
        on_resolve {
            destroy (1+, spell, opponent controls)
        }
    }

}
