card "Benghalancer the Resurgent" {
    id: 73345237
    type: Link Monster
    attribute: LIGHT
    race: Plant
    link: 4
    link_arrows: [top, left, right, bottom]
    atk: 2500

    materials {
        require: 2+ effect monster
        method: link
    }

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        damage_step: false
        on_resolve {
            deal_damage to opponent: 1000
            add_to_hand (1+, card, you controls, where { is_face_up }) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [gy]
        cost {
            banish self
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    redirect_effect "Effect 3" {
        when_going_to: field
        redirect_to: banished
    }

}
