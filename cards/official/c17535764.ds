card "Gokipole" {
    id: 17535764
    type: Effect Monster
    attribute: EARTH
    race: Insect
    level: 3
    atk: 1000
    def: 1200

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: on_custom_event "chain_end"
        on_resolve {
            return (1+, monster, either_player controls) to hand
            reveal (1+, card, opponent controls)
            special_summon (1, monster) from gy
            destroy (1+, monster, either_player controls)
        }
    }

}
