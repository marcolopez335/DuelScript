card "Mikanko Purification Dance" {
    id: 16433136
    type: Equip Spell

    passive "Effect 1" {
        scope: self
        grant: cannot_be_destroyed by effect
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            return (all, card, either controls) to hand
        }
    }

    effect "Effect 3" {
        speed: 1
        mandatory
        resolve {
            add_to_hand target
        }
    }
}
