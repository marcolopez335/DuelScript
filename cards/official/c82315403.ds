card "Cyber Eternity Dragon" {
    id: 82315403
    type: Fusion Monster
    attribute: LIGHT
    race: Machine
    level: 10
    atk: 2800
    def: 4000

    summon {
        cannot_normal_summon
        fusion materials: (1, monster, where archetype == "Cyber Dragon") + (2, monster, where race == Machine)
    }

    passive "Effect 1" {
        scope: self
        grant: cannot_be_targeted by effects
    }

    passive "Effect 2" {
        scope: self
        grant: cannot_be_destroyed by effect
    }

    effect "Effect 3" {
        speed: 1
        timing: if
        trigger: custom "chain_end"
        resolve {
            special_summon (all, card, either controls)
        }
    }

    effect "Effect 4" {
        speed: 1
        once_per_turn: hard
        mandatory
        cost {
            banish self
        }
        resolve {
            special_summon target
        }
    }
}
