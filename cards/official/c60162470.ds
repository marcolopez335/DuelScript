        }
    }

    effect "Effect 4" {
        speed: spell_speed_1
        trigger: on_custom_event "chain_end"
        activate_from: [spell_trap_zone]
        on_resolve {
            destroy (1+, monster, either_player controls, where { is_face_up })
        }
    }

    raw_effect "Effect 5" {
        effect_type: Field + MandatoryTrigger
        code: ChainNegated
        range: MonsterZone
        on_resolve {
        }
    }

