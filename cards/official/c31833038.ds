// ヴァレルロード・ドラゴン
// Borreload Dragon
// Transpiled from c31833038.lua

card "Borreload Dragon" {
    id: 31833038
    type: Link Monster
    attribute: DARK
    race: Dragon
    link: 4
    link_arrows: [left, right, bottom_left, bottom_right]
    atk: 3000

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ effect monster
        method: link
    }

    continuous_effect "Effect 1" {
        scope: self
        grant: cannot_be_targeted_by_card_effects
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        damage_step: false
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    raw_effect "Effect 3" {
        effect_type: Single + Trigger
        category: Control
        code: DamageCalculation
        on_resolve {
            take_control of (1, monster, opponent controls)
            destroy (1+, monster, opponent controls)
            send (1+, card, either_player controls) to gy
        }
    }

    raw_effect "Effect 4" {
        effect_type: Single
        code: UpdateAttack
        property: BothSide
        on_resolve {
            modifier: atk - 500
        }
    }

    raw_effect "Effect 5" {
        effect_type: Single
        code: UpdateDefense
        property: BothSide
        on_resolve {
            modifier: def - 500
        }
    }

}
