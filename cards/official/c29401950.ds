// 奈落の落とし穴
// Bottomless Trap Hole
// Transpiled from c29401950.lua

card "Bottomless Trap Hole" {
    id: 29401950
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        trigger: when_summoned
        on_resolve {
            destroy (1+, card, either_player controls, where { is_face_up })
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        trigger: when_summoned by_flip_summon
        on_resolve {
            destroy (1+, card, either_player controls, where { is_face_up })
        }
    }

    effect "Effect 3" {
        speed: spell_speed_2
        trigger: when_summoned by_special_summon
        on_resolve {
            destroy (1+, card, either_player controls, where { is_face_up })
        }
    }

}
