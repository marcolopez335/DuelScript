card "Vesper Girsu" {
    id: 97345699
    type: Quick-Play Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        on_resolve {
            send (1+, monster, opponent controls) to gy
            gain_lp: 0
