card "Gouki Heel Ogre" {
    id: 10552026
    type: Link Monster
    attribute: EARTH
    race: Warrior
    link: 2
    link_arrows: [top, bottom]
    atk: 1000

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ effect monster
        method: link
    }

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            negate activation
            special_summon (1, monster) from gy
        }
    }

