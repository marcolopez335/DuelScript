// ＧＤロボ・オービタル ７
// Galaxy Defense Robot Orbital 7
// Transpiled from c91714772.lua

card "Galaxy Defense Robot Orbital 7" {
    id: 91714772
    type: Effect Monster
    attribute: LIGHT
    race: Machine
    level: 8
    atk: 2000
    def: 2000

    summon_condition {
        tributes_required: 2
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        activate_from: [hand, monster_zone]
        cost {
            tribute self
        }
        on_resolve {
            add_to_hand (1+, monster, you controls) from deck
            reveal (1+, card, opponent controls)
            send (1+, monster, you controls, deck) to gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        activate_from: [gy]
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
