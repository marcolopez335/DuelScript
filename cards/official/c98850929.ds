card "Sacred Serpent's Wake" {
    id: 98850929
    type: Quick-Play Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, monster, you controls, where { is_face_up and is_synchro }) as target
        }
        on_resolve {
            return (1+, monster, you controls, where { is_face_up and is_synchro }) to hand
            reveal (1+, card, opponent controls)
        }
    }

}
