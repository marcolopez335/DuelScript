// 恐楽園の死配人 ＜Ａｒｌｅｃｈｉｎｏ＞
// Amazement Abomination Arlekino
// Transpiled from c31600845.lua

card "Amazement Abomination Arlekino" {
    id: 31600845
    type: Effect Monster
    attribute: LIGHT
    race: Psychic
    level: 7
    atk: 2600
    def: 2200

    summon_condition {
        tributes_required: 2
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [hand]
        on_resolve {
            special_summon (1, monster) from gy
            add_to_hand (1+, card, you controls, where { card_id == 20989253 }) from gy
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        damage_step: false
        on_activate {
            select (1+, card, you controls, where { card_id == 20989253 }) as target
        }
        on_resolve {
            return (1+, card, you controls, where { card_id == 20989253 }) to deck shuffle
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    continuous_effect "Effect 3" {
        scope: self
        grant: cannot_be_destroyed_by_battle
    }

}
