// 闘炎の剣士
// Fighting Flame Swordsman
// Transpiled from c1047075.lua

card "Fighting Flame Swordsman" {
    id: 1047075
    type: Effect Monster
    attribute: FIRE
    race: Warrior
    level: 4
    atk: 1800
    def: 1600

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: when_summoned
        on_resolve {
            add_to_hand (1+, monster, you controls, where { is_spell }) from deck
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        on_resolve {
            add_to_hand (1+, monster, you controls, where { is_spell }) from deck
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        trigger: on_custom_event "chain_end"
        on_resolve {
            send (1+, monster, you controls, deck) to gy
        }
    }

}
