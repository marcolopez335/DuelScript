card "Union Controller" {
    id: 2133971
    type: Fusion Monster
    attribute: LIGHT
    race: Machine
    level: 6
    atk: 2200
    def: 1900

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        method: fusion
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
