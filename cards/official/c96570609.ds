// 天帝アイテール
// Ehther the Heavenly Monarch
// Transpiled from c96570609.lua

card "Ehther the Heavenly Monarch" {
    id: 96570609
    type: Effect Monster
    attribute: LIGHT
    race: Fairy
    level: 8
    atk: 2800
    def: 1000

    summon_condition {
        tributes_required: 2
    }

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        timing: if
        trigger: when_summoned
        on_resolve {
            send (1+, spell, you controls, hand) to gy
            special_summon (1, monster) from gy
            add_to_hand (1+, spell, you controls) from hand
            destroy (1+, monster, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        optional: true
        activate_from: [hand]
        on_resolve {
            normal_summon (1, monster, you controls)
        }
    }

    raw_effect "Effect 3" {
        effect_type: Single
        code: CannotChangePosition
        on_resolve {
            register_effect on self { grant: cannot_attack duration: until_end_of_turn }
        }
    }

    raw_effect "Effect 4" {
        effect_type: Single
        code: Unreleasable
        on_resolve {
            register_effect on self { grant: cannot_change_battle_position duration: until_end_of_turn }
        }
    }

}
