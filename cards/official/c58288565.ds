card "Butterfly Fish" {
    id: 58288565
    type: Effect Monster
    attribute: WATER
    race: Fish
    level: 3
    atk: 700
    def: 400

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: on_custom_event "chain_end"
        on_resolve {
            add_to_hand (1+, monster, you controls) from hand
