// レプティレス・ニャミニ
// Reptilianne Nyami
// Transpiled from c42090294.lua

card "Reptilianne Nyami" {
    id: 42090294
    type: Effect Monster
    attribute: DARK
    race: Reptile
    level: 2
    atk: 200
    def: 0

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        damage_step: false
        activate_from: [hand]
        on_activate {
            select (1+, card, you controls, where { is_face_up }) as target
        }
        cost {
            send self to gy
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [gy]
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
