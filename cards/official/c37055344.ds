card "Ghostrick-Go-Round" {
    id: 37055344
    type: Continuous Trap

    effect "Effect 1" {
        speed: 2
        mandatory
        condition: phase == battle
        resolve {
            change_position target to face_down_defense
            change_position (1, card, opponent controls, from monster_zone) to attack_position
            change_position target to attack_position
            change_position (1, card, opponent controls, from monster_zone) to face_down_defense
        }
    }

    effect "Effect 2" {
        speed: 2
        once_per_turn: soft
        condition: phase == battle
        resolve {
            change_position target to face_down_defense
            change_position target to attack_position
        }
    }
}
