card "Walls of the Imperial Tomb" {
    id: 26984177
    type: Field Spell

    effect "Effect 1" {
        speed: 1
        mandatory
        resolve {
            add_to_hand (1, card, you control, from deck)
            shuffle_hand yours
            shuffle_deck yours
            send (1, card, you control, from hand) to deck
        }
    }

    effect "Effect 3" {
        speed: 1
        once_per_turn: hard
        mandatory
        resolve {
            add_to_hand (all, card, either controls)
            return (all, card, either controls) to deck
        }
    }

    effect "Effect 4" {
        speed: 1
        timing: if
        trigger: opponent_activates [activate_spell, activate_trap, activate_spell]
        resolve {
            draw 1
        }
    }
}
