card "Performage Trapeze Witch" {
    id: 33206889
    type: Fusion Monster
    attribute: DARK
    race: Spellcaster
    level: 7
    atk: 2400
    def: 1800

    summon {
        cannot_normal_summon
        fusion materials: (2, monster, where archetype == "Performage")
    }

    passive "Effect 1" {
        scope: self
        grant: cannot_be_targeted by effects
    }

    passive "Effect 2" {
        scope: self
        grant: cannot_be_destroyed by effect
    }

    passive "Effect 3" {
        scope: self
        grant: cannot_be_targeted by effects
    }

    effect "Effect 4" {
        speed: 1
        timing: when
        trigger: summoned
        resolve {
            modify_atk target - 600 until end_of_turn
        }
    }
}
