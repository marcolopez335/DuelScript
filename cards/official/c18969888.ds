card "Sangenpai Transcendent Dragion" {
    id: 18969888
    type: Synchro Monster
    attribute: FIRE
    race: Dragon
    level: 10
    atk: 3000
    def: 3000

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    raw_effect "Effect 1" {
        effect_type: Single + Trigger
        category: PositionChange
        code: SpecialSummonSuccess
        property: Delay
        on_resolve {
            change_battle_position (1, monster)
        }
    }

    raw_effect "Effect 2" {
        effect_type: Field
        code: 191
        range: MonsterZone
        on_resolve {
            register_effect on self { grant: must_attack_if_able duration: until_end_of_turn }
        }
    }

    raw_effect "Effect 3" {
        effect_type: Field
        code: CannotChangeControl
        property: InitialValue
        range: MonsterZone
        on_resolve {
            register_effect on self { grant: cannot_activate_effects duration: until_end_of_turn }
        }
    }

    raw_effect "Effect 4" {
        effect_type: QuickEffect
        category: Destroy + SpecialSummon
        code: FreeChain
        range: Graveyard
        count_limit: (1, 18969888)
        on_resolve {
            special_summon (1, monster) from gy
            destroy (1+, monster, either_player controls)
        }
    }

    raw_effect "Effect 5" {
        effect_type: Field + Continuous
        code: AttackAnnounce
        on_resolve {
            set_flag "tracked" on self
        }
    }

