card "Groza, Tyrant of Thunder" {
    id: 45420955
    type: Synchro Monster
    attribute: DARK
    race: Fiend
    level: 8
    atk: 2800
    def: 2800

    summon {
        cannot_normal_summon
        synchro materials {
            tuner: (1, tuner monster)
            non_tuner: (1+, non-tuner monster, where race == Fiend)
        }
    }

    effect "Effect 1" {
        speed: 2
        once_per_turn: hard
        resolve {
            discard (all, card, either controls)
            negate
        }
    }

    effect "Effect 2" {
        speed: 1
        timing: if
        trigger: custom "chain_end"
    }
}
