// リビング・フォッシル
// Living Fossil
// Transpiled from c34959756.lua

card "Living Fossil" {
    id: 34959756
    type: Equip Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        on_resolve {
            special_summon (1, monster) from gy
            equip (1, card) to (1, monster)
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    raw_effect "Effect 2" {
        effect_type: Equip
        code: UpdateAttack
        on_resolve {
            modifier: atk - 1000
        }
    }

    raw_effect "Effect 3" {
        effect_type: Equip
        code: UpdateDefense
        on_resolve {
            modifier: def - 1000
        }
    }

    continuous_effect "Effect 4" {
        scope: self
        grant: cannot_activate_effects
    }

    raw_effect "Effect 5" {
        effect_type: Single + Continuous
        code: ChainNegated
        on_resolve {
            banish (1+, card, either_player controls)
        }
    }

}
