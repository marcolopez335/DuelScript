// 鉄獣戦線 塊撃のベアブルム
// Tri-Brigade Bearbrumm the Rampant Rampager
// Transpiled from c47163170.lua

card "Tri-Brigade Bearbrumm the Rampant Rampager" {
    id: 47163170
    type: Link Monster
    attribute: FIRE
    race: Beast
    link: 2
    link_arrows: [left, bottom_right]
    atk: 1700

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ effect monster
        method: link
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, spell, you controls, where { is_face_up and level <= 4 }) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        trigger: on_custom_event "chain_end"
        on_resolve {
            add_to_hand (1+, spell, you controls, where { is_face_up and level <= 4 }) from hand
            reveal (1+, card, opponent controls)
            shuffle_deck
            shuffle_hand
            return (1+, spell, you controls, where { is_face_up and level <= 4 }) to deck shuffle
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
