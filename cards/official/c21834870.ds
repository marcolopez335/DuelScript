// 天威無双の拳
// Fists of the Unrivaled Tenyi
// Transpiled from c21834870.lua

card "Fists of the Unrivaled Tenyi" {
    id: 21834870
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            negate activation
            send (1+, monster, you controls) to gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        optional: true
        timing: if
        trigger: when_destroyed
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
