card "Neiroy, the Dream Mirror Disciple" {
    id: 18189187
    type: Effect Monster
    attribute: LIGHT
    race: Fairy
    level: 3
    atk: 1000
    def: 1000

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [hand]
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        trigger: when_summoned by_special_summon
        on_resolve {
            return (1+, spell, either_player controls) to hand
            draw 1
            return (1+, spell, either_player controls) to deck shuffle
        }
    }

}
