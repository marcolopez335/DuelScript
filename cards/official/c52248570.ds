// プリズンクインデーモン
// Imprisoned Queen Archfiend
// Transpiled from c52248570.lua

card "Imprisoned Queen Archfiend" {
    id: 52248570
    type: Effect Monster
    attribute: DARK
    race: Fiend
    level: 8
    atk: 2600
    def: 1700

    summon_condition {
        tributes_required: 2
    }

    raw_effect "Effect 1" {
        effect_type: Field + Continuous
        code: PhaseStandby
        property: BothSide + Uncopyable
        range: MonsterZone
        count_limit: (1, 0)
        on_resolve {
            destroy (1+, card, either_player controls, where { is_face_up and level <= 4 and race == Fiend })
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        trigger: during_standby_phase
        activate_from: [gy]
        on_activate {
            select (1+, card, either_player controls, where { is_face_up and level <= 4 and race == Fiend }) as target
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
