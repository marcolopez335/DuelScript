card "Poseidra, the Storming Atlantean" {
    id: 99193444
    type: Effect Monster
    attribute: WATER
    race: Sea Serpent
    level: 7
    atk: 2800
    def: 1600

    summon_condition {
        tributes_required: 2
    }

    raw_effect "Effect 1" {
        effect_type: Single
        code: AttackDisabled
        property: SingleRange
