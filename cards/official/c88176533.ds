card "Devotee of Nephthys" {
    id: 88176533
    type: Ritual Monster
    attribute: WIND
    race: Spellcaster
    level: 2
    atk: 1200
    def: 1200

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 1+ monster
        method: ritual
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        activate_from: [gy]
        on_resolve {
            destroy (1+, card, you controls, deck)
            special_summon (1, monster) from gy
        }
    }

}
