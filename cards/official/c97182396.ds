// Amaze Attraction Viking Vortex
// Transpiled from c97182396.lua

card "Amaze Attraction Viking Vortex" {
    id: 97182396
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        timing: when
        trigger: when attack_declared
        activate_from: [spell_trap_zone]
        on_resolve {
            negate attack
            take_control of (1, monster, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        activate_from: [spell_trap_zone]
        on_resolve {
            add_to_hand (1+, card, either_player controls) from gy
        }
    }

}
