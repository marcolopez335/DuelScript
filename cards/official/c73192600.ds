// 星遺物の対焉
// World Legacy Cliffhanger
// Transpiled from c73192600.lua

card "World Legacy Cliffhanger" {
    id: 73192600
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        trigger: when attack_declared
        on_resolve {
            return (1+, monster, either_player controls, where { is_monster }) to deck shuffle
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
