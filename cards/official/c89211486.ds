        on_activate {
            select (1+, card, either_player controls, where { is_face_up and card_id == 68505803 }) as target
        }
        cost {
            tribute self
        }
        on_resolve {
            destroy (1+, card, either_player controls, where { is_face_up and card_id == 68505803 })
        }
    }

