card "Desperado Barrel Dragon" {
    id: 76728962
    type: Effect Monster
    attribute: DARK
    race: Machine
    level: 8
    atk: 2800
    def: 2200

    summon {
        tributes: 2
    }

    effect "Effect 1" {
        speed: 1
        timing: if
        trigger: destroyed
        resolve {
            special_summon (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 2
        once_per_turn: soft
        condition: phase == battle
        resolve {
            destroy (all, card, either controls)
            draw 1
        }
    }

    effect "Effect 3" {
        speed: 1
        timing: if
        trigger: custom "chain_end"
        resolve {
            return (all, card, either controls) to hand
        }
    }
}
