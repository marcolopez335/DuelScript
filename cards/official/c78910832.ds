// Vic Viper Type-L
// Transpiled from c78910832.lua

card "Vic Viper Type-L" {
    id: 78910832
    type: Effect Monster
    attribute: LIGHT
    race: Machine
    level: 4
    atk: 1200
    def: 800

    raw_effect "Effect 1" {
        effect_type: Field + Trigger
        code: PhaseBattleStart
        range: MonsterZone
        count_limit: (1, 78910832)
        on_resolve {
            special_summon (1, monster) from gy
            send (1+, card, you controls, hand) to gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        damage_step: false
        trigger: when_destroyed
        on_activate {
            select (1+, card, you controls, where { level <= 4 and attribute == LIGHT and race == Machine }) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    raw_effect "Effect 3" {
        effect_type: Single
        code: UpdateAttack
        property: BothSide
        on_resolve {
            modifier: atk + 1200
        }
    }

}
