card "Performapal Changeraffe" {
    id: 69228245
    type: Effect Monster | Pendulum Monster
    attribute: EARTH
    race: Beast
    level: 1
    scale: 5
    atk: 100
    def: 500

    effect "Effect 1" {
        speed: 1
        timing: when
        trigger: battle_damage
        resolve {
            destroy (all, card, either controls)
            special_summon (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        timing: when
        trigger: summoned
        resolve {
            grant target cannot_be_destroyed by battle until end_of_turn
        }
    }

    effect "Effect 3" {
        speed: 1
        timing: when
        trigger: summoned by special
        resolve {
            grant target cannot_attack until end_of_turn
        }
    }
}
