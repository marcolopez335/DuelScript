card "Bujingi Ophidian" {
    id: 94096616
    type: Effect Monster
    attribute: LIGHT
    race: Winged Beast
    level: 4
    atk: 1700
    def: 500

    effect "Effect 1" {
        speed: spell_speed_1
        damage_step: false
        activate_from: [hand]
        on_activate {
            select (1+, card, either_player controls) as target
        }
        cost {
            send self to gy
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
