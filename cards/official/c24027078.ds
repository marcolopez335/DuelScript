card "Morgan, the Enchantress of Avalon" {
    password: 24027078
    type: Effect Monster
    attribute: DARK
    race: Spellcaster
    level: 3
    atk: 1300
    def: 1600

    effect "Effect 1" {
        speed: spell_speed_2
