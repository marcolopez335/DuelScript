card "Amazoness Pet Liger" {
    id: 68507541
    type: Fusion Monster
    attribute: EARTH
    race: Beast
    level: 7
    atk: 2500
    def: 2400

    summon {
        cannot_normal_summon
        special_summon_procedure {
            from: extra_deck
            to: your_field
        }
    }

    passive "Effect 3" {
        scope: self
