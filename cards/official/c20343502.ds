// ティーチャーマドルチェ・グラスフレ
// Madolche Teacher Glassouffle
// Transpiled from c20343502.lua

card "Madolche Teacher Glassouffle" {
    id: 20343502
    type: Xyz Monster
    attribute: EARTH
    race: Fairy
    rank: 4
    atk: 1800
    def: 2500

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        same_level: true
        method: xyz
    }

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        damage_step: false
        on_activate {
            select (1+, card, either_player controls) as target
        }
        cost {
            detach 1 overlay_unit from self
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: when
        trigger: on_custom_event "chain_end"
        on_resolve {
            return (1+, card, either_player controls) to deck shuffle
        }
    }

}
