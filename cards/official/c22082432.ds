// 神の怒り
// Dangers of the Divine
// Transpiled from c22082432.lua

card "Dangers of the Divine" {
    id: 22082432
    type: Quick-Play Spell

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        cost {
            pay_lp 1000
        }
        on_resolve {
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            destroy (1+, monster, opponent controls)
            return (1+, monster, either_player controls) to hand
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        trigger: on_custom_event "chain_end"
        on_resolve {
            send (1+, monster, either_player controls) to gy
        }
    }

    raw_effect "Effect 3" {
        effect_type: Single
        code: SetAttack
        property: SetAvailable + BothSide
        on_resolve {
            modifier: atk + 4000
        }
    }

    raw_effect "Effect 4" {
        effect_type: Single
        code: SetDefense
        property: SetAvailable + BothSide
        on_resolve {
            modifier: def + 4000
        }
    }

    continuous_effect "Effect 5" {
        scope: self
        grant: cannot_attack
    }

}
