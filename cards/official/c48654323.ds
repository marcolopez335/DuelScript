// 凶導の白聖骸
// White Relic of Dogmatika
// Transpiled from c48654323.lua

card "White Relic of Dogmatika" {
    id: 48654323
    type: Ritual Monster
    attribute: LIGHT
    race: Spellcaster
    level: 4
    atk: 500
    def: 2500

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 1+ monster
        method: ritual
    }

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        timing: if
        damage_step: false
        trigger: when_summoned by_special_summon
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    continuous_effect "Effect 2" {
        scope: field
        grant: cannot_be_destroyed_by_battle
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        on_resolve {
            reveal (1+, card, opponent controls)
            send (1+, monster, either_player controls) to gy
            shuffle_deck
        }
    }

    raw_effect "Effect 4" {
        effect_type: Single
        code: UpdateAttack
        property: BothSide
        on_resolve {
            modifier: atk + 0
        }
    }

}
