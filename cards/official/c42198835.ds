// 外法の騎士
// Illegal Knight
// Transpiled from c42198835.lua

card "Illegal Knight" {
    id: 42198835
    type: Effect Monster
    attribute: DARK
    race: Fiend
    level: 7
    atk: 2000
    def: 2000

    summon_condition {
        tributes_required: 2
    }

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        activate_from: [hand]
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        damage_step: false
        on_activate {
            select (1+, card, you controls) as target
        }
        on_resolve {
            take_control of (1, monster, opponent controls)
            return (1+, card, you controls) to hand
        }
    }

}
