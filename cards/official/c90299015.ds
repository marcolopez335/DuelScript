card "Vampire Ghost" {
    id: 90299015
    type: Effect Monster
    attribute: DARK
    race: Zombie
    level: 3
    atk: 1500
    def: 0

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: when_summoned
        cost {
            send self to gy
        }
        on_resolve {
            add_to_hand (1+, card, you controls) from hand
            reveal (1+, card, opponent controls)
            send (1+, card, you controls, hand) to gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        activate_from: [gy]
        cost {
            pay_lp your_lp / 2
        }
        on_resolve {
            normal_summon (1, monster, you controls)
        }
    }

}
