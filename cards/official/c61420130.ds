card "Paleozoic Hallucigenia" {
    id: 61420130
    type: Normal Trap

    effect "Effect 1" {
        speed: 2
        mandatory
        resolve {
            set_atk target target.atk / 2 until end_of_turn
            set_def target target.def / 2 until end_of_turn
        }
    }

    effect "Effect 2" {
        speed: 2
        timing: when
        trigger: opponent_activates [activate_spell, activate_trap, activate_spell]
        resolve {
            special_summon (all, card, either controls)
        }
    }
}
