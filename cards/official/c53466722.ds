// 始祖の竜王
// First of the Dragonlords
// Transpiled from c53466722.lua

card "First of the Dragonlords" {
    id: 53466722
    type: Fusion Monster
    attribute: DARK
    race: Dragon
    level: 11
    atk: 3700
    def: 3000

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        method: fusion
    }

    continuous_effect "Effect 1" {
        scope: self
        grant: cannot_be_destroyed_by_battle
    }

    continuous_effect "Effect 2" {
        scope: self
        grant: unaffected_by_card_effects
    }

    effect "Effect 3" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            destroy (1+, spell, either_player controls)
        }
    }

}
