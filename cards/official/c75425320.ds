card "Disciples of the True Dracophoenix" {
    id: 75425320
    type: Continuous Spell

    effect "Effect 1" {
        speed: 1
        mandatory
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        mandatory
        resolve {
            return (all, card, either controls) to deck
            draw 1
        }
    }

    effect "Effect 3" {
        speed: 1
        once_per_turn: soft
        mandatory
        condition: previous_location == spell_trap_zone
        resolve {
            send target to deck
            draw 1
        }
    }

    effect "Effect 4" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: custom "chain_end"
        resolve {
            destroy (all, card, either controls)
        }
    }
}
