card "Marincess Aqua Argonaut" {
    id: 20934852
    type: Link Monster
    attribute: WATER
    race: Cyberse
    link: 4
    link_arrows: [top, left, right, bottom]
    atk: 2300

    summon {
        cannot_normal_summon
    }

    passive "Effect 1" {
        scope: self
        grant: cannot_be_targeted by effects
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        mandatory
        resolve {
            return (all, card, either controls) to hand
        }
    }

    effect "Effect 3" {
        speed: 2
        once_per_turn: soft
        timing: when
        trigger: opponent_activates [activate_spell, activate_trap, activate_spell]
        resolve {
            special_summon (all, card, either controls)
            negate
        }
    }
}
