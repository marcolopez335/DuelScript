// 先史遺産アカンバロの土偶
// Chronomaly Acambaro Figures
// Transpiled from c24506253.lua

card "Chronomaly Acambaro Figures" {
    id: 24506253
    type: Effect Monster
    attribute: EARTH
    race: Rock
    level: 5
    atk: 1000
    def: 1800

    summon_condition {
        tributes_required: 1
    }

    replacement_effect "Effect 1" {
        instead_of: destroyed_by_any
        do: {
            banish self
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [gy]
        cost {
            pay_lp your_lp / 2
        }
        on_resolve {
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
