card "Red Zone" {
    id: 50056656
    type: Continuous Trap

    effect "Effect 1" {
        speed: spell_speed_2
        on_resolve {
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        timing: when
        damage_step: false
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        activate_from: [spell_trap_zone]
        on_activate {
            select (1+, monster, you controls, where { is_face_up and attribute == DARK and race == Dragon }) as target
        }
        on_resolve {
            destroy (1+, monster, you controls, where { is_face_up and attribute == DARK and race == Dragon })
        }
    }

    effect "Effect 3" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        damage_step: false
        activate_from: [spell_trap_zone]
        on_activate {
            select (1+, monster, you controls, where { is_face_up and attribute == DARK and race == Dragon }) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
