card "Sky Striker Ace - Shizuku" {
    id: 90673288
    type: Link Monster
    attribute: WATER
    race: Machine
    link: 1
    link_arrows: [top_right]
    atk: 1500

    summon {
        cannot_normal_summon
        special_summon_procedure {
            from: extra_deck
            to: your_field
        }
    }

    effect "Effect 4" {
        speed: 1
        once_per_turn: soft
        timing: when
        trigger: end_phase
        resolve {
            add_to_hand (all, card, either controls)
        }
    }


    passive "Passive 5" {
        scope: field
        target: (all, monster, opponent controls)
        modifier: atk - count((all, spell, you control, from gy)) * 100
    }


    passive "Passive 6" {
        scope: field
        target: (all, monster, opponent controls)
        modifier: def - count((all, spell, you control, from gy)) * 100
    }
}
