// ホロウヴァレット・ドラゴン
// Hollowrokket Dragon
// Transpiled from c51548207.lua

card "Hollowrokket Dragon" {
    id: 51548207
    type: Effect Monster
    attribute: DARK
    race: Dragon
    level: 6
    atk: 2400
    def: 1600

    summon_condition {
        tributes_required: 1
    }

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            destroy (1+, card, you controls, deck)
            reveal (1, card, opponent controls, deck)
            banish (1+, card, you controls, deck)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: when
        trigger: during_end_phase
        activate_from: [gy]
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
