// トランス・デーモン
// Trance Archfiend
// Transpiled from c94283662.lua

card "Trance Archfiend" {
    id: 94283662
    type: Effect Monster
    attribute: DARK
    race: Fiend
    level: 4
    atk: 1500
    def: 500

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        on_resolve {
            discard (1, card)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        optional: true
        timing: when
        damage_step: false
        trigger: on_custom_event "chain_end"
        on_activate {
            select (1+, card, you controls, where { is_face_up and attribute == DARK }) as target
        }
        on_resolve {
            add_to_hand (1+, card, you controls, where { is_face_up and attribute == DARK }) from hand
        }
    }

}
