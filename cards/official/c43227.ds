// マグナム・ザ・リリーバー
// Magnum the Reliever
// Transpiled from c43227.lua

card "Magnum the Reliever" {
    id: 43227
    type: Fusion Monster
    attribute: LIGHT
    race: Fiend
    level: 8
    atk: 2800
    def: 2000

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        method: fusion
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, spell, you controls) as target
        }
        on_resolve {
            return (1+, spell, you controls) to deck shuffle
            draw 1
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        timing: when
        damage_step: false
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_activate {
            select (1+, spell, you controls) as target
        }
        cost {
            banish self
        }
        on_resolve {
            destroy (1+, spell, you controls, gy)
        }
    }

}
