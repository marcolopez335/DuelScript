// 義賊の極意書
// Secrets of the Gallant
// Transpiled from c95096437.lua

card "Secrets of the Gallant" {
    id: 95096437
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        damage_step: false
        on_activate {
            select (1+, card, either_player controls, where { is_face_up and is_monster }) as target
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
