card "Number 66: Master Key Beetle" {
    id: 76067258
    type: Xyz Monster
    attribute: DARK
    race: Insect
    rank: 4
    atk: 2500
    def: 800

    summon {
        cannot_normal_summon
        xyz materials: (2, monster, where level == 4 and attribute == DARK)
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: soft
        mandatory
        cost {
            detach 1 from self
        }
        resolve {
            grant target cannot_be_destroyed by effect until end_of_turn
        }
    }

    replacement "Effect 2" {
        instead_of: destroyed
        do {
            banish self
        }
    }
}
