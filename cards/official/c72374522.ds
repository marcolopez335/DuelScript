// 紫毒の茨牙
// Thorn Fangs of Violet Poison
// Transpiled from c72374522.lua

card "Thorn Fangs of Violet Poison" {
    id: 72374522
    type: Normal Spell

    effect "Effect 1" {
        speed: spell_speed_1
        damage_step: false
        on_activate {
            select (1+, monster, opponent controls, where { is_face_up }) as target
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            destroy (1+, monster, opponent controls, where { is_face_up })
            send (1+, monster, opponent controls, where { is_face_up }) to gy
            deal_damage to opponent: 1000
        }
    }

}
