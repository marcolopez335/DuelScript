card "Cyberse Quantum Dragon" {
    id: 63533837
    type: Synchro Monster
    attribute: DARK
    race: Cyberse
    level: 7
    atk: 2500
    def: 2000

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    summon_condition {
        cannot_normal_summon: true
    }

    raw_effect "Effect 1" {
        effect_type: Single + Trigger
        category: ToHand
        code: DamageCalculation
        count_limit: (1, 0)
        on_resolve {
            return (1+, monster, you controls) to hand
        }
    }

    continuous_effect "Effect 2" {
        scope: field
        grant: cannot_be_targeted_by_card_effects
    }

    continuous_effect "Effect 3" {
        scope: field
        grant: cannot_be_targeted_by_card_effects
    }

}
