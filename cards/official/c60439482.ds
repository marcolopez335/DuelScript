// レグルスの矢
// Regulus' Arrow
// Transpiled from c60439482.lua

card "Regulus' Arrow" {
    id: 60439482
    type: Quick-Play Spell

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: soft
        on_resolve {
            destroy (1+, card, you controls)
            negate effect
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        damage_step: false
        activate_from: [gy]
        on_activate {
            select (1+, card, you controls) as target
        }
        cost {
            banish self
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
