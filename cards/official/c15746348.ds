// 水霊媒師エリア
// Eria the Water Channeler
// Transpiled from c15746348.lua

card "Eria the Water Channeler" {
    id: 15746348
    type: Effect Monster
    attribute: WATER
    race: Spellcaster
    level: 5
    atk: 1850
    def: 1500

    summon_condition {
        tributes_required: 1
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [hand]
        cost {
            send self to gy
        }
        on_resolve {
            add_to_hand (1+, card, you controls, where { attribute == WATER }) from deck
            reveal (1+, card, opponent controls)
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: when
        trigger: when_battle_damage
        activate_from: [hand]
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
