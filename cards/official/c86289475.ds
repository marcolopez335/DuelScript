// 磁石の戦士Ω＋
// Magnet Warrior Omega Plus
// Transpiled from c86289475.lua

card "Magnet Warrior Omega Plus" {
    id: 86289475
    type: Effect Monster
    attribute: EARTH
    race: Rock
    level: 4
    atk: 800
    def: 1900

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [hand, gy]
        on_resolve {
            destroy (1+, monster, you controls, hand)
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        timing: when
        damage_step: false
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_activate {
            select (1+, monster, you controls, where { race == Rock and is_face_up }) as target
        }
        cost {
            tribute self
        }
        on_resolve {
            change_battle_position (1, monster)
        }
    }

}
