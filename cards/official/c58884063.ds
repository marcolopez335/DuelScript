// Gold Pride - Nytro Blaster
// Transpiled from c58884063.lua

card "Gold Pride - Nytro Blaster" {
    id: 58884063
    type: Link Monster
    attribute: DARK
    race: Pyro
    link: 2
    link_arrows: [top, bottom]
    atk: 2300

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ effect monster
        method: link
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, card, opponent controls) as target
        }
        on_resolve {
            destroy (1+, card, opponent controls, gy)
            destroy (1+, card, opponent controls, gy)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        trigger: during_end_phase
        on_resolve {
            return (1+, card, opponent controls) to deck shuffle
            special_summon (1, monster) from gy
        }
    }

}
