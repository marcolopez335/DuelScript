// リブロマンサー・インターフェア
// Libromancer Intervention
// Transpiled from c44889144.lua

card "Libromancer Intervention" {
    id: 44889144
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        damage_step: false
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_activate {
            select (1+, card, you controls) as target
        }
        on_resolve {
            add_to_hand (1+, card, you controls) from gy
            negate effect
            special_summon (1, monster) from gy
        }
    }

}
