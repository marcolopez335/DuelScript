card "UFOLight" {
    id: 9275482
    type: Effect Monster
    attribute: FIRE
    race: Unknown
    level: 8
    atk: 1500
    def: 1500

    summon_condition {
        tributes_required: 2
    }

    continuous_effect "Effect 1" {
        scope: self
        grant: cannot_be_targeted_by_card_effects
    }

    continuous_effect "Effect 2" {
        scope: field
        grant: cannot_be_destroyed_by_battle
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: when
        trigger: during_end_phase
        on_resolve {
            draw 1
            shuffle_hand
            banish (1+, card, opponent controls, hand)
        }
    }

    raw_effect "Effect 4" {
        effect_type: Single
        code: UpdateAttack
        on_resolve {
            modifier: atk + 0
        }
    }

}
