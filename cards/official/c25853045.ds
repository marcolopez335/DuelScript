// FA－ブラック・レイ・ランサー
// Full Armored Black Ray Lancer
// Transpiled from c25853045.lua

card "Full Armored Black Ray Lancer" {
    id: 25853045
    type: Xyz Monster
    attribute: WATER
    race: Beast-Warrior
    rank: 4
    atk: 2100
    def: 600

    materials {
        require: 2+ monster
        same_level: true
        method: xyz
    }

    summon_condition {
        cannot_normal_summon: true
    }

    raw_effect "Effect 1" {
        effect_type: Single
        code: UpdateAttack
        property: SingleRange
        range: MonsterZone
        on_resolve {
            modifier: atk + 0
        }
    }

    replacement_effect "Effect 2" {
        instead_of: destroyed_by_any
        do: {
            banish self
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        optional: true
        timing: when
        damage_step: false
        trigger: when_battle_damage
        on_activate {
            select (1+, spell, either_player controls, where { is_spell }) as target
        }
        on_resolve {
            destroy (1+, spell, either_player controls, where { is_spell })
        }
    }

}
