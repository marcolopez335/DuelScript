// 鉄獣戦線 徒花のフェリジット
// Tri-Brigade Ferrijit the Barren Blossom
// Transpiled from c26847978.lua

card "Tri-Brigade Ferrijit the Barren Blossom" {
    id: 26847978
    type: Link Monster
    attribute: EARTH
    race: Beast
    link: 2
    link_arrows: [left, bottom_left]
    atk: 1600

    materials {
        require: 2+ effect monster
        method: link
    }

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        trigger: on_custom_event "chain_end"
        on_resolve {
            draw 1
            shuffle_hand
            return (1+, monster, you controls) to deck shuffle
        }
    }

}
