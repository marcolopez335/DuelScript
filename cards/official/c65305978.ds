// 炎王の聖域
// Fire King Sanctuary
// Transpiled from c65305978.lua

card "Fire King Sanctuary" {
    id: 65305978
    type: Continuous Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    replacement_effect "Effect 2" {
        instead_of: destroyed_by_any
        do: {
            banish self
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        activate_from: [spell_trap_zone]
        on_resolve {
            xyz_summon (1, xyz monster) using (1+, monster, you controls)
        }
    }

}
