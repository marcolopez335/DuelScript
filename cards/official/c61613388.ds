card "U.A. Turnover Tactics" {
    password: 61613388
    type: Quick-Play Spell

    raw_effect "Effect 1" {
        effect_type: Activate
        category: ToDeck + SpecialSummon
        code: FreeChain
        count_limit: (1, 61613388)
        on_resolve {
            return (1+, monster, you controls) to deck shuffle
            shuffle_deck
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            special_summon (1, monster) from gy
        }
    }

}
