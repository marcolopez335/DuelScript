card "Traptrix Pudica" {
    id: 49027020
    type: Effect Monster
    attribute: EARTH
    race: Plant
    level: 4
    atk: 900
    def: 1900

    raw_effect "Effect 1" {
        effect_type: Single
        code: ImmuneEffect
        property: SingleRange
        range: MonsterZone
        on_resolve {
            register_effect on self { grant: unaffected_by_card_effects duration: until_end_of_turn }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: when
        trigger: when_summoned
        on_resolve {
            add_to_hand (1+, card, either_player controls) from gy
