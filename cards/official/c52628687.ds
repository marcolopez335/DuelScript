// ネクロの魔導書
// Spellbook of Life
// Transpiled from c52628687.lua

card "Spellbook of Life" {
    id: 52628687
    type: Equip Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, spell, you controls, where { race == Spellcaster }) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
            equip (1, card) to (1, monster)
        }
    }

}
