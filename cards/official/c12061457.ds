card "Soul Scissors" {
    id: 12061457
    type: Effect Monster
    attribute: DARK
    race: Fiend
    level: 2
    atk: 550
    def: 350

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: custom "chain_end"
        resolve {
            special_summon (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: summoned by special
        target (1, card, opponent controls, from monster_zone)
        resolve {
            destroy (all, card, either controls)
        }
    }
}
