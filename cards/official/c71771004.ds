// 供物の下ごしらえ
// Readying of Rites
// Transpiled from c71771004.lua

card "Readying of Rites" {
    id: 71771004
    type: Normal Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        on_resolve {
            add_to_hand (1+, card, you controls, where { race == Fiend }) from deck
            reveal (1+, card, opponent controls)
            shuffle_hand
            create_token { atk: 0 def: 0 }
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: when
        trigger: when_battle_destroyed
        activate_from: [gy]
        cost {
            banish self
        }
        on_resolve {
            draw 1
        }
    }

}
