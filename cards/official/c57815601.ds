// 霊獣の騎襲
// Ritual Beast Ambush
// Transpiled from c57815601.lua

card "Ritual Beast Ambush" {
    id: 57815601
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
            special_summon (1, monster) from gy
            send (1+, card, either_player controls) to gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
