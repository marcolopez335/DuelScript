card "Cyberse Witch" {
    id: 11674673
    type: Link Monster
    attribute: DARK
    race: Cyberse
    link: 2
    link_arrows: [bottom_left, bottom]
    atk: 800

    materials {
        require: 2+ effect monster
        method: link
    }

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        cost {
            banish self
        }
        on_resolve {
            add_to_hand (1+, monster, you controls, where { card_id == 34767865 }) from deck
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_activate {
            select (1+, monster, you controls, where { card_id == 34767865 }) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
