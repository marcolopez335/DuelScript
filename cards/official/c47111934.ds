// ワーム・ヤガン
// Worm Yagan
// Transpiled from c47111934.lua

card "Worm Yagan" {
    id: 47111934
    type: Effect Monster
    attribute: LIGHT
    race: Reptile
    level: 4
    atk: 1000
    def: 1800

    effect "Effect 1" {
        speed: spell_speed_1
        activate_from: [gy]
        on_resolve {
            special_summon (1, monster) from gy
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        damage_step: false
        trigger: on_custom_event "chain_active"
        on_activate {
            select (1+, monster, you controls, where { is_face_up }) as target
        }
        on_resolve {
            return (1+, monster, you controls, where { is_face_up }) to hand
        }
    }

}
