// カズーラの蟲惑魔
// Traptrix Nepenthes
// Transpiled from c28201945.lua

card "Traptrix Nepenthes" {
    id: 28201945
    type: Effect Monster
    attribute: EARTH
    race: Plant
    level: 4
    atk: 800
    def: 2000

    continuous_effect "Effect 1" {
        scope: self
        grant: unaffected_by_card_effects
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            special_summon (1, monster) from gy
            add_to_hand (1+, monster, you controls) from deck
            reveal (1+, card, opponent controls)
        }
    }

}
