// カズーラの蟲惑魔
// Traptrix Nepenthes
// Transpiled from c28201945.lua

card "Traptrix Nepenthes" {
    id: 28201945
    type: Effect Monster
    attribute: EARTH
    race: Plant
    level: 4
    atk: 800
    def: 2000

    raw_effect "Effect 1" {
        effect_type: Single
        code: ImmuneEffect
        property: SingleRange
        range: MonsterZone
        on_resolve {
            register_effect on self { grant: unaffected_by_card_effects duration: until_end_of_turn }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            special_summon (1, monster) from gy
            add_to_hand (1+, monster, you controls) from deck
            reveal (1+, card, opponent controls)
        }
    }

}
