card "Traptrix Nepenthes" {
    id: 28201945
    type: Effect Monster
    attribute: EARTH
    race: Plant
    level: 4
    atk: 800
    def: 2000

    passive "Effect 1" {
        scope: self
        grant: unaffected_by effects
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: opponent_activates [activate_spell, activate_trap, activate_spell]
        resolve {
            special_summon (all, card, either controls)
            add_to_hand (all, card, either controls)
        }
    }
}
