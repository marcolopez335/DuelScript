card "Salvage" {
    id: 96947648
    type: Normal Spell

    effect "Effect 1" {
        speed: spell_speed_1
        damage_step: false
        on_activate {
            select (1+, monster, either_player controls, where { is_monster and attribute == WATER }) as target
        }
        on_resolve {
            add_to_hand (1+, monster, either_player controls, where { is_monster and attribute == WATER }) from gy
        }
    }

}
