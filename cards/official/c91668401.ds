card "Cyber Angel Izana" {
    id: 91668401
    type: Ritual Monster
    attribute: LIGHT
    race: Fairy
    level: 8
    atk: 2500
    def: 2600

    summon {
        cannot_normal_summon
    }

    passive "Effect 4" {
        scope: self
        grant: cannot_attack_directly
    }

    effect "Effect 1" {
        speed: 1
        timing: if
        trigger: summoned by special
        resolve {
            send (all, card, either controls) to gy
        }
    }

    effect "Effect 2" {
        speed: 1
        timing: when
        trigger: battle_damage
    }

    effect "Effect 3" {
        speed: 2
        once_per_turn: soft
        timing: when
        trigger: opponent_activates [activate_spell, activate_trap, activate_spell]
        resolve {
            return (all, card, either controls) to deck
            destroy (all, card, either controls)
        }
    }
}
