card "Number 7: Lucky Straight" {
    id: 82308875
    type: Xyz Monster
    attribute: LIGHT
    race: Fairy
    rank: 7
    atk: 700
    def: 700

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        same_level: true
        method: xyz
    }

    raw_effect "Effect 1" {
        effect_type: Ignition
        category: ToGrave + DefChange + SpecialSummon + Draw + SynchroSummon
        range: MonsterZone
        cost {
            detach 1 overlay_unit from self
