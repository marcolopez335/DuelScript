// 生存境界
// Survival's End
// Transpiled from c44612603.lua

card "Survival's End" {
    id: 44612603
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        on_resolve {
            destroy (1+, monster, either_player controls, where { is_face_up and is_monster })
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        optional: true
        damage_step: false
        activate_from: [gy]
        cost {
            banish self
        }
        on_resolve {
            destroy (1+, monster, either_player controls, where { is_face_up and is_monster })
        }
    }

}
