// 新世壊成劫
// New World Formation
// Transpiled from c58019984.lua

card "New World Formation" {
    id: 58019984
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, trap, either_player controls) as target
        }
        on_resolve {
            set (1, card)
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        damage_step: false
        activate_from: [gy]
        on_activate {
            select (1+, trap, either_player controls) as target
        }
        cost {
            banish self
        }
        on_resolve {
            return (1+, trap, either_player controls) to deck shuffle
        }
    }

}
