// 地獄人形の館
// Mansion of the Dreadful Dolls
// Transpiled from c36890111.lua

card "Mansion of the Dreadful Dolls" {
    id: 36890111
    type: Field Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        on_resolve {
            add_to_hand (1+, monster, you controls) from deck
            reveal (1+, card, opponent controls)
        }
    }

    continuous_effect "Effect 2" {
        scope: field
        grant: cannot_be_destroyed_by_battle
    }

    continuous_effect "Effect 3" {
        scope: field
        grant: unaffected_by_card_effects
    }

    effect "Effect 4" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        activate_from: [field_zone]
        cost {
            detach 1 overlay_unit from self
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
