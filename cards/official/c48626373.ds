card "Kashtira Arise-Heart" {
    id: 48626373
    type: Xyz Monster
    attribute: DARK
    race: Machine
    rank: 7
    atk: 3000
    def: 3000

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        same_level: true
        method: xyz
    }

    redirect_effect "Effect 1" {
        when_going_to: gy
        redirect_to: banished
    }

    raw_effect "Effect 2" {
        effect_type: Field + MandatoryTrigger
        code: TurnEnd
        range: MonsterZone
        on_resolve {
            attach (1, card) to self as_material
