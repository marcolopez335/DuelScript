card "Materiactor Meltdown" {
    id: 38669664
    type: Continuous Spell

    effect "Effect 1" {
        speed: spell_speed_1
        on_resolve {
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [spell_trap_zone]
        on_resolve {
            reveal (1, card, opponent controls, deck)
            return (1+, monster, you controls) to hand
            reveal (1+, card, opponent controls)
            shuffle_hand
            send_to_deck (1+, card, you controls)
            return (1+, monster, you controls) to hand
            reveal (1+, card, opponent controls)
            shuffle_hand
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        activate_from: [spell_trap_zone]
        on_resolve {
            attach (1, card) to self as_material
        }
    }

}
