// 戦華盟将－双龍
// Ancient Warriors Oath - Double Dragon Lords
// Transpiled from c65711558.lua

card "Ancient Warriors Oath - Double Dragon Lords" {
    id: 65711558
    type: Link Monster
    attribute: WIND
    race: Beast-Warrior
    link: 2
    link_arrows: [bottom_left, bottom_right]
    atk: 1100

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ effect monster
        method: link
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        on_resolve {
            add_to_hand (1+, card, you controls, where { is_face_up }) from deck
            reveal (1+, card, opponent controls)
        }
    }

    raw_effect "Effect 2" {
        effect_type: Field
        code: UpdateAttack
        range: MonsterZone
        on_resolve {
            modifier: atk + 500
        }
    }

    raw_effect "Effect 3" {
        effect_type: Field
        code: UpdateDefense
        range: MonsterZone
        on_resolve {
            modifier: def + 500
        }
    }

    effect "Effect 4" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        damage_step: false
        on_activate {
            select (1+, card, you controls, where { is_face_up }) as target
        }
        cost {
            send self to gy
        }
        on_resolve {
            add_to_hand (1+, card, you controls, where { is_face_up }) from deck
        }
    }

}
