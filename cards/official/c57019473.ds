card "Sishunder" {
    id: 57019473
    type: Effect Monster
    attribute: LIGHT
    race: Thunder
    level: 4
    atk: 900
    def: 400

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        timing: when
        damage_step: false
        trigger: when_summoned
        on_resolve {
            banish (1+, card, either_player controls, where { race == Thunder and attribute == LIGHT })
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
