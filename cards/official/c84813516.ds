    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        cost {
            send self to gy
        }
        on_resolve {
            destroy (1+, trap, you controls, hand)
        }
    }

    effect "Effect 4" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        damage_step: false
        trigger: when_destroyed
        on_activate {
            select (1+, trap, you controls) as target
        }
        on_resolve {
            flip_coin { heads { draw 1 } tails { draw 1 } }
            add_to_hand (1+, trap, you controls) from hand
        }
    }

