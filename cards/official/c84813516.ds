card "Thunder Ball" {
    id: 84813516
    type: Effect Monster
    attribute: DARK
    race: Fiend
    level: 3
    atk: 450
    def: 400

    raw_effect "Effect 1" {
        effect_type: Field + Trigger
        category: SpecialSummon
        code: BattleDestroyed
        range: Hand
        count_limit: (1, 84813516)
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    raw_effect "Effect 2" {
        effect_type: Field + Continuous
        code: BattleEnd
        on_resolve {
            set_flag "tracked" on self
        }
