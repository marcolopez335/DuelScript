card "Beetrooper Assault Roller" {
    id: 51578214
    type: Effect Monster
    attribute: EARTH
    race: Insect
    level: 4
    atk: 1600
    def: 1400

    raw_effect "Effect 1" {
        effect_type: Field
        code: CannotSummon
        property: Uncopyable
        range: Hand
        count_limit: (1, 51578214)
        on_resolve {
            banish (1+, monster, you controls, gy)
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single
        code: UpdateAttack
        property: SingleRange
        range: MonsterZone
        on_resolve {
            modifier: atk + count((1+, monster, you controls)) * 200
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: when
        trigger: when_battle_damage
        on_resolve {
            add_to_hand (1+, monster, you controls, where { race == Insect }) from gy
            reveal (1+, card, opponent controls)
        }
    }

}
