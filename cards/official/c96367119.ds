// ブラック・ノーブル
// Black Shadow Squall
// Transpiled from c96367119.lua

card "Black Shadow Squall" {
    id: 96367119
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            negate activation
            destroy (1+, card, you controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        activate_from: [gy]
        on_resolve {
            set (1, card)
        }
    }

}
