card "Carpiponica, Mystical Beast of the Forest" {
    id: 85055821
    type: Effect Monster
    attribute: EARTH
    race: Beast
    level: 7
    atk: 1000
    def: 2600

    summon {
        tributes: 2
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: custom "chain_end"
        condition: previous_location == hand
        resolve {
            return (all, card, either controls) to deck
            special_summon (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: summoned
        resolve {
            add_to_hand (all, card, either controls)
        }
    }

    effect "Effect 3" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: summoned by special
        resolve {
            add_to_hand (all, card, either controls)
        }
    }
}
