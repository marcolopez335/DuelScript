// オルフェゴール・ロンギルス
// Longirsu, the Orcust Orchestrator
// Transpiled from c76145142.lua

card "Longirsu, the Orcust Orchestrator" {
    id: 76145142
    type: Link Monster
    attribute: DARK
    race: Machine
    link: 3
    link_arrows: [top_left, top, bottom_right]
    atk: 2500

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ effect monster
        method: link
    }

    continuous_effect "Effect 1" {
        scope: self
        grant: cannot_be_destroyed_by_effect
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, monster, opponent controls) as target
        }
        on_resolve {
            return (1+, monster, opponent controls) to deck shuffle
            shuffle_deck
            send (1+, monster, opponent controls) to gy
        }
    }

    effect "Effect 3" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        damage_step: false
        on_activate {
            select (1+, monster, opponent controls) as target
        }
        on_resolve {
            return (1+, monster, opponent controls) to deck shuffle
            shuffle_deck
            send (1+, monster, opponent controls) to gy
        }
    }

}
