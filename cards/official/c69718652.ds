// 聖霊獣騎 ノチウドラゴ
// Ritual Beast Ulti-Nochiudrago
// Transpiled from c69718652.lua

card "Ritual Beast Ulti-Nochiudrago" {
    id: 69718652
    type: Fusion Monster
    attribute: LIGHT
    race: Wyrm
    level: 7
    atk: 2400
    def: 1900

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        method: fusion
    }

    continuous_effect "Effect 1" {
        scope: field
        grant: cannot_be_targeted_by_card_effects
    }

    effect "Effect 2" {
        speed: spell_speed_2
        optional: true
        damage_step: false
        on_activate {
            select (1+, monster, you controls) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    continuous_effect "Effect 3" {
        scope: self
        grant: cannot_attack_directly
    }

}
