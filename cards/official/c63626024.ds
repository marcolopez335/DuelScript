// 忍法 妖変化の術
// Ninjitsu Art of Mirage-Transformation
// Transpiled from c63626024.lua

card "Ninjitsu Art of Mirage-Transformation" {
    id: 63626024
    type: Continuous Trap

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, card, either_player controls) as target
        }
        cost {
            tribute self
        }
        on_resolve {
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single + Continuous
        code: ChainNegated
        on_resolve {
            send (1+, card, either_player controls) to gy
        }
    }

}
