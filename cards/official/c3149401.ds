// 誇りと魂の究極竜
// Ultimate Dragon of Pride and Soul
// Transpiled from c3149401.lua

card "Ultimate Dragon of Pride and Soul" {
    id: 3149401
    type: Fusion Monster
    attribute: DARK
    race: Dragon
    level: 12
    atk: 4500
    def: 4500

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        method: fusion
    }

    continuous_effect "Effect 1" {
        scope: self
        grant: cannot_be_destroyed_by_effect
    }

    continuous_effect "Effect 2" {
        scope: self
        grant: cannot_be_targeted_by_card_effects
    }

    raw_effect "Effect 3" {
        effect_type: Single
        code: UpdateAttack
        property: SingleRange
        range: MonsterZone
        on_resolve {
            modifier: atk + 4500
        }
    }

    raw_effect "Effect 4" {
        effect_type: Single
        code: UpdateDefense
        property: SingleRange
        range: MonsterZone
        on_resolve {
            modifier: def + 4500
        }
    }

    effect "Effect 5" {
        speed: spell_speed_1
        once_per_turn: soft
        on_resolve {
            destroy (1+, card, either_player controls)
        }
    }

}
