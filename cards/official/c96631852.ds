// 鉄壁の布陣
// Impenetrable Formation
// Transpiled from c96631852.lua

card "Impenetrable Formation" {
    id: 96631852
    type: Continuous Spell

    effect "Effect 1" {
        speed: spell_speed_1
        damage_step: false
        on_activate {
            select (1+, monster, you controls, where { is_face_up }) as target
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    raw_effect "Effect 2" {
        effect_type: Field + Continuous
        code: ChainNegated
        range: SpellTrapZone
        on_resolve {
            destroy (1+, monster, you controls, where { is_face_up })
        }
    }

}
