card "Vennu, Bright Bird of Divinity" {
    id: 10441498
    type: Ritual Monster
    attribute: LIGHT
    race: Fairy
    level: 8
    atk: 2800
    def: 2000

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 1+ monster
        method: ritual
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        damage_step: false
        trigger: when_tributed
        on_resolve {
            add_to_hand (1+, monster, either_player controls) from gy
        }
    }

}
