// 重装機甲 パンツァードラゴン
// Panzer Dragon
// Transpiled from c72959823.lua

card "Panzer Dragon" {
    id: 72959823
    type: Fusion Monster
    attribute: LIGHT
    race: Machine
    level: 5
    atk: 1000
    def: 2600

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        method: fusion
    }

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        timing: if
        damage_step: false
        trigger: on_custom_event "chain_end"
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            destroy (1+, card, either_player controls)
        }
    }

}
