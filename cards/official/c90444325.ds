card "Megalith Hagith" {
    id: 90444325
    type: Ritual Monster
    attribute: EARTH
    race: Rock
    level: 4
    atk: 1300
    def: 2600

    summon {
        cannot_normal_summon
    }

    effect "Effect 1" {
        speed: 1
        timing: if
        trigger: summoned by special
        resolve {
            add_to_hand (1, card, where archetype == "Megalith" and not is_monster) from deck
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        mandatory
    }

    effect "Effect 3" {
        speed: 1
        mandatory
        resolve {
            add_to_hand target
        }
    }
}
