card "Overburst Dragon" {
    id: 15627227
    type: Link Monster
    attribute: DARK
    race: Dragon
    link: 2
    link_arrows: [left, right]
    atk: 1800

    summon {
        cannot_normal_summon
        link materials: (2, monster, where archetype == "Rokket")
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        mandatory
        resolve {
            special_summon (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        timing: if
        trigger: custom "chain_end"
        resolve {
            add_to_hand (all, card, either controls)
        }
    }
}
