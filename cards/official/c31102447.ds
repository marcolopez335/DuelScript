// アマゾネスの斥候
// Amazoness Spy
// Transpiled from c31102447.lua

card "Amazoness Spy" {
    id: 31102447
    type: Effect Monster
    attribute: EARTH
    race: Warrior
    level: 3
    atk: 800
    def: 1200

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [hand]
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        optional: true
        timing: when
        damage_step: false
        trigger: when_battle_damage
        on_resolve {
            add_to_hand (1, card, you controls) from gy
            return (1+, monster, either_player controls) to deck shuffle
        }
    }

}
