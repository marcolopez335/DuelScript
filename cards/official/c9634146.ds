card "Signal Warrior" {
    id: 9634146
    type: Synchro Monster
    attribute: LIGHT
    race: Warrior
    level: 7
    atk: 2400
    def: 1000

    summon {
        cannot_normal_summon
        synchro materials {
            tuner: (1, tuner monster)
            non_tuner: (1+, non-tuner monster)
        }
    }

    passive "Effect 2" {
        scope: self
        grant: cannot_be_destroyed by battle
    }

    passive "Effect 3" {
        scope: self
        grant: cannot_be_destroyed by effect
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: soft
        mandatory
        trigger: standby_phase
    }

    effect "Effect 4" {
        speed: 1
        once_per_turn: soft
        mandatory
        resolve {
            damage opponent 1000
            draw 1
            destroy (all, card, either controls)
        }
    }
}
