// 光道の龍
// Lightsworn Dragonling
// Transpiled from c59481082.lua

card "Lightsworn Dragonling" {
    id: 59481082
    type: Effect Monster
    attribute: LIGHT
    race: Dragon
    level: 4
    atk: 1500
    def: 1300

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [hand]
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        on_resolve {
            send (1+, monster, you controls, gy) to gy
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        trigger: on_custom_event "chain_end"
        on_resolve {
            add_to_hand (1+, monster, you controls, where { race == Dragon }) from gy
            reveal (1+, card, opponent controls)
        }
    }

}
