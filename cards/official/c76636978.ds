// スターダスト・ドラゴン－ヴィクテム・サンクチュアリ
// Stardust Dragon - Victim Sanctuary
// Transpiled from c76636978.lua

card "Stardust Dragon - Victim Sanctuary" {
    id: 76636978
    type: Synchro Monster
    attribute: WIND
    race: Dragon
    level: 8
    atk: 2500
    def: 2000

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            negate effect
            destroy (1+, monster, either_player controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        activate_from: [gy]
        cost {
            banish self
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    raw_effect "Effect 3" {
        effect_type: Field + Continuous
        code: Released
        on_resolve {
            set_flag "tracked" on self
            set_flag "tracked" on self
        }
    }

}
