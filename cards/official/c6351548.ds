// 曙光の騎士
// Dawn Knight
// Transpiled from c6351548.lua

card "Dawn Knight" {
    id: 6351548
    type: Effect Monster
    attribute: LIGHT
    race: Warrior
    level: 4
    atk: 1400
    def: 1200

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: on_custom_event "chain_end"
        on_resolve {
            send (1+, card, you controls, deck) to gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        trigger: on_custom_event "chain_end"
        on_activate {
            select (1+, card, you controls, where { attribute == LIGHT }) as target
        }
        on_resolve {
            return (1+, card, you controls, where { attribute == LIGHT }) to deck shuffle
        }
    }

}
