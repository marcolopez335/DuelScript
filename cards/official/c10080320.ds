// Jurassic World
// Field Spell
// All Dinosaur monsters gain 300 ATK and DEF.

card "Jurassic World" {
    type: Field Spell
    password: 10080320

    continuous_effect "Dinosaur Boost" {
        while: on_field
        apply_to: (1+, monster, either_player controls, monster_zone, of_race: Dinosaur)
        modifier: atk +300
        modifier: def +300
    }
}
