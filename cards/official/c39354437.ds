card "Icejade Aegirine" {
    id: 39354437
    type: Effect Monster
    attribute: WATER
    race: Aqua
    level: 3
    atk: 1000
    def: 2000

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned
        resolve {
            add_to_hand (1, card, where archetype == "Icejade" and not is_monster) from deck
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            add_to_hand (1, card, where archetype == "Icejade" and not is_monster) from deck
        }
    }

    effect "Effect 4" {
        speed: 2
        once_per_turn: soft
        timing: when
        trigger: attacked
        resolve {
            special_summon (all, card, either controls)
        }
    }
}
