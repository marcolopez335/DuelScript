// A-to-Z-Dragon Buster Cannon
// Transpiled from c65172015.lua

card "A-to-Z-Dragon Buster Cannon" {
    password: 65172015
    type: Fusion Monster
    attribute: LIGHT
    race: Machine
    level: 10
    atk: 4000
    def: 4000

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        on_resolve {
            reveal self
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        optional: true
        damage_step: true
        trigger: opponent_activates [search | special_summon | send_to_gy | draw]
        on_resolve {
            negate activation
            destroy (1+, card, either_player controls)
        }
    }

    effect "Effect 3" {
        speed: spell_speed_2
        optional: true
        cost {
            banish self
        }
        on_resolve {
            special_summon (1, monster) from gy
            special_summon (1, monster) from gy
            send (1, card) to gy
        }
    }

}
