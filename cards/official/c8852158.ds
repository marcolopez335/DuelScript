// 影霊翼騎 ウェンディクルフ
// Reeshaddoll Wendikurhu
// Transpiled from c8852158.lua

card "Reeshaddoll Wendikurhu" {
    id: 8852158
    type: Fusion Monster
    attribute: WIND
    race: Psychic
    level: 6
    atk: 200
    def: 2800

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        method: fusion
    }

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        on_resolve {
            change_battle_position (1, monster)
            change_battle_position (1, monster)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        optional: true
        timing: if
        damage_step: false
        trigger: on_custom_event "chain_end"
        on_activate {
            select (1+, monster, either_player controls) as target
        }
        on_resolve {
            return (1+, monster, either_player controls) to hand
        }
    }

}
