// 死霊王 ドーハスーラ
// Doomking Balerdroch
// Transpiled from c39185163.lua

card "Doomking Balerdroch" {
    id: 39185163
    type: Effect Monster
    attribute: DARK
    race: Zombie
    level: 8
    atk: 2800
    def: 2000

    summon_condition {
        tributes_required: 2
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: when
        trigger: during_standby_phase
        activate_from: [gy]
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            negate effect
            set_flag "tracked" on self
            banish (1+, monster, either_player controls, where { is_monster })
            set_flag "tracked" on self
        }
    }

}
