// Eliminating the League
// Transpiled from c73872164.lua

card "Eliminating the League" {
    id: 73872164
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        damage_step: false
        on_activate {
            select (1+, spell, opponent controls, where { is_spell }) as target
        }
        on_resolve {
            destroy (1+, spell, opponent controls, hand)
            reveal (1+, card, opponent controls)
            send (1+, spell, opponent controls, hand) to gy
            shuffle_hand
        }
    }

}
