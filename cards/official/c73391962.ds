card "Azamina Mu Rcielago" {
    id: 73391962
    type: Fusion Monster
    attribute: DARK
    race: Warrior
    level: 6
    atk: 2000
    def: 2400

    summon {
        cannot_normal_summon
        special_summon_procedure {
            from: extra_deck
            to: your_field
        }
    }

    effect "Effect 3" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            add_to_hand (all, card, either controls)
        }
    }

    effect "Effect 4" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: destroyed
        resolve {
            add_to_hand (all, card, either controls)
        }
    }


    passive "Passive 5" {
        scope: field
        target: (all, monster, opponent controls)
        modifier: atk - count((all, card, you control, from monster_zone, where archetype == "Azamina" and is_face_up)) * 500
    }


    passive "Passive 6" {
        scope: field
        target: (all, monster, opponent controls)
        modifier: def - count((all, card, you control, from monster_zone, where archetype == "Azamina" and is_face_up)) * 500
    }
}
