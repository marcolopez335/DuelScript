card "Chaos King Archfiend" {
    id: 36407615
    type: Synchro Monster
    attribute: DARK
    race: Fiend
    level: 7
    atk: 2600
    def: 2600

    summon {
        cannot_normal_summon
        synchro materials {
            tuner: (1, tuner monster, where race == Fiend)
            non_tuner: (1+, non-tuner monster)
        }
    }

    effect "Effect 1" {
        speed: 1
        timing: when
        trigger: summoned
        resolve {
            set_atk (all, card, opponent controls, from monster_zone) target.def until end_of_turn
            set_def (all, card, opponent controls, from monster_zone) target.atk until end_of_turn
        }
    }
}
