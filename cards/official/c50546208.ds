card "Lunalight Yellow Marten" {
    id: 50546208
    type: Effect Monster
    attribute: DARK
    race: Beast-Warrior
    level: 4
    atk: 800
    def: 2000

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        activate_from: [hand, gy]
        on_resolve {
            add_to_hand (1+, spell, you controls) from deck
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        trigger: on_custom_event "chain_end"
        on_resolve {
            add_to_hand (1+, spell, you controls) from deck
            reveal (1+, card, opponent controls)
        }
    }

}
