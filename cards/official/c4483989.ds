// 反撃準備
// Prepare to Strike Back
// Transpiled from c4483989.lua

card "Prepare to Strike Back" {
    id: 4483989
    type: Continuous Trap

    effect "Effect 1" {
        speed: spell_speed_2
        on_resolve {
            change_battle_position (1, monster)
            deal_damage to opponent: 1000
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        trigger: when attack_declared
        activate_from: [spell_trap_zone]
        on_resolve {
            change_battle_position (1, monster)
            deal_damage to opponent: 1000
        }
    }

}
