// 幻影騎士団ダーク・ガントレット
// The Phantom Knights of Dark Gauntlets
// Transpiled from c24212820.lua

card "The Phantom Knights of Dark Gauntlets" {
    id: 24212820
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        on_resolve {
            send (1+, spell, you controls, deck) to gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        optional: true
        timing: when
        trigger: when attack_declared
        activate_from: [gy]
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    raw_effect "Effect 3" {
        effect_type: Single
        code: UpdateDefense
        property: SingleRange
        range: MonsterZone
        on_resolve {
            modifier: def + count((1+, card, you controls, gy)) * 300
        }
    }

}
