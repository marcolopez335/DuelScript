card "Puppet Plant" {
    id: 51119924
    type: Effect Monster
    attribute: EARTH
    race: Plant
    level: 3
    atk: 1000
    def: 1000

    effect "Effect 1" {
        speed: spell_speed_1
        damage_step: false
        activate_from: [hand]
        on_activate {
            select (1+, card, either_player controls, where { is_face_up }) as target
        }
        cost {
            send self to gy
        }
        on_resolve {
            take_control of (1, monster, opponent controls)
        }
    }

}
