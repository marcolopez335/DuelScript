// シンクロ・コントロール
// Synchro Control
// Transpiled from c88289295.lua

card "Synchro Control" {
    id: 88289295
    type: Quick-Play Spell

    effect "Effect 1" {
        speed: spell_speed_1
        damage_step: false
        on_activate {
            select (1+, monster, you controls, where { is_face_up and is_synchro }) as target
        }
        cost {
            pay_lp 1000
        }
        on_resolve {
            take_control of (1, monster, opponent controls)
        }
    }

}
