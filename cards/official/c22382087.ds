card "Garum the Storm Vassal" {
    id: 22382087
    type: Effect Monster
    attribute: WIND
    race: Winged Beast
    level: 3
    atk: 800
    def: 1000

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [hand]
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
