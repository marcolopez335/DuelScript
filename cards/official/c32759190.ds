// 見えざる手ヤドエル
// Hecahands Yadel
// Transpiled from c32759190.lua

card "Hecahands Yadel" {
    id: 32759190
    type: Effect Monster
    attribute: LIGHT
    race: Unknown
    level: 6
    atk: 2100
    def: 1600

    summon_condition {
        tributes_required: 1
    }

    continuous_effect "Effect 1" {
        scope: field
        grant: cannot_be_destroyed_by_battle
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [hand]
        cost {
            reveal self
        }
        on_resolve {
            return (1+, spell, you controls) to deck shuffle
            add_to_hand (1+, spell, you controls) from deck
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        damage_step: false
        trigger: on_custom_event "chain_end"
        on_activate {
            select (1+, spell, you controls) as target
        }
        on_resolve {
            set (1, card)
        }
    }

}
