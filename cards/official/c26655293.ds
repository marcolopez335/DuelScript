// Magnarokket Dragon
// Transpiled from c26655293.lua

card "Magnarokket Dragon" {
    password: 26655293
    type: Effect Monster
    attribute: DARK
    race: Dragon
    level: 4
    atk: 1800
    def: 1200

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        trigger: opponent_activates [search | special_summon | send_to_gy | draw]
        on_resolve {
            destroy (1+, card, either_player controls)
            send (1, card) to gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        trigger: when_sent_to gy
        on_resolve {
            reveal self
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        trigger: during_end_phase
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
