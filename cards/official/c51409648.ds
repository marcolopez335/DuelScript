card "Rindbrumm the Striking Dragon" {
    id: 51409648
    type: Fusion Monster
    attribute: DARK
    race: Winged Beast
    level: 8
    atk: 2500
    def: 2000

    summon {
        cannot_normal_summon
        special_summon_procedure {
            from: extra_deck
            to: your_field
        }
    }

    effect "Effect 1" {
        speed: 2
        once_per_turn: hard
        timing: when
        trigger: opponent_activates [activate_spell, activate_trap, activate_spell]
        resolve {
            negate
            return (all, card, either controls) to hand
        }
    }

    effect "Effect 2" {
        speed: 2
        once_per_turn: soft
        resolve {
            special_summon (all, card, either controls)
            banish (all, card, either controls)
        }
    }
}
