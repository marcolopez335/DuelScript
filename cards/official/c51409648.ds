// 撃鉄竜リンドブルム
// Rindbrumm the Striking Dragon
// Transpiled from c51409648.lua

card "Rindbrumm the Striking Dragon" {
    id: 51409648
    type: Fusion Monster
    attribute: DARK
    race: Winged Beast
    level: 8
    atk: 2500
    def: 2000

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        method: fusion
    }

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            negate effect
            return (1+, monster, either_player controls) to hand
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        damage_step: false
        activate_from: [gy]
        on_activate {
            select (1+, monster, either_player controls) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
            banish (1+, monster, either_player controls)
        }
    }

}
