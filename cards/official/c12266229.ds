card "Illusion of Chaos" {
    id: 12266229
    type: Ritual Monster
    attribute: DARK
    race: Spellcaster
    level: 7
    atk: 2100
    def: 2500

    summon {
        cannot_normal_summon
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        mandatory
        resolve {
            add_to_hand (all, card, either controls)
            return (all, card, either controls) to deck
        }
    }

    effect "Effect 2" {
        speed: 2
        once_per_turn: soft
        timing: when
        trigger: opponent_activates [activate_spell, activate_trap, activate_spell]
        resolve {
            add_to_hand (all, card, either controls)
            special_summon (all, card, either controls)
            negate
        }
    }
}
