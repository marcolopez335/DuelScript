// イリュージョン・オブ・カオス
// Illusion of Chaos
// Transpiled from c12266229.lua

card "Illusion of Chaos" {
    id: 12266229
    type: Ritual Monster
    attribute: DARK
    race: Spellcaster
    level: 7
    atk: 2100
    def: 2500

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 1+ monster
        method: ritual
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [hand]
        on_resolve {
            add_to_hand (1+, monster, you controls) from deck
            reveal (1+, card, opponent controls)
            shuffle_hand
            shuffle_deck
            return (1+, monster, you controls) to deck shuffle
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            add_to_hand (1+, monster, you controls) from deck
            special_summon (1, monster) from gy
            negate effect
        }
    }

}
