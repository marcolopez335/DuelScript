// Illusion of Chaos
// Transpiled from c12266229.lua

card "Illusion of Chaos" {
    password: 12266229
    type: Ritual Monster
    attribute: DARK
    race: Spellcaster
    level: 7
    atk: 2100
    def: 2500

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        on_resolve {
            add_to_hand (1, card) from gy
            shuffle deck
            shuffle deck
            return (1, card) to deck shuffle
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        trigger: opponent_activates [search | special_summon | send_to_gy | draw]
        on_resolve {
            add_to_hand (1, card) from gy
            special_summon (1, monster) from gy
            negate effect
        }
    }

}
