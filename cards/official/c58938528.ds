card "Performapal Ladyange" {
    id: 58938528
    type: Effect Monster | Pendulum Monster
    attribute: LIGHT
    race: Fairy
    level: 3
    scale: 1
    atk: 1000
    def: 1500

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: when
        trigger: when attack_declared
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [hand]
        cost {
            send self to gy
        }
        on_resolve {
            draw 1
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [gy]
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
