card "Shooting Riser Dragon" {
    id: 68431965
    type: Synchro Monster | Tuner
    attribute: LIGHT
    race: Dragon
    level: 7
    atk: 2100
    def: 1700

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
