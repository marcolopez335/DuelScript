card "Trickstar Delfiendium" {
    id: 3792766
    type: Link Monster
    attribute: LIGHT
    race: Fairy
    link: 3
    link_arrows: [top, bottom_left, bottom_right]
    atk: 2200

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ effect monster
        method: link
    }

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        timing: when
        damage_step: false
        trigger: when attack_declared
        on_activate {
            select (1+, monster, opponent controls) as target
        }
        on_resolve {
            return (1+, monster, opponent controls) to hand
        }
    }

}
