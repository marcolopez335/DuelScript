// エターナル・サイバー
// Cyber Eternal
// Transpiled from c32768230.lua

card "Cyber Eternal" {
    id: 32768230
    type: Quick-Play Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, monster, either_player controls) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
            return (1+, monster, either_player controls) to deck shuffle
        }
    }

    replacement_effect "Effect 2" {
        instead_of: destroyed_by_any
        do: {
            banish self
        }
    }

}
