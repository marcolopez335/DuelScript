// 荒野の大竜巻
// Wild Tornado
// Transpiled from c47766694.lua

card "Wild Tornado" {
    id: 47766694
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        damage_step: false
        on_activate {
            select (1+, card, you controls) as target
        }
        on_resolve {
            destroy (1+, card, you controls, hand)
            set (1, card)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        damage_step: false
        trigger: on_custom_event "chain_end"
        on_activate {
            select (1+, card, you controls) as target
        }
        on_resolve {
            destroy (1+, card, you controls, hand)
        }
    }

}
