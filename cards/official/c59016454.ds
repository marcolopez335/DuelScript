// 黒魔術のバリア －ミラーフォース－
// Dark Magic Mirror Force
// Transpiled from c59016454.lua

card "Dark Magic Mirror Force" {
    id: 59016454
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        trigger: when attack_declared
        on_resolve {
            destroy (1+, monster, opponent controls)
            deal_damage to opponent: 1000
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            destroy (1+, monster, opponent controls)
            deal_damage to opponent: 1000
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
