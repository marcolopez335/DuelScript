card "Hundred Eyes Dragon" {
    id: 95453143
    type: Synchro Monster
    attribute: DARK
    race: Dragon
    level: 8
    atk: 3000
    def: 2500

    summon {
        cannot_normal_summon
        synchro materials {
            tuner: (1, tuner monster, where attribute == DARK)
            non_tuner: (1+, non-tuner monster, where race == Fiend)
        }
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: soft
        mandatory
        cost {
            banish self
        }
    }

    effect "Effect 2" {
        speed: 1
        mandatory
        trigger: custom "chain_end"
        condition: reason == destroy
        resolve {
            add_to_hand (all, card, either controls)
        }
    }
}
