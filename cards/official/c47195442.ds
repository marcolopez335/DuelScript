// 四獣層ウォンキー
// Wonky Quartet
// Transpiled from c47195442.lua

card "Wonky Quartet" {
    id: 47195442
    type: Xyz Monster
    attribute: EARTH
    race: Beast
    rank: 4
    atk: 0
    def: 2600

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        same_level: true
        method: xyz
    }

    continuous_effect "Effect 1" {
        scope: self
        grant: unaffected_by_card_effects
    }

    effect "Effect 2" {
        speed: spell_speed_1
        trigger: when_summoned by_special_summon
        on_resolve {
            attach (1, card) to self as_material
            take_control of (1, monster, opponent controls)
            deal_damage to opponent: 1000
            destroy (1+, card, either_player controls)
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        trigger: during_standby_phase
        on_resolve {
            attach (1, card) to self as_material
            take_control of (1, monster, opponent controls)
            deal_damage to opponent: 1000
            destroy (1+, card, either_player controls)
        }
    }

}
