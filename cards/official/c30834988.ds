card "All-Out Attacks" {
    id: 30834988
    type: Continuous Trap

    effect "Effect 1" {
        speed: spell_speed_2
        on_resolve {
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        trigger: when_summoned by_special_summon
        activate_from: [spell_trap_zone]
        on_resolve {
            change_battle_position (1, monster)
