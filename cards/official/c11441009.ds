card "P.U.N.K. JAM FEVER!" {
    id: 11441009
    type: Xyz Monster
    attribute: LIGHT
    race: Psychic
    rank: 8
    atk: 2800
    def: 600

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        same_level: true
        method: xyz
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        cost {
            pay_lp 600
            detach 1 overlay_unit from self
        }
        on_resolve {
            draw 1
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        cost {
            detach 1 overlay_unit from self
        }
        on_resolve {
            negate activation
            destroy (1+, card, you controls, gy)
        }
    }

}
