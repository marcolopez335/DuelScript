card "Psychic Blaster Mk-II" {
    id: 88139289
    type: Synchro Monster
    attribute: EARTH
    race: Psychic
    level: 9
    atk: 3200
    def: 2700

    summon {
        cannot_normal_summon
        synchro materials {
            tuner: (1, tuner monster, where race == Psychic)
            non_tuner: (1+, non-tuner monster, where race == Psychic)
        }
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        mandatory
        resolve {
            special_summon (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 2
        once_per_turn: hard
        cost {
            banish self
        }
        resolve {
            banish (all, card, either controls)
            gain_lp 1000
        }
    }
}
