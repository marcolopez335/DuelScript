card "Painful Decision" {
    id: 1033312
    type: Normal Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        on_resolve {
            send (1+, card, you controls, deck) to gy
            add_to_hand (1+, card, you controls, where { level <= 4 and is_monster }) from deck
            reveal (1+, card, opponent controls)
        }
    }

}
