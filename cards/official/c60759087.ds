card "Evil★Twin Present" {
    id: 60759087
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, spell, either_player controls) as target
        }
        on_resolve {
            take_control of (1, monster, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, spell, either_player controls) as target
        }
        on_resolve {
            return (1+, spell, either_player controls) to deck shuffle
        }
    }

}
