// ライゼオル・プラグイン
// Ryzeal Plugin
// Transpiled from c60394026.lua

card "Ryzeal Plugin" {
    id: 60394026
    type: Quick-Play Spell

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, monster, you controls) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
            attach (1, card) to self as_material
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
