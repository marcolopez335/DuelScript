card "Heosvarog the Mechanical Dawn" {
    id: 8963089
    type: Fusion Monster
    attribute: LIGHT
    race: Machine
    level: 7
    atk: 0
    def: 2800

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        method: fusion
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        cost {
            banish self
        }
        on_resolve {
            negate activation
        }
    }

    raw_effect "Effect 3" {
        effect_type: Field + Continuous
        code: PhaseStandby
        count_limit: (1, 0)
        on_resolve {
            add_to_hand (1+, monster, you controls) from gy
        }
    }

}
