card "S-Force Lapcewell" {
    id: 27383719
    type: Effect Monster
    attribute: LIGHT
    race: Fiend
    level: 6
    atk: 2400
    def: 2500

    summon_condition {
        tributes_required: 1
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        damage_step: false
        trigger: when_summoned by_special_summon
        on_activate {
            select (1+, monster, opponent controls) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        on_resolve {
            destroy (1+, monster, opponent controls)
        }
    }

