// 天雷ノ双風神 シーナ
// Shiina, Twin Tempests of Celestial Thunder
// Transpiled from c12197223.lua

card "Shiina, Twin Tempests of Celestial Thunder" {
    id: 12197223
    type: Effect Monster
    attribute: WIND
    race: Dragon
    level: 9
    atk: 2900
    def: 1500

    summon_condition {
        tributes_required: 2
    }

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        activate_from: [hand]
        on_resolve {
            special_summon (1, monster) from gy
            return (1+, spell, either_player controls) to hand
        }
    }

    continuous_effect "Effect 2" {
        scope: self
        grant: cannot_be_destroyed
    }

}
