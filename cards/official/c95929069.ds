card "Ice Hand" {
    id: 95929069
    type: Effect Monster
    attribute: WATER
    race: Aqua
    level: 4
    atk: 1400
    def: 1600

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        timing: when
        damage_step: false
        trigger: on_custom_event "chain_end"
