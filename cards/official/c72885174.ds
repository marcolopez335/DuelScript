// フォーチュン・スリップ
// Slip of Fortune
// Transpiled from c72885174.lua

card "Slip of Fortune" {
    id: 72885174
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        damage_step: false
        trigger: when attack_declared
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            negate attack
            banish (1+, card, either_player controls)
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
