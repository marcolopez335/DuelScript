// Slip of Fortune
// Transpiled from c72885174.lua

card "Slip of Fortune" {
    password: 72885174
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_1
        trigger: when attack_declared
        on_resolve {
            negate attack
            banish (1+, card)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        trigger: during_standby_phase
        on_resolve {
            reveal self
        }
    }

}
