card "Naturia Beast" {
    password: 33198837
    type: Synchro Monster
    attribute: EARTH
    race: Beast
    level: 5
    atk: 2200
    def: 1700

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_2
        optional: true
