card "Number 42: Galaxy Tomahawk" {
    password: 10389142
    type: Xyz Monster
    attribute: WIND
    race: Machine
    rank: 7
    atk: 0
    def: 3000

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        same_level: true
        method: xyz
    }

    raw_effect "Effect 1" {
        effect_type: Ignition
        category: Destroy + SpecialSummon + Token
        range: MonsterZone
        count_limit: (1, 0)
        cost {
            detach 2 overlay_unit from self
        }
        on_resolve {
            create_token { atk: 0 def: 0 }
