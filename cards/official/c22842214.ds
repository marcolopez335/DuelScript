// シー・ランサー
// Sea Lancer
// Transpiled from c22842214.lua

card "Sea Lancer" {
    id: 22842214
    type: Effect Monster
    attribute: WATER
    race: Beast-Warrior
    level: 5
    atk: 1300
    def: 1000

    summon_condition {
        tributes_required: 1
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_activate {
            select (1+, spell, either_player controls) as target
        }
        on_resolve {
            send (1+, spell, either_player controls) to gy
        }
    }

    replacement_effect "Effect 2" {
        instead_of: destroyed_by_any
        do: {
            banish self
        }
    }

    raw_effect "Effect 3" {
        effect_type: Single
        code: UpdateAttack
        property: SingleRange
        range: MonsterZone
        on_resolve {
            modifier: atk + 1000
        }
    }

    raw_effect "Effect 4" {
        effect_type: Single
        code: CannotAttack2
        on_resolve {
        }
    }

    continuous_effect "Effect 5" {
        scope: self
        grant: cannot_be_targeted_by_card_effects
    }

    continuous_effect "Effect 6" {
        scope: self
        grant: cannot_be_destroyed_by_effect
    }

    continuous_effect "Effect 7" {
        scope: self
        grant: cannot_be_destroyed_by_battle
    }

}
