card "Elemental HERO Cosmo Neos" {
    id: 90050480
    type: Fusion Monster
    attribute: LIGHT
    race: Warrior
    level: 11
    atk: 3500
    def: 3000

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        method: fusion
    }

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        trigger: during_end_phase
        on_resolve {
            return self to deck shuffle
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        optional: true
        timing: when
        trigger: during_end_phase
        on_resolve {
            return self to deck shuffle
        }
    }

}
