card "Burial from a Different Dimension" {
    id: 48976825
    type: Quick-Play Spell

    effect "Effect 1" {
        speed: spell_speed_2
        damage_step: false
        on_activate {
            select (1+, monster, either_player controls, where { is_face_up and is_monster }) as target
        }
        on_resolve {
            send (1+, monster, either_player controls, where { is_face_up and is_monster }) to gy
        }
    }

}
