card "Materiactor Critical" {
    id: 64767757
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            return (1+, monster, you controls) to hand
            reveal (1+, card, opponent controls)
            shuffle_hand
            negate activation
            return (1+, monster, you controls) to deck shuffle
            set (1, card)
        }
    }

}
