card "Green Ninja" {
    id: 15198996
    type: Effect Monster
    attribute: WIND
    race: Warrior
    level: 2
    atk: 600
    def: 600

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            special_summon (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: custom "chain_end"
        resolve {
            change_position target
        }
    }
}
