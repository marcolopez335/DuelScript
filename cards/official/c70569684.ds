card "High Rate Draw" {
    id: 70569684
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        on_resolve {
            destroy (1+, monster, you controls)
            draw 1
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        damage_step: false
        activate_from: [gy]
        on_activate {
            select (1+, monster, you controls) as target
        }
        on_resolve {
            destroy (1+, monster, you controls)
            set (1, card)
        }
    }

}
