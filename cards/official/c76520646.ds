card "Infinity Dark" {
    id: 76520646
    type: Effect Monster | Union
    attribute: DARK
    race: Fiend
    level: 4
    atk: 1500
    def: 1200

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        timing: when
        damage_step: false
