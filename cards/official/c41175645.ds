card "Silent Magician" {
    id: 41175645
    type: Effect Monster | Effect Monster
    attribute: LIGHT
    race: Spellcaster
    level: 4
    atk: 1000
    def: 1000

    summon {
        cannot_normal_summon
    }

    effect "Effect 4" {
        speed: 2
        once_per_turn: soft
        timing: when
        trigger: opponent_activates [activate_spell, activate_trap, activate_spell]
        resolve {
            negate
            send (all, card, either controls) to gy
        }
    }

    effect "Effect 5" {
        speed: 1
        timing: if
        trigger: destroyed
        resolve {
            special_summon (1, monster, where archetype == "Silent Magician") from hand in attack_position
        }
    }
}
