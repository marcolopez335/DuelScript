// 究極宝玉陣
// Ultimate Crystal Magic
// Transpiled from c36328300.lua

card "Ultimate Crystal Magic" {
    id: 36328300
    type: Normal Trap

    raw_effect "Effect 1" {
        effect_type: Activate
        category: SpecialSummon + Control
        code: BattleDamage
        cost {
            send self to gy
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    raw_effect "Effect 2" {
        effect_type: Field + Trigger
        code: ChainNegated
        property: Oath + Delay
        range: Graveyard
        cost {
            banish self
        }
        on_resolve {
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            emit_event "custom"
        }
    }

}
