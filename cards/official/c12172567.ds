// マインド・キャスリン
// Mind Castlin
// Transpiled from c12172567.lua

card "Mind Castlin" {
    id: 12172567
    type: Synchro Monster
    attribute: DARK
    race: Psychic
    level: 6
    atk: 1500
    def: 2600

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_activate {
            select (1+, monster, either_player controls) as target
        }
        on_resolve {
            take_control of (1, monster, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        damage_step: false
        trigger: on_custom_event "chain_end"
        on_activate {
            select (1+, monster, either_player controls) as target
        }
        on_resolve {
            take_control of (1, monster, opponent controls)
        }
    }

}
