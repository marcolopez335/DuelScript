card "Mind Castlin" {
    id: 12172567
    type: Synchro Monster
    attribute: DARK
    race: Psychic
    level: 6
    atk: 1500
    def: 2600

    summon {
        cannot_normal_summon
        synchro materials {
            tuner: (1, tuner monster)
            non_tuner: (1+, non-tuner monster)
        }
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: soft
        mandatory
        resolve {
            take_control (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: custom "chain_end"
        resolve {
            take_control (all, card, either controls)
        }
    }
}
