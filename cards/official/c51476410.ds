// クロック・リザード
// Clock Lizard
// Transpiled from c51476410.lua

card "Clock Lizard" {
    id: 51476410
    type: Link Monster
    attribute: DARK
    race: Cyberse
    link: 2
    link_arrows: [bottom_left, bottom]
    atk: 1200

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ effect monster
        method: link
    }

    raw_effect "Effect 1" {
        effect_type: Ignition
        category: Banish + SpecialSummon + Control + Announce
        code: FreeChain
        range: MonsterZone
        cost {
            tribute self
        }
        on_resolve {
            fusion_summon (1, fusion monster) using (1+, monster, you controls)
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single + Trigger
        category: SynchroSummon
        code: TurnEnd
        property: Delay
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
