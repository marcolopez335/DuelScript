// Assault Blackwing - Kunai the Drizzle
// Transpiled from c70456282.lua

card "Assault Blackwing - Kunai the Drizzle" {
    id: 70456282
    type: Effect Monster
    attribute: DARK
    race: Winged Beast
    level: 5
    atk: 2100
    def: 1600

    summon_condition {
        tributes_required: 1
    }

    raw_effect "Effect 1" {
        effect_type: Field
        code: CannotSummon
        property: Uncopyable
        range: Hand
        on_resolve {
            tribute (1, monster, you controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_activate {
            select (1+, card, either_player controls, where { is_face_up and is_synchro and level >= 1 }) as target
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
