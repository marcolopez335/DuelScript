// Arcana Force EX - The Chaos Ruler
// Transpiled from c12686296.lua

card "Arcana Force EX - The Chaos Ruler" {
    id: 12686296
    type: Fusion Monster
    attribute: LIGHT
    race: Fairy
    level: 10
    atk: 3300
    def: 3300

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        method: fusion
    }

    effect "Effect 1" {
        speed: spell_speed_1
        trigger: when_summoned by_special_summon
        on_resolve {
            flip_coin { heads { draw 1 } tails { draw 1 } }
            special_summon (1, monster) from gy
            return (1+, monster, either_player controls) to hand
            reveal (1+, card, opponent controls)
        }
    }

    continuous_effect "Effect 2" {
        scope: field
        grant: cannot_activate_effects
    }

}
