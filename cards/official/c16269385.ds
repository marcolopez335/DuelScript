card "Prank-Kids Place" {
    id: 16269385
    type: Field Spell

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        mandatory
        resolve {
            add_to_hand (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: summoned by special
        resolve {
            modify_atk (all, card, you control, from monster_zone, where is_face_up) + 500 until end_of_turn
        }
    }

    effect "Effect 3" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: summoned by special
        resolve {
            modify_atk (all, card, opponent controls, from monster_zone, where is_face_up) - 500 until end_of_turn
        }
    }
}
