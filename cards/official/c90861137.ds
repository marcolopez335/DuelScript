// 『焔聖剣－ジョワユーズ』
// 'Infernoble Arms - Joyeuse'
// Transpiled from c90861137.lua

card "'Infernoble Arms - Joyeuse'" {
    id: 90861137
    type: Equip Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        activate_from: [spell_trap_zone]
        on_activate {
            select (1+, card, you controls, where { race == Warrior and attribute == FIRE }) as target
        }
        on_resolve {
            add_to_hand (1+, card, you controls, where { race == Warrior and attribute == FIRE }) from hand
            reveal (1+, card, opponent controls)
            destroy (1+, card, you controls, hand)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: on_custom_event "chain_end"
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        on_resolve {
            equip self to (1, monster, you controls)
        }
    }

}
