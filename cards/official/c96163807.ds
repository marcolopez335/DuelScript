card "Tristan, Knight of the Underworld" {
    id: 96163807
    type: Effect Monster
    attribute: DARK
    race: Zombie
    level: 4
    atk: 1800
    def: 0

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        timing: when
        damage_step: false
        trigger: when_summoned
        on_activate {
            select (1+, monster, you controls, where { race == Zombie }) as target
        }
        on_resolve {
            return (1+, monster, you controls, where { race == Zombie }) to hand
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single
        code: UpdateAttack
        property: SingleRange
        range: MonsterZone
        on_resolve {
            modifier: atk + 300
        }
    }

}
