// Performapal Teeter Totter Hopper
// Transpiled from c29169993.lua

card "Performapal Teeter Totter Hopper" {
    id: 29169993
    type: Effect Monster
    attribute: EARTH
    race: Insect
    level: 4
    atk: 100
    def: 1200

    raw_effect "Effect 1" {
        effect_type: Single
        code: CannotHandReturn
        property: SingleRange
        range: MonsterZone
        on_resolve {
            register_effect on self { grant: cannot_be_destroyed duration: until_end_of_turn }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: when
        damage_step: false
        trigger: during_end_phase
        on_resolve {
            send (1+, monster, either_player controls) to gy
            add_to_hand (1+, monster, either_player controls) from gy
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: on_custom_event "chain_end"
        activate_from: [gy]
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
