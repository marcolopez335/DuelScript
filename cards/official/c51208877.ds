// 運命の抱く爆弾
// Blast Held by Destiny
// Transpiled from c51208877.lua

card "Blast Held by Destiny" {
    id: 51208877
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        trigger: when attack_declared
        on_resolve {
            destroy (1+, monster, opponent controls)
            deal_damage to opponent: 1000
            deal_damage to opponent: 1000
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        timing: if
        damage_step: false
        trigger: on_custom_event "chain_end"
        on_resolve {
            return (1+, monster, opponent controls) to hand
            reveal (1+, card, opponent controls)
        }
    }

}
