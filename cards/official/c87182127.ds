card "Ancient Gear Howitzer" {
    id: 87182127
    type: Fusion Monster
    attribute: EARTH
    race: Machine
    level: 8
    atk: 1000
    def: 1800

    summon {
        cannot_normal_summon
        fusion materials: (2, monster, where archetype == "Ancient Gear")
    }

    passive "Effect 1" {
        scope: self
        grant: unaffected_by effects
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        mandatory
        resolve {
            damage opponent 1000
        }
    }

    effect "Effect 3" {
        speed: 1
        timing: when
        trigger: battle_damage
        condition: in_gy
        resolve {
            special_summon (1, monster, where archetype == "Ancient Gear") from deck in attack_position
        }
    }
}
