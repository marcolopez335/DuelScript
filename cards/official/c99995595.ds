// バッテリーリサイクル
// Recycling Batteries
// Transpiled from c99995595.lua

card "Recycling Batteries" {
    id: 99995595
    type: Normal Spell

    effect "Effect 1" {
        speed: spell_speed_1
        damage_step: false
        on_activate {
            select (1+, card, either_player controls, where { race == Thunder }) as target
        }
        on_resolve {
            add_to_hand (1+, card, either_player controls, where { race == Thunder }) from gy
        }
    }

}
