card "Wind Pegasus @Ignister" {
    id: 98506199
    type: Synchro Monster
    attribute: WIND
    race: Cyberse
    level: 7
    atk: 2300
    def: 1500

    summon {
        cannot_normal_summon
        synchro materials {
            tuner: (1, tuner monster)
            non_tuner: (1+, non-tuner monster)
        }
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        mandatory
        resolve {
            destroy (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: destroyed
        cost {
            banish self
        }
        resolve {
            return (all, card, either controls) to deck
        }
    }
}
