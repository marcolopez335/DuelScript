// 救援光
// Light of Redemption
// Transpiled from c2362787.lua

card "Light of Redemption" {
    id: 2362787
    type: Normal Spell

    effect "Effect 1" {
        speed: spell_speed_1
        damage_step: false
        on_activate {
            select (1+, card, either_player controls, where { is_face_up and attribute == LIGHT }) as target
        }
        cost {
            pay_lp 800
        }
        on_resolve {
            add_to_hand (1+, card, either_player controls, where { is_face_up and attribute == LIGHT }) from gy
            reveal (1+, card, opponent controls)
        }
    }

}
