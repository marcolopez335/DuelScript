card "Vicious Claw" {
    id: 75524092
    type: Equip Spell

    effect "Effect 4" {
        speed: 1
        mandatory
        resolve {
            add_to_hand self
            destroy (1, card, either controls, from monster_zone)
            damage opponent 600
        }
    }

    replacement "Effect 2" {
        instead_of: destroyed
        do {
            banish self
        }
    }


    passive "Passive 5" {
        target: equipped_card
        modifier: atk + 300
    }
}
