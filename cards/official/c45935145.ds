card "Wollow, Founder of the Drudge Dragons" {
    id: 45935145
    type: Xyz Monster
    attribute: DARK
    race: Zombie
    rank: 6
    atk: 2400
    def: 1300

    summon {
        cannot_normal_summon
        xyz materials: (2, monster, where level == 6)
    }

    effect "Effect 3" {
        speed: 2
        once_per_turn: hard
        resolve {
            return (all, card, either controls) to deck
            special_summon (all, card, either controls)
        }
    }


    passive "Passive 4" {
        scope: field
        target: (all, monster, you control)
        modifier: atk + count((all, card, opponent controls, from gy)) * 100
    }


    passive "Passive 5" {
        scope: field
        target: (all, monster, you control)
        modifier: def + count((all, card, opponent controls, from gy)) * 100
    }
}
