// 熾天龍 ジャッジメント
// Judgment, the Dragon of Heaven
// Transpiled from c41659072.lua

card "Judgment, the Dragon of Heaven" {
    id: 41659072
    type: Synchro Monster
    attribute: LIGHT
    race: Dragon
    level: 8
    atk: 3000
    def: 2600

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        cost {
            pay_lp your_lp / 2
        }
        on_resolve {
            destroy (1+, card, you controls, gy)
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        trigger: during_end_phase
        on_resolve {
            banish (1+, card, you controls, gy)
        }
    }

}
