card "Judgment, the Dragon of Heaven" {
    id: 41659072
    type: Synchro Monster
    attribute: LIGHT
    race: Dragon
    level: 8
    atk: 3000
    def: 2600

    summon {
        cannot_normal_summon
        synchro materials {
            tuner: (1, tuner monster)
            non_tuner: (1+, non-tuner monster)
        }
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: soft
        mandatory
        cost {
            pay_lp your_lp / 2
        }
        resolve {
            destroy (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        mandatory
        trigger: end_phase
        resolve {
            banish (all, card, either controls)
        }
    }
}
