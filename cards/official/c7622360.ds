card "Matador Archfiend" {
    id: 7622360
    type: Ritual Monster
    attribute: DARK
    race: Warrior
    level: 6
    atk: 0
    def: 0

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 1+ monster
        method: ritual
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        on_resolve {
            add_to_hand (1+, card, you controls) from deck
            reveal (1+, card, opponent controls)
        }
    }

    continuous_effect "Effect 2" {
        scope: self
        grant: cannot_be_destroyed_by_battle
    }

    continuous_effect "Effect 3" {
        scope: self
        grant: cannot_be_destroyed_by_battle
    }

    effect "Effect 4" {
        speed: spell_speed_1
        trigger: on_custom_event "chain_end"
        on_resolve {
            destroy (1+, card, you controls, deck)
            deal_damage to opponent: 1000
        }
    }

    continuous_effect "Effect 5" {
        scope: self
        grant: cannot_attack
    }

}
