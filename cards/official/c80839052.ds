card "Koa'ki Meiru Supplier" {
    id: 80839052
    type: Effect Monster
    attribute: EARTH
    race: Rock
    level: 4
    atk: 1400
    def: 1600

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
