card "Nine Pillars of Yang Zing" {
    id: 57831349
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            negate activation
            return (1+, card, you controls) to deck shuffle
            destroy (1+, card, you controls)
        }
    }

}
