// ボーンクラッシャー
// Bone Crusher
// Transpiled from c37675138.lua

card "Bone Crusher" {
    id: 37675138
    type: Effect Monster
    attribute: EARTH
    race: Zombie
    level: 4
    atk: 1600
    def: 200

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        timing: when
        damage_step: false
        trigger: when_summoned by_special_summon
        on_activate {
            select (1+, spell, either_player controls, where { is_spell }) as target
        }
        on_resolve {
            destroy (1+, spell, either_player controls, where { is_spell })
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single + Continuous
        code: SpecialSummonSuccess
        property: BothSide
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
