// 救いの架け橋
// Rainbow Bridge of Salvation
// Transpiled from c5611760.lua

card "Rainbow Bridge of Salvation" {
    id: 5611760
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        on_resolve {
            set_flag "tracked" on self
            return (1+, monster, either_player controls) to deck shuffle
            shuffle_deck
            shuffle_deck
            draw 5
            draw 5
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        optional: true
        activate_from: [gy]
        cost {
            banish self
        }
        on_resolve {
            set_flag "tracked" on self
            return (1+, monster, either_player controls) to hand
            reveal (1+, card, opponent controls)
        }
    }

}
