// パンデミック・ドラゴン
// Pandemic Dragon
// Transpiled from c68299524.lua

card "Pandemic Dragon" {
    id: 68299524
    type: Effect Monster
    attribute: DARK
    race: Dragon
    level: 7
    atk: 2500
    def: 1000

    summon_condition {
        tributes_required: 2
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        cost {
            pay_lp your_lp / 2
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_activate {
            select (1+, monster, either_player controls, where { is_face_up }) as target
        }
        on_resolve {
            destroy (1+, monster, either_player controls, where { is_face_up })
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        trigger: when_destroyed
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
