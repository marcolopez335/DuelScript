// 壊星壊獣ジズキエル
// Jizukiru, the Star Destroying Kaiju
// Transpiled from c63941210.lua

card "Jizukiru, the Star Destroying Kaiju" {
    id: 63941210
    type: Effect Monster
    attribute: LIGHT
    race: Machine
    level: 10
    atk: 3300
    def: 2600

    summon_condition {
        tributes_required: 2
    }

    effect "Effect 1" {
        speed: spell_speed_2
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            negate effect
            destroy (1+, card, either_player controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        activate_from: [hand]
        cost {
            tribute (1, monster, opponent controls)
        }
        on_resolve {
            special_summon self from hand
        }
    }

}
