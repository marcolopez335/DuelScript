card "Royal Rhino with Deceitful Dice" {
    id: 74289646
    type: Effect Monster
    attribute: EARTH
    race: Beast
    level: 1
    atk: 600
    def: 600

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            flip_coin { heads { draw 1 } tails { draw 1 } }
            deal_damage to opponent: 1000
            destroy (1+, card, opponent controls)
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single
        code: UpdateAttack
        on_resolve {
            modifier: atk + 0
        }
    }

}
