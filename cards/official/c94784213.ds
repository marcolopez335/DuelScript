card "Majespecter Fox - Kyubi" {
    id: 94784213
    type: Effect Monster | Pendulum Monster
    attribute: WIND
    race: Spellcaster
    level: 4
    scale: 2
    atk: 1500
    def: 1000

    effect "Effect 1" {
