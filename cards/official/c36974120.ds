card "Vouiburial, the Dragon Undertaker" {
    id: 36974120
    type: Effect Monster
    attribute: DARK
    race: Unknown
    level: 10
    atk: 3000
    def: 0

    summon_condition {
        tributes_required: 2
    }

    continuous_effect "Effect 1" {
        scope: field
        grant: cannot_be_destroyed_by_battle
    }

    effect "Effect 2" {
        speed: spell_speed_1
        optional: true
        timing: if
        trigger: on_custom_event "chain_end"
        activate_from: [hand, monster_zone]
        on_resolve {
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            destroy (1+, monster, opponent controls)
        }
    }

}
