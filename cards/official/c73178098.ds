// 虚栄巨影
// Ego Boost
// Transpiled from c73178098.lua

card "Ego Boost" {
    id: 73178098
    type: Quick-Play Spell

    effect "Effect 1" {
        speed: spell_speed_2
        damage_step: false
        trigger: when attack_declared
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
