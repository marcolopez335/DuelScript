// 災誕の呪眼
// Evil Eyes Unleashed
// Transpiled from c8775395.lua

card "Evil Eyes Unleashed" {
    id: 8775395
    type: Normal Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        cost {
            send self to gy
        }
        on_resolve {
            add_to_hand (1+, card, you controls) from deck
            reveal (1+, card, opponent controls)
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        activate_from: [gy]
        cost {
            banish self
        }
        on_resolve {
            equip (1, card) to (1, monster)
        }
    }

}
