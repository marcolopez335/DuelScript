// ヴェルズ・サンダーバード
// Evilswarm Thunderbird
// Transpiled from c78663366.lua

card "Evilswarm Thunderbird" {
    id: 78663366
    type: Effect Monster
    attribute: DARK
    race: Thunder
    level: 4
    atk: 1650
    def: 1050

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            banish (1+, card, either_player controls)
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
