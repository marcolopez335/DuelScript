// 竜の精神
// Dragon's Mind
// Transpiled from c85442146.lua

card "Dragon's Mind" {
    id: 85442146
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            negate activation
            destroy (1+, monster, you controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        activate_from: [gy]
        cost {
            pay_lp 2500
        }
        on_resolve {
            set (1, card)
        }
    }

}
