// ヴァルモニカ・インヴィターレ
// Vaalmonica Invitare
// Transpiled from c38491852.lua

card "Vaalmonica Invitare" {
    id: 38491852
    type: Quick-Play Spell

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            special_summon (1, monster) from gy
            send (1+, card, you controls) to extra_deck
            add_to_hand (1+, monster, you controls) from deck
            reveal (1+, card, opponent controls)
        }
    }

}
