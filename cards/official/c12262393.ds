card "Delta The Magnet Warrior" {
    id: 12262393
    type: Effect Monster
    attribute: EARTH
    race: Rock
    level: 4
    atk: 1600
    def: 1400

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned
        resolve {
            send (all, card, either controls) to gy
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            send (all, card, either controls) to gy
        }
    }

    effect "Effect 3" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: custom "chain_end"
        cost {
            banish self
        }
        resolve {
            special_summon (all, card, either controls)
        }
    }
}
