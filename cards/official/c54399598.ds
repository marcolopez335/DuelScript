card "Fleeting Flower of the Magician" {
    id: 54399598
    type: Quick-Play Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        on_resolve {
            destroy (1+, monster, you controls, gy)
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            add_to_hand (1+, monster, you controls, where { is_spell and is_face_up }) from gy
        }
    }

}
