card "Light End Dragon" {
    id: 25132288
    type: Synchro Monster
    attribute: LIGHT
    race: Dragon
    level: 8
    atk: 2600
    def: 2100

    summon {
        cannot_normal_summon
        synchro materials {
            tuner: (1, tuner monster)
            non_tuner: (1+, non-tuner monster, where attribute == LIGHT)
        }
    }

    effect "Effect 1" {
        speed: 1
        timing: when
        trigger: summoned
        resolve {
            modify_atk self - 500 until end_of_turn
            modify_def self - 500 until end_of_turn
            modify_atk target - 1500 until end_of_turn
            modify_def target - 1500 until end_of_turn
        }
    }
}
