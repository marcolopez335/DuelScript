// Concours de Cuisine (Culinary Confrontation)
// Transpiled from c14283055.lua

card "Concours de Cuisine (Culinary Confrontation)" {
    id: 14283055
    type: Quick-Play Spell

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            special_summon (1, monster) from gy
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        damage_step: false
        activate_from: [gy]
        on_activate {
            select (1+, card, either_player controls, where { in_archetype: "Archetyp" and is_pendulum }) as target
        }
        cost {
            banish self
        }
        on_resolve {
        }
    }

}
