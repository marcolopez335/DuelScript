card "Wattcobra" {
    id: 88205593
    type: Effect Monster
    attribute: LIGHT
    race: Thunder
    level: 4
    atk: 1000
    def: 500

    continuous_effect "Effect 1" {
        scope: self
        grant: direct_attack
    }

    effect "Effect 2" {
        speed: spell_speed_1
        trigger: when_battle_destroyed
