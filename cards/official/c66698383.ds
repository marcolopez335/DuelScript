// 灼銀の機竜
// Vermillion Dragon Mech
// Transpiled from c66698383.lua

card "Vermillion Dragon Mech" {
    id: 66698383
    type: Synchro Monster
    attribute: FIRE
    race: Machine
    level: 9
    atk: 2700
    def: 1800

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_activate {
            select (1+, card, you controls, where { is_face_up and is_tuner }) as target
        }
        cost {
            banish self
        }
        on_resolve {
            destroy (1+, card, you controls, gy)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        optional: true
        timing: if
        damage_step: false
        trigger: on_custom_event "chain_end"
        on_activate {
            select (1+, card, you controls, where { is_face_up and is_tuner }) as target
        }
        on_resolve {
            add_to_hand (1+, card, you controls, where { is_face_up and is_tuner }) from gy
        }
    }

}
