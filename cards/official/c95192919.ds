// 烈風の覇者シムルグ
// Simorgh, Lord of the Storm
// Transpiled from c95192919.lua

card "Simorgh, Lord of the Storm" {
    id: 95192919
    type: Effect Monster
    attribute: WIND
    race: Winged Beast
    level: 8
    atk: 2900
    def: 2000

    summon_condition {
        tributes_required: 2
    }

    continuous_effect "Effect 1" {
        scope: self
        grant: cannot_be_targeted_by_card_effects
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        timing: when
        damage_step: false
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        cost {
            tribute self
        }
        on_resolve {
            return (1+, card, either_player controls, where { attribute == WIND }) to deck shuffle
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: when
        trigger: when_battle_damage
        activate_from: [gy]
        on_resolve {
            add_to_hand (1+, card, either_player controls, where { attribute == WIND }) from gy
        }
    }

}
