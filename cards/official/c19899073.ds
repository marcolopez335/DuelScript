// 天叢雲之巳剣
// Ame no Murakumo no Mitsurugi
// Transpiled from c19899073.lua

card "Ame no Murakumo no Mitsurugi" {
    id: 19899073
    type: Ritual Monster
    attribute: DARK
    race: Reptile
    level: 8
    atk: 3200
    def: 800

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 1+ monster
        method: ritual
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        on_resolve {
            destroy (1+, monster, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            discard (1, card)
            negate effect
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        trigger: when_tributed
        on_resolve {
            return (1+, monster, opponent controls) to hand
            reveal (1+, card, opponent controls)
            special_summon (1, monster) from gy
        }
    }

}
