// 烙印の気炎
// Branded in High Spirits
// Transpiled from c29948294.lua

card "Branded in High Spirits" {
    id: 29948294
    type: Quick-Play Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        on_resolve {
            reveal (1+, card, opponent controls)
            shuffle_hand
            send (1+, monster, either_player controls) to gy
            send (1+, monster, either_player controls) to gy
            add_to_hand (1+, monster, either_player controls) from gy
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: when
        trigger: during_end_phase
        activate_from: [gy]
        on_resolve {
            add_to_hand (1+, monster, either_player controls) from gy
        }
    }

    raw_effect "Effect 3" {
        effect_type: Field + Continuous
        code: ChainEnd
        on_resolve {
            set_flag "tracked" on self
        }
    }

}
