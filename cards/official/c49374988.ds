// マドルチェ・メェプル
// Madolche Baaple
// Transpiled from c49374988.lua

card "Madolche Baaple" {
    id: 49374988
    type: Effect Monster
    attribute: EARTH
    race: Beast
    level: 3
    atk: 0
    def: 1800

    effect "Effect 1" {
        speed: spell_speed_1
        trigger: on_custom_event "chain_end"
        on_resolve {
            return (1+, card, either_player controls) to deck shuffle
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            change_battle_position (1, monster)
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
