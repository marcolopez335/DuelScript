// 海神の依代
// Yorishiro of the Aqua
// Transpiled from c57511992.lua

card "Yorishiro of the Aqua" {
    id: 57511992
    type: Effect Monster
    attribute: WATER
    race: Aqua
    level: 4
    atk: 700
    def: 2000

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        activate_from: [gy]
        on_activate {
            select (1+, monster, either_player controls) as target
        }
        cost {
            banish self
        }
        on_resolve {
            return (1+, monster, either_player controls) to hand
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_activate {
            select (1+, monster, either_player controls) as target
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            special_summon (1, monster) from gy
        }
    }

}
