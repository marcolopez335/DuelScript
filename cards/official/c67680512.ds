card "Unchained Soul of Rage" {
    id: 67680512
    type: Link Monster
    attribute: DARK
    race: Fiend
    link: 2
    link_arrows: [top, bottom]
    atk: 1800

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ effect monster
        method: link
    }

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        damage_step: false
        on_resolve {
            special_summon (1, link monster) from extra_deck
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        damage_step: false
        trigger: when_destroyed
        on_resolve {
            add_to_hand (1+, card, either_player controls, where { is_face_up }) from gy
        }
    }

}
