card "Scrap-Iron Sacred Statue" {
    id: 85520170
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        damage_step: false
        on_resolve {
            special_summon (1, monster) from gy
            return (1+, card, either_player controls) to deck shuffle
            destroy (1+, monster, opponent controls)
            change_battle_position (1, monster)
            emit_event "custom"
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        timing: if
        trigger: when_destroyed
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
