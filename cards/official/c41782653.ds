card "Overtex Qoatlus" {
    password: 41782653
    type: Effect Monster | Spirit
    attribute: DARK
    race: Dinosaur
    level: 7
    atk: 2700
    def: 2100

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        on_resolve {
            reveal self
        }
    }

    effect "Effect 3" {
        speed: spell_speed_2
