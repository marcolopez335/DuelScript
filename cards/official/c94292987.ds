card "Fabled Gammajin" {
    id: 94292987
    type: Synchro Monster | Tuner
    attribute: LIGHT
    race: Fiend
    level: 4
    atk: 2000
    def: 0

    summon {
        cannot_normal_summon
    }

    passive "Effect 1" {
        scope: self
        grant: cannot_be_targeted by effects
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            special_summon (1, monster, where archetype == "Fabled") from hand in attack_position
        }
    }

    effect "Effect 3" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: custom "chain_end"
        resolve {
            draw 1
            discard (all, card, either controls)
        }
    }
}
