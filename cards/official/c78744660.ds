// デス・レジーナ・デーモン
// Doom Regina Archfiend
// Transpiled from c78744660.lua

card "Doom Regina Archfiend" {
    id: 78744660
    // FIXME: card not found in CDB — type/stats are placeholders
    type: Effect Monster
    attribute: DARK
    race: Fiend
    level: 1
    atk: 0
    def: 0

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_activate {
            select (1+, spell, opponent controls) as target
        }
        on_resolve {
            destroy (1+, spell, opponent controls)
            return (1+, spell, opponent controls) to hand
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        on_resolve {
            destroy (1+, spell, opponent controls)
            banish (1+, spell, opponent controls)
        }
    }

    continuous_effect "Effect 3" {
        scope: self
        grant: unaffected_by_card_effects
    }

}
