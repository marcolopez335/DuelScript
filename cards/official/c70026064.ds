card "Bujin Hiruko" {
    id: 70026064
    type: Normal Monster | Pendulum Monster
    attribute: LIGHT
    race: Beast-Warrior
    level: 4
    scale: 3
    atk: 1000
    def: 2000
    flavor: "[ Pendulum Effect ] You can banish this card in your Pendulum Zone, then target 1 'Bujin' Xyz Monster you control; Special Summon from your Extra Deck, 1 'Bujin' Xyz Monster with a different name, by using that target as the Xyz Material. (This Special Summon is treated as an Xyz Summon. Xyz Materials attached to it also become Xyz Materials on the Summoned monster.) ---------------------------------------- [ Flavor Text ] Imprisoned after a showdown with 'Bujin Hirume' over the Sky Throne, this master schemer eventually escaped by manipulating Hirume and creating the sinister 'Bujinki Amaterasu', then went on to almost engulf the world in darkness, but was finally defeated by Yamato and his allies."

    raw_effect "Effect 1" {
        effect_type: Ignition
        category: SpecialSummon
        property: CardTarget
        range: PendulumZone
        cost {
            banish self
        }
        on_resolve {
            attach (1, card) to self as_material
            special_summon (1, monster) from gy
        }
    }

}
