card "Madolche Mini Meowcaroons" {
    id: 38745241
    type: Link Monster
    attribute: EARTH
    race: Beast
    link: 3
    link_arrows: [bottom_left, bottom, bottom_right]
    atk: 2300

    summon {
        cannot_normal_summon
        link materials: (2+, effect monster)
    }

    passive "Effect 3" {
        scope: self
        grant: cannot_activate effects
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            add_to_hand (1, card, where archetype == "Madolche") from deck
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        mandatory
        resolve {
            special_summon (all, card, either controls)
            return (all, card, either controls) to deck
        }
    }
}
