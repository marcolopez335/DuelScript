// くず鉄のかかし
// Scrap-Iron Scarecrow
// Transpiled from c98427577.lua

card "Scrap-Iron Scarecrow" {
    id: 98427577
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        damage_step: false
        trigger: when attack_declared
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            negate attack
            change_battle_position (1, monster)
            emit_event "custom"
        }
    }

}
