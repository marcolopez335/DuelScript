// ラヴァル・ステライド
// Laval Stennon
// Transpiled from c20374351.lua

card "Laval Stennon" {
    id: 20374351
    type: Synchro Monster
    attribute: FIRE
    race: Pyro
    level: 7
    atk: 2700
    def: 1800

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        trigger: when_summoned by_special_summon
        on_resolve {
            send (1+, monster, you controls, gy) to gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        cost {
            banish self
        }
        on_resolve {
            negate activation
            destroy (1+, monster, you controls, gy)
        }
    }

}
