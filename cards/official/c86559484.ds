card "Xyz-Raypierce" {
    id: 86559484
    type: Effect Monster
    attribute: FIRE
    race: Dragon
    level: 4
    atk: 1700
    def: 200

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        mandatory
        cost {
            banish self
        }
        resolve {
            special_summon (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: custom "chain_end"
        condition: previous_location == field
        resolve {
            damage opponent 1000
        }
    }
}
