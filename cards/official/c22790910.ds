// 智の賢者－ヒンメル
// Sage of Wisdom - Himmel
// Transpiled from c22790910.lua

card "Sage of Wisdom - Himmel" {
    id: 22790910
    type: Effect Monster
    attribute: EARTH
    race: Machine
    level: 5
    atk: 500
    def: 2500

    summon_condition {
        tributes_required: 1
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        activate_from: [hand]
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        cost {
            banish self
        }
        on_resolve {
            negate effect
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        damage_step: false
        trigger: on_custom_event "chain_end"
        on_activate {
            select (1+, spell, you controls, where { is_face_up }) as target
        }
        on_resolve {
            add_to_hand (1+, spell, you controls, where { is_face_up }) from hand
        }
    }

}
