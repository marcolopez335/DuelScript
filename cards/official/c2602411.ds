            select (1+, monster, either_player controls, where { is_face_up }) as target
        }
        on_resolve {
            send (1+, monster, either_player controls, where { is_face_up }) to gy
            equip (1, card) to (1, monster)
        }
    }

    continuous_effect "Effect 2" {
        scope: field
        grant: cannot_activate_effects
    }

    effect "Effect 3" {
        speed: spell_speed_1
        damage_step: false
        activate_from: [spell_trap_zone]
        on_activate {
            select (1+, monster, either_player controls, where { is_face_up }) as target
        }
        cost {
            send self to gy
        }
        on_resolve {
            add_to_hand (1+, monster, either_player controls, where { is_face_up }) from gy
        }
    }

    raw_effect "Effect 4" {
        effect_type: Single
        code: CannotAttack2
        on_resolve {
