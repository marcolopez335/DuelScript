card "Curse of Aramatir" {
    id: 34690953
    type: Continuous Spell

    effect "Effect 1" {
        speed: 1
        mandatory
        resolve {
            special_summon target
            send (1, card, you control, from hand) to gy
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        mandatory
        resolve {
            create_token {
                name: "Token"
                count: 1
            }
            special_summon (all, card, either controls)
            send (all, card, either controls) to gy
        }
    }
}
