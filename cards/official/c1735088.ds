card "Wind-Up Zenmaintenance" {
    id: 1735088
    type: Link Monster
    attribute: LIGHT
    race: Machine
    link: 2
    link_arrows: [bottom_left, bottom_right]
    atk: 1800

    summon {
        cannot_normal_summon
        link materials: (2, monster, where archetype == "Wind UP")
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            add_to_hand (1, card, where archetype == "Wind-Up") from deck
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        mandatory
        resolve {
            special_summon (all, card, either controls)
        }
    }

    effect "Effect 3" {
        speed: 1
        timing: if
        trigger: custom "chain_end"
        condition: reason == destroy
        resolve {
            add_to_hand target
        }
    }
}
