// 発条補修ゼンマイコン
// Wind-Up Zenmaintenance
// Transpiled from c1735088.lua

card "Wind-Up Zenmaintenance" {
    id: 1735088
    type: Link Monster
    attribute: LIGHT
    race: Machine
    link: 2
    link_arrows: [bottom_left, bottom_right]
    atk: 1800

    materials {
        require: 2+ effect monster
        method: link
    }

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        on_resolve {
            add_to_hand (1+, card, you controls) from deck
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        optional: true
        timing: if
        damage_step: false
        trigger: on_custom_event "chain_end"
        on_activate {
            select (1+, card, you controls) as target
        }
        on_resolve {
            attach (1, card) to self as_material
        }
    }

}
