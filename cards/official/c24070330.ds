card "Symphonic Warrior Rockks" {
    id: 24070330
    type: Synchro Monster | Pendulum Monster
    attribute: WIND
    race: Machine
    level: 7
    scale: 10
    atk: 2500
    def: 1500

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
