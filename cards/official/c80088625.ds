card "Binary Blader" {
    id: 80088625
    type: Link Monster
    attribute: EARTH
    race: Cyberse
    link: 2
    link_arrows: [left, right]
    atk: 1800

    summon {
        cannot_normal_summon
        special_summon_procedure {
            from: extra_deck
            to: your_field
        }
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: soft
        timing: when
        trigger: summoned
        resolve {
            grant self double_attack until end_of_turn
            grant self cannot_be_destroyed by battle until end_of_turn
        }
    }

    effect "Effect 2" {
        speed: 1
        timing: when
        trigger: custom "chain_end"
        resolve {
            banish (all, card, either controls)
        }
    }
}
