// 蒼穹を睨めるダーク
// Derk, Longing for the Blue Skies
// Transpiled from c46708514.lua

card "Derk, Longing for the Blue Skies" {
    id: 46708514
    type: Effect Monster
    attribute: DARK
    race: Reptile
    level: 10
    atk: 3000
    def: 2700

    summon_condition {
        tributes_required: 2
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: when
        trigger: when_summoned by_special_summon
        activate_from: [gy]
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        cost {
            banish self
        }
        on_resolve {
            negate effect
            destroy (1+, card, you controls, hand)
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: when
        trigger: during_end_phase
        activate_from: [banished]
        on_resolve {
            send (1+, card, you controls, hand) to gy
        }
    }

}
