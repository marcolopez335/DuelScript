// 戦華の妙－魯敬
// Ancient Warriors - Eccentric Lu Jing
// Transpiled from c13923256.lua

card "Ancient Warriors - Eccentric Lu Jing" {
    id: 13923256
    type: Effect Monster
    attribute: WATER
    race: Beast-Warrior
    level: 4
    atk: 700
    def: 2000

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, spell, you controls) as target
        }
        on_resolve {
            send (1+, spell, you controls, gy) to gy
            add_to_hand (1+, spell, you controls) from gy
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        damage_step: false
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_activate {
            select (1+, spell, you controls) as target
        }
        on_resolve {
            destroy (1+, spell, you controls, gy)
        }
    }

}
