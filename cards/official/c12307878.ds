// 召喚獣プルガトリオ
// Invoked Purgatrio
// Transpiled from c12307878.lua

card "Invoked Purgatrio" {
    id: 12307878
    type: Fusion Monster
    attribute: FIRE
    race: Fiend
    level: 7
    atk: 2300
    def: 2000

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        method: fusion
    }

    raw_effect "Effect 1" {
        effect_type: Single
        code: UpdateAttack
        property: SingleRange
        range: MonsterZone
        on_resolve {
            modifier: atk + count((1+, card, either_player controls)) * 200
        }
    }

    continuous_effect "Effect 2" {
        scope: self
        grant: attack_all_opponent_monsters
    }

    continuous_effect "Effect 3" {
        scope: self
        grant: piercing
    }

}
