// スクラップ・コング
// Scrap Kong
// Transpiled from c97000273.lua

card "Scrap Kong" {
    id: 97000273
    type: Effect Monster
    attribute: EARTH
    race: Beast
    level: 4
    atk: 2000
    def: 1000

    effect "Effect 1" {
        speed: spell_speed_1
        trigger: when_summoned
        on_resolve {
            destroy (1+, monster, either_player controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        optional: true
        timing: if
        damage_step: false
        trigger: when_destroyed
        on_resolve {
            add_to_hand (1+, monster, either_player controls) from gy
            reveal (1+, card, opponent controls)
        }
    }

}
