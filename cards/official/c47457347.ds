card "Omega Summon" {
    id: 47457347
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        damage_step: false
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
            special_summon (1, monster) from gy
            send (1+, card, either_player controls) to gy
        }
    }

}
