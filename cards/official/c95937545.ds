card "Golden Allure Queen" {
    id: 95937545
    type: Link Monster
    attribute: DARK
    race: Spellcaster
    link: 3
    link_arrows: [left, right, bottom]
    atk: 2500

    summon {
        cannot_normal_summon
    }

    passive "Effect 5" {
        scope: self
        grant: cannot_be_destroyed by effect
    }

    effect "Effect 1" {
        speed: 1
        timing: if
        trigger: summoned by special
        resolve {
            special_summon (all, card, either controls)
        }
    }

    effect "Effect 3" {
        speed: 2
        once_per_turn: soft
        timing: when
        trigger: opponent_activates [activate_spell, activate_trap, activate_spell]
        resolve {
            destroy (all, card, either controls)
        }
    }
}
