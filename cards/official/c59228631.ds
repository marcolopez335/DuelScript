// ホーリーナイツ・アステル
// Starry Knight Astel
// Transpiled from c59228631.lua

card "Starry Knight Astel" {
    id: 59228631
    type: Effect Monster
    attribute: LIGHT
    race: Fairy
    level: 4
    atk: 500
    def: 2000

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        damage_step: false
        on_activate {
            select (1+, card, you controls, where { is_face_up }) as target
        }
        on_resolve {
            tribute (1, monster, you controls)
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        activate_from: [gy]
        on_activate {
            select (1+, card, you controls, where { is_face_up }) as target
        }
        cost {
            banish self
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
