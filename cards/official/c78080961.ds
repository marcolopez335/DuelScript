card "SPYRAL Quik-Fix" {
    id: 78080961
    type: Effect Monster
    attribute: EARTH
    race: Machine
    level: 1
    atk: 500
    def: 400

    effect "Effect 1" {
        speed: 1
        timing: if
        trigger: summoned
        resolve {
            add_to_hand (1, card, where archetype == "SPYRAL GEAR") from deck
        }
    }

    effect "Effect 2" {
        speed: 1
        timing: if
        trigger: summoned by special
        cost {
            discard (1, card, you control, from hand)
        }
        resolve {
            add_to_hand (1, card, where archetype == "SPYRAL GEAR") from deck
        }
    }

    effect "Effect 3" {
        speed: 1
        mandatory
        resolve {
            special_summon (all, card, either controls)
        }
    }
}
