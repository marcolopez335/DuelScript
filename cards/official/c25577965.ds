// 炎魔刃フレイムタン
// Flametongue the Blazing Magical Blade
// Transpiled from c25577965.lua

card "Flametongue the Blazing Magical Blade" {
    id: 25577965
    type: Link Monster
    attribute: FIRE
    race: Warrior
    link: 2
    link_arrows: [bottom_left, bottom_right]
    atk: 1400

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ effect monster
        method: link
    }

    continuous_effect "Effect 1" {
        scope: field
        grant: cannot_be_destroyed_by_effect
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        on_resolve {
            add_to_hand (1+, spell, either_player controls) from gy
            reveal (1+, card, opponent controls)
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    continuous_effect "Effect 3" {
        scope: field
        grant: cannot_activate_effects
    }

}
