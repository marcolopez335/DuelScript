card "Frozen Rose" {
    id: 53503015
    type: Quick-Play Spell

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            return (1+, monster, you controls, where { race == Plant and level <= 4 }) to hand
            reveal (1+, card, opponent controls)
        }
    }

