card "Infinite Machine" {
    id: 36894320
    type: Continuous Trap

    effect "Effect 1" {
        speed: spell_speed_2
        cost {
            send self to gy
        }
        on_resolve {
        }
    }

    replacement_effect "Effect 2" {
        instead_of: destroyed_by_any
        do: {
            banish self
        }
    }

    effect "Effect 3" {
        speed: spell_speed_2
        optional: true
