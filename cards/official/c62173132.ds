card "Susurrus of the Sinful Spoils" {
    id: 62173132
    type: Quick-Play Spell

    effect "Effect 1" {
        speed: 2
        once_per_turn: hard
        mandatory
        resolve {
            return (all, card, either controls) to deck
            add_to_hand (all, card, either controls)
            special_summon (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 2
        once_per_turn: soft
        timing: if
        trigger: custom "chain_end"
        resolve {
            special_summon target
        }
    }
}
