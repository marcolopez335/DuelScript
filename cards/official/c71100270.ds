// 百鬼羅刹の大饕獣
// Goblin's Crazy Beast
// Transpiled from c71100270.lua

card "Goblin's Crazy Beast" {
    id: 71100270
    type: Xyz Monster
    attribute: DARK
    race: Fiend
    rank: 6
    atk: 2700
    def: 0

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        same_level: true
        method: xyz
    }

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        damage_step: false
        on_activate {
            select (1+, monster, you controls) as target
        }
        on_resolve {
            detach 1 overlay_unit from self
            attach (1, card) to self as_material
        }
    }

    replacement_effect "Effect 2" {
        instead_of: destroyed_by_any
        do: {
            banish self
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [gy]
        on_resolve {
            special_summon (1, monster) from gy
            attach (1, card) to self as_material
        }
    }

}
