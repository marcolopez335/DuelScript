card "Citadel Whale" {
    password: 46290741
    type: Effect Monster
    attribute: WATER
    race: Fish
    level: 7
    atk: 2350
    def: 2150

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [hand, gy]
        cost {
            tribute self
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
