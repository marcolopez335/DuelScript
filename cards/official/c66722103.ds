card "Thunderclap Monk" {
    id: 66722103
    type: Effect Monster
    attribute: LIGHT
    race: Thunder
    level: 4
    atk: 1900
    def: 200

    effect "Effect 1" {
        speed: 2
        once_per_turn: hard
        timing: when
        trigger: opponent_activates [activate_spell, activate_trap, activate_spell]
        cost {
            tribute self
        }
        resolve {
            negate
            destroy (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: custom "chain_end"
        condition: previous_location == field
        resolve {
            special_summon (all, card, either controls)
        }
    }
}
