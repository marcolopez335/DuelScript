// 封狼雷坊
// Thunderclap Monk
// Transpiled from c66722103.lua

card "Thunderclap Monk" {
    id: 66722103
    type: Effect Monster
    attribute: LIGHT
    race: Thunder
    level: 4
    atk: 1900
    def: 200

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        cost {
            tribute self
        }
        on_resolve {
            negate activation
            destroy (1+, card, you controls, hand)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        trigger: on_custom_event "chain_end"
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
