card "Battlewasp - Ballista the Armageddon" {
    id: 26443791
    type: Synchro Monster
    attribute: WIND
    race: Insect
    level: 12
    atk: 3000
    def: 800

    summon {
        cannot_normal_summon
        synchro materials {
            tuner: (1, tuner monster)
            non_tuner: (1+, non-tuner monster)
        }
    }

    passive "Effect 1" {
        scope: self
        grant: piercing
    }

    effect "Effect 2" {
        speed: 1
        timing: if
        trigger: summoned by special
        cost {
            banish self
        }
    }

    effect "Effect 3" {
        speed: 1
        timing: if
        trigger: destroyed
        resolve {
            special_summon (all, card, either controls)
        }
    }
}
