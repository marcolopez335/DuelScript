// 超竜災禍
// Here There Be Dragons
// Transpiled from c4575541.lua

card "Here There Be Dragons" {
    id: 4575541
    type: Quick-Play Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        on_resolve {
            special_summon (1, monster) from gy
            xyz_summon (1, xyz monster) using (1+, monster, you controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        activate_from: [gy]
        on_activate {
            select (1+, monster, you controls) as target
        }
        cost {
            banish self
        }
        on_resolve {
            send (1+, monster, you controls) to gy
        }
    }

}
