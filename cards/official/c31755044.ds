// 十二獣ヴァイパー
// Zoodiac Whiptail
// Transpiled from c31755044.lua

card "Zoodiac Whiptail" {
    id: 31755044
    type: Effect Monster
    attribute: EARTH
    race: Beast-Warrior
    level: 4
    atk: 1200
    def: 400

    effect "Effect 1" {
        speed: spell_speed_2
        optional: true
        damage_step: false
        activate_from: [hand, monster_zone]
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            attach (1, card) to self as_material
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        trigger: on_custom_event "chain_end"
        on_resolve {
            banish (1+, card, either_player controls)
        }
    }

}
