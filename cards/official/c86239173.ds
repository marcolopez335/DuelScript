card "Horned Saurus" {
    id: 86239173
    type: Fusion Monster
    attribute: DARK
    race: Dinosaur
    level: 6
    atk: 2000
    def: 1800

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        method: fusion
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
