// オッドアイズ・ミラージュ・ドラゴン
// Odd-Eyes Mirage Dragon
// Transpiled from c67754901.lua

card "Odd-Eyes Mirage Dragon" {
    id: 67754901
    type: Effect Monster | Pendulum Monster
    attribute: DARK
    race: Dragon
    level: 3
    scale: 8
    atk: 1200
    def: 600

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        damage_step: false
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        trigger: when_destroyed
        on_resolve {
            destroy (1+, card, either_player controls)
            special_summon (1, monster) from gy
        }
    }

}
