card "Merry Melffys" {
    id: 81019803
    type: Synchro Monster
    attribute: EARTH
    race: Beast
    level: 4
    atk: 1500
    def: 1000

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 1 tuner monster
