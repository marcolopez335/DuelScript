// パーペチュアルキングデーモン
// Masterking Archfiend
// Transpiled from c35606858.lua

card "Masterking Archfiend" {
    password: 35606858
    type: Link Monster
    attribute: DARK
    race: Fiend
    link: 2
    link_arrows: [bottom_left, bottom_right]
    atk: 2000

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ effect monster
        method: link
    }

    raw_effect "Effect 1" {
        effect_type: Field + Continuous
        code: 4098
        property: 263168
        range: MonsterZone
        count_limit: (1, 0)
        on_resolve {
            destroy (1+, monster, you controls, deck)
        }
    }

    raw_effect "Effect 2" {
        effect_type: Field + Trigger
        category: ToGrave
        code: 1201
        property: 65536
        range: MonsterZone
        count_limit: (1, 0)
        on_resolve {
            send (1+, monster, you controls, deck) to gy
        }
    }

    raw_effect "Effect 3" {
        effect_type: Single + Trigger
        category: ToHand + ToDeck + SpecialSummon + FusionSummon
        code: 304042314
        property: 65536
        range: MonsterZone
        count_limit: (1, 0)
        on_resolve {
            flip_coin { heads { draw 1 } tails { draw 1 } }
            add_to_hand (1+, monster, you controls) from deck
            reveal (1+, card, opponent controls)
            special_summon (1, monster) from gy
            return (1+, monster, you controls) to deck shuffle
        }
    }

    raw_effect "Effect 4" {
        effect_type: Field + Continuous
        code: ChainEnd
        property: 1024
        range: MonsterZone
        on_resolve {
            emit_event "custom"
        }
    }

}
