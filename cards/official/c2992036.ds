// 根絶の機皇神
// Meklord Astro the Eradicator
// Transpiled from c2992036.lua

card "Meklord Astro the Eradicator" {
    id: 2992036
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        damage_step: false
        on_resolve {
            add_to_hand (1, card, you controls) from gy
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        activate_from: [gy]
        cost {
            banish self
        }
        on_resolve {
            destroy (1+, monster, you controls, gy)
            deal_damage to opponent: 1000
        }
    }

}
