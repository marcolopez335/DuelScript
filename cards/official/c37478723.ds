// 『焔聖剣-デュランダル』
// 'Infernoble Arms - Durendal'
// Transpiled from c37478723.lua

card "'Infernoble Arms - Durendal'" {
    id: 37478723
    type: Equip Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [spell_trap_zone]
        on_resolve {
            add_to_hand (1+, card, you controls, where { level <= 5 and race == Warrior and attribute == FIRE }) from deck
            reveal (1+, card, opponent controls)
            destroy (1+, card, you controls, deck)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        damage_step: false
        trigger: on_custom_event "chain_end"
        on_resolve {
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        on_resolve {
            equip self to (1, monster, you controls)
        }
    }

}
