// 死の罪宝－ルシエラ
// Sinful Spoils of Doom - Rciela
// Transpiled from c16240772.lua

card "Sinful Spoils of Doom - Rciela" {
    id: 16240772
    type: Quick-Play Spell

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, monster, opponent controls, where { is_face_up and level >= 7 and race == Spellcaster }) as target
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            send (1+, monster, opponent controls, where { is_face_up and level >= 7 and race == Spellcaster }) to gy
            destroy (1+, monster, opponent controls)
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            destroy (1+, monster, opponent controls, where { is_face_up and level >= 7 and race == Spellcaster })
        }
    }

}
