// 超魔導戦士－マスター・オブ・カオス
// Master of Chaos
// Transpiled from c85059922.lua

card "Master of Chaos" {
    id: 85059922
    type: Fusion Monster
    attribute: DARK
    race: Spellcaster
    level: 8
    atk: 3000
    def: 2500

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        method: fusion
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        damage_step: false
        trigger: when_summoned by_special_summon
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        cost {
            tribute self
        }
        on_resolve {
            banish (1+, spell, opponent controls, where { is_spell })
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        damage_step: false
        trigger: when_destroyed
        on_resolve {
            return (1+, spell, opponent controls, where { is_spell }) to hand
        }
    }

}
