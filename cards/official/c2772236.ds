card "Wattchimera" {
    id: 2772236
    type: Synchro Monster
    attribute: LIGHT
    race: Thunder
    level: 6
    atk: 1400
    def: 1200

    summon {
        cannot_normal_summon
        synchro materials {
            tuner: (1, tuner monster, where archetype == "Watt")
            non_tuner: (1+, non-tuner monster, where race == Thunder)
        }
    }

    passive "Effect 1" {
        scope: self
        grant: direct_attack
    }

    effect "Effect 2" {
        speed: 1
        mandatory
        trigger: destroyed_by_battle
        resolve {
            return (all, card, either controls) to deck
        }
    }
}
