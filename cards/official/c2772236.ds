// エレキマイラ
// Wattchimera
// Transpiled from c2772236.lua

card "Wattchimera" {
    id: 2772236
    type: Synchro Monster
    attribute: LIGHT
    race: Thunder
    level: 6
    atk: 1400
    def: 1200

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    summon_condition {
        cannot_normal_summon: true
    }

    raw_effect "Effect 1" {
        effect_type: Single
        code: DefenseDisabled
        on_resolve {
            register_effect on self { grant: direct_attack duration: until_end_of_turn }
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single + MandatoryTrigger
        category: ToDeck
        code: BattleDestroyed
        on_resolve {
            return (1+, card, either_player controls) to deck shuffle
        }
    }

}
