card "Wattchimera" {
    id: 2772236
    type: Synchro Monster
    attribute: LIGHT
    race: Thunder
    level: 6
    atk: 1400
    def: 1200

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    summon_condition {
        cannot_normal_summon: true
    }

    continuous_effect "Effect 1" {
        scope: self
        grant: direct_attack
    }

    effect "Effect 2" {
        speed: spell_speed_1
        trigger: when_battle_destroyed
        on_resolve {
            return (1+, card, either_player controls) to deck shuffle
        }
    }

}
