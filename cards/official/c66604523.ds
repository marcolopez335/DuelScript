// エクシーズ・リバーサル
// Xyz Reversal
// Transpiled from c66604523.lua

card "Xyz Reversal" {
    id: 66604523
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        damage_step: false
        on_activate {
            select (1+, card, either_player controls, where { is_face_up and is_xyz }) as target
        }
        on_resolve {
            take_control of (1, monster, opponent controls)
        }
    }

}
