// 武神器－イクタ
// Bujingi Boar
// Transpiled from c42551040.lua

card "Bujingi Boar" {
    id: 42551040
    type: Effect Monster
    attribute: LIGHT
    race: Beast
    level: 4
    atk: 1100
    def: 1900

    effect "Effect 1" {
        speed: spell_speed_1
        damage_step: false
        activate_from: [gy]
        on_activate {
            select (1+, monster, you controls) as target
        }
        cost {
            banish self
        }
        on_resolve {
            change_battle_position (1, monster)
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
