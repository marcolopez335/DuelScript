card "Bujingi Boar" {
    id: 42551040
    type: Effect Monster
    attribute: LIGHT
    race: Beast
    level: 4
    atk: 1100
    def: 1900

    raw_effect "Effect 1" {
        effect_type: Ignition
        category: PositionChange
        property: CardTarget
        range: Graveyard
        cost {
            banish self
        }
        on_resolve {
            change_battle_position (1, monster)
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
