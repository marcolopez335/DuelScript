card "Magikey World" {
    id: 35815783
    type: Field Spell

    passive "Effect 2" {
        scope: self
        grant: cannot_be_destroyed
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        mandatory
        resolve {
            add_to_hand (all, card, either controls)
        }
    }

    effect "Effect 3" {
        speed: 1
        once_per_turn: soft
        mandatory
        resolve {
            add_to_hand (all, card, either controls)
            return (all, card, either controls) to deck
        }
    }
}
