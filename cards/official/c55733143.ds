// ミミグル・チャーム
// Mimighoul Charm
// Transpiled from c55733143.lua

card "Mimighoul Charm" {
    id: 55733143
    type: Continuous Spell

    effect "Effect 1" {
        speed: spell_speed_1
        on_resolve {
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        twice_per_turn
        optional: true
        timing: if
        trigger: on_custom_event "chain_active"
        activate_from: [spell_trap_zone]
        on_resolve {
            reveal (1+, card, opponent controls)
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            banish (1+, card, either_player controls)
        }
    }

    continuous_effect "Effect 3" {
        scope: self
        grant: cannot_activate_effects
    }

}
