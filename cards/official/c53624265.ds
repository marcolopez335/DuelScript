card "Unchained Twins - Rakea" {
    id: 53624265
    type: Effect Monster
    attribute: WATER
    race: Fiend
    level: 3
    atk: 1500
    def: 1500

    effect "Effect 1" {
        speed: 2
        once_per_turn: hard
        target (1, card, you control, from field)
        resolve {
            destroy (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: destroyed
        resolve {
            special_summon (1, monster, where archetype == "Unchained") from hand in attack_position
        }
    }
}
