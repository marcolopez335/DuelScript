card "Raidraptor - Heel Eagle" {
    id: 51933043
    type: Effect Monster
    attribute: DARK
    race: Winged Beast
    level: 3
    atk: 700
    def: 700

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [hand]
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        activate_from: [gy]
        on_activate {
            select (1+, spell, either_player controls) as target
        }
        cost {
            banish self
        }
        on_resolve {
            add_to_hand (1+, spell, either_player controls) from gy
        }
    }

}
