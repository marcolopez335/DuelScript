        timing: when
        damage_step: false
        trigger: when attack_declared
        on_resolve {
            negate attack
            banish (1+, card, you controls, gy)
        }
    }

    effect "Effect 4" {
        speed: spell_speed_1
        once_per_turn: soft
        trigger: during_end_phase
        activate_from: [banished]
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    raw_effect "Effect 5" {
        effect_type: Single
        code: 21142671
        property: BothSide + Uncopyable
        on_resolve {
        }
    }

