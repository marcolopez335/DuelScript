card "Sky Galloping Gaia the Dragon Champion" {
    id: 2519690
    type: Fusion Monster
    attribute: WIND
    race: Dragon
    level: 7
    atk: 2600
    def: 2100

    summon {
        cannot_normal_summon
        special_summon_procedure {
            from: extra_deck
            to: your_field
        }
    }

    effect "Effect 2" {
        speed: 1
        timing: if
        trigger: summoned by special
        resolve {
            add_to_hand (all, card, either controls)
        }
    }

    effect "Effect 3" {
        speed: 1
        timing: when
        trigger: summoned
        resolve {
            add_to_hand target
        }
    }
}
