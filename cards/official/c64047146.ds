card "Horn of the Unicorn" {
    id: 64047146
    type: Equip Spell

    effect "Effect 3" {
        speed: 1
        mandatory
        trigger: custom "chain_end"
        condition: previous_location == field
        resolve {
            return (all, card, either controls) to deck
        }
    }

    effect "Effect 4" {
        speed: 1
        mandatory
        resolve {
            send target to deck
        }
    }


    passive "Passive 5" {
        target: equipped_card
        modifier: atk + 700
    }
}
