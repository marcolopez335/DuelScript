card "Draining Shield" {
    id: 43250041
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        damage_step: false
        trigger: when attack_declared
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            negate attack
            gain_lp: 1000
        }
    }

}
