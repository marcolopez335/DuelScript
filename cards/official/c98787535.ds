card "Aleirtt, the Ogdoadic Dark" {
    id: 98787535
    type: Effect Monster
    attribute: DARK
    race: Reptile
    level: 8
    atk: 2000
    def: 800

    summon_condition {
        tributes_required: 2
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [gy]
        cost {
            tribute self
        }
        on_resolve {
            special_summon (1, monster) from gy
            add_to_hand (1+, monster, either_player controls) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        damage_step: false
        trigger: when_summoned by_special_summon
        on_resolve {
            send (1+, monster, either_player controls) to gy
        }
    }

}
