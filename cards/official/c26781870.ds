card "Fraud Freeze" {
    id: 26781870
    type: Continuous Trap

    effect "Effect 1" {
        speed: 2
        mandatory
        resolve {
            add_to_hand (all, card, opponent controls, from monster_zone)
        }
    }

    effect "Effect 2" {
        speed: 2
        once_per_turn: soft
        timing: when
        trigger: summoned by special
        resolve {
            return (all, card, either controls) to hand
        }
    }
}
