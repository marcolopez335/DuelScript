card "Collected Power" {
    id: 7565547
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        damage_step: false
        on_activate {
            select (1+, spell, either_player controls) as target
        }
        on_resolve {
            equip (1, card) to (1, monster)
            destroy (1+, spell, either_player controls)
        }
    }

}
