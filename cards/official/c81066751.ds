// Divine Punishment
// Transpiled from c81066751.lua

card "Divine Punishment" {
    id: 81066751
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            negate activation
            destroy (1+, card, either_player controls, where { is_face_up })
        }
    }

}
