// 転生炎獣レイジング・フェニックス
// Salamangreat Raging Phoenix
// Transpiled from c57134592.lua

card "Salamangreat Raging Phoenix" {
    id: 57134592
    type: Link Monster
    attribute: FIRE
    race: Cyberse
    link: 4
    link_arrows: [top, bottom_left, bottom, bottom_right]
    atk: 2800

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ effect monster
        method: link
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        on_resolve {
            add_to_hand (1+, card, you controls) from deck
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        trigger: when_destroyed
        activate_from: [gy]
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
