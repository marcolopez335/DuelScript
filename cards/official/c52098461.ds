// ラス・オブ・ネオス
// Wrath of Neos
// Transpiled from c52098461.lua

card "Wrath of Neos" {
    id: 52098461
    type: Normal Spell

    effect "Effect 1" {
        speed: spell_speed_1
        damage_step: false
        on_activate {
            select (1+, card, either_player controls, where { is_face_up }) as target
        }
        on_resolve {
            return (1+, card, either_player controls, where { is_face_up }) to deck shuffle
            destroy (1+, card, either_player controls, where { is_face_up })
        }
    }

}
