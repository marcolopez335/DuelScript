card "Unchained Twins - Sarama" {
    id: 31588572
    type: Effect Monster
    attribute: DARK
    race: Fiend
    level: 3
    atk: 1500
    def: 1500

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        mandatory
        resolve {
            send (all, card, either controls) to gy
            destroy (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: destroyed
        resolve {
            special_summon (1, monster, where archetype == "Unchained") from hand in attack_position
        }
    }
}
