card "Wattuna" {
    id: 10113611
    type: Effect Monster | Tuner
    attribute: LIGHT
    race: Thunder
    level: 4
    atk: 800
    def: 700

    raw_effect "Effect 1" {
        effect_type: Single
        code: DefenseDisabled
        on_resolve {
            register_effect on self { grant: direct_attack duration: until_end_of_turn }
        }
    }

    raw_effect "Effect 2" {
        effect_type: Field + Trigger
        category: SpecialSummon
        code: BattleDestroyed
        range: Hand
        count_limit: (1, 10113611)
        on_resolve {
            special_summon (1, monster) from gy
