// RR－ネクロ・ヴァルチャー
// Raidraptor - Necro Vulture
// Transpiled from c51814159.lua

card "Raidraptor - Necro Vulture" {
    id: 51814159
    type: Effect Monster
    attribute: DARK
    race: Winged Beast
    level: 4
    atk: 1000
    def: 1600

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_activate {
            select (1+, spell, either_player controls) as target
        }
        cost {
            tribute self
        }
        on_resolve {
            add_to_hand (1+, spell, either_player controls) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
