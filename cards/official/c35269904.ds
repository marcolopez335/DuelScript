// 三戦の号
// Triple Tactics Thrust
// Transpiled from c35269904.lua

card "Triple Tactics Thrust" {
    id: 35269904
    type: Normal Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        on_resolve {
            add_to_hand (1+, card, you controls) from deck
            reveal (1+, card, opponent controls)
            set (1, card)
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    continuous_effect "Effect 2" {
        scope: self
        grant: cannot_activate_effects
    }

}
