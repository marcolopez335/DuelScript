// スカラベの大群
// Swarm of Scarabs
// Transpiled from c15383415.lua

card "Swarm of Scarabs" {
    id: 15383415
    type: Effect Monster
    attribute: DARK
    race: Insect
    level: 3
    atk: 500
    def: 1000

    effect "Effect 1" {
        speed: spell_speed_1
        on_resolve {
            change_battle_position (1, monster)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        damage_step: false
        trigger: when_summoned by_flip_summon
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            destroy (1+, card, either_player controls)
        }
    }

}
