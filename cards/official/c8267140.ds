// コズミック・サイクロン
// Cosmic Cyclone
// Transpiled from c8267140.lua

card "Cosmic Cyclone" {
    id: 8267140
    type: Quick-Play Spell

    effect "Effect 1" {
        speed: spell_speed_1
        damage_step: false
        on_activate {
            select (1+, spell, either_player controls, where { is_spell }) as target
        }
        cost {
            pay_lp 1000
        }
        on_resolve {
            banish (1+, spell, either_player controls, where { is_spell })
        }
    }

}
