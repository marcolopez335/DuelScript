card "Veidos the Eruption Dragon of Extinction" {
    id: 78783557
    type: Effect Monster
    attribute: DARK
    race: Pyro
    level: 9
    atk: 2800
    def: 1500

    summon_condition {
        tributes_required: 2
    }

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        damage_step: false
        activate_from: [hand]
        on_resolve {
            special_summon (1, monster) from gy
            destroy (1+, monster, either_player controls)
            add_to_hand (1, card, you controls) from gy
            set (1, card)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        trigger: on_custom_event "chain_end"
        on_resolve {
            destroy (1+, monster, either_player controls)
        }
    }

}
