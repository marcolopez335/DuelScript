card "Fabled Leviathan" {
    id: 39477584
    type: Synchro Monster
    attribute: LIGHT
    race: Fiend
    level: 10
    atk: 3000
    def: 2000

    summon {
        cannot_normal_summon
        synchro materials {
            tuner: (1, tuner monster, where archetype == "Fabled")
            non_tuner: (1+, non-tuner monster)
        }
    }

    effect "Effect 1" {
        speed: 1
        timing: when
        trigger: custom "chain_end"
        condition: reason includes destroy and previous_location == field
        resolve {
            add_to_hand (all, card, either controls)
        }
    }
}
