// サイバー・ネットワーク
// Cyber Network
// Transpiled from c12670770.lua

card "Cyber Network" {
    id: 12670770
    type: Continuous Trap

    effect "Effect 1" {
        speed: spell_speed_2
        on_resolve {
            banish (1+, spell, either_player controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        optional: true
        activate_from: [spell_trap_zone]
        on_resolve {
            banish (1+, spell, either_player controls)
        }
    }

    effect "Effect 3" {
        speed: spell_speed_2
        trigger: on_custom_event "chain_end"
        on_resolve {
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            destroy (1+, spell, either_player controls)
        }
    }

}
