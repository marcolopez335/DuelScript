card "Fire Hand" {
    id: 68535320
    type: Effect Monster
    attribute: FIRE
    race: Pyro
    level: 4
    atk: 1600
    def: 1000

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        timing: when
        damage_step: false
        trigger: on_custom_event "chain_end"
        on_activate {
            select (1+, card, you controls) as target
        }
        on_resolve {
            destroy (1+, card, you controls, deck)
            special_summon (1, monster) from gy
        }
    }

}
