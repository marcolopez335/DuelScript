card "Metalfoes Counter" {
    id: 33327029
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        optional: true
