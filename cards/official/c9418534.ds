// 人造人間－サイコ・リターナー
// Jinzo - Returner
// Transpiled from c9418534.lua

card "Jinzo - Returner" {
    id: 9418534
    type: Effect Monster
    attribute: DARK
    race: Machine
    level: 3
    atk: 600
    def: 1400

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        timing: when
        damage_step: false
        trigger: on_custom_event "chain_end"
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    continuous_effect "Effect 2" {
        scope: self
        grant: direct_attack
    }

}
