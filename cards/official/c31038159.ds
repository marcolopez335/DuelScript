card "Genesis Dragon" {
    id: 31038159
    type: Effect Monster
    attribute: LIGHT
    race: Dragon
    level: 6
    atk: 2200
    def: 1800

    summon_condition {
        tributes_required: 1
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_resolve {
            add_to_hand (1+, card, you controls, where { race == Dragon }) from gy
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        optional: true
        timing: when
        trigger: on_custom_event "chain_end"
        on_resolve {
            return (1+, card, you controls, where { race == Dragon }) to deck shuffle
        }
    }

}
