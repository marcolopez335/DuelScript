card "Sky Striker Maneuver - Afterburners!" {
    id: 99550630
    type: Normal Spell

    effect "Effect 1" {
        speed: spell_speed_1
        damage_step: false
        on_activate {
            select (1+, spell, either_player controls) as target
        }
        on_resolve {
            destroy (1+, spell, either_player controls)
            destroy (1+, spell, either_player controls)
        }
    }

}
