card "Super Defense Robot Monki" {
    id: 71880877
    type: Effect Monster
    attribute: EARTH
    race: Machine
    level: 3
    atk: 800
    def: 1200

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        timing: when
        trigger: when_summoned
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_activate {
            select (1+, monster, you controls, where { race == Machine and is_monster }) as target
        }
        cost {
            banish self
        }
        on_resolve {
            add_to_hand (1+, monster, you controls, where { race == Machine and is_monster }) from hand
            reveal (1+, card, opponent controls)
        }
    }

}
