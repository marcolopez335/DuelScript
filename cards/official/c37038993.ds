card "Puralis, the Purple Pyrotile" {
    id: 37038993
    type: Synchro Monster | Tuner
    attribute: FIRE
    race: Reptile
    level: 2
    atk: 800
    def: 1400

    summon {
        cannot_normal_summon
        synchro materials {
            tuner: (1, tuner monster)
            non_tuner: (1, non-tuner monster)
        }
    }

    effect "Effect 1" {
        speed: 1
        mandatory
        trigger: custom "chain_end"
        resolve {
            modify_atk (all, card, opponent controls, from monster_zone) - 500 until end_of_turn
        }
    }
}
