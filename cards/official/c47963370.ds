card "Magician of Chaos" {
    id: 47963370
    type: Ritual Monster
    attribute: DARK
    race: Spellcaster
    level: 7
    atk: 2500
    def: 2100

    summon {
        cannot_normal_summon
    }

    effect "Effect 2" {
        speed: 2
        once_per_turn: soft
        timing: when
        trigger: opponent_activates [activate_spell, activate_trap, activate_spell]
        target (1, card, either controls, from field)
        resolve {
            destroy (all, card, either controls)
        }
    }

    effect "Effect 3" {
        speed: 1
        timing: if
        trigger: destroyed
        resolve {
            special_summon (all, card, either controls)
        }
    }
}
