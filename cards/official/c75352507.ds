// 蕾禍ノ玄神憑月
// Ragnaraika Selene Snapper
// Transpiled from c75352507.lua

card "Ragnaraika Selene Snapper" {
    id: 75352507
    type: Link Monster
    attribute: WATER
    race: Reptile
    link: 3
    link_arrows: [left, right, bottom]
    atk: 2600

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ effect monster
        method: link
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, spell, you controls) as target
        }
        cost {
            banish self
        }
        on_resolve {
            destroy (1+, spell, you controls, gy)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        activate_from: [gy]
        on_activate {
            select (1+, spell, you controls) as target
        }
        on_resolve {
            return (1+, spell, you controls) to deck shuffle
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
