card "The Six Samurai - Yaichi" {
    id: 64398890
    type: Effect Monster
    attribute: WATER
    race: Warrior
    level: 3
    atk: 1300
    def: 800

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_activate {
            select (1+, monster, you controls, where { is_face_down }) as target
        }
        on_resolve {
            destroy (1+, monster, you controls, where { is_face_down })
        }
    }

    replacement_effect "Effect 2" {
        instead_of: destroyed_by_any
        do: {
            banish self
        }
    }

}
