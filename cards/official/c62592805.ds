// エピュアリィ・ノアール
// Epurrely Noir
// Transpiled from c62592805.lua

card "Epurrely Noir" {
    id: 62592805
    type: Xyz Monster
    attribute: DARK
    race: Fairy
    rank: 2
    atk: 1000
    def: 2000

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        same_level: true
        method: xyz
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_activate {
            select (1+, trap, you controls) as target
        }
        on_resolve {
            add_to_hand (1+, trap, you controls) from deck
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            attach (1, card) to self as_material
            set (1, card)
        }
    }

}
