card "Gladiator Beast Dragases" {
    id: 62000467
    type: Link Monster
    attribute: WIND
    race: Winged Beast
    link: 2
    link_arrows: [bottom_left, bottom_right]
    atk: 2000

    summon {
        cannot_normal_summon
        special_summon_procedure {
            from: extra_deck
            to: your_field
        }
    }

    passive "Effect 1" {
        scope: self
        grant: cannot_be_destroyed by battle
    }

    passive "Effect 2" {
        scope: self
        grant: cannot_activate effects
    }

    effect "Effect 3" {
        speed: 1
        once_per_turn: hard
        timing: when
        trigger: standby_phase
        resolve {
            special_summon (all, card, either controls)
            special_summon (all, card, either controls)
        }
    }
}
