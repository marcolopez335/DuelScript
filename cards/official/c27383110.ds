        category: ToHand
        code: 295818566
        property: CardTarget
        range: Graveyard
        cost {
            banish self
        }
        on_resolve {
            add_to_hand (1+, card, either_player controls) from gy
            reveal (1+, card, opponent controls)
        }
    }

    raw_effect "Effect 2" {
        effect_type: Field + Continuous
        code: SentToGrave
        range: Graveyard
        on_resolve {
            emit_event "custom"
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        on_resolve {
            ritual_summon (1, ritual monster) using (1+, monster, you controls)
        }
    }

