card "Meteor Black Comet Dragon" {
    id: 30086349
    type: Fusion Monster
    attribute: DARK
    race: Dragon
    level: 8
    atk: 3500
    def: 2000

    summon {
        cannot_normal_summon
        special_summon_procedure {
            from: extra_deck
            to: your_field
        }
    }

    effect "Effect 1" {
        speed: 1
        timing: if
        trigger: summoned by special
        resolve {
            send (all, card, either controls) to gy
            damage opponent 1000
        }
    }

    effect "Effect 2" {
        speed: 1
        timing: if
        trigger: custom "chain_end"
        resolve {
            special_summon (all, card, either controls)
        }
    }
}
