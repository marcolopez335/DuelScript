// 流星竜メテオ・ブラック・ドラゴン
// Meteor Black Comet Dragon
// Transpiled from c30086349.lua

card "Meteor Black Comet Dragon" {
    id: 30086349
    type: Fusion Monster
    attribute: DARK
    race: Dragon
    level: 8
    atk: 3500
    def: 2000

    materials {
        require: 2+ monster
        method: fusion
    }

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        on_resolve {
            send (1+, card, you controls, hand) to gy
            deal_damage to opponent: 1000
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        optional: true
        timing: if
        damage_step: false
        trigger: on_custom_event "chain_end"
        on_activate {
            select (1+, card, you controls) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
