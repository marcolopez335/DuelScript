// エクシーズ・フォース
// Xyz Force
// Transpiled from c31398842.lua

card "Xyz Force" {
    id: 31398842
    type: Normal Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        on_resolve {
            add_to_hand (1, card, you controls) from gy
            send (1+, monster, either_player controls) to gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        activate_from: [gy]
        cost {
            banish self
        }
        on_resolve {
            detach 1 overlay_unit from self
            special_summon (1, monster) from gy
        }
    }

}
