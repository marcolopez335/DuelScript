        timing: if
        trigger: when_summoned by_special_summon
        on_resolve {
            return (1+, monster, opponent controls) to hand
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 5" {
        speed: spell_speed_2
        once_per_turn: soft
