card "Mimighoul Master" {
    id: 55537983
    type: Effect Monster
    attribute: EARTH
    race: Zombie
    level: 4
    atk: 1800
    def: 1200

    passive "Effect 1" {
        scope: self
        grant: cannot_be_destroyed by battle
    }

    passive "Effect 2" {
        scope: self
        grant: cannot_be_destroyed by effect
    }

    effect "Effect 3" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned
        resolve {
            return (all, card, either controls) to hand
        }
    }

    effect "Effect 4" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            return (all, card, either controls) to hand
        }
    }

    effect "Effect 5" {
        speed: 2
        once_per_turn: soft
        resolve {
            add_to_hand target
        }
    }
}
