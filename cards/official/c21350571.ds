// 幻獣の角
// Horn of the Phantom Beast
// Transpiled from c21350571.lua

card "Horn of the Phantom Beast" {
    id: 21350571
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        damage_step: false
        on_activate {
            select (1+, card, either_player controls, where { is_face_up }) as target
        }
        on_resolve {
            equip (1, card) to (1, monster)
        }
    }

}
