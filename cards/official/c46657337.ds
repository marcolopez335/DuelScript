card "Muka Muka" {
    id: 46657337
    type: Effect Monster
    attribute: EARTH
    race: Rock
    level: 2
    atk: 600
    def: 300

    raw_effect "Effect 1" {
        effect_type: Single
        code: UpdateAttack
        property: SingleRange
        range: MonsterZone
        on_resolve {
