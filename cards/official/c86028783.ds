// 新鋭の女戦士
// Rookie Warrior Lady
// Transpiled from c86028783.lua

card "Rookie Warrior Lady" {
    id: 86028783
    type: Effect Monster
    attribute: EARTH
    race: Warrior
    level: 3
    atk: 1000
    def: 800

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: when
        trigger: when attack_declared
        activate_from: [hand, monster_zone]
        cost {
            send self to gy
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        activate_from: [gy]
        cost {
            banish self
        }
        on_resolve {
            add_to_hand (1+, card, either_player controls, where { race == Warrior and attribute == EARTH }) from gy
        }
    }

}
