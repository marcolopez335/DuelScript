card "World Soul - Carbon" {
    id: 15079028
    type: Effect Monster
    attribute: EARTH
    race: Fairy
    level: 4
    atk: 1200
    def: 1200

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        cost {
            tribute self
        }
        on_resolve {
            add_to_hand (1+, card, you controls, where { race == Fairy }) from deck
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: on_custom_event "chain_end"
        activate_from: [gy]
        on_resolve {
            return (1+, card, you controls, where { race == Fairy }) to deck shuffle
        }
    }

}
