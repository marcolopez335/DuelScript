card "Noh-P.U.N.K. Rising Scale" {
    id: 75046994
    type: Effect Monster
    attribute: WATER
    race: Sea Serpent
    level: 8
    atk: 2400
    def: 2400

    summon_condition {
        tributes_required: 2
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [hand]
        cost {
            banish self
