card "Dragonmaid Nudyarl" {
    id: 49575521
    type: Effect Monster
    attribute: WATER
    race: Dragon
    level: 7
    atk: 2600
    def: 1600

    summon_condition {
        tributes_required: 2
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        activate_from: [hand]
        on_activate {
            select (1+, monster, you controls) as target
        }
        cost {
            discard (1, card, you controls)
        }
        on_resolve {
            return (1+, monster, you controls) to deck shuffle
        }
    }

    continuous_effect "Effect 2" {
        scope: self
        grant: cannot_be_destroyed_by_effect
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: when
        trigger: during battle_phase
        on_resolve {
            return (1+, monster, you controls) to hand
            special_summon (1, monster) from gy
        }
    }

}
