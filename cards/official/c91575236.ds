// イモータル・ドラゴン
// Immortal Dragon
// Transpiled from c91575236.lua

card "Immortal Dragon" {
    id: 91575236
    type: Synchro Monster | Tuner
    attribute: DARK
    race: Zombie
    level: 6
    atk: 500
    def: 2400

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        on_resolve {
            send (1+, card, you controls, deck) to gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: when
        trigger: when_battle_damage
        activate_from: [gy]
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
