// ブラッド・ローズ・ドラゴン
// Ruddy Rose Dragon
// Transpiled from c40139997.lua

card "Ruddy Rose Dragon" {
    id: 40139997
    type: Synchro Monster
    attribute: FIRE
    race: Dragon
    level: 10
    atk: 3200
    def: 2400

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        on_resolve {
            banish (1+, card, either_player controls, gy)
            destroy (1+, card, either_player controls, gy)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        cost {
            tribute self
        }
        on_resolve {
            negate activation
            special_summon (1, monster) from gy
        }
    }

}
