// Ruddy Rose Dragon
// Transpiled from c40139997.lua

card "Ruddy Rose Dragon" {
    password: 40139997
    type: Synchro Monster
    attribute: FIRE
    race: Dragon
    level: 10
    atk: 3200
    def: 2400

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        trigger: when_summoned by_special_summon
        on_resolve {
            banish (1+, card)
            destroy (1+, card, either_player controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        optional: true
        damage_step: true
        trigger: opponent_activates [search | special_summon | send_to_gy | draw]
        cost {
            tribute self
        }
        on_resolve {
            negate activation
            special_summon (1, monster) from gy
        }
    }

}
