card "Tri-Brigade Fraktall" {
    id: 87209160
    type: Effect Monster
    attribute: FIRE
    race: Beast-Warrior
    level: 4
    atk: 1900
    def: 1600

    raw_effect "Effect 1" {
        effect_type: Ignition
        category: ToGrave
        range: Hand + MonsterZone
        count_limit: (1, 87209160)
        cost {
            send self to gy
        }
        on_resolve {
            send (1+, monster, you controls, gy) to gy
        }
    }

    raw_effect "Effect 2" {
        effect_type: Ignition
        category: SpecialSummon
        range: MonsterZone
        count_limit: (1, 0)
        cost {
            banish self
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            special_summon (1, monster) from gy
        }
    }

}
