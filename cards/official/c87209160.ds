// 鉄獣戦線 フラクトール
// Tri-Brigade Fraktall
// Transpiled from c87209160.lua

card "Tri-Brigade Fraktall" {
    id: 87209160
    type: Effect Monster
    attribute: FIRE
    race: Beast-Warrior
    level: 4
    atk: 1900
    def: 1600

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [hand, monster_zone]
        cost {
            send self to gy
        }
        on_resolve {
            send (1+, monster, you controls, gy) to gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        cost {
            banish self
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            special_summon (1, monster) from gy
        }
    }

}
