// DDDの契約変更
// D/D/D Contract Change
// Transpiled from c811734.lua

card "D/D/D Contract Change" {
    id: 811734
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        trigger: when attack_declared
        on_resolve {
            banish (1+, monster, you controls, gy)
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            add_to_hand (1+, monster, you controls) from gy
            reveal (1+, card, opponent controls)
        }
    }

}
