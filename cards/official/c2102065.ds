card "Brinegir" {
    id: 2102065
    type: Effect Monster
    attribute: WATER
    race: Sea Serpent
    level: 7
    atk: 1000
    def: 2600

    summon {
        tributes: 2
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned
        resolve {
            modify_atk self + target.atk until end_of_turn
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            modify_atk target + 1000 until end_of_turn
        }
    }

    effect "Effect 3" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: custom "chain_end"
        resolve {
            modify_atk target + 1000 until end_of_turn
        }
    }
}
