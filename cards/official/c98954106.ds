// 貪欲な瓶
// Jar of Avarice
// Transpiled from c98954106.lua

card "Jar of Avarice" {
    id: 98954106
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            return (1+, card, either_player controls) to deck shuffle
            shuffle_deck
            draw 1
        }
    }

}
