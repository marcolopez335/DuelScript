card "Deskbot 001" {
    id: 94693857
    type: Effect Monster | Tuner
    attribute: EARTH
    race: Machine
    level: 1
    atk: 500
    def: 500

    raw_effect "Effect 1" {
        effect_type: Single
        code: UpdateAttack
        property: SingleRange
        range: MonsterZone
        on_resolve {
            modifier: atk + count((1+, monster, you controls)) * 500
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single
        code: UpdateDefense
        property: SingleRange
        range: MonsterZone
        on_resolve {
            modifier: def + count((1+, monster, you controls)) * 500
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        activate_from: [gy]
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
