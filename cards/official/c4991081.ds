card "Harpie's Pet Dragon - Fearsome Fire Blast" {
    id: 4991081
    type: Effect Monster
    attribute: WIND
    race: Dragon
    level: 7
    atk: 2000
    def: 2500

    summon_condition {
        tributes_required: 2
    }

    continuous_effect "Effect 1" {
        scope: field
        grant: cannot_be_targeted_by_card_effects
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [hand]
        on_resolve {
