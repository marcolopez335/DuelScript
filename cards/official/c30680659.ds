card "Water Enchantress of the Temple" {
    id: 30680659
    type: Effect Monster
    attribute: WATER
    race: Spellcaster
    level: 3
    atk: 1500
    def: 1200

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [hand]
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        activate_from: [hand, gy]
        cost {
            banish self
        }
        on_resolve {
            return (1+, card, you controls) to hand
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        on_resolve {
            send (1+, card, you controls) to gy
            special_summon (1, monster) from gy
        }
    }

}
