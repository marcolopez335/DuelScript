card "Tindangle Dholes" {
    id: 12678601
    type: Effect Monster
    attribute: DARK
    race: Fiend
    level: 5
    atk: 1000
    def: 1000

    summon_condition {
        tributes_required: 1
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        damage_step: false
        trigger: on_custom_event "chain_end"
        on_activate {
            select (1+, spell, you controls, where { is_spell }) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single + Flip + Trigger
        category: ToGrave
        property: Delay
        count_limit: (1, 0)
        on_resolve {
            send (1+, spell, you controls, deck) to gy
        }
    }

    raw_effect "Effect 3" {
        effect_type: Single + Continuous
        code: FlipSuccess
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
