// Expendable Dai
// Transpiled from c84125619.lua

card "Expendable Dai" {
    id: 84125619
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        damage_step: false
        on_activate {
            select (1+, card, either_player controls, where { race == Warrior }) as target
        }
        on_resolve {
            destroy (1+, card, either_player controls, where { race == Warrior })
            draw 1
        }
    }

}
