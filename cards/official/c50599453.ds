card "Leafplace Plaice" {
    id: 50599453
    type: Effect Monster
    attribute: DARK
    race: Psychic
    level: 3
    atk: ?
    def: ?

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: when
        trigger: during_standby_phase
        activate_from: [hand, gy]
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single
        code: UpdateAttack
        property: SingleRange
        range: MonsterZone
        on_resolve {
            modifier: atk + count((1+, card, either_player controls)) * 200
        }
    }

    raw_effect "Effect 3" {
        effect_type: Single
        code: UpdateDefense
        property: SingleRange
        range: MonsterZone
        on_resolve {
            modifier: def + count((1+, card, either_player controls)) * 200
        }
    }

}
