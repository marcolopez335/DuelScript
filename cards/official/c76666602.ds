// 聖痕喰らいし竜
// The Dragon that Devours the Dogma
// Transpiled from c76666602.lua

card "The Dragon that Devours the Dogma" {
    id: 76666602
    type: Fusion Monster
    attribute: DARK
    race: Beast
    level: 8
    atk: 3000
    def: 2500

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        method: fusion
    }

    raw_effect "Effect 1" {
        effect_type: Single
        code: UpdateAttack
        property: SingleRange
        range: MonsterZone
        on_resolve {
            modifier: atk + 500
        }
    }

    continuous_effect "Effect 2" {
        scope: self
        grant: unaffected_by_card_effects
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        on_resolve {
            return (1+, monster, either_player controls) to deck shuffle
        }
    }

    effect "Effect 4" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: when
        trigger: during_end_phase
        activate_from: [gy]
        on_resolve {
            add_to_hand (1+, monster, either_player controls) from gy
            reveal (1+, card, opponent controls)
        }
    }

}
