        on_resolve {
            banish (1+, card, either_player controls, where { is_synchro and is_face_up })
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        activate_from: [gy]
        on_resolve {
            banish (1+, card, either_player controls, where { is_synchro and is_face_up })
            add_to_hand (1+, card, either_player controls, where { is_synchro and is_face_up }) from gy
        }
    }

}
