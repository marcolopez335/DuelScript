card "Salamangreat Weasel" {
    id: 57357130
    type: Effect Monster | Tuner
    attribute: FIRE
    race: Cyberse
    level: 3
    atk: 700
    def: 1400

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        mandatory
        resolve {
            special_summon (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
