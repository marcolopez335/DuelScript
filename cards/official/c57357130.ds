// 転生炎獣ウィーゼル
// Salamangreat Weasel
// Transpiled from c57357130.lua

card "Salamangreat Weasel" {
    id: 57357130
    type: Effect Monster | Tuner
    attribute: FIRE
    race: Cyberse
    level: 3
    atk: 700
    def: 1400

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [hand]
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        damage_step: false
        trigger: when_summoned by_special_summon
        activate_from: [gy]
        on_activate {
            select (1+, monster, you controls) as target
        }
        on_resolve {
            return (1+, monster, you controls) to deck shuffle
            special_summon (1, monster) from gy
            draw 1
        }
    }

}
