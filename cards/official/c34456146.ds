card "Sage of Benevolence - Ciela" {
    id: 34456146
    type: Effect Monster
    attribute: WATER
    race: Machine
    level: 6
    atk: 2200
    def: 1000

    summon_condition {
        tributes_required: 1
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        activate_from: [hand]
        on_resolve {
            special_summon (1, monster) from gy
        }
