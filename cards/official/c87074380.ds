card "Machina Citadel" {
    id: 87074380
    type: Effect Monster | Spirit
    attribute: EARTH
    race: Machine
    level: 10
    atk: 3000
    def: 2500

    summon_condition {
        tributes_required: 2
    }

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
