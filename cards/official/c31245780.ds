card "Battle Mania" {
    id: 31245780
    type: Normal Trap

    effect "Effect 1" {
        speed: 2
        mandatory
        resolve {
            change_position (all, card, opponent controls, from monster_zone, where is_face_up) to attack_position
            grant (all, card, opponent controls, from monster_zone, where is_face_up) must_attack until end_of_turn
            grant (all, card, opponent controls, from monster_zone, where is_face_up) cannot_change_position until end_of_turn
        }
    }
}
