card "Windwitch - Winter Bell" {
    id: 14577226
    type: Synchro Monster
    attribute: WIND
    race: Spellcaster
    level: 7
    atk: 2400
    def: 2000

    summon {
        cannot_normal_summon
        synchro materials {
            tuner: (1, tuner monster)
            non_tuner: (1+, non-tuner monster, where attribute == WIND)
        }
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        mandatory
        resolve {
            damage opponent 1000
        }
    }

    effect "Effect 2" {
        speed: 2
        once_per_turn: soft
        condition: phase == battle
        resolve {
            special_summon (all, card, either controls)
        }
    }
}
