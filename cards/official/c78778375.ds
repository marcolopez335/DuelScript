// デストーイ・クルーエル・ホエール
// Frightfur Cruel Whale
// Transpiled from c78778375.lua

card "Frightfur Cruel Whale" {
    id: 78778375
    type: Fusion Monster
    attribute: WATER
    race: Fiend
    level: 9
    atk: 2600
    def: 2400

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        method: fusion
    }

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        on_resolve {
            destroy (1+, card, you controls, deck)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        damage_step: false
        on_activate {
            select (1+, card, you controls, where { is_fusion and is_face_up }) as target
        }
        on_resolve {
            send (1+, card, you controls, deck) to gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    raw_effect "Effect 3" {
        effect_type: Single
        code: UpdateAttack
        property: BothSide
        on_resolve {
            modifier: atk + 0
        }
    }

}
