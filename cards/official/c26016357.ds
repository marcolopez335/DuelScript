// マドルチェ・マーマメイド
// Madolche Marmalmaide
// Transpiled from c26016357.lua

card "Madolche Marmalmaide" {
    id: 26016357
    type: Effect Monster
    attribute: EARTH
    race: Spellcaster
    level: 4
    atk: 800
    def: 2000

    effect "Effect 1" {
        speed: spell_speed_1
        trigger: on_custom_event "chain_end"
        on_resolve {
            return (1+, spell, either_player controls) to deck shuffle
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        optional: true
        timing: when
        damage_step: false
        trigger: on_custom_event "chain_active"
        on_activate {
            select (1+, spell, either_player controls) as target
        }
        on_resolve {
            add_to_hand (1+, spell, either_player controls) from gy
            reveal (1+, card, opponent controls)
        }
    }

}
