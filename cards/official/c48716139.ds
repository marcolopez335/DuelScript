// 草薙剣
// Sword of Kusanagi
// Transpiled from c48716139.lua

card "Sword of Kusanagi" {
    id: 48716139
    type: Equip Spell

    raw_effect "Effect 1" {
        effect_type: Equip
        code: GraveRedirectCb
        on_resolve {
            register_effect on self { grant: piercing duration: until_end_of_turn }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        trigger: on_custom_event "chain_end"
        on_resolve {
            add_to_hand (1+, card, either_player controls) from gy
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        on_resolve {
            equip self to (1, monster, you controls)
        }
    }

}
