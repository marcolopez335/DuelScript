// ナンバーズハンター
// Numeral Hunter
// Transpiled from c37115973.lua

card "Numeral Hunter" {
    id: 37115973
    type: Effect Monster
    attribute: LIGHT
    race: Warrior
    level: 4
    atk: 1600
    def: 1400

    effect "Effect 1" {
        speed: spell_speed_1
        trigger: when_summoned
        on_resolve {
            return (1+, monster, either_player controls) to deck shuffle
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        trigger: when_summoned by_flip_summon
        on_resolve {
            return (1+, monster, either_player controls) to deck shuffle
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        trigger: when_summoned by_special_summon
        on_resolve {
            return (1+, monster, either_player controls) to deck shuffle
        }
    }

    continuous_effect "Effect 4" {
        scope: field
        grant: cannot_be_used_as_material
    }

    continuous_effect "Effect 5" {
        scope: self
        grant: cannot_be_destroyed_by_battle
    }

    continuous_effect "Effect 6" {
        scope: self
        grant: unaffected_by_card_effects
    }

}
