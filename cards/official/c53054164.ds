// わくわくメルフィーズ
// Joyous Melffys
// Transpiled from c53054164.lua

card "Joyous Melffys" {
    id: 53054164
    type: Xyz Monster
    attribute: EARTH
    race: Beast
    rank: 2
    atk: 2000
    def: 500

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        same_level: true
        method: xyz
    }

    effect "Effect 1" {
        speed: spell_speed_1
        cost {
            detach 1 overlay_unit from self
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            set_flag "tracked" on self
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        damage_step: false
        on_resolve {
            return (1+, card, you controls) to deck shuffle
            special_summon (1, monster) from gy
        }
    }

    continuous_effect "Effect 3" {
        scope: field
        grant: direct_attack
    }

}
