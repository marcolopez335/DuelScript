card "Sangenpai Bident Dragion" {
    id: 82570174
    type: Synchro Monster | Tuner
    attribute: FIRE
    race: Dragon
    level: 7
    atk: 2600
    def: 2000

    summon {
        cannot_normal_summon
        synchro materials {
            tuner: (1, tuner monster, where race == Dragon)
            non_tuner: (1+, non-tuner monster, where race == Dragon)
        }
    }

    passive "Effect 4" {
        scope: self
        grant: cannot_attack
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            special_summon (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 2
        once_per_turn: soft
        resolve {
            special_summon (all, card, either controls)
            destroy (all, card, either controls)
        }
    }
}
