card "Ryu-Kishin Clown" {
    id: 42647539
    type: Effect Monster
    attribute: DARK
    race: Fiend
    level: 2
    atk: 800
    def: 500

    effect "Effect 1" {
        speed: spell_speed_1
        damage_step: false
        trigger: when_summoned
        on_activate {
            select (1+, card, either_player controls, where { is_face_up }) as target
        }
        on_resolve {
            change_battle_position (1, monster)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        damage_step: false
