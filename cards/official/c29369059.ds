// ヤミー☆サプライズ
// Yummy☆Surprise
// Transpiled from c29369059.lua

card "Yummy☆Surprise" {
    id: 29369059
    type: Quick-Play Spell

    effect "Effect 1" {
        speed: spell_speed_1
        on_resolve {
            return (1+, card, either_player controls) to hand
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            return (1+, card, either_player controls) to hand
            reveal (1+, card, opponent controls)
            shuffle_hand
            send (1+, card, either_player controls) to gy
            special_summon (1, monster) from gy
        }
    }

}
