// 魔救の奇跡－ドラガイト
// Adamancipator Risen - Dragite
// Transpiled from c9464441.lua

card "Adamancipator Risen - Dragite" {
    id: 9464441
    type: Synchro Monster
    attribute: WATER
    race: Rock
    level: 8
    atk: 3000
    def: 2200

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        on_resolve {
            reveal (1, card, opponent controls, deck)
            return (1+, card, opponent controls) to hand
            shuffle_hand
            send_to_deck (1+, card, you controls) bottom
            send_to_deck (1+, card, you controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            negate activation
            destroy (1+, card, opponent controls)
        }
    }

}
