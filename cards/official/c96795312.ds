// 武の賢者－アーカス
// Sage of Strength - Akash
// Transpiled from c96795312.lua

card "Sage of Strength - Akash" {
    id: 96795312
    type: Effect Monster
    attribute: FIRE
    race: Machine
    level: 5
    atk: 2400
    def: 200

    summon_condition {
        tributes_required: 1
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        activate_from: [hand]
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    replacement_effect "Effect 2" {
        instead_of: destroyed_by_any
        do: {
            banish self
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        damage_step: false
        trigger: on_custom_event "chain_end"
        on_activate {
            select (1+, spell, you controls) as target
        }
        on_resolve {
            add_to_hand (1+, spell, you controls) from hand
        }
    }

}
