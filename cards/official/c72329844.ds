card "Spright Sprind" {
    id: 72329844
    type: Link Monster
    attribute: FIRE
    race: Thunder
    link: 2
    link_arrows: [top_right, bottom_left]
    atk: 1400

    summon {
        cannot_normal_summon
        link materials: (2, monster)
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            send (all, card, either controls) to gy
        }
    }

    effect "Effect 3" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        cost {
            detach 1 from self
        }
        resolve {
            add_to_hand (all, card, either controls)
        }
    }
}
