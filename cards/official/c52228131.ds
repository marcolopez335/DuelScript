card "Parry" {
    id: 52228131
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            reveal (1+, card, opponent controls)
            return (1+, card, you controls) to deck shuffle
            negate activation
            destroy (1+, card, you controls, hand)
        }
    }

