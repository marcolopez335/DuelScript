// 黄金のホムンクルス
// Golden Homunculus
// Transpiled from c27408609.lua

card "Golden Homunculus" {
    id: 27408609
    type: Effect Monster
    attribute: LIGHT
    race: Warrior
    level: 6
    atk: 1500
    def: 1500

    summon_condition {
        tributes_required: 1
    }

    raw_effect "Effect 1" {
        effect_type: Single
        code: UpdateAttack
        property: SingleRange
        range: MonsterZone
        on_resolve {
            modifier: atk + count((1+, card, either_player controls)) * 300
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single
        code: UpdateDefense
        property: SingleRange
        range: MonsterZone
        on_resolve {
            modifier: def + count((1+, card, either_player controls)) * 300
        }
    }

}
