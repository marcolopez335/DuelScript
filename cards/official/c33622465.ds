// 救護部隊
// First-Aid Squad
// Transpiled from c33622465.lua

card "First-Aid Squad" {
    id: 33622465
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        damage_step: false
        on_activate {
            select (1+, card, either_player controls, where { is_monster }) as target
        }
        on_resolve {
            add_to_hand (1+, card, either_player controls, where { is_monster }) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        timing: when
        trigger: when_battle_damage
        activate_from: [gy]
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
