card "Puppet Pawn" {
    id: 89839552
    type: Effect Monster
    attribute: EARTH
    race: Warrior
    level: 3
    atk: 800
    def: 1200

    continuous_effect "Effect 1" {
        scope: self
        grant: direct_attack
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: when
        trigger: when_battle_destroyed
        on_resolve {
            add_to_hand (1+, monster, opponent controls) from deck
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        activate_from: [gy]
        cost {
            banish self
        }
        on_resolve {
            add_to_hand (1+, monster, opponent controls) from deck
            reveal (1+, card, opponent controls)
            add_to_hand (1+, monster, opponent controls) from deck
            reveal (1+, card, opponent controls)
        }
    }

}
