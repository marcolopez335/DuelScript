card "Full Active Duplex" {
    id: 4483598
    type: Effect Monster
    attribute: WIND
    race: Cyberse
    level: 9
    atk: 2800
    def: 1000

    summon {
        tributes: 2
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        mandatory
        cost {
            banish self
        }
        resolve {
            special_summon (all, card, either controls)
        }
