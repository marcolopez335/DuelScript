// Ｕ．Ａ．ハイパー・スタジアム
// U.A. Hyper Stadium
// Transpiled from c12931061.lua

card "U.A. Hyper Stadium" {
    id: 12931061
    type: Field Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        on_resolve {
            add_to_hand (1+, monster, you controls) from gy
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        activate_from: [field_zone]
        cost {
            pay_lp your_lp / 2
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            set_flag "tracked" on self
        }
    }

}
