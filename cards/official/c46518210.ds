// 溟界神－ネフェルアビス
// Nephilabyss, the Ogdoadic Overlord
// Transpiled from c46518210.lua

card "Nephilabyss, the Ogdoadic Overlord" {
    id: 46518210
    type: Effect Monster
    attribute: DARK
    race: Reptile
    level: 10
    atk: 2200
    def: 3100

    summon_condition {
        tributes_required: 2
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: when
        trigger: on_custom_event "chain_end"
        activate_from: [gy]
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_activate {
            select (1+, monster, either_player controls, where { is_monster }) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    continuous_effect "Effect 3" {
        scope: field
        grant: cannot_be_used_as_material
    }

}
