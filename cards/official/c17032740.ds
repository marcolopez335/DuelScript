card "Elemental HERO Chaos Neos" {
    id: 17032740
    type: Fusion Monster
    attribute: DARK
    race: Warrior
    level: 9
    atk: 3000
    def: 2500

    summon {
        cannot_normal_summon
        fusion materials: "Elemental HERO Neos" + "Neo-Spacian Dark Panther" + "Neo-Spacian Glow Moss"
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: soft
        mandatory
        condition: phase == main1
        resolve {
            destroy (all, card, either controls)
            return (all, card, either controls) to hand
        }
    }

    effect "Effect 2" {
        speed: 1
        mandatory
        trigger: end_phase
        resolve {
            return self to deck
        }
    }

    effect "Effect 3" {
        speed: 1
        timing: when
        trigger: end_phase
        resolve {
            return self to deck
        }
    }
}
