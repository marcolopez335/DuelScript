    raw_effect "Effect 4" {
        effect_type: Single + Trigger
        category: ToHand + Search
        code: TurnEnd
        property: Delay
        count_limit: (1, 26400609)
        on_resolve {
            add_to_hand (1+, monster, you controls) from gy
