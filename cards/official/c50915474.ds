card "Goddess of the Two Sides" {
    id: 50915474
    type: Effect Monster
    attribute: LIGHT
    race: Fairy
    level: 3
    atk: 950
    def: 700

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned
        resolve {
            return (all, card, either controls) to hand
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            return (all, card, either controls) to hand
        }
    }

    effect "Effect 3" {
        speed: 1
        once_per_turn: soft
        mandatory
        resolve {
            add_to_hand target
        }
    }
}
