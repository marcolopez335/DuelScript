card "Dragon's Gunfire" {
    id: 55991637
    type: Normal Spell

    effect "Effect 1" {
        speed: spell_speed_1
        on_resolve {
            deal_damage to opponent: 1000
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        damage_step: false
        on_activate {
            select (1+, monster, you controls) as target
        }
        on_resolve {
            destroy (1+, monster, you controls)
        }
    }

}
