card "Herald of Creation" {
    id: 66337215
    type: Effect Monster
    attribute: LIGHT
    race: Spellcaster
    level: 4
    atk: 1800
    def: 600

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_activate {
            select (1+, card, you controls, where { level >= 7 }) as target
        }
        on_resolve {
            add_to_hand (1+, card, you controls, where { level >= 7 }) from hand
        }
    }

}
