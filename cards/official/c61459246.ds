// Dream Mirror Oneiromancy
// Transpiled from c61459246.lua

card "Dream Mirror Oneiromancy" {
    password: 61459246
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        trigger: opponent_activates [search | special_summon | send_to_gy | draw]
        on_resolve {
            negate activation
            destroy (1+, card, either_player controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        trigger: when_summoned by_special_summon
        on_resolve {
            negate summon
            destroy (1+, card, either_player controls)
        }
    }

}
