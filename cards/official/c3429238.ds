card "Drill Warrior" {
    id: 3429238
    type: Synchro Monster
    attribute: EARTH
    race: Warrior
    level: 6
    atk: 2400
    def: 2000

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        on_resolve {
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        on_resolve {
            send (1+, monster, opponent controls, hand) to gy
            banish (1+, monster, opponent controls, hand)
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        trigger: during_standby_phase
        activate_from: [banished]
        on_resolve {
            special_summon (1, monster) from gy
            add_to_hand (1+, monster, opponent controls) from hand
            reveal (1+, card, opponent controls)
        }
    }

