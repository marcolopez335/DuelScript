card "Abyss Actor - Sassy Rookie" {
    id: 51028231
    type: Effect Monster | Pendulum Monster
    attribute: DARK
    race: Fiend
    level: 4
    scale: 2
    atk: 1700
    def: 1000

    passive "Effect 2" {
        scope: self
        grant: cannot_be_destroyed
    }

    effect "Effect 3" {
        speed: 1
        timing: if
        trigger: destroyed
        resolve {
            special_summon (all, card, either controls)
        }
    }

    effect "Effect 4" {
        speed: 1
        timing: if
        trigger: destroyed
        resolve {
            destroy (all, card, either controls)
        }
    }

    replacement "Effect 1" {
        instead_of: destroyed
        do {
            return self to extra_deck
        }
    }
}
