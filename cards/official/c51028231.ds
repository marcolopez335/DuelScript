card "Abyss Actor - Sassy Rookie" {
    id: 51028231
    type: Effect Monster | Pendulum Monster
    attribute: DARK
    race: Fiend
    level: 4
    scale: 2
    atk: 1700
    def: 1000

    replacement_effect "Effect 1" {
        instead_of: destroyed_by_any
        do: {
            return self to extra_deck
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single
        code: CannotHandReturn
        property: SingleRange
        range: MonsterZone
        on_resolve {
            register_effect on self { grant: cannot_be_destroyed duration: until_end_of_turn }
        }
    }

    raw_effect "Effect 3" {
        effect_type: Single + Trigger
        category: SpecialSummon
        code: Destroyed
        property: Delay
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    raw_effect "Effect 4" {
        effect_type: Single + Trigger
        category: Destroy
        code: Destroyed
        property: CardTarget + Delay
        on_resolve {
            destroy (1+, card, you controls, deck)
        }
    }

}
