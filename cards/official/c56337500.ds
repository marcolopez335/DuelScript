// サイバース・リマインダー
// Cyberse Reminder
// Transpiled from c56337500.lua

card "Cyberse Reminder" {
    id: 56337500
    type: Xyz Monster
    attribute: LIGHT
    race: Cyberse
    rank: 3
    atk: 1800
    def: 800

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        same_level: true
        method: xyz
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, spell, you controls) as target
        }
        cost {
            detach 1 overlay_unit from self
        }
        on_resolve {
            add_to_hand (1+, spell, you controls) from deck
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        trigger: when_destroyed
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    continuous_effect "Effect 3" {
        scope: field
        grant: cannot_be_used_as_material
    }

}
