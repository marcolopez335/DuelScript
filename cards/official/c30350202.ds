// 凶征竜－エクレプシス
// Eclipse, Dragon Ruler of Catastrophes
// Transpiled from c30350202.lua

card "Eclipse, Dragon Ruler of Catastrophes" {
    id: 30350202
    type: Xyz Monster
    attribute: DARK
    race: Dragon
    rank: 7
    atk: 2700
    def: 1900

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        same_level: true
        method: xyz
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        damage_step: false
        trigger: when_summoned by_special_summon
        on_activate {
            select (1+, card, you controls) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
            return (1+, card, you controls) to deck shuffle
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        cost {
            detach 2 overlay_unit from self
        }
        on_resolve {
            negate activation
            banish (1+, card, you controls, deck)
        }
    }

}
