// Eclipse, Dragon Ruler of Catastrophes
// Transpiled from c30350202.lua

card "Eclipse, Dragon Ruler of Catastrophes" {
    password: 30350202
    type: Xyz Monster
    attribute: DARK
    race: Dragon
    rank: 7
    atk: 2700
    def: 1900

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        trigger: when_summoned by_special_summon
        on_resolve {
            special_summon (1, monster) from gy
            return (1, card) to deck shuffle
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        damage_step: true
        trigger: opponent_activates [search | special_summon | send_to_gy | draw]
        cost {
            detach 1 overlay_unit from self
        }
        on_resolve {
            negate activation
            banish (1+, card)
        }
    }

}
