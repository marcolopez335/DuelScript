card "K9-X 'Ripper/M'" {
    id: 31286915
    type: Xyz Monster
    attribute: WIND
    race: Beast
    rank: 9
    atk: 3100
    def: 2600

    summon {
        cannot_normal_summon
    }

    passive "Effect 1" {
        scope: self
        grant: piercing
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            return (all, card, either controls) to deck
        }
    }

    effect "Effect 3" {
        speed: 2
        once_per_turn: soft
        timing: when
        trigger: opponent_activates [activate_spell, activate_trap, activate_spell]
        cost {
            detach 2 from self
        }
        resolve {
            negate
            destroy (all, card, either controls)
        }
    }
}
