card "Gagaga Samurai" {
    id: 91499077
    type: Xyz Monster
    attribute: EARTH
    race: Warrior
    rank: 4
    atk: 1900
    def: 1600

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        same_level: true
        method: xyz
    }

    raw_effect "Effect 1" {
        effect_type: Ignition
        property: CardTarget
        range: MonsterZone
        count_limit: (1, 0)
        cost {
            detach 1 overlay_unit from self
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    raw_effect "Effect 2" {
        effect_type: Field + Trigger
        code: BattleTarget
        range: MonsterZone
        on_resolve {
            change_battle_position (1, monster)
        }
    }

}
