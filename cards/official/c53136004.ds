card "Emperor of Prophecy" {
    id: 53136004
    type: Effect Monster
    attribute: DARK
    race: Spellcaster
    level: 5
    atk: 2300
    def: 2000

    summon_condition {
        tributes_required: 1
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, monster, you controls, where { is_face_up }) as target
        }
        cost {
            banish self
        }
        on_resolve {
            take_control of (1, monster, opponent controls)
        }
    }

}
