    effect "Effect 3" {
        speed: spell_speed_1
        optional: true
        timing: if
        damage_step: false
        trigger: on_custom_event "chain_end"
        on_activate {
            select (1+, card, either_player controls, where { is_face_up and race == Machine and attribute == EARTH }) as target
        }
        on_resolve {
            destroy (1+, card, either_player controls, where { is_face_up and race == Machine and attribute == EARTH })
