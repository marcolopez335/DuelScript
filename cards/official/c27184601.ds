card "Artmage Diactorus" {
    password: 27184601
    type: Fusion Monster
    attribute: LIGHT
    race: Fairy
    level: 8
    atk: 2800
    def: 2500

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        on_resolve {
            change_battle_position (1, monster)
        }
