// キラーチューン・シンクロ
// Kewl Tune Synchro
// Transpiled from c78058681.lua

card "Kewl Tune Synchro" {
    password: 78058681
    type: Quick-Play Spell

    raw_effect "Effect 1" {
        effect_type: Activate
        category: ToHand + SpecialSummon + Search
        code: FreeChain
        count_limit: (2, 78058681)
        on_resolve {
            add_to_hand (1+, monster, either_player controls) from gy
            reveal (1+, card, opponent controls)
            shuffle_hand
            synchro_summon (1, synchro monster) using (1+, monster, you controls)
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
