card "Prank-Kids Bow-Wow-Bark" {
    id: 43886072
    type: Link Monster
    attribute: FIRE
    race: Pyro
    link: 2
    link_arrows: [right, bottom]
    atk: 2000

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ effect monster
        method: link
    }

    raw_effect "Effect 1" {
        effect_type: Field
        code: UpdateAttack
        range: MonsterZone
        on_resolve {
            modifier: atk + 1000
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        damage_step: false
        cost {
            tribute self
        }
        on_resolve {
            add_to_hand (1+, card, you controls) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
