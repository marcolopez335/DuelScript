// マシンナーズ・リザーブレイク
// Machina Resavenger
// Transpiled from c54563536.lua

card "Machina Resavenger" {
    id: 54563536
    type: Effect Monster
    attribute: DARK
    race: Machine
    level: 4
    atk: 1200
    def: 1800

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        damage_step: false
        activate_from: [hand, monster_zone]
        on_activate {
            select (1+, card, either_player controls) as target
        }
        cost {
            send self to gy
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: when
        trigger: when_battle_damage
        activate_from: [gy]
        on_resolve {
            add_to_hand (1+, card, either_player controls) from gy
        }
    }

}
