// コーンフィールド コアトル
// Cornfield Coatl
// Transpiled from c92565383.lua

card "Cornfield Coatl" {
    id: 92565383
    type: Effect Monster
    attribute: WIND
    race: Unknown
    level: 4
    atk: 500
    def: 1700

    continuous_effect "Effect 1" {
        scope: field
        grant: cannot_be_destroyed_by_battle
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [hand]
        cost {
            discard (1, card, you controls)
        }
        on_resolve {
            add_to_hand (1+, monster, you controls) from deck
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 3" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        activate_from: [monster_zone, gy]
        cost {
            banish self
        }
        on_resolve {
            negate effect
            destroy (1+, monster, you controls, deck)
        }
    }

}
