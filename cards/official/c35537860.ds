// 精神同調波
// Synch Blast Wave
// Transpiled from c35537860.lua

card "Synch Blast Wave" {
    id: 35537860
    type: Normal Spell

    effect "Effect 1" {
        speed: spell_speed_1
        damage_step: false
        on_activate {
            select (1+, monster, you controls, where { is_face_up and is_synchro }) as target
        }
        on_resolve {
            destroy (1+, monster, you controls, where { is_face_up and is_synchro })
        }
    }

}
