// ロイヤル・ペンギンズ・ガーデン
// Royal Penguins Garden
// Transpiled from c80893872.lua

card "Royal Penguins Garden" {
    id: 80893872
    type: Continuous Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        on_resolve {
            add_to_hand (1+, card, you controls) from deck
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        activate_from: [spell_trap_zone]
        on_resolve {
            reveal (1+, card, opponent controls)
            shuffle_hand
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            discard (1, card)
        }
    }

}
