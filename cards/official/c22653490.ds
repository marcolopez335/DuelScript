// 電光千鳥
// Lightning Chidori
// Transpiled from c22653490.lua

card "Lightning Chidori" {
    id: 22653490
    type: Xyz Monster
    attribute: WIND
    race: Thunder
    rank: 4
    atk: 1900
    def: 1600

    materials {
        require: 2+ monster
        same_level: true
        method: xyz
    }

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        damage_step: false
        trigger: when_summoned by_special_summon
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            return (1+, card, either_player controls) to deck shuffle
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_activate {
            select (1+, card, either_player controls) as target
        }
        cost {
            detach 1 overlay_unit from self
        }
        on_resolve {
            return (1+, card, either_player controls) to deck shuffle
        }
    }

}
