card "Drytron Nu II" {
    id: 22435424
    type: Effect Monster | Spirit
    attribute: LIGHT
    race: Machine
    level: 1
    atk: 2000
    def: 0

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [hand, gy]
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        on_resolve {
            return (1+, monster, either_player controls) to hand
            reveal (1+, card, opponent controls)
        }
    }

    continuous_effect "Effect 3" {
        scope: field
        grant: cannot_be_used_as_material
    }

    redirect_effect "Effect 4" {
        when_going_to: field
        redirect_to: banished
    }

