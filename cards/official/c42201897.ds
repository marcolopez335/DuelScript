// アザミナ・ハマルティア
// Azamina Determination
// Transpiled from c42201897.lua

card "Azamina Determination" {
    id: 42201897
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        on_resolve {
            reveal (1+, card, opponent controls)
            return (1+, spell, you controls) to deck shuffle
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        damage_step: false
        activate_from: [gy]
        cost {
            banish self
        }
        on_resolve {
            set (1, card)
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
