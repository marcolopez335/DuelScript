card "Rage Rose Witch" {
    id: 33955120
    type: Synchro Monster
    attribute: DARK
    race: Plant
    level: 6
    atk: 1600
    def: 2400

    summon {
        cannot_normal_summon
    }

    passive "Effect 1" {
        scope: self
        grant: cannot_be_destroyed by effect
    }

    passive "Effect 4" {
        scope: self
        grant: cannot_attack
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            send (all, card, either controls) to gy
        }
    }

    effect "Effect 3" {
        speed: 1
        once_per_turn: soft
        timing: when
        trigger: destroyed
        resolve {
            special_summon (all, card, either controls)
        }
    }
}
