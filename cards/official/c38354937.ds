card "Locomotion R-Genex" {
    id: 38354937
    type: Synchro Monster
    attribute: DARK
    race: Machine
    level: 9
    atk: 2500
    def: 2000

    summon {
        cannot_normal_summon
        synchro materials {
            tuner: (1, tuner monster, where archetype == "Genex")
            non_tuner: (1+, non-tuner monster, where attribute == DARK)
        }
    }

    effect "Effect 1" {
        speed: 1
        mandatory
        trigger: summoned by special
        resolve {
            take_control (all, card, either controls)
        }
    }
}
