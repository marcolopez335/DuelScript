card "Prank-Kids Battle Butler" {
    id: 81997228
    type: Fusion Monster
    attribute: WIND
    race: Thunder
    level: 10
    atk: 3000
    def: 3000

    summon {
        cannot_normal_summon
        fusion materials: "Prank-Kids Fansies" + "Prank-Kids Lampsies" + "Prank-Kids Dropsies"
    }

    effect "Effect 2" {
        speed: 2
        cost {
            tribute self
        }
        resolve {
            destroy (all, card, either controls)
        }
    }

    effect "Effect 3" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: custom "chain_end"
        resolve {
            special_summon (all, card, either controls)
        }
    }
}
