    }

    raw_effect "Effect 1" {
        effect_type: Field + Trigger
        category: Destroy
        code: SpecialSummonSuccess
        property: Delay
        range: MonsterZone
        count_limit: (1, 42307760)
        on_resolve {
            destroy (1+, monster, either_player controls)
