card "Transcendosaurus Exaraptor" {
    id: 56818742
    type: Link Monster
    attribute: DARK
    race: Dinosaur
    link: 3
    link_arrows: [top, left, right]
    atk: 3000

    summon {
        cannot_normal_summon
        link materials: (2+, monster, where race == Dinosaur)
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            special_summon (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: battle_damage
        resolve {
            draw 1
        }
    }

    effect "Effect 3" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: custom "chain_end"
        resolve {
            draw 1
        }
    }

    effect "Effect 4" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: destroyed
        resolve {
            return (all, card, either controls) to deck
            special_summon (all, card, either controls)
        }
    }
}
