card "Metalfoes Orichalc" {
    id: 28016193
    type: Fusion Monster
    attribute: FIRE
    race: Psychic
    level: 8
    atk: 2800
    def: 2200

    summon {
        cannot_normal_summon
        fusion materials: (2, monster, where archetype == "Metalfoes")
    }

    passive "Effect 1" {
        scope: self
        grant: piercing
    }

    effect "Effect 2" {
        speed: 1
        timing: if
        trigger: custom "chain_end"
        condition: previous_location == field
        resolve {
            destroy (all, card, either controls)
        }
    }
}
