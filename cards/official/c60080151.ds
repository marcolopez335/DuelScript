// 好敵手の記憶
// Memory of an Adversary
// Transpiled from c60080151.lua

card "Memory of an Adversary" {
    id: 60080151
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        trigger: when attack_declared
        on_resolve {
            deal_damage to opponent: 1000
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
