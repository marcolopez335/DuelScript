// 星遺物の醒存
// World Legacy Survivor
// Transpiled from c31706048.lua

card "World Legacy Survivor" {
    id: 31706048
    type: Normal Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        on_resolve {
            reveal (1, card, opponent controls, deck)
            add_to_hand (1+, monster, either_player controls) from gy
            reveal (1+, card, opponent controls)
            shuffle_hand
            send (1+, monster, either_player controls) to gy
            send (1+, monster, either_player controls) to gy
            return (1+, monster, either_player controls) to deck shuffle
            shuffle_deck
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
