card "Metalfoes Mithrilium" {
    id: 4688231
    type: Fusion Monster
    attribute: FIRE
    race: Psychic
    level: 6
    atk: 2600
    def: 1000

    summon {
        cannot_normal_summon
        special_summon_procedure {
            from: extra_deck
            to: your_field
        }
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        mandatory
        resolve {
            return (all, card, either controls) to deck
            add_to_hand (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        timing: if
        trigger: custom "chain_end"
        condition: previous_location == field
        resolve {
            special_summon (all, card, either controls)
        }
    }
}
