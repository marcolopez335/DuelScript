// スプリガンズ・コール！
// Springans Call!
// Transpiled from c83199011.lua

card "Springans Call!" {
    id: 83199011
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, card, you controls, where { is_fusion }) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        damage_step: false
        activate_from: [gy]
        on_activate {
            select (1+, card, you controls, where { is_fusion }) as target
        }
        cost {
            banish self
        }
        on_resolve {
            attach (1, card) to self as_material
        }
    }

}
