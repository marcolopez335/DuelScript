card "Toxic Boxfish" {
    id: 48882106
    type: Synchro Monster
    attribute: WATER
    race: Fish
    level: 4
    atk: 1800
    def: 800

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
