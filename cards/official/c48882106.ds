card "Toxic Boxfish" {
    password: 48882106
    type: Synchro Monster
    attribute: WATER
    race: Fish
    level: 4
    atk: 1800
    def: 800

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
