        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            banish (1+, card, either_player controls)
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single + Trigger
        category: Disable
        code: TurnEnd
        property: CardTarget + Delay
        count_limit: (1, 0)
        on_resolve {
        }
    }

