card "Photon Change" {
    id: 42925441
    type: Continuous Trap

    effect "Effect 1" {
        speed: 2
        mandatory
        resolve {
            special_summon (1, card, you control, from deck)
            add_to_hand (1, card, you control, from deck)
            special_summon target
            add_to_hand target
        }
    }

    effect "Effect 2" {
        speed: 2
        once_per_turn: hard
        resolve {
            special_summon (all, card, either controls)
            add_to_hand (all, card, either controls)
            special_summon (all, card, either controls)
            add_to_hand (all, card, either controls)
        }
    }
}
