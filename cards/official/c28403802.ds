// Ｐ.Ｕ.Ｎ.Ｋ. ＪＡＭドラゴン・ドライブ
// P.U.N.K. JAM Dragon Drive
// Transpiled from c28403802.lua

card "P.U.N.K. JAM Dragon Drive" {
    id: 28403802
    type: Synchro Monster
    attribute: EARTH
    race: Psychic
    level: 8
    atk: 2700
    def: 2400

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        cost {
            pay_lp 600
        }
        on_resolve {
            add_to_hand (1, card, you controls) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        activate_from: [gy]
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
