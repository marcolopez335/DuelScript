// 教導の死徒
// Dogmatika Lawbringer
// Transpiled from c30394645.lua

card "Dogmatika Lawbringer" {
    id: 30394645
    type: Effect Monster
    attribute: LIGHT
    race: Spellcaster
    level: 8
    atk: 2000
    def: 2000

    summon_condition {
        tributes_required: 2
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [hand]
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        on_resolve {
            send (1+, monster, either_player controls) to gy
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        damage_step: false
        trigger: on_custom_event "chain_end"
        on_resolve {
            return (1+, monster, either_player controls) to hand
        }
    }

}
