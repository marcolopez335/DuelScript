// 海造賊－静寂のメルケ号
// Plunder Patrollship Moerk
// Transpiled from c20248754.lua

card "Plunder Patrollship Moerk" {
    id: 20248754
    type: Xyz Monster
    attribute: DARK
    race: Fiend
    rank: 4
    atk: 1000
    def: 2500

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        same_level: true
        method: xyz
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, spell, you controls, where { is_face_up }) as target
        }
        on_resolve {
            banish (1+, spell, you controls, deck)
            add_to_hand (1+, spell, you controls, where { is_face_up }) from deck
            reveal (1+, card, opponent controls)
            shuffle_deck
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        damage_step: false
        on_activate {
            select (1+, spell, you controls, where { is_face_up }) as target
        }
        on_resolve {
            banish (1+, spell, you controls, deck)
            add_to_hand (1+, spell, you controls, where { is_face_up }) from deck
            reveal (1+, card, opponent controls)
            shuffle_deck
        }
    }

    replacement_effect "Effect 3" {
        instead_of: destroyed_by_any
        do: {
            banish self
        }
    }

}
