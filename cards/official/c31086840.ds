    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        timing: when
        trigger: when attack_declared
        on_resolve {
            attach (1, card) to self as_material
            special_summon (1, monster) from gy
            destroy (1+, card, either_player controls)
        }
    }

