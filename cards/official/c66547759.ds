card "Number 23: Lancelot, Dark Knight of the Underworld" {
    id: 66547759
    type: Xyz Monster
    attribute: DARK
    race: Zombie
    rank: 8
    atk: 2000
    def: 1500

    materials {
        require: 2+ monster
        same_level: true
        method: xyz
    }

    summon_condition {
