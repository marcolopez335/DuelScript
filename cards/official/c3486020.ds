card "Yoko, the Graceful Mayakashi" {
    id: 3486020
    type: Synchro Monster
    attribute: FIRE
    race: Zombie
    level: 9
    atk: 2900
    def: 2400

    summon {
        cannot_normal_summon
        synchro materials {
            tuner: (1, tuner monster)
            non_tuner: (1+, non-tuner monster)
        }
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            destroy (1, monster, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: destroyed
        resolve {
            banish (all, card, either controls)
            special_summon (all, card, either controls)
        }
    }
}
