card "Junk Warrior Extreme" {
    id: 16327715
    type: Synchro Monster
    attribute: DARK
    race: Warrior
    level: 8
    atk: 2900
    def: 2300

    summon {
        cannot_normal_summon
        special_summon_procedure {
            from: extra_deck
            to: your_field
        }
    }

    passive "Effect 3" {
        scope: self
        grant: cannot_activate effects
    }

    passive "Effect 4" {
        scope: self
        grant: cannot_attack
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            special_summon (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        timing: when
        trigger: battle_damage
        cost {
            banish self
        }
        resolve {
            special_summon (all, card, either controls)
        }
    }
}
