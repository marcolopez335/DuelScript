// 真六武衆－シエン
// Legendary Six Samurai - Shi En
// Transpiled from c29981921.lua

card "Legendary Six Samurai - Shi En" {
    id: 29981921
    type: Synchro Monster
    attribute: DARK
    race: Warrior
    level: 5
    atk: 2500
    def: 1400

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            negate activation
            destroy (1+, monster, you controls)
        }
    }

    replacement_effect "Effect 2" {
        instead_of: destroyed_by_any
        do: {
            banish self
        }
    }

}
