// セフィラの輝跡
// Zefra Path
// Transpiled from c5255013.lua

card "Zefra Path" {
    id: 5255013
    type: Continuous Spell

    effect "Effect 1" {
        speed: spell_speed_1
        on_resolve {
            return (1+, monster, you controls) to deck shuffle
        }
    }

    continuous_effect "Effect 2" {
        scope: field
        grant: cannot_be_used_as_material
    }

    continuous_effect "Effect 3" {
        scope: self
        grant: cannot_be_targeted_by_card_effects
    }

    raw_effect "Effect 4" {
        effect_type: Field + Continuous
        code: SpecialSummonAttempt
        range: SpellTrapZone
        on_resolve {
            destroy (1+, monster, you controls)
        }
    }

}
