// セフィラの輝跡
// Zefra Path
// Transpiled from c5255013.lua

card "Zefra Path" {
    id: 5255013
    type: Continuous Spell

    raw_effect "Effect 1" {
        effect_type: Activate
        category: ToDeck
        code: FreeChain
        on_resolve {
            return (1+, monster, you controls) to deck shuffle
        }
    }

    raw_effect "Effect 2" {
        effect_type: Field
        code: CannotDisable
        property: InitialValue
        range: SpellTrapZone
        on_resolve {
            register_effect on self { grant: cannot_be_used_as_material duration: until_end_of_turn }
        }
    }

    raw_effect "Effect 3" {
        effect_type: Single
        code: CannotDirectAttack2
        property: SingleRange
        range: SpellTrapZone
        on_resolve {
            register_effect on self { grant: cannot_be_targeted_by_card_effects duration: until_end_of_turn }
        }
    }

    raw_effect "Effect 4" {
        effect_type: Field + Continuous
        code: SpecialSummonAttempt
        range: SpellTrapZone
        on_resolve {
            destroy (1+, monster, you controls)
        }
    }

}
