card "Delta of Invitation" {
    id: 3129133
    type: Field Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        on_resolve {
            send (1+, monster, either_player controls, where { level >= 5 and race == Zombie }) to gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        activate_from: [field_zone]
        on_resolve {
            create_token { atk: 0 def: 0 }
            special_summon (1, monster) from gy
        }
    }

    raw_effect "Effect 3" {
        effect_type: Field + Trigger
        category: ToHand
        code: ChainSolving
        range: Graveyard
        count_limit: (1, 0)
        on_resolve {
            return (1+, monster, either_player controls, where { level >= 5 and race == Zombie }) to hand
        }
    }

}
