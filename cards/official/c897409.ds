// 銀河百式
// Galaxy Hundred
// Transpiled from c897409.lua

card "Galaxy Hundred" {
    id: 897409
    type: Continuous Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        on_resolve {
            send (1+, card, you controls, deck) to gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        activate_from: [spell_trap_zone]
        on_resolve {
            reveal (1+, card, opponent controls)
            banish (1+, card, you controls, deck)
            special_summon (1, monster) from gy
            shuffle_deck
        }
    }

}
