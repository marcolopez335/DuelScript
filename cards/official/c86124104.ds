// 終焉の悪魔デミス
// Demise, Agent of Armageddon
// Transpiled from c86124104.lua

card "Demise, Agent of Armageddon" {
    id: 86124104
    type: Ritual Monster
    attribute: DARK
    race: Fiend
    level: 4
    atk: 1800
    def: 1000

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 1+ monster
        method: ritual
    }

    raw_effect "Effect 1" {
        effect_type: Single
        code: 114
        property: SingleRange
        range: Hand + MonsterZone
        on_resolve {
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        trigger: when_summoned by_special_summon
        on_resolve {
            destroy (1+, monster, either_player controls, where { is_face_up and is_ritual })
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        optional: true
        timing: if
        damage_step: false
        trigger: on_custom_event "chain_end"
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
