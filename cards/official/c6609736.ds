// Ｎｏ－Ｐ．Ｕ．Ｎ．Ｋ．ディア・ノート
// Noh-P.U.N.K. Deer Note
// Transpiled from c6609736.lua

card "Noh-P.U.N.K. Deer Note" {
    id: 6609736
    type: Effect Monster
    attribute: EARTH
    race: Warrior
    level: 5
    atk: 2100
    def: 1800

    summon_condition {
        tributes_required: 1
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [hand]
        on_resolve {
            special_summon (1, monster) from gy
            send (1+, monster, either_player controls) to gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        damage_step: false
        trigger: on_custom_event "chain_end"
        on_activate {
            select (1+, monster, either_player controls) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    continuous_effect "Effect 3" {
        scope: field
        grant: cannot_be_used_as_material
    }

}
