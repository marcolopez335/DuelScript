// 彼岸の悪鬼 ハックルスパー
// Calcab, Malebranche of the Burning Abyss
// Transpiled from c73213494.lua

card "Calcab, Malebranche of the Burning Abyss" {
    id: 73213494
    type: Effect Monster
    attribute: DARK
    race: Fiend
    level: 3
    atk: 1400
    def: 0

    raw_effect "Effect 1" {
        effect_type: Single
        code: 141
        on_resolve {
            destroy self
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [hand]
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        damage_step: false
        trigger: on_custom_event "chain_end"
        on_activate {
            select (1+, spell, you controls, where { is_spell }) as target
        }
        on_resolve {
            return (1+, spell, you controls, where { is_spell }) to hand
        }
    }

}
