card "Dyna Mondo" {
    id: 73898890
    type: Link Monster
    attribute: EARTH
    race: Cyberse
    link: 2
    link_arrows: [top, bottom]
    atk: 2200

    summon {
        cannot_normal_summon
        link materials: (2, monster)
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            return (all, card, either controls) to deck
        }
    }

    effect "Effect 2" {
        speed: 2
        once_per_turn: soft
        cost {
            tribute self
        }
        resolve {
            add_to_hand (all, card, either controls)
            special_summon (all, card, either controls)
        }
    }
}
