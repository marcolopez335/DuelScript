card "Altergeist Dragvirion" {
    id: 21187631
    type: Synchro Monster
    attribute: DARK
    race: Spellcaster
    level: 6
    atk: 2200
    def: 1200

    summon {
        cannot_normal_summon
        synchro materials {
            tuner: (1, tuner monster)
            non_tuner: (1+, non-tuner monster)
        }
    }

    effect "Effect 1" {
        speed: 2
        once_per_turn: hard
        timing: when
        trigger: summoned
        resolve {
            negate
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: custom "chain_end"
        condition: reason == release
        resolve {
            special_summon (all, card, either controls)
        }
    }
}
