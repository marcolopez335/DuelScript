// 破壊剣一閃
// Destruction Sword Flash
// Transpiled from c15155568.lua

card "Destruction Sword Flash" {
    id: 15155568
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        on_resolve {
            banish (1+, monster, opponent controls, where { is_face_up and is_fusion })
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        activate_from: [gy]
        cost {
            banish self
        }
        on_resolve {
            negate effect
            destroy (1+, monster, opponent controls, where { is_face_up and is_fusion })
        }
    }

}
