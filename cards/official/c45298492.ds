card "Scarred Warrior" {
    id: 45298492
    type: Synchro Monster
    attribute: EARTH
    race: Warrior
    level: 5
    atk: 2100
    def: 1000

    summon {
        cannot_normal_summon
        synchro materials {
            tuner: (1, tuner monster)
            non_tuner: (1+, non-tuner monster)
        }
    }

    passive "Effect 1" {
        scope: self
        grant: cannot_be_targeted by effects
    }

    passive "Effect 2" {
        scope: self
        grant: cannot_be_destroyed
    }
}
