card "Scarred Warrior" {
    id: 45298492
    type: Synchro Monster
    attribute: EARTH
    race: Warrior
    level: 5
    atk: 2100
    def: 1000

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
