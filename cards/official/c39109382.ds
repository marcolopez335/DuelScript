// 機皇統制
// Meklord Assembly
// Transpiled from c39109382.lua

card "Meklord Assembly" {
    id: 39109382
    type: Continuous Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        on_resolve {
            add_to_hand (1+, monster, you controls) from deck
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        activate_from: [spell_trap_zone]
        on_resolve {
            destroy (1+, monster, you controls, deck)
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        damage_step: false
        trigger: when_destroyed
        activate_from: [spell_trap_zone]
        on_resolve {
            destroy (1+, monster, you controls, deck)
        }
    }

}
