card "Worm Victory" {
    id: 2088870
    type: Effect Monster
    attribute: LIGHT
    race: Reptile
    level: 7
    atk: 0
    def: 2500

    summon_condition {
        tributes_required: 2
    }

    raw_effect "Effect 1" {
        effect_type: Single + Flip
        category: Destroy
        on_resolve {
            destroy (1+, monster, either_player controls)
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single
        code: UpdateAttack
        property: SingleRange
        range: MonsterZone
        on_resolve {
            modifier: atk + count((1+, card, you controls, gy)) * 500
        }
    }

}
