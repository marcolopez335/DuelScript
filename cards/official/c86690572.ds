// 炎渦の胎動
// Burgeoning Whirlflame
// Transpiled from c86690572.lua

card "Burgeoning Whirlflame" {
    id: 86690572
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        cost {
            send self to gy
        }
        on_resolve {
            negate activation
            destroy (1+, card, you controls, hand)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        optional: true
        activate_from: [gy]
        cost {
            banish self
        }
        on_resolve {
            add_to_hand (1+, card, you controls, where { attribute == FIRE }) from hand
            reveal (1+, card, opponent controls)
        }
    }

}
