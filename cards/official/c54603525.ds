// 四天の龍 クリアウィング・シンクロ・ドラゴン
// Clear Wing Synchro Dragon of the Four Heavenly Dragons
// Transpiled from c54603525.lua

card "Clear Wing Synchro Dragon of the Four Heavenly Dragons" {
    id: 54603525
    type: Synchro Monster
    attribute: WIND
    race: Dragon
    level: 7
    atk: 2500
    def: 2000

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        on_resolve {
            destroy (1+, monster, opponent controls, where { level <= 4 and attribute == WIND and is_tuner })
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            special_summon (1, monster) from gy
            synchro_summon (1, synchro monster) using (1+, monster, you controls)
        }
    }

}
