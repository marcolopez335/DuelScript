// Clear Wing Synchro Dragon of the Four Heavenly Dragons
// Transpiled from c54603525.lua

card "Clear Wing Synchro Dragon of the Four Heavenly Dragons" {
    password: 54603525
    type: Synchro Monster
    attribute: WIND
    race: Dragon
    level: 7
    atk: 2500
    def: 2000

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        trigger: when_summoned by_special_summon
        on_resolve {
            destroy (1+, card, either_player controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        trigger: opponent_activates [search | special_summon | send_to_gy | draw]
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
