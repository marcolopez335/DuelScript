card "Maestroke the Symphony Djinn" {
    id: 25341652
    type: Xyz Monster
    attribute: DARK
    race: Fiend
    rank: 4
    atk: 1800
    def: 2300

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        same_level: true
        method: xyz
    }

    raw_effect "Effect 1" {
        effect_type: Ignition
        category: DiceRoll
        property: CardTarget
        range: MonsterZone
        count_limit: (1, 0)
