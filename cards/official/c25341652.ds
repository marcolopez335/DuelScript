// 交響魔人マエストローク
// Maestroke the Symphony Djinn
// Transpiled from c25341652.lua

card "Maestroke the Symphony Djinn" {
    id: 25341652
    type: Xyz Monster
    attribute: DARK
    race: Fiend
    rank: 4
    atk: 1800
    def: 2300

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        same_level: true
        method: xyz
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_activate {
            select (1+, card, either_player controls) as target
        }
        cost {
            detach 1 overlay_unit from self
        }
        on_resolve {
            change_battle_position (1, monster)
        }
    }

    replacement_effect "Effect 2" {
        instead_of: destroyed_by_any
        do: {
            banish self
        }
    }

}
