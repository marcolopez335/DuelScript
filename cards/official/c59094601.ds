// 蘇りし天空神
// The Revived Sky God
// Transpiled from c59094601.lua

card "The Revived Sky God" {
    id: 59094601
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        on_resolve {
            special_summon (1, monster) from gy
            draw 1
            draw 1
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        activate_from: [gy]
        cost {
            banish self
        }
        on_resolve {
            shuffle_deck
            send_to_deck (1+, card, you controls) top
            return (1+, card, you controls) to deck shuffle
            reveal (1+, card, opponent controls)
            draw 1
        }
    }

}
