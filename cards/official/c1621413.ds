card "Dark Requiem Xyz Dragon" {
    id: 1621413
    type: Xyz Monster
    attribute: DARK
    race: Dragon
    rank: 5
    atk: 3000
    def: 2500

    materials {
        require: 2+ monster
        same_level: true
        method: xyz
    }

    summon_condition {
        cannot_normal_summon: true
    }

    raw_effect "Effect 1" {
        effect_type: Ignition
        category: AtkChange
        property: CardTarget
        range: MonsterZone
        count_limit: (1, 0)
        cost {
            detach 1 overlay_unit from self
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    raw_effect "Effect 2" {
        effect_type: QuickEffect
        category: Destroy + SpecialSummon + Negate
        code: Chaining
        property: Oath + CountCodeDuel
        range: MonsterZone
        cost {
            detach 1 overlay_unit from self
        }
        on_resolve {
            negate activation
            special_summon (1, monster) from gy
        }
    }

}
