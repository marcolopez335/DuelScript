// ダーク・レクイエム・エクシーズ・ドラゴン
// Dark Requiem Xyz Dragon
// Transpiled from c1621413.lua

card "Dark Requiem Xyz Dragon" {
    id: 1621413
    type: Xyz Monster
    attribute: DARK
    race: Dragon
    rank: 5
    atk: 3000
    def: 2500

    materials {
        require: 2+ monster
        same_level: true
        method: xyz
    }

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_activate {
            select (1+, card, you controls) as target
        }
        cost {
            detach 1 overlay_unit from self
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        cost {
            detach 1 overlay_unit from self
        }
        on_resolve {
            negate activation
            special_summon (1, monster) from gy
        }
    }

}
