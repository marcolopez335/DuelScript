// Spell-Stopping Statute
// Transpiled from c10069180.lua

card "Spell-Stopping Statute" {
    id: 10069180
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            negate activation
            destroy (1+, card, either_player controls)
        }
    }

}
