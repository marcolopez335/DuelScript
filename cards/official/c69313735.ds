// ディスカバード・アタック
// Checkmate
// Transpiled from c69313735.lua

card "Checkmate" {
    id: 69313735
    type: Normal Spell

    effect "Effect 1" {
        speed: spell_speed_1
        damage_step: false
        on_activate {
            select (1+, card, either_player controls, where { is_face_up and card_id == 35975813 }) as target
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
