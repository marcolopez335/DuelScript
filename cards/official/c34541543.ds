// 大陰陽師 タオ
// Master Tao the Chanter
// Transpiled from c34541543.lua

card "Master Tao the Chanter" {
    id: 34541543
    type: Effect Monster
    attribute: EARTH
    race: Unknown
    level: 3
    atk: 1200
    def: 900

    continuous_effect "Effect 1" {
        scope: field
        grant: cannot_be_destroyed_by_battle
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        damage_step: false
        trigger: on_custom_event "chain_end"
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
