// ＧＰ－スター・リオン
// Gold Pride - Star Leon
// Transpiled from c22390469.lua

card "Gold Pride - Star Leon" {
    id: 22390469
    type: Synchro Monster
    attribute: LIGHT
    race: Thunder
    level: 6
    atk: 2000
    def: 2000

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        damage_step: false
        on_activate {
            select (1+, card, opponent controls, where { is_face_up }) as target
        }
        on_resolve {
            destroy (1+, card, opponent controls, gy)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        trigger: during_end_phase
        on_resolve {
            return (1+, card, opponent controls, where { is_face_up }) to deck shuffle
            special_summon (1, monster) from gy
        }
    }

}
