card "Super Roboyarou" {
    id: 1412158
    type: Fusion Monster
    attribute: EARTH
    race: Machine
    level: 6
    atk: 1200
    def: 500

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        method: fusion
    }

    raw_effect "Effect 1" {
        effect_type: Single
        code: UpdateAttack
        property: SingleRange
        range: MonsterZone
        on_resolve {
            modifier: atk + 1000
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        on_resolve {
            return (1+, card, either_player controls) to deck shuffle
            special_summon (1, monster) from gy
        }
    }

}
