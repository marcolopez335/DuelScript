card "Tearlaments Rulkallos" {
    password: 84330567
    type: Fusion Monster
    attribute: WATER
    race: Aqua
    level: 8
    atk: 3000
    def: 2500

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        on_resolve {
            reveal self
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
