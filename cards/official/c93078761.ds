card "Diced Dice" {
    id: 93078761
    type: Quick-Play Spell

    raw_effect "Effect 1" {
        effect_type: Activate
        category: ToHand + ToDeck + Search + DiceRoll
        code: FreeChain
        count_limit: (1, 93078761)
        on_resolve {
            flip_coin { heads { draw 1 } tails { draw 1 } }
            add_to_hand (1+, card, you controls) from deck
            reveal (1+, card, opponent controls)
