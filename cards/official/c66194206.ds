// ライトロードの裁き
// Lightsworn Judgment
// Transpiled from c66194206.lua

card "Lightsworn Judgment" {
    id: 66194206
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        on_resolve {
            return (1+, card, you controls, where { card_id == 57774843 }) to deck shuffle
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        optional: true
        timing: if
        trigger: on_custom_event "chain_end"
        on_resolve {
            add_to_hand (1+, card, you controls, where { card_id == 57774843 }) from deck
            reveal (1+, card, opponent controls)
        }
    }

}
