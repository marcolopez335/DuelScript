card "Lightsworn Judgment" {
    password: 66194206
    type: Normal Trap

    raw_effect "Effect 1" {
        effect_type: Activate
        category: ToDeck
        code: FreeChain
        on_resolve {
            return (1+, card, you controls) to deck shuffle
        }
