card "Dual Avatar Fists - Armored Ah-Gyo" {
    id: 60237530
    type: Fusion Monster
    attribute: LIGHT
    race: Warrior
    level: 6
    atk: 2100
    def: 1500

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        method: fusion
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
