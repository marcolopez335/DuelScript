card "Chimera the King of Phantom Beasts" {
    id: 1769875
    type: Fusion Monster
    attribute: WIND
    race: Beast
    level: 6
    atk: 2100
    def: 1800

    summon {
        cannot_normal_summon
        fusion materials: (1, monster, where race == Beast) + (1, monster, where race == Fiend)
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: summoned by special
        resolve {
            special_summon target
        }
    }

    effect "Effect 3" {
        speed: 2
        once_per_turn: soft
        cost {
            banish self
        }
        resolve {
            special_summon (all, card, either controls)
        }
    }
}
