card "Mecha Phantom Beast Jaculuslan" {
    id: 26949946
    type: Synchro Monster
    attribute: WIND
    race: Machine
    level: 9
    atk: 2700
    def: 2000

    summon {
        cannot_normal_summon
        synchro materials {
            tuner: (1, tuner monster, where archetype == "Mecha Phantom Beast")
            non_tuner: (1+, non-tuner monster, where archetype == "Mecha Phantom Beast")
        }
    }

    passive "Effect 2" {
        scope: self
        grant: cannot_be_destroyed by battle
    }

    passive "Effect 3" {
        scope: self
        grant: cannot_be_destroyed by effect
    }

    effect "Effect 1" {
        speed: 1
        timing: when
        trigger: summoned by special
        cost {
            tribute self
        }
        resolve {
            send (all, card, either controls) to gy
        }
    }

    effect "Effect 4" {
        speed: 1
        timing: if
        trigger: destroyed
        resolve {
            send target to gy
        }
    }
}
