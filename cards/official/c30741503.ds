// オルフェゴール・ガラテア
// Galatea, the Orcust Automaton
// Transpiled from c30741503.lua

card "Galatea, the Orcust Automaton" {
    id: 30741503
    type: Link Monster
    attribute: DARK
    race: Machine
    link: 2
    link_arrows: [top_right, bottom_left]
    atk: 1800

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ effect monster
        method: link
    }

    raw_effect "Effect 1" {
        effect_type: Single
        code: CannotBeEffectTarget
        property: SingleRange
        range: MonsterZone
        on_resolve {
            register_effect on self { grant: cannot_be_destroyed_by_battle duration: until_end_of_turn }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        on_resolve {
            return (1+, spell, you controls) to deck shuffle
            shuffle_deck
            set (1, card)
        }
    }

    effect "Effect 3" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        damage_step: false
        on_resolve {
            return (1+, spell, you controls) to deck shuffle
            shuffle_deck
            set (1, card)
        }
    }

}
