// ゴーストリックの人形
// Ghostrick Doll
// Transpiled from c46925518.lua

card "Ghostrick Doll" {
    id: 46925518
    type: Effect Monster
    attribute: DARK
    race: Spellcaster
    level: 2
    atk: 300
    def: 1200

    continuous_effect "Effect 1" {
        scope: self
        grant: cannot_attack
    }

    effect "Effect 2" {
        speed: spell_speed_1
        on_resolve {
            change_battle_position (1, monster)
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        trigger: on_custom_event "chain_active"
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
