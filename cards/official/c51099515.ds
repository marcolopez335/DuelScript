// 恐撃
// Ghosts From the Past
// Transpiled from c51099515.lua

card "Ghosts From the Past" {
    id: 51099515
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        damage_step: false
        on_activate {
            select (1+, monster, you controls, where { is_monster }) as target
        }
        cost {
            banish self
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
