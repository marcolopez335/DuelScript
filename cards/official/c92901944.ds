card "Scrap Searcher" {
    id: 92901944
    type: Effect Monster
    attribute: EARTH
    race: Winged Beast
    level: 1
    atk: 100
    def: 300

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        timing: when
        trigger: on_custom_event "chain_end"
        activate_from: [gy]
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        trigger: when_summoned by_special_summon
        on_resolve {
            destroy (1+, monster, you controls)
        }
    }

}
