card "Centur-Ion Primera" {
    id: 15005145
    type: Effect Monster | Tuner
    attribute: LIGHT
    race: Spellcaster
    level: 4
    atk: 1600
    def: 1600

    passive "Effect 1" {
        scope: self
        grant: cannot_be_destroyed by effect
    }

    passive "Effect 5" {
        scope: self
        grant: cannot_attack
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned
        resolve {
            add_to_hand (1, card, where archetype == "Centur-Ion") from deck
        }
    }

    effect "Effect 3" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            add_to_hand (1, card, where archetype == "Centur-Ion") from deck
        }
    }

    effect "Effect 4" {
        speed: 2
        once_per_turn: soft
        resolve {
            special_summon (all, card, either controls)
        }
    }
}
