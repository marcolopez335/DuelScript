// Flash Charge Dragon
// Transpiled from c95372220.lua

card "Flash Charge Dragon" {
    password: 95372220
    type: Link Monster
    attribute: DARK
    race: Dragon
    link: 3
    atk: 2300

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        on_resolve {
            reveal self
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        trigger: when_summoned
        on_resolve {
            destroy (1+, card, either_player controls)
            deal_damage to opponent: 500
        }
    }

    effect "Effect 3" {
        speed: spell_speed_2
        optional: true
        damage_step: true
        trigger: opponent_activates [search | special_summon | send_to_gy | draw]
        cost {
            tribute self
        }
        on_resolve {
            negate activation
            send (1, card) to gy
        }
    }

}
