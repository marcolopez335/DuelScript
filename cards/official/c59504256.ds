// ティスティナの半神
// Demigod of the Tistina
// Transpiled from c59504256.lua

card "Demigod of the Tistina" {
    id: 59504256
    type: Effect Monster
    attribute: LIGHT
    race: Aqua
    level: 10
    atk: 2000
    def: 0

    summon_condition {
        tributes_required: 2
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [hand]
        on_resolve {
            special_summon (1, monster) from gy
            return (1+, spell, opponent controls) to hand
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        on_resolve {
            change_battle_position (1, monster)
            send (1+, spell, opponent controls) to gy
        }
    }

}
