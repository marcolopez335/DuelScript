card "Machine King Prototype" {
    id: 89222931
    type: Effect Monster
    attribute: EARTH
    race: Machine
    level: 3
    atk: 1600
    def: 1500

    raw_effect "Effect 1" {
        effect_type: Single
        code: UpdateAttack
        property: SingleRange
        range: MonsterZone
        on_resolve {
            modifier: atk + count((1+, monster, you controls)) * 100
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single
        code: UpdateDefense
        property: SingleRange
        range: MonsterZone
        on_resolve {
            modifier: def + count((1+, monster, you controls)) * 100
        }
    }

}
