// 小法師ヒダルマー
// Fire Fighting Daruma Doll
// Transpiled from c64514892.lua

card "Fire Fighting Daruma Doll" {
    id: 64514892
    type: Link Monster
    attribute: FIRE
    race: Beast-Warrior
    link: 2
    link_arrows: [bottom_left, bottom_right]
    atk: 1500

    materials {
        require: 2+ effect monster
        method: link
    }

    summon_condition {
        cannot_normal_summon: true
    }

    raw_effect "Effect 1" {
        effect_type: Single
        code: UpdateAttack
        property: SingleRange
        range: MonsterZone
        on_resolve {
            modifier: atk + count((1+, monster, you controls)) * 100
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_activate {
            select (1+, spell, either_player controls, where { is_face_up }) as target
        }
        on_resolve {
            destroy (1+, spell, either_player controls, where { is_face_up })
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        optional: true
        timing: when
        damage_step: false
        trigger: when_battle_damage
        on_activate {
            select (1+, spell, either_player controls, where { is_face_up }) as target
        }
        on_resolve {
            return (1+, spell, either_player controls, where { is_face_up }) to hand
        }
    }

}
