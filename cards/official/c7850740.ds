// エクシーズ・スライドルフィン
// Xyz Slidolphin
// Transpiled from c7850740.lua

card "Xyz Slidolphin" {
    id: 7850740
    type: Effect Monster
    attribute: WATER
    race: Sea Serpent
    level: 4
    atk: 1200
    def: 1800

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        activate_from: [hand]
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        damage_step: false
        trigger: when_summoned by_special_summon
        activate_from: [gy]
        on_activate {
            select (1+, card, either_player controls, where { is_face_up and is_xyz }) as target
        }
        on_resolve {
            attach (1, card) to self as_material
        }
    }

}
