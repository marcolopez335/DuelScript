card "Toon Black Luster Soldier" {
    id: 28711704
    type: Effect Monster | Spirit
    attribute: EARTH
    race: Warrior
    level: 8
    atk: 3000
    def: 2500

    summon_condition {
        cannot_normal_summon: true
    }

    raw_effect "Effect 1" {
        effect_type: Field
        code: CannotSummon
        property: Uncopyable
        range: Hand
        on_resolve {
            tribute (1, monster, you controls)
        }
    }

    continuous_effect "Effect 2" {
        scope: self
        grant: direct_attack
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_activate {
            select (1+, monster, you controls, where { is_monster and level >= 1 and level >= 1 }) as target
        }
        on_resolve {
            banish (1+, monster, you controls, hand)
        }
    }

}
