// 呪魂の仮面
// Mask of the Accursed
// Transpiled from c56948373.lua

card "Mask of the Accursed" {
    id: 56948373
    type: Equip Spell

    raw_effect "Effect 1" {
        effect_type: Equip
        code: 85
        on_resolve {
            register_effect on self { grant: cannot_attack duration: until_end_of_turn }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        trigger: during_standby_phase
        activate_from: [spell_trap_zone]
        on_resolve {
            deal_damage to opponent: 1000
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        on_resolve {
            equip self to (1, monster, you controls)
        }
    }

}
