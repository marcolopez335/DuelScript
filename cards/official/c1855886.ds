card "Scar of the Vendread" {
    id: 1855886
    type: Effect Monster
    attribute: DARK
    race: Zombie
    level: 6
    atk: 2300
    def: 0

    summon_condition {
        tributes_required: 1
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
