card "Shiranui Sunsaga" {
    id: 59843383
    type: Synchro Monster
    attribute: FIRE
    race: Zombie
    level: 10
    atk: 3500
    def: 0

    summon {
        cannot_normal_summon
        synchro materials {
            tuner: (1, tuner monster, where race == Zombie)
            non_tuner: (1+, non-tuner monster, where race == Zombie)
        }
    }

    effect "Effect 1" {
        speed: 1
        timing: if
        trigger: summoned by special
        resolve {
            return (all, card, either controls) to deck
            destroy (all, card, either controls)
        }
    }

    replacement "Effect 2" {
        instead_of: destroyed
        do {
            banish self
        }
    }
}
