card "Xtra HERO Wonder Driver" {
    id: 1948619
    type: Link Monster
    attribute: LIGHT
    race: Warrior
    link: 2
    link_arrows: [top, bottom]
    atk: 1900

    summon {
        cannot_normal_summon
        link materials: (2, monster, where archetype == "HERO")
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        mandatory
        trigger: summoned
        resolve {
            special_summon target
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        mandatory
        trigger: summoned by special
        resolve {
            set target
        }
    }

    effect "Effect 3" {
        speed: 1
        timing: if
        trigger: custom "chain_end"
        resolve {
            special_summon (all, card, either controls)
        }
    }
}
