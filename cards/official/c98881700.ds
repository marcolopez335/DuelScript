card "Crystal Shark" {
    id: 98881700
    type: Effect Monster
    attribute: WATER
    race: Fish
    level: 5
    atk: 1100
    def: 800

    summon_condition {
        tributes_required: 1
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        activate_from: [hand, gy]
        on_activate {
            select (1+, card, either_player controls, where { is_face_up and attribute == WATER }) as target
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single
        code: 242
        property: SingleRange
        range: MonsterZone
        on_resolve {
        }
    }

}
