card "Tip of the Tinying Tongue" {
    id: 85640370
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            negate effect
            add_to_hand (1+, card, you controls) from deck
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        optional: true
        timing: if
        damage_step: false
        trigger: when_destroyed
        on_resolve {
        }
    }

}
