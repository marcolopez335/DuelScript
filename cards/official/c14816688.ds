// シャッフル・リボーン
// Shuffle Reborn
// Transpiled from c14816688.lua

card "Shuffle Reborn" {
    id: 14816688
    type: Normal Spell

    effect "Effect 1" {
        speed: spell_speed_1
        damage_step: false
        on_activate {
            select (1+, card, opponent controls) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
            banish (1+, card, opponent controls, hand)
            destroy (1+, monster, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        activate_from: [gy]
        on_activate {
            select (1+, card, opponent controls) as target
        }
        cost {
            banish self
        }
        on_resolve {
            return (1+, card, opponent controls) to deck shuffle
            shuffle_deck
            draw 1
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    raw_effect "Effect 3" {
        effect_type: Field + Continuous
        code: PhaseEnd
        count_limit: (1, 0)
        on_resolve {
            banish (1+, card, opponent controls, hand)
        }
    }

}
