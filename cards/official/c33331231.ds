card "Surgical Striker - H.A.M.P." {
    id: 33331231
    type: Effect Monster
    attribute: DARK
    race: Machine
    level: 8
    atk: 2500
    def: 2500

    summon_condition {
        tributes_required: 2
    }

    raw_effect "Effect 1" {
        effect_type: Field
        code: CannotSummon
        property: Uncopyable
        range: Hand
        count_limit: (1, 0)
        on_resolve {
            tribute (1, monster, you controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        optional: true
        timing: when
        damage_step: false
        trigger: when_battle_damage
        on_activate {
            select (1+, monster, you controls) as target
        }
        on_resolve {
            destroy (1+, monster, you controls)
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        activate_from: [hand]
        on_resolve {
            special_summon self from hand
        }
    }

}
