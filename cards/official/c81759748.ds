// ダーク・スパイダー
// Dark Spider
// Transpiled from c81759748.lua

card "Dark Spider" {
    id: 81759748
    type: Effect Monster
    attribute: DARK
    race: Insect
    level: 1
    atk: 0
    def: 0

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_activate {
            select (1+, card, either_player controls, where { is_face_up and race == Insect and level >= 1 }) as target
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
