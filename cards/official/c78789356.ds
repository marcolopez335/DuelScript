card "Ogdoadic Daybreak" {
    id: 78789356
    type: Quick-Play Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        on_resolve {
            create_token { atk: 0 def: 0 }
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        activate_from: [gy]
        cost {
            banish self
        }
        on_resolve {
            return (1+, card, you controls, where { race == Reptile }) to deck shuffle
            shuffle_deck
            send (1+, card, you controls, deck) to gy
        }
    }

