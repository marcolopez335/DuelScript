// Ｎｏ．１ インフェクション・バアル・ゼブル
// Number 1: Infection Buzzking
// Transpiled from c10666000.lua

card "Number 1: Infection Buzzking" {
    id: 10666000
    type: Xyz Monster
    attribute: DARK
    race: Fiend
    rank: 8
    atk: 3000
    def: 2500

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        same_level: true
        method: xyz
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: when
        trigger: during_standby_phase
        on_resolve {
            attach (1, card) to self as_material
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        on_resolve {
            reveal (1+, card, opponent controls)
            send (1+, monster, opponent controls, gy) to gy
            shuffle_deck
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        cost {
            detach 1 overlay_unit from self
        }
        on_resolve {
            destroy (1+, monster, opponent controls, gy)
            deal_damage to opponent: 1000
        }
    }

}
