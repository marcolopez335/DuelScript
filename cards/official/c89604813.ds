card "Blue-Eyes Ultimate Spirit Dragon" {
    id: 89604813
    type: Synchro Monster
    attribute: LIGHT
    race: Dragon
    level: 12
    atk: 3500
    def: 4000

    summon {
        cannot_normal_summon
        synchro materials {
            tuner: (2+, tuner monster)
            non_tuner: (1, non-tuner monster, where archetype == "Blue Eyes")
        }
    }

    passive "Effect 1" {
        scope: self
        grant: cannot_attack
    }

    effect "Effect 2" {
        speed: 2
        once_per_turn: hard
        timing: when
        trigger: opponent_activates [activate_spell, activate_trap, activate_spell]
        resolve {
            negate
        }
    }

    effect "Effect 3" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: destroyed
        resolve {
            special_summon (all, card, either controls)
        }
    }
}
