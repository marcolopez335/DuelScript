card "Armored Kappa" {
    id: 50789693
    type: Xyz Monster
    attribute: WATER
    race: Psychic
    rank: 2
    atk: 400
    def: 1000

    summon {
        cannot_normal_summon
        xyz materials: (2, monster, where level == 2)
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: soft
        mandatory
        cost {
            detach 1 from self
        }
        choose {
            option "Gain 1000 ATK" {
                resolve {
                    modify_atk self + 1000 until while_face_up
                }
            }
            option "Gain 1000 DEF" {
                resolve {
                    modify_def self + 1000 until while_face_up
                }
            }
        }
    }

    effect "Effect 2" {
        speed: 2
        once_per_turn: hard
        cost {
            discard (1, card, you control, from hand)
        }
        resolve {
            grant (all, card, you control, from monster_zone) cannot_be_destroyed by battle until end_of_turn
        }
    }
}
