// Mitsurugi Great Purification
// Transpiled from c17954937.lua

card "Mitsurugi Great Purification" {
    password: 17954937
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        trigger: opponent_activates [search | special_summon | send_to_gy | draw]
        cost {
            tribute self
        }
        on_resolve {
            negate effect
            destroy (1+, card, either_player controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        cost {
            banish self
        }
        on_resolve {
            special_summon (1, monster) from gy
            tribute (1, monster, you controls)
        }
    }

}
