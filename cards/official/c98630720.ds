card "Borrelend Dragon" {
    id: 98630720
    type: Link Monster
    attribute: DARK
    race: Dragon
    link: 5
    link_arrows: [top, left, right, bottom_left, bottom_right]
    atk: 3500

    summon {
        cannot_normal_summon
    }

    passive "Effect 1" {
        scope: self
        grant: cannot_be_destroyed by battle
    }

    passive "Effect 2" {
        scope: self
        grant: cannot_be_destroyed by effect
    }

    passive "Effect 3" {
        scope: self
        grant: cannot_be_targeted by effects
    }

    passive "Effect 4" {
        scope: self
        grant: attack_all_monsters
    }

    effect "Effect 5" {
        speed: 2
        once_per_turn: hard
        resolve {
            special_summon (all, card, either controls)
        }
    }
}
