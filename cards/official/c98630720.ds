// ヴァレルエンド・ドラゴン
// Borrelend Dragon
// Transpiled from c98630720.lua

card "Borrelend Dragon" {
    id: 98630720
    type: Link Monster
    attribute: DARK
    race: Dragon
    link: 5
    link_arrows: [top, left, right, bottom_left, bottom_right]
    atk: 3500

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ effect monster
        method: link
    }

    continuous_effect "Effect 1" {
        scope: self
        grant: cannot_be_destroyed_by_battle
    }

    continuous_effect "Effect 2" {
        scope: self
        grant: cannot_be_destroyed_by_effect
    }

    continuous_effect "Effect 3" {
        scope: self
        grant: cannot_be_targeted_by_card_effects
    }

    continuous_effect "Effect 4" {
        scope: self
        grant: attack_all_opponent_monsters
    }

    effect "Effect 5" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        damage_step: false
        on_activate {
            select (1+, monster, either_player controls) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
