card "S-Force Gravitino" {
    id: 21368442
    type: Effect Monster
    attribute: LIGHT
    race: Psychic
    level: 5
    atk: 2000
    def: 1400

    summon_condition {
        tributes_required: 1
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
