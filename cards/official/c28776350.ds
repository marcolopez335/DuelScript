// アカシック・マジシャン
// Akashic Magician
// Transpiled from c28776350.lua

card "Akashic Magician" {
    id: 28776350
    type: Link Monster
    attribute: DARK
    race: Spellcaster
    link: 2
    link_arrows: [top, bottom]
    atk: 1700

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ effect monster
        method: link
    }

    raw_effect "Effect 1" {
        effect_type: Single + Continuous
        code: SpecialSummonSuccess
        property: BothSide
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single + MandatoryTrigger
        category: ToHand
        code: SpecialSummonSuccess
        on_resolve {
            add_to_hand (1+, card, either_player controls) from gy
        }
    }

    raw_effect "Effect 3" {
        effect_type: Ignition
        category: ToHand + DeckDestroy + Search
        range: MonsterZone
        count_limit: (1, 0)
        on_resolve {
            reveal (1, card, opponent controls, deck)
            add_to_hand (1+, card, either_player controls) from gy
            reveal (1+, card, opponent controls)
            shuffle_hand
            send (1+, card, either_player controls) to gy
        }
    }

}
