// エクシーズ・リフレクト
// Xyz Reflect
// Transpiled from c2371506.lua

card "Xyz Reflect" {
    id: 2371506
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            negate activation
            destroy (1+, card, either_player controls, where { is_face_up and is_xyz })
            deal_damage to opponent: 800
        }
    }

}
