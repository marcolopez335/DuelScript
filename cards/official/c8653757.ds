// Photon Timestop
// Transpiled from c8653757.lua

card "Photon Timestop" {
    id: 8653757
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        on_resolve {
            add_to_hand (1, card, you controls) from gy
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        optional: true
        timing: if
        trigger: when_destroyed
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
