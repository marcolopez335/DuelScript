// 竜脈の魔術師
// Dragonpulse Magician
// Transpiled from c15146890.lua

card "Dragonpulse Magician" {
    id: 15146890
    type: Normal Monster | Pendulum Monster
    attribute: EARTH
    race: Spellcaster
    level: 4
    scale: 1
    atk: 1800
    def: 900
    flavor: "[ Pendulum Effect ] Once per turn, if you have a 'Magician' card in your other Pendulum Zone: You can discard 1 Pendulum Monster, then target 1 face-up monster on the field; destroy it. ---------------------------------------- [ Flavor Text ] This boy magician has the gift of seeing the natural lines of energy that run through the earth, which his people call the Pulse of the Dragon. His exuberance and skill put him in high regard with his mentor, the 'Dragonpit Magician'."

    raw_effect "Effect 1" {
        effect_type: Ignition
        category: Destroy
        property: CardTarget
        range: PendulumZone
        count_limit: (1, 0)
        on_resolve {
            destroy (1+, card, either_player controls, where { is_pendulum })
        }
    }

}
