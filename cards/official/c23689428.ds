// 無限起動 ゴライアス
// Infinitrack Goliath
// Transpiled from c23689428.lua

card "Infinitrack Goliath" {
    id: 23689428
    type: Link Monster
    attribute: EARTH
    race: Machine
    link: 1
    link_arrows: [bottom_right]
    atk: 1000

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ effect monster
        method: link
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        damage_step: false
        trigger: on_custom_event "chain_end"
        on_activate {
            select (1+, card, either_player controls, where { is_face_up and is_xyz }) as target
        }
        on_resolve {
            attach (1, card) to self as_material
        }
    }

    raw_effect "Effect 2" {
        effect_type: XyzMaterial
        code: IndestructableEffect
        property: SingleRange
        range: MonsterZone
        on_resolve {
            register_effect on self { grant: cannot_be_destroyed_by_effect duration: until_end_of_turn }
        }
    }

}
