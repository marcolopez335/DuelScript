card "Ascension Sky Dragon" {
    id: 37910722
    type: Synchro Monster
    attribute: LIGHT
    race: Dragon
    level: 10
    atk: ?
    def: 3000

    summon {
        cannot_normal_summon
        synchro materials {
            tuner: (1, tuner monster)
            non_tuner: (1+, non-tuner monster)
        }
    }

    effect "Effect 1" {
        speed: 1
        mandatory
        trigger: summoned by special
        resolve {
            modify_atk self + count((all, card, you control, from hand)) * 800 until end_of_turn
        }
    }

    effect "Effect 2" {
        speed: 1
        timing: when
        trigger: custom "chain_end"
        resolve {
            special_summon (all, card, either controls)
        }
    }
}
