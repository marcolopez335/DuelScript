card "Tackle Crusader" {
    id: 12467005
    type: Effect Monster
    attribute: EARTH
    race: Rock
    level: 4
    atk: 1500
    def: 1800

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        timing: if
        damage_step: false
        trigger: on_custom_event "chain_end"
        on_resolve {
            change_battle_position (1, monster)
            add_to_hand (1+, spell, either_player controls) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
