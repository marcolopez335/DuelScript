card "Magikey Mechmortar - Garesglasser" {
    password: 45877457
    type: Ritual Monster
    attribute: EARTH
    race: Machine
    level: 8
    atk: 2000
    def: 2800

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        on_resolve {
            reveal self
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
