card "Battlewasp - Arbalest the Rapidfire" {
    id: 90161770
    type: Effect Monster
    attribute: WIND
    race: Insect
    level: 4
    atk: 1800
    def: 800

    effect "Effect 1" {
        speed: 1
        timing: when
        trigger: summoned
        resolve {
            special_summon (1, monster, where archetype == "Battlewasp") from hand in attack_position
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: destroyed
        resolve {
            special_summon (1, monster, where archetype == "Battlewasp") from hand in attack_position
        }
    }
}
