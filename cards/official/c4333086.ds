// 不知火流 燕の太刀
// Shiranui Style Swallow's Slash
// Transpiled from c4333086.lua

card "Shiranui Style Swallow's Slash" {
    id: 4333086
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, monster, either_player controls, where { race == Zombie }) as target
        }
        on_resolve {
            destroy (1+, monster, either_player controls, where { race == Zombie })
            banish (1+, monster, either_player controls, where { race == Zombie })
        }
    }

}
