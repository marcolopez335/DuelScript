card "Armory Arm" {
    id: 29071332
    type: Synchro Monster
    attribute: LIGHT
    race: Machine
    level: 4
    atk: 1800
    def: 1200

    summon {
        cannot_normal_summon
        synchro materials {
            tuner: (1, tuner monster)
            non_tuner: (1+, non-tuner monster)
        }
    }

    effect "Effect 1" {
        speed: 1
        mandatory
        resolve {
            send (all, card, either controls) to gy
        }
    }

    effect "Effect 2" {
        speed: 1
        mandatory
        resolve {
            special_summon (all, card, either controls)
        }
    }

    effect "Effect 4" {
        speed: 1
        mandatory
        trigger: battle_damage
        resolve {
            damage opponent 1000
        }
    }
}
