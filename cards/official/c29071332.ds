        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    raw_effect "Effect 3" {
        effect_type: Equip
        code: UpdateAttack
        on_resolve {
            modifier: atk + 1000
        }
    }

    raw_effect "Effect 4" {
        effect_type: Field + MandatoryTrigger
        category: Damage
        code: BattleDamage
        property: InitialValue
        range: SpellTrapZone
        on_resolve {
            deal_damage to opponent: 1000
        }
    }

    raw_effect "Effect 5" {
        effect_type: Single
        code: CannotAttack2
