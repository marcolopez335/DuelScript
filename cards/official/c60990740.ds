        once_per_turn: soft
        optional: true
        timing: if
        trigger: on_custom_event "chain_end"
        on_resolve {
            send_to_deck (1+, card, you controls)
        }
    }

    raw_effect "Effect 3" {
        effect_type: Single
        code: CannotBeLinkMaterial
        property: IgnoreRange
