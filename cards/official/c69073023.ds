// 無限起動要塞メガトンゲイル
// Infinitrack Fortress Megaclops
// Transpiled from c69073023.lua

card "Infinitrack Fortress Megaclops" {
    id: 69073023
    type: Link Monster
    attribute: EARTH
    race: Machine
    link: 3
    link_arrows: [right, bottom_left, bottom_right]
    atk: 4000

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ effect monster
        method: link
    }

    raw_effect "Effect 1" {
        effect_type: Single
        code: ImmuneEffect
        property: SingleRange + Uncopyable
        range: MonsterZone
        on_resolve {
            register_effect on self { grant: unaffected_by_card_effects duration: until_end_of_turn }
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single
        code: CannotBeEffectTarget
        on_resolve {
            register_effect on self { grant: cannot_be_destroyed_by_battle duration: until_end_of_turn }
        }
    }

    raw_effect "Effect 3" {
        effect_type: Ignition
        category: SpecialSummon
        property: CardTarget
        range: MonsterZone
        count_limit: (1, 69073023)
        on_resolve {
            special_summon (1, monster) from gy
            attach (1, card) to self as_material
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
