// 無限起動要塞メガトンゲイル
// Infinitrack Fortress Megaclops
// Transpiled from c69073023.lua

card "Infinitrack Fortress Megaclops" {
    id: 69073023
    type: Link Monster
    attribute: EARTH
    race: Machine
    link: 3
    link_arrows: [right, bottom_left, bottom_right]
    atk: 4000

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ effect monster
        method: link
    }

    continuous_effect "Effect 1" {
        scope: self
        grant: unaffected_by_card_effects
    }

    continuous_effect "Effect 2" {
        scope: self
        grant: cannot_be_destroyed_by_battle
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
            attach (1, card) to self as_material
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
