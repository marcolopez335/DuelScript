// 捲怒重来
// Revenge Rally
// Transpiled from c51686645.lua

card "Revenge Rally" {
    id: 51686645
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        damage_step: false
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            equip (1, card) to (1, monster)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: hard
        trigger: on_custom_event "chain_end"
        on_resolve {
            draw 2
            shuffle_hand
            discard (1, card)
            draw 1
        }
    }

}
