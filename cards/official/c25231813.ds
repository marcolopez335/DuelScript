// 白銀の翼
// Silver Wing
// Transpiled from c25231813.lua

card "Silver Wing" {
    id: 25231813
    type: Equip Spell

    raw_effect "Effect 1" {
        effect_type: Equip
        code: 47
        on_resolve {
            register_effect on self { grant: cannot_be_destroyed duration: until_end_of_turn }
        }
    }

    replacement_effect "Effect 2" {
        instead_of: destroyed_by_any
        do: {
            banish self
        }
    }

    raw_effect "Effect 3" {
        effect_type: Activate
        category: EquipAction
        code: FreeChain
        on_resolve {
            equip self to (1, monster, you controls)
        }
    }

}
