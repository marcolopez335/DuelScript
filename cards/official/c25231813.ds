// 白銀の翼
// Silver Wing
// Transpiled from c25231813.lua

card "Silver Wing" {
    id: 25231813
    type: Equip Spell

    continuous_effect "Effect 1" {
        scope: self
        grant: cannot_be_destroyed
    }

    replacement_effect "Effect 2" {
        instead_of: destroyed_by_any
        do: {
            banish self
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        on_resolve {
            equip self to (1, monster, you controls)
        }
    }

}
