card "Yamorimori" {
    id: 51474037
    type: Effect Monster
    attribute: WATER
    race: Reptile
    level: 2
    atk: 0
    def: 0

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        activate_from: [gy]
        on_activate {
            select (1+, monster, either_player controls) as target
        }
        cost {
            banish self
        }
        on_resolve {
            change_battle_position (1, monster)
            destroy (1+, monster, either_player controls)
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
