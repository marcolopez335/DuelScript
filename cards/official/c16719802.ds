// スター・ブライト・ドラゴン
// Bright Star Dragon
// Transpiled from c16719802.lua

card "Bright Star Dragon" {
    id: 16719802
    type: Effect Monster
    attribute: LIGHT
    race: Dragon
    level: 4
    atk: 1900
    def: 1000

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        timing: when
        damage_step: false
        trigger: when_summoned
        on_activate {
            select (1+, card, either_player controls, where { is_face_up and level >= 1 }) as target
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
