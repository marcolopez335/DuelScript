card "Geomathmech Magma" {
    id: 15248594
    type: Synchro Monster | Tuner
    attribute: FIRE
    race: Cyberse
    level: 8
    atk: 2500
    def: 0

    summon {
        cannot_normal_summon
        synchro materials {
            tuner: (1, tuner monster)
            non_tuner: (1+, non-tuner monster)
        }
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        timing: when
        trigger: battle_damage
        target (1+, card, opponent controls, from field)
        resolve {
            destroy (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: destroyed
        resolve {
            add_to_hand (1, card, where archetype == "Mathmech" and not is_monster) from deck
        }
    }
}
