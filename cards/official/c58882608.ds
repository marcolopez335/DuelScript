card "Breath of the Tistina" {
    id: 58882608
    type: Continuous Spell

    effect "Effect 1" {
        speed: 1
        mandatory
        resolve {
            change_position target to face_down_defense
            add_to_hand (1, card, you control, from deck)
        }
