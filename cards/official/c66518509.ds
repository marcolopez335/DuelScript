// 冥骸融合－メメント・フュージョン
// Mementotlan Fusion
// Transpiled from c66518509.lua

card "Mementotlan Fusion" {
    id: 66518509
    type: Quick-Play Spell

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        on_resolve {
            fusion_summon (1, fusion monster) using (1+, monster, you controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        activate_from: [gy]
        cost {
            banish self
        }
        on_resolve {
            destroy (1+, monster, you controls, gy)
            add_to_hand (1+, monster, you controls) from gy
            reveal (1+, card, opponent controls)
        }
    }

    raw_effect "Effect 3" {
        effect_type: Field + Continuous
        code: SpecialSummonAttempt
        on_resolve {
            set_flag "tracked" on self
        }
    }

}
