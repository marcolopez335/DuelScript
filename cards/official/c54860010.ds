card "Worm Prince" {
    id: 54860010
    type: Effect Monster
    attribute: LIGHT
    race: Reptile
    level: 6
    atk: 2200
    def: 400

    summon_condition {
        tributes_required: 1
    }

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        timing: when
        trigger: when_battle_damage
