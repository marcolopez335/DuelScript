card "Transcendosaurus Gigantozowler" {
    id: 67745632
    type: Fusion Monster
    attribute: EARTH
    race: Dinosaur
    level: 12
    atk: 3800
    def: 2000

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        method: fusion
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        damage_step: false
        trigger: when_summoned by_special_summon
        on_resolve {
            add_to_hand (1+, card, either_player controls, where { race == Dinosaur }) from hand
            shuffle_hand
            destroy (1+, card, either_player controls, hand)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        trigger: when_destroyed
        on_resolve {
            return (1+, card, either_player controls, where { race == Dinosaur }) to deck shuffle
            special_summon (1, monster) from gy
        }
    }

}
