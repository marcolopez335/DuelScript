card "Galaxy War Drake" {
    id: 19316241
    type: Effect Monster
    attribute: LIGHT
    race: Dragon
    level: 4
    atk: 1500
    def: 1000

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        activate_from: [hand, gy]
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    continuous_effect "Effect 3" {
        scope: field
        grant: cannot_be_used_as_material
    }

    redirect_effect "Effect 4" {
        when_going_to: field
        redirect_to: banished
    }

    raw_effect "Effect 5" {
        effect_type: Single
        code: CannotAttackAnnounce2
        property: BothSide
        on_resolve {
        }
    }

    raw_effect "Effect 6" {
        effect_type: Single
        code: CannotAttackAnnounce2
        property: BothSide
        on_resolve {
        }
    }

}
