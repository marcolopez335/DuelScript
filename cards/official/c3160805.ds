// 明と宵の逆転
// Exchange of Night and Day
// Transpiled from c3160805.lua

card "Exchange of Night and Day" {
    id: 3160805
    type: Continuous Trap

    effect "Effect 1" {
        speed: spell_speed_2
        on_resolve {
            send (1+, card, you controls, deck) to gy
            add_to_hand (1+, card, you controls) from deck
            reveal (1+, card, opponent controls)
            send (1+, card, you controls, deck) to gy
            add_to_hand (1+, card, you controls) from deck
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        optional: true
        activate_from: [spell_trap_zone]
        on_resolve {
            send (1+, card, you controls, deck) to gy
            add_to_hand (1+, card, you controls) from deck
            reveal (1+, card, opponent controls)
            send (1+, card, you controls, deck) to gy
            add_to_hand (1+, card, you controls) from deck
            reveal (1+, card, opponent controls)
        }
    }

}
