// 天刑王 ブラック・ハイランダー
// Dark Highlander
// Transpiled from c75326861.lua

card "Dark Highlander" {
    id: 75326861
    type: Synchro Monster
    attribute: DARK
    race: Fiend
    level: 7
    atk: 2800
    def: 2300

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    summon_condition {
        cannot_normal_summon: true
    }

    continuous_effect "Effect 1" {
        scope: field
        grant: cannot_be_used_as_material
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            destroy (1+, card, either_player controls)
            deal_damage to opponent: 1000
        }
    }

}
