card "Overlay Regen" {
    id: 27068117
    type: Normal Spell

    effect "Effect 1" {
        speed: spell_speed_1
        damage_step: false
        on_activate {
            select (1+, card, either_player controls, where { is_face_up and is_xyz }) as target
        }
        on_resolve {
            attach (1, card) to self as_material
        }
    }

}
