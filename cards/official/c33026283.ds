// 双天将 金剛
// Dual Avatar - Empowered Kon-Gyo
// Transpiled from c33026283.lua

card "Dual Avatar - Empowered Kon-Gyo" {
    id: 33026283
    type: Fusion Monster
    attribute: LIGHT
    race: Warrior
    level: 8
    atk: 3000
    def: 1700

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        method: fusion
    }

    continuous_effect "Effect 1" {
        scope: field
        grant: cannot_activate_effects
    }

    effect "Effect 2" {
        speed: spell_speed_1
        optional: true
        timing: when
        trigger: on_custom_event "chain_end"
        on_resolve {
            return (1+, monster, opponent controls) to hand
        }
    }

    effect "Effect 3" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            negate activation
        }
    }

}
