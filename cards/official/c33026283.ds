card "Dual Avatar - Empowered Kon-Gyo" {
    id: 33026283
    type: Fusion Monster
    attribute: LIGHT
    race: Warrior
    level: 8
    atk: 3000
    def: 1700

    summon {
        cannot_normal_summon
        fusion materials: "Dual Avatar Fists - Yuhi" + (2, monster, where archetype == "Dual Avatar")
    }

    passive "Effect 1" {
        scope: self
        grant: cannot_activate effects
    }

    effect "Effect 2" {
        speed: 1
        timing: when
        trigger: custom "chain_end"
        resolve {
            return (all, card, either controls) to hand
        }
    }

    effect "Effect 3" {
        speed: 2
        once_per_turn: hard
        timing: when
        trigger: opponent_activates [activate_spell, activate_trap, activate_spell]
        resolve {
            negate
        }
    }
}
