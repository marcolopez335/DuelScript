card "Winged Kuriboh Sabatiel LV10" {
    id: 40237839
    type: Effect Monster
    attribute: LIGHT
    race: Fairy
    level: 10
    atk: 300
    def: 200

    summon_condition {
        tributes_required: 2
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        activate_from: [hand]
        cost {
            pay_lp 1000
        }
        on_resolve {
            return (1+, spell, opponent controls) to hand
            reveal (1+, card, opponent controls)
            return (1+, spell, opponent controls) to deck shuffle
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        activate_from: [hand]
        on_resolve {
            special_summon (1, monster) from gy
            deal_damage to opponent: 1000
        }
    }

    raw_effect "Effect 3" {
        effect_type: Field
        code: CannotDisable
        property: InitialValue + IgnoreRange2
        on_resolve {
            register_effect on self { grant: cannot_be_used_as_material duration: until_end_of_turn }
        }
    }

}
