card "Wizard @Ignister" {
    id: 3723262
    type: Effect Monster
    attribute: DARK
    race: Cyberse
    level: 4
    atk: 1800
    def: 800

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        activate_from: [hand]
        on_resolve {
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        activate_from: [monster_zone, gy]
        cost {
            banish self
        }
        on_resolve {
            change_battle_position (1, monster)
        }
    }

}
