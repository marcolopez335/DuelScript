// インフェルノイド・ネヘモス
// Infernoid Onuncu
// Transpiled from c14799437.lua

card "Infernoid Onuncu" {
    id: 14799437
    type: Effect Monster | Spirit
    attribute: FIRE
    race: Fiend
    level: 10
    atk: 3000
    def: 3000

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        timing: when
        trigger: when_summoned by_special_summon
        on_resolve {
            destroy (1+, monster, either_player controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        cost {
            tribute self
        }
        on_resolve {
            negate activation
            banish (1+, monster, either_player controls)
        }
    }

}
