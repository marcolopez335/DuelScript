        timing: if
        trigger: when_summoned by_special_summon
        cost {
            discard (1, card, you controls)
        }
        on_resolve {
            draw 1
        }
    }

    effect "Effect 4" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        on_resolve {
            add_to_hand (1+, spell, you controls) from gy
            reveal (1+, card, opponent controls)
        }
    }

    raw_effect "Effect 5" {
        effect_type: Single
        code: UpdateAttack
        property: BothSide
        on_resolve {
