// 四天の龍 ダーク・リベリオン・エクシーズ・ドラゴン
// Dark Rebellion Xyz Dragon of the Four Heavenly Dragons
// Transpiled from c90091224.lua

card "Dark Rebellion Xyz Dragon of the Four Heavenly Dragons" {
    id: 90091224
    type: Xyz Monster
    attribute: DARK
    race: Dragon
    rank: 4
    atk: 2500
    def: 2000

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        same_level: true
        method: xyz
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        damage_step: false
        trigger: when_summoned by_special_summon
        on_resolve {
            destroy (1+, card, either_player controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        cost {
            detach 1 overlay_unit from self
        }
        on_resolve {
            attach (1, card) to self as_material
            special_summon (1, monster) from gy
        }
    }

}
