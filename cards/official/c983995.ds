// Rebound
// Transpiled from c983995.lua

card "Rebound" {
    id: 983995
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            negate effect
            send (1+, card, opponent controls, hand) to gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        trigger: on_custom_event "chain_end"
        on_resolve {
            draw 1
        }
    }

}
