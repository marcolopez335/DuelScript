// ルーレット・スパイダー
// Roulette Spider
// Transpiled from c36708764.lua

card "Roulette Spider" {
    id: 36708764
    type: Quick-Play Spell

    effect "Effect 1" {
        speed: spell_speed_1
        trigger: when attack_declared
        on_resolve {
            flip_coin { heads { draw 1 } tails { draw 1 } }
            gain_lp: 0
            negate attack
            deal_damage to opponent: 1000
            destroy (1+, monster, you controls)
        }
    }

}
