    level: 2
    atk: 500
    def: 100

    raw_effect "Effect 1" {
        effect_type: Single + Continuous
        code: AttackAnnounce
        property: BothSide
        on_resolve {
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        trigger: during battle_phase
        on_resolve {
            destroy (1+, monster, either_player controls)
        }
    }

    effect "Effect 3" {
