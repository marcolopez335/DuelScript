// 暗黒界の登極
// Dark World Accession
// Transpiled from c65956182.lua

card "Dark World Accession" {
    id: 65956182
    type: Quick-Play Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        on_resolve {
            fusion_summon (1, fusion monster) using (1+, monster, you controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        activate_from: [gy]
        on_resolve {
            add_to_hand (1+, monster, you controls) from gy
            shuffle_hand
            send (1+, monster, you controls, gy) to gy
        }
    }

}
