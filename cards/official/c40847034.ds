// キラーチューン・プレイリスト
// Kewl Tune Playlist
// Transpiled from c40847034.lua

card "Kewl Tune Playlist" {
    id: 40847034
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        twice_per_turn
        damage_step: false
        on_activate {
            select (1+, monster, either_player controls) as target
        }
        on_resolve {
            add_to_hand (1+, monster, either_player controls) from gy
            shuffle_hand
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
