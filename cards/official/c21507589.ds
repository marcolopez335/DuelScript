// フィッシュアンドバックス
// Fish and Swaps
// Transpiled from c21507589.lua

card "Fish and Swaps" {
    id: 21507589
    type: Normal Spell

    effect "Effect 1" {
        speed: spell_speed_1
        damage_step: false
        on_activate {
            select (1+, card, you controls, where { is_face_up }) as target
        }
        on_resolve {
            add_to_hand (1+, card, you controls, where { is_face_up }) from hand
            reveal (1+, card, opponent controls)
        }
    }

}
