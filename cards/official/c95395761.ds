card "Inzektor Ant" {
    id: 95395761
    type: Effect Monster
    attribute: DARK
    race: Insect
    level: 3
    atk: 200
    def: 600

    passive "Effect 7" {
        scope: self
        grant: cannot_be_targeted by effects
    }

    passive "Effect 8" {
        scope: self
        grant: cannot_be_destroyed by effect
    }

    passive "Effect 9" {
        scope: self
        grant: cannot_be_destroyed by battle
    }

    replacement "Effect 5" {
        instead_of: destroyed
        do {
            banish self
        }
    }


    passive "Passive 2" {
        target: equipped_card
        modifier: atk + 200
    }


    passive "Passive 3" {
        target: equipped_card
        modifier: def + 600
    }
}
