card "D/D/D Gust King Alexander" {
    id: 987311
    type: Synchro Monster
    attribute: WIND
    race: Fiend
    level: 7
    atk: 2500
    def: 2000

    summon {
        cannot_normal_summon
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned
        resolve {
            special_summon (all, card, either controls)
