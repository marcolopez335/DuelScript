card "Drytron Meteonis DA Draconids" {
    id: 56863746
    type: Ritual Monster
    attribute: LIGHT
    race: Machine
    level: 12
    atk: 5000
    def: 5000

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 1+ monster
        method: ritual
    }

    continuous_effect "Effect 1" {
        scope: field
        grant: cannot_be_destroyed_by_effect
    }

    effect "Effect 2" {
        speed: spell_speed_2
        twice_per_turn
        optional: true
        timing: when
