// 雷の裁き
// Judgment of Thunder
// Transpiled from c85080048.lua

card "Judgment of Thunder" {
    id: 85080048
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        damage_step: false
        trigger: when_summoned
        on_activate {
            select (1+, card, either_player controls, where { is_face_up and race == Thunder }) as target
        }
        on_resolve {
            destroy (1+, card, either_player controls, where { is_face_up and race == Thunder })
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        damage_step: false
        trigger: when_summoned by_special_summon
        on_activate {
            select (1+, card, either_player controls, where { is_face_up and race == Thunder }) as target
        }
        on_resolve {
            destroy (1+, card, either_player controls, where { is_face_up and race == Thunder })
        }
    }

    effect "Effect 3" {
        speed: spell_speed_2
        damage_step: false
        trigger: when_summoned by_flip_summon
        on_activate {
            select (1+, card, either_player controls, where { is_face_up and race == Thunder }) as target
        }
        on_resolve {
            destroy (1+, card, either_player controls, where { is_face_up and race == Thunder })
        }
    }

}
