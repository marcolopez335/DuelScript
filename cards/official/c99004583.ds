// アクションマジック－フルターン
// Action Magic - Full Turn
// Transpiled from c99004583.lua

card "Action Magic - Full Turn" {
    id: 99004583
    type: Quick-Play Spell

    effect "Effect 1" {
        speed: spell_speed_1
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            set_flag "tracked" on self
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        activate_from: [gy]
        on_resolve {
            set (1, card)
        }
    }

}
