card "Sylvan Guardioak" {
    id: 99429730
    type: Effect Monster
    attribute: EARTH
    race: Plant
    level: 6
    atk: 2400
    def: 1500

    summon_condition {
        tributes_required: 1
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        on_resolve {
            reveal (1, card, opponent controls, deck)
            send (1+, card, either_player controls) to gy
            send_to_deck (1+, card, you controls) bottom
            send_to_deck (1+, card, you controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        optional: true
        timing: if
        damage_step: false
        trigger: on_custom_event "chain_end"
        on_resolve {
            return (1+, card, either_player controls) to deck shuffle
        }
    }

}
