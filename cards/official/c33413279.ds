// エクスプローシブ・マジシャン
// Explosive Magician
// Transpiled from c33413279.lua

card "Explosive Magician" {
    id: 33413279
    type: Synchro Monster
    attribute: LIGHT
    race: Spellcaster
    level: 6
    atk: 2500
    def: 1800

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    effect "Effect 1" {
        speed: spell_speed_1
        damage_step: false
        on_activate {
            select (1+, spell, either_player controls) as target
        }
        on_resolve {
            destroy (1+, spell, either_player controls)
        }
    }

}
