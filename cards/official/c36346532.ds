card "Paleozoic Cambroraster" {
    id: 36346532
    type: Link Monster
    attribute: WATER
    race: Aqua
    link: 2
    link_arrows: [top, bottom]
    atk: 1200

    summon {
        cannot_normal_summon
    }

    passive "Effect 1" {
        scope: self
        grant: unaffected_by effects
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        mandatory
        resolve {
            send (all, card, either controls) to gy
        }
    }

    replacement "Effect 3" {
        instead_of: destroyed
        do {
            banish self
        }
    }
}
