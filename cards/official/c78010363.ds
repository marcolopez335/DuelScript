// 黒き森のウィッチ
// Witch of the Black Forest
// Transpiled from c78010363.lua

card "Witch of the Black Forest" {
    id: 78010363
    type: Effect Monster
    attribute: DARK
    race: Spellcaster
    level: 4
    atk: 1100
    def: 1200

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        trigger: on_custom_event "chain_end"
        on_resolve {
            add_to_hand (1+, monster, opponent controls) from deck
            reveal (1+, card, opponent controls)
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
