card "Zalamander Catalyzer" {
    id: 40460013
    type: Effect Monster
    attribute: FIRE
    race: Fiend
    level: 4
    atk: 1600
    def: 200

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [hand]
        on_resolve {
            special_summon (1, monster) from gy
            send (1+, card, you controls, hand) to gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: when
        trigger: when_battle_damage
        activate_from: [gy]
        on_resolve {
            add_to_hand (1+, card, you controls) from hand
            reveal (1+, card, opponent controls)
        }
    }

}
