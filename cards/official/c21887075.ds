// 無尽機関アルギロ・システム
// Endless Engine Argyro System
// Transpiled from c21887075.lua

card "Endless Engine Argyro System" {
    id: 21887075
    type: Normal Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        on_resolve {
            send (1+, card, you controls, deck) to gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        activate_from: [gy]
        on_resolve {
            add_to_hand (1+, card, you controls) from deck
            reveal (1+, card, opponent controls)
            return (1+, card, you controls) to deck shuffle
        }
    }

}
