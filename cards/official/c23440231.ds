// インフェルノイド・リリス
// Infernoid Devyaty
// Transpiled from c23440231.lua

card "Infernoid Devyaty" {
    id: 23440231
    type: Effect Monster | Spirit
    attribute: FIRE
    race: Fiend
    level: 9
    atk: 2900
    def: 2900

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        timing: when
        trigger: when_summoned by_special_summon
        on_resolve {
            destroy (1+, spell, either_player controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        cost {
            tribute self
        }
        on_resolve {
            negate activation
            banish (1+, spell, either_player controls)
        }
    }

}
