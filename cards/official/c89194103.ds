// 魔轟神獣クダベ
// The Fabled Kudabbi
// Transpiled from c89194103.lua

card "The Fabled Kudabbi" {
    id: 89194103
    type: Synchro Monster
    attribute: LIGHT
    race: Beast
    level: 4
    atk: 2200
    def: 1100

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    summon_condition {
        cannot_normal_summon: true
    }

    continuous_effect "Effect 1" {
        scope: self
        grant: cannot_be_destroyed_by_battle
    }

    continuous_effect "Effect 2" {
        scope: self
        grant: cannot_be_destroyed_by_effect
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        trigger: during_end_phase
        on_resolve {
            destroy (1+, card, either_player controls)
        }
    }

}
