card "Amaterasu" {
    id: 20073910
    type: Effect Monster | Flip
    attribute: LIGHT
    race: Fairy
    level: 9
    atk: 3000
    def: 3000

    summon_condition {
        tributes_required: 2
    }

    effect "Effect 1" {
        speed: spell_speed_2
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            draw 1
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        trigger: on_custom_event "chain_active"
        on_resolve {
            banish (1+, card, either_player controls)
        }
    }

}
