card "Archfiend's Ascent" {
    id: 61248471
    type: Xyz Monster
    attribute: DARK
    race: Fiend
    rank: 6
    atk: 2500
    def: 1200

    summon {
        cannot_normal_summon
    }

    effect "Effect 3" {
        speed: 1
        timing: if
        trigger: custom "chain_end"
        resolve {
            special_summon (all, card, either controls)
        }
