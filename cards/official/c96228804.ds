card "Regulus, the Prince of Endymion" {
    id: 96228804
    type: Effect Monster
    attribute: LIGHT
    race: Spellcaster
    level: 4
    atk: 1700
    def: 1300

    continuous_effect "Effect 1" {
        scope: self
        grant: cannot_be_destroyed
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        activate_from: [hand]
        on_resolve {
            gain_lp: 0
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
