card "Daigusto Laplampilica" {
    id: 76937326
    type: Synchro Monster
    attribute: WIND
    race: Psychic
    level: 6
    atk: 1900
    def: 2600

    summon {
        cannot_normal_summon
        synchro materials {
            tuner: (1, tuner monster)
            non_tuner: (1+, non-tuner monster, where archetype == "Gusto")
        }
    }

    passive "Effect 2" {
        scope: self
        grant: cannot_be_targeted by effects
    }

    effect "Effect 1" {
        speed: 1
        timing: if
        trigger: summoned by special
        resolve {
            special_summon (1, monster, where archetype == "Gusto") from hand in attack_position
        }
    }
}
