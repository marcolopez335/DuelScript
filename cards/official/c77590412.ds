// パペット・ルーク
// Puppet Rook
// Transpiled from c77590412.lua

card "Puppet Rook" {
    id: 77590412
    type: Effect Monster
    attribute: EARTH
    race: Warrior
    level: 4
    atk: 1200
    def: 1800

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        timing: when
        trigger: when_summoned
        on_resolve {
            change_battle_position (1, monster)
            send (1+, card, you controls, deck) to gy
        }
    }

    continuous_effect "Effect 2" {
        scope: field
        grant: must_attack_if_able
    }

    continuous_effect "Effect 3" {
        scope: field
        grant: must_attack_if_able
    }

    effect "Effect 4" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: when
        damage_step: false
        trigger: when_attacked
        on_resolve {
            send (1+, card, you controls, deck) to gy
            special_summon (1, monster) from gy
        }
    }

}
