// ドラゴンメイドのお片付け
// Dragonmaid Tidying
// Transpiled from c57416183.lua

card "Dragonmaid Tidying" {
    id: 57416183
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        damage_step: false
        on_resolve {
            add_to_hand (1+, card, you controls, where { is_face_up and race == Dragon }) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        activate_from: [gy]
        cost {
            banish self
        }
        on_resolve {
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
