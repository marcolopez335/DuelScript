// ヴェルズ・ゴーレム
// Evilswarm Golem
// Transpiled from c31456110.lua

card "Evilswarm Golem" {
    id: 31456110
    type: Effect Monster
    attribute: DARK
    race: Rock
    level: 5
    atk: 2150
    def: 1250

    summon_condition {
        tributes_required: 1
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_activate {
            select (1+, card, either_player controls, where { is_face_up and level >= 5 }) as target
        }
        on_resolve {
            destroy (1+, card, either_player controls, where { is_face_up and level >= 5 })
        }
    }

}
