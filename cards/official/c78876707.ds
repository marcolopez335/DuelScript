card "Sacred Noble Knight of King Custennin" {
    id: 78876707
    type: Xyz Monster
    attribute: LIGHT
    race: Warrior
    rank: 4
    atk: 1500
    def: 2500

    summon {
        cannot_normal_summon
        xyz materials: (2, monster, where level == 4 and archetype == "Noble Knight")
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        mandatory
        cost {
            detach 1 from self
        }
        resolve {
            add_to_hand (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: custom "chain_end"
        resolve {
            special_summon (all, card, either controls)
        }
    }
}
