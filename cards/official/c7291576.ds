card "Secret Six Samurai - Genba" {
    id: 7291576
    type: Effect Monster | Tuner
    attribute: FIRE
    race: Warrior
    level: 2
    atk: 500
    def: 2100

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        timing: when
        damage_step: false
