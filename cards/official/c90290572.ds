// 代行者の近衛 ムーン
// Protector of The Agents - Moon
// Transpiled from c90290572.lua

card "Protector of The Agents - Moon" {
    id: 90290572
    type: Link Monster
    attribute: LIGHT
    race: Fairy
    link: 2
    link_arrows: [right, bottom_right]
    atk: 1800

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ effect monster
        method: link
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        on_resolve {
            add_to_hand (1+, card, you controls) from deck
            reveal (1+, card, opponent controls)
            send (1+, card, you controls, deck) to gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        cost {
            tribute self
        }
        on_resolve {
            destroy (1+, card, you controls, deck)
        }
    }

}
