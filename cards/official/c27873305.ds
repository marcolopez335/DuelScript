card "D/D/D Wave Oblivion King Caesar Ragnarok" {
    id: 27873305
    type: Fusion Monster
    attribute: DARK
    race: Fiend
    level: 10
    atk: 3200
    def: 3000

    summon {
        cannot_normal_summon
        fusion materials: (2, monster, where archetype == "D/D/D")
    }

    passive "Effect 4" {
        scope: self
        grant: cannot_be_targeted by effects
    }

    passive "Effect 5" {
        scope: self
        grant: cannot_be_destroyed by effect
    }

    passive "Effect 6" {
        scope: self
