// デス・クラーケン
// Doom Kraken
// Transpiled from c69436288.lua

card "Doom Kraken" {
    id: 69436288
    type: Effect Monster
    attribute: WATER
    race: Aqua
    level: 4
    atk: 1400
    def: 1600

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        damage_step: false
        activate_from: [hand]
        on_resolve {
            special_summon (1, monster) from gy
            return (1+, card, either_player controls) to hand
            destroy (1+, card, either_player controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: when
        trigger: when attack_declared
        on_resolve {
            return (1+, card, either_player controls) to hand
            negate attack
        }
    }

}
