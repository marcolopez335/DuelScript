// ガガガシスター
// Gagaga Sister
// Transpiled from c387282.lua

card "Gagaga Sister" {
    id: 387282
    type: Effect Monster
    attribute: DARK
    race: Spellcaster
    level: 2
    atk: 200
    def: 800

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        timing: when
        trigger: when_summoned
        on_resolve {
            add_to_hand (1+, spell, you controls) from deck
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
