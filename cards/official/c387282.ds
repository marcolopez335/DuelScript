card "Gagaga Sister" {
    id: 387282
    type: Effect Monster
    attribute: DARK
    race: Spellcaster
    level: 2
    atk: 200
    def: 800

    raw_effect "Effect 1" {
        effect_type: Single + Trigger
        category: ToHand + Search
        code: SummonSuccess
        on_resolve {
            add_to_hand (1+, spell, you controls) from deck
            reveal (1+, card, opponent controls)
        }
    }

    raw_effect "Effect 2" {
        effect_type: Ignition
        category: LevelChange
        property: CardTarget
        range: MonsterZone
        count_limit: (1, 387282)
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
