card "Power Tool Braver Dragon" {
    id: 63265554
    type: Synchro Monster
    attribute: EARTH
    race: Machine
    level: 9
    atk: 2500
    def: 2300

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        on_resolve {
            equip (1, card) to (1, monster)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        damage_step: false
        on_activate {
            select (1+, spell, you controls, where { is_spell }) as target
        }
        cost {
            send self to gy
        }
        on_resolve {
            change_battle_position (1, monster)
            negate effect
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    continuous_effect "Effect 3" {
        scope: self
        grant: cannot_activate_effects
    }

    continuous_effect "Effect 4" {
        scope: self
        grant: cannot_activate_effects
    }

