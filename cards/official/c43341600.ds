card "Apple of Enlightenment" {
    id: 43341600
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        damage_step: false
        on_activate {
            select (1+, monster, you controls) as target
        }
        on_resolve {
            banish (1+, monster, you controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        optional: true
        timing: if
        trigger: on_custom_event "chain_end"
        on_resolve {
            draw 1
        }
    }

    raw_effect "Effect 3" {
        effect_type: Single + Trigger
        category: Draw
        code: TurnEnd
        property: InitialValue + Delay
        on_resolve {
            draw 1
        }
    }

}
