// ＤＤＤ創始王クロヴィス
// D/D/D First King Clovis
// Transpiled from c70576413.lua

card "D/D/D First King Clovis" {
    id: 70576413
    type: Synchro Monster
    attribute: DARK
    race: Fiend
    level: 6
    atk: 2100
    def: 1900

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        damage_step: false
        trigger: when_summoned by_special_summon
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single + Trigger
        code: TurnEnd
        property: Delay
        on_resolve {
            set_flag "tracked" on self
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    continuous_effect "Effect 3" {
        scope: field
        grant: piercing
    }

}
