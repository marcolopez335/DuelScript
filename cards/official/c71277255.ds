card "Mannadium Riumheart" {
    id: 71277255
    type: Effect Monster
    attribute: LIGHT
    race: Warrior
    level: 4
    atk: 1500
    def: 2100

    effect "Effect 1" {
        speed: 2
        once_per_turn: hard
        resolve {
            destroy (all, card, either controls)
            special_summon (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: summoned
        resolve {
            add_to_hand (all, card, either controls)
        }
    }

    effect "Effect 3" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: summoned by special
        resolve {
            add_to_hand (1, card, where archetype == "Mannadium") from deck
        }
    }
}
