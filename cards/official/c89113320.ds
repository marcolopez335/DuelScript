// Performapal Bit Bite Turtle
// Transpiled from c89113320.lua

card "Performapal Bit Bite Turtle" {
    id: 89113320
    type: Effect Monster | Pendulum Monster
    attribute: WATER
    race: Reptile
    level: 3
    scale: 3
    atk: 800
    def: 1200

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        on_resolve {
            reveal (1+, card, opponent controls)
            shuffle_hand
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        optional: true
        timing: when
        trigger: when_battle_damage
        on_resolve {
            destroy (1+, monster, you controls, hand)
        }
    }

}
