card "Ancient Gear Tanker" {
    id: 91098230
    type: Effect Monster
    attribute: EARTH
    race: Machine
    level: 4
    atk: 1300
    def: 1300

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned
        resolve {
            special_summon (1, monster, where archetype == "Ancient Gear") from hand in attack_position
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            special_summon (1, monster, where archetype == "Ancient Gear") from hand in attack_position
        }
    }

    effect "Effect 3" {
        speed: 1
        once_per_turn: soft
        mandatory
        resolve {
            destroy (all, card, either controls)
        }
    }
}
