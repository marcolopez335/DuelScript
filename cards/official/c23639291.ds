// アグレッシブ・クラウディアン
// Raging Cloudian
// Transpiled from c23639291.lua

card "Raging Cloudian" {
    id: 23639291
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        damage_step: false
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    raw_effect "Effect 2" {
        effect_type: Field + Continuous
        code: ChainEnd
        property: IgnoreRange + BothSide
        range: SpellTrapZone
        on_resolve {
            set_flag "tracked" on self
            emit_event "custom"
        }
    }

}
