card "Sangan" {
    id: 26202165
    type: Effect Monster
    attribute: DARK
    race: Fiend
    level: 3
    atk: 1000
    def: 600

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        trigger: on_custom_event "chain_end"
        on_resolve {
            add_to_hand (1+, monster, opponent controls) from deck
            reveal (1+, card, opponent controls)
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
