// 幽世離レ
// Terrors of the Afterroot
// Transpiled from c85698115.lua

card "Terrors of the Afterroot" {
    id: 85698115
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        damage_step: false
        on_resolve {
            special_summon (1, monster) from gy
            banish (1+, monster, opponent controls)
            send (1+, monster, opponent controls) to gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        optional: true
        damage_step: false
        activate_from: [gy]
        cost {
            banish self
        }
        on_resolve {
            return (1+, monster, opponent controls) to deck shuffle
            set (1, card)
        }
    }

}
