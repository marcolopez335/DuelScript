// 幽世離レ
// Terrors of the Afterroot
// Transpiled from c85698115.lua

card "Terrors of the Afterroot" {
    id: 85698115
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        damage_step: false
        on_activate {
            select (1+, monster, opponent controls, where { is_monster and is_face_up }) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
            banish (1+, monster, opponent controls, where { is_monster and is_face_up })
            send (1+, monster, opponent controls, where { is_monster and is_face_up }) to gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        optional: true
        damage_step: false
        activate_from: [gy]
        on_activate {
            select (1+, monster, opponent controls, where { is_monster and is_face_up }) as target
        }
        cost {
            banish self
        }
        on_resolve {
            return (1+, monster, opponent controls, where { is_monster and is_face_up }) to deck shuffle
            set (1, card)
        }
    }

}
