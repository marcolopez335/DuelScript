card "Prank-Kids Meow-Meow-Mu" {
    id: 25725326
    type: Link Monster
    attribute: EARTH
    race: Rock
    link: 1
    link_arrows: [bottom]
    atk: 1000

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ effect monster
        method: link
    }

    raw_effect "Effect 1" {
        effect_type: Single + Continuous
        code: SpecialSummonSuccess
        property: BothSide
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    raw_effect "Effect 2" {
        effect_type: Field
        property: InitialValue
        range: MonsterZone + Graveyard
        count_limit: (1, 25725326)
        on_resolve {
            banish (1+, card, either_player controls)
        }
    }

    continuous_effect "Effect 3" {
        scope: field
        grant: cannot_be_used_as_material
    }

}
