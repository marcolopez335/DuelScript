card "Bystial Dis Pater" {
    id: 27572350
    type: Synchro Monster
    attribute: DARK
    race: Dragon
    level: 10
    atk: 3500
    def: 3500

    summon {
        cannot_normal_summon
        synchro materials {
            tuner: (1, tuner monster)
            non_tuner: (1+, non-tuner monster, where race == Dragon)
        }
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        mandatory
        resolve {
            special_summon (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 2
        once_per_turn: soft
        timing: when
        trigger: opponent_activates [activate_spell, activate_trap, activate_spell]
        resolve {
            return (all, card, either controls) to deck
            destroy (all, card, either controls)
            negate
        }
    }
}
