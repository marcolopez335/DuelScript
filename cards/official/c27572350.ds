// 深淵の神獣ディス・パテル
// Bystial Dis Pater
// Transpiled from c27572350.lua

card "Bystial Dis Pater" {
    id: 27572350
    type: Synchro Monster
    attribute: DARK
    race: Dragon
    level: 10
    atk: 3500
    def: 3500

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        timing: when
        damage_step: false
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            return (1+, card, either_player controls) to deck shuffle
            destroy (1+, card, either_player controls)
            negate effect
        }
    }

}
