card "Fiendsmith's Requiem" {
    id: 2463794
    type: Link Monster
    attribute: LIGHT
    race: Fiend
    link: 1
    link_arrows: [bottom]
    atk: 600

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ effect monster
        method: link
    }

    effect "Effect 1" {
        speed: spell_speed_2
        optional: true
        cost {
            tribute self
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        activate_from: [monster_zone, gy]
        on_activate {
            select (1+, card, you controls) as target
        }
        on_resolve {
            equip (1, card) to (1, monster)
            send (1+, card, you controls, hand) to gy
        }
    }

    raw_effect "Effect 3" {
        effect_type: Single
        code: CannotAttack2
        property: BothSide
        on_resolve {
        }
    }

    raw_effect "Effect 4" {
        effect_type: Equip
        code: UpdateAttack
        on_resolve {
            modifier: atk + 600
        }
    }

}
