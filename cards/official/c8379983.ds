card "Lunalight Gold Leo" {
    id: 8379983
    type: Effect Monster
    attribute: DARK
    race: Beast-Warrior
    level: 4
    atk: 600
    def: 1600

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned
        resolve {
            add_to_hand (all, card, either controls)
            discard (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            add_to_hand (1, monster, where archetype == "Lunalight") from deck
            discard (all, card, either controls)
        }
    }
}
