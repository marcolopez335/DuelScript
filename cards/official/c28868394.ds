// ジーナの蟲惑魔
// Traptrix Vesiculo
// Transpiled from c28868394.lua

card "Traptrix Vesiculo" {
    id: 28868394
    type: Effect Monster
    attribute: EARTH
    race: Plant
    level: 4
    atk: 1400
    def: 1400

    continuous_effect "Effect 1" {
        scope: self
        grant: unaffected_by_card_effects
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [hand]
        cost {
            send self to gy
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        activate_from: [gy]
        on_activate {
            select (1+, trap, you controls, where { is_trap and is_face_down }) as target
        }
        cost {
            banish self
        }
        on_resolve {
            set (1, card)
        }
    }

}
