// 剣闘獣の闘器マニカ
// Gladiator Beast's Battle Manica
// Transpiled from c52496105.lua

card "Gladiator Beast's Battle Manica" {
    id: 52496105
    type: Equip Spell

    raw_effect "Effect 1" {
        effect_type: Equip
        code: CannotBeEffectTarget
        on_resolve {
            register_effect on self { grant: cannot_be_destroyed_by_battle duration: until_end_of_turn }
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single + MandatoryTrigger
        category: ToHand
        code: ChainEnd
        on_resolve {
            add_to_hand (1+, card, either_player controls) from gy
            reveal (1+, card, opponent controls)
        }
    }

    raw_effect "Effect 3" {
        effect_type: Activate
        category: EquipAction
        code: FreeChain
        on_resolve {
            equip self to (1, monster, you controls)
        }
    }

}
