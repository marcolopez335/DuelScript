card "Exosister Karmael" {
    id: 77675029
    type: Xyz Monster
    attribute: DARK
    race: Fairy
    rank: 4
    atk: 2600
    def: 1800

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        same_level: true
