    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            send (1+, spell, you controls, gy) to gy
        }
    }

    raw_effect "Effect 3" {
        effect_type: Field + Continuous
        code: PhaseEnd
        count_limit: (1, 0)
        on_resolve {
            set (1, card)
        }
