// 四次元の墓
// The Graveyard in the Fourth Dimension
// Transpiled from c88089103.lua

card "The Graveyard in the Fourth Dimension" {
    id: 88089103
    type: Normal Spell

    effect "Effect 1" {
        speed: spell_speed_1
        damage_step: false
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            return (1+, card, either_player controls) to deck shuffle
            reveal (1+, card, opponent controls)
        }
    }

}
