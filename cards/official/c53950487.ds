// B・F－突撃のヴォウジェ
// Battlewasp - Halberd the Charge
// Transpiled from c53950487.lua

card "Battlewasp - Halberd the Charge" {
    id: 53950487
    type: Synchro Monster
    attribute: WIND
    race: Insect
    level: 6
    atk: 2500
    def: 800

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_2
        optional: true
        timing: when
        trigger: when attack_declared
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: when
        trigger: when_battle_destroyed
        on_resolve {
            deal_damage to opponent: 1000
        }
    }

}
