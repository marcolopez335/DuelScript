                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            send (1+, monster, you controls, deck) to gy
        }
    }

    raw_effect "Effect 3" {
        effect_type: Field + Continuous
        code: PhaseEnd
        count_limit: (1, 0)
        on_resolve {
            special_summon (1, monster) from gy
        }
