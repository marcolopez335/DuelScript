// RR－ファントム・クロー
// Raidraptor's Phantom Knights Claw
// Transpiled from c13486638.lua

card "Raidraptor's Phantom Knights Claw" {
    id: 13486638
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        cost {
            send self to gy
        }
        on_resolve {
            negate activation
            destroy (1+, monster, you controls, where { is_face_up and is_xyz and attribute == DARK })
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
