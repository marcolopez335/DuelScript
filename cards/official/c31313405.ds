// 転生炎獣パイロ・フェニックス
// Salamangreat Pyro Phoenix
// Transpiled from c31313405.lua

card "Salamangreat Pyro Phoenix" {
    id: 31313405
    type: Link Monster
    attribute: FIRE
    race: Cyberse
    link: 4
    link_arrows: [top, left, right, bottom]
    atk: 2800

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ effect monster
        method: link
    }

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        on_resolve {
            destroy (1+, card, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, card, opponent controls) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        damage_step: false
        trigger: when_summoned by_special_summon
        on_activate {
            select (1+, card, opponent controls) as target
        }
        on_resolve {
            deal_damage to opponent: 1000
        }
    }

}
