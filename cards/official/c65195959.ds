// EMプラスタートル
// Performapal Stamp Turtle
// Transpiled from c65195959.lua

card "Performapal Stamp Turtle" {
    id: 65195959
    type: Effect Monster
    attribute: WATER
    race: Aqua
    level: 4
    atk: 100
    def: 1800

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_activate {
            select (1+, card, either_player controls, where { is_face_up and level >= 1 }) as target
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
