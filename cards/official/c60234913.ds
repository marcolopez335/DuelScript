// 救世の儀式
// Ritual of Grace
// Transpiled from c60234913.lua

card "Ritual of Grace" {
    id: 60234913
    type: Ritual Spell

    effect "Effect 1" {
        speed: spell_speed_1
        on_resolve {
            ritual_summon (1, ritual monster) using (1+, monster, you controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        damage_step: false
        activate_from: [gy]
        on_activate {
            select (1+, card, either_player controls, where { is_face_up and is_ritual }) as target
        }
        cost {
            banish self
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        on_resolve {
            ritual_summon (1, ritual monster) using (1+, monster, you controls)
        }
    }

}
