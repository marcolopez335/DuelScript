// ベビー・トラゴン
// Baby Tiragon
// Transpiled from c12533811.lua

card "Baby Tiragon" {
    id: 12533811
    type: Xyz Monster
    attribute: EARTH
    race: Dragon
    rank: 1
    atk: 900
    def: 900

    materials {
        require: 2+ monster
        same_level: true
        method: xyz
    }

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        damage_step: false
        on_activate {
            select (1+, card, either_player controls, where { is_face_up }) as target
        }
        cost {
            detach 1 overlay_unit from self
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
