// 光鱗のトビウオ
// Golden Flying Fish
// Transpiled from c76203291.lua

card "Golden Flying Fish" {
    id: 76203291
    type: Effect Monster
    attribute: LIGHT
    race: Fish
    level: 4
    atk: 1700
    def: 1000

    effect "Effect 1" {
        speed: spell_speed_1
        damage_step: false
        on_activate {
            select (1+, card, either_player controls, where { race == Fish }) as target
        }
        cost {
            tribute self
        }
        on_resolve {
            destroy (1+, card, either_player controls, where { race == Fish })
        }
    }

}
