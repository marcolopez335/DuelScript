// チェンジ・デステニー
// Changing Destiny
// Transpiled from c24673894.lua

card "Changing Destiny" {
    id: 24673894
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        damage_step: false
        trigger: when attack_declared
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            negate attack
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            gain_lp: 1000
            deal_damage to opponent: 1000
        }
    }

}
