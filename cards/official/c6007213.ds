card "Uria, Lord of Searing Flames" {
    id: 6007213
    type: Effect Monster | Spirit
    attribute: FIRE
    race: Pyro
    level: 10
    atk: 0
    def: 0

    summon_condition {
        cannot_normal_summon: true
    }

    raw_effect "Effect 1" {
        effect_type: Single
        code: SpsummonCondition
        property: BothSide + Uncopyable
        on_resolve {
        }
    }

    raw_effect "Effect 2" {
        effect_type: Field
        code: CannotSummon
        property: Uncopyable
        range: Hand
        on_resolve {
            send (1+, trap, you controls, where { is_face_up and is_trap }) to gy
        }
    }

    raw_effect "Effect 3" {
        effect_type: Single
        code: UpdateAttack
        property: SingleRange
        range: MonsterZone
        on_resolve {
            modifier: atk + count((1+, card, you controls, gy)) * 1000
        }
    }

    effect "Effect 4" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_activate {
            select (1+, trap, you controls, where { is_face_up and is_trap }) as target
        }
        on_resolve {
            destroy (1+, trap, you controls, where { is_face_up and is_trap })
        }
    }

