// Stardust Dragon
// WIND Dragon Synchro — Level 8, 2500/2000
// 1 Tuner + 1+ non-Tuner monsters
// Quick Effect: When a card or effect is activated that would destroy
// a card(s) on the field: Tribute this card; negate the activation,
// and if you do, destroy it.
// During the End Phase, if this effect was activated this turn:
// Special Summon this card from your GY.

card "Stardust Dragon" {
    type: Synchro Monster | Effect Monster
    attribute: WIND
    race: Dragon
    level: 8
    atk: 2500
    def: 2000
    password: 44508094

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Negate Destruction" {
        speed: spell_speed_2
        optional: true
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]

        cost {
            tribute self
        }

        on_resolve {
            negate activation and destroy
        }
    }

    effect "Revive Self" {
        speed: spell_speed_1
        optional: true
        once_per_turn: soft
        trigger: during_end_phase

        condition: in_gy

        on_resolve {
            special_summon self from gy in attack_position
        }
    }
}
