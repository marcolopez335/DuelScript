// 突撃指令
// Order to Charge
// Transpiled from c78986941.lua

card "Order to Charge" {
    id: 78986941
    type: Quick-Play Spell

    effect "Effect 1" {
        speed: spell_speed_2
        damage_step: false
        on_activate {
            select (1+, monster, opponent controls) as target
        }
        on_resolve {
            tribute (1, monster, you controls)
            destroy (1+, monster, opponent controls)
        }
    }

}
