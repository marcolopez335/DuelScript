// 漆黒のズムウォルト
// Dark Diviner
// Transpiled from c31919988.lua

card "Dark Diviner" {
    id: 31919988
    type: Synchro Monster
    attribute: DARK
    race: Fiend
    level: 4
    atk: 2000
    def: 1000

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    summon_condition {
        cannot_normal_summon: true
    }

    continuous_effect "Effect 1" {
        scope: self
        grant: cannot_be_destroyed_by_battle
    }

    effect "Effect 2" {
        speed: spell_speed_1
        trigger: when attack_declared
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        trigger: when_battle_damage
        on_resolve {
            mill 3
        }
    }

}
