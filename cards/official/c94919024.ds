// 月光紅狐
// Lunalight Crimson Fox
// Transpiled from c94919024.lua

card "Lunalight Crimson Fox" {
    id: 94919024
    type: Effect Monster
    attribute: DARK
    race: Beast-Warrior
    level: 4
    atk: 1800
    def: 600

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        timing: if
        damage_step: false
        trigger: on_custom_event "chain_end"
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        activate_from: [gy]
        cost {
            banish self
        }
        on_resolve {
            negate activation
            send (1+, card, either_player controls) to gy
            gain_lp: 1000
            gain_lp: 1000
        }
    }

}
