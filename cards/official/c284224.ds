// 双天将 密迹
// Dual Avatar - Empowered Mitsu-Jaku
// Transpiled from c284224.lua

card "Dual Avatar - Empowered Mitsu-Jaku" {
    id: 284224
    type: Fusion Monster
    attribute: LIGHT
    race: Warrior
    level: 7
    atk: 2000
    def: 3000

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        method: fusion
    }

    raw_effect "Effect 1" {
        effect_type: Field
        code: CannotHandReturn
        range: MonsterZone
        on_resolve {
            register_effect on self { grant: cannot_be_destroyed duration: until_end_of_turn }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        on_resolve {
            return (1+, spell, opponent controls) to hand
        }
    }

    effect "Effect 3" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            destroy (1+, spell, opponent controls)
        }
    }

}
