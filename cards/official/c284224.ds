card "Dual Avatar - Empowered Mitsu-Jaku" {
    id: 284224
    type: Fusion Monster
    attribute: LIGHT
    race: Warrior
    level: 7
    atk: 2000
    def: 3000

    summon {
        cannot_normal_summon
        fusion materials: "Dual Avatar Feet - Kokoku" + (2, monster, where archetype == "Dual Avatar")
    }

    passive "Effect 1" {
        scope: self
        grant: cannot_be_destroyed
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        mandatory
        resolve {
            return (all, card, either controls) to hand
        }
    }

    effect "Effect 3" {
        speed: 2
        once_per_turn: hard
        timing: when
        trigger: opponent_activates [activate_spell, activate_trap, activate_spell]
        resolve {
            destroy (all, card, either controls)
        }
    }
}
