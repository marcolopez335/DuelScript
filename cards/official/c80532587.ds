// 旧神ヌトス
// Elder Entity N'tss
// Transpiled from c80532587.lua

card "Elder Entity N'tss" {
    id: 80532587
    type: Fusion Monster
    attribute: LIGHT
    race: Fairy
    level: 4
    atk: 2500
    def: 1200

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        method: fusion
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        optional: true
        timing: if
        damage_step: false
        trigger: on_custom_event "chain_end"
        on_activate {
            select (1+, monster, you controls) as target
        }
        on_resolve {
            destroy (1+, monster, you controls)
        }
    }

}
