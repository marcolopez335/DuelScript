card "Performapal Flip Hippo" {
    id: 91449532
    type: Effect Monster
    attribute: EARTH
    race: Beast
    level: 3
    atk: 800
    def: 800

    effect "Effect 1" {
        speed: 1
        timing: when
        trigger: summoned
        resolve {
            special_summon (1, monster, where archetype == "Performapal") from hand in attack_position
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        mandatory
        resolve {
            change_position target to defense_position
        }
    }
}
