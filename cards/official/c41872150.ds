// イナゴの軍勢
// Swarm of Locusts
// Transpiled from c41872150.lua

card "Swarm of Locusts" {
    id: 41872150
    type: Effect Monster
    attribute: DARK
    race: Insect
    level: 3
    atk: 1000
    def: 500

    effect "Effect 1" {
        speed: spell_speed_1
        on_resolve {
            change_battle_position (1, monster)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        damage_step: false
        trigger: when_summoned by_flip_summon
        on_activate {
            select (1+, spell, either_player controls) as target
        }
        on_resolve {
            destroy (1+, spell, either_player controls)
        }
    }

}
