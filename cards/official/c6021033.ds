// デスカイザー・ドラゴン
// Doomkaiser Dragon
// Transpiled from c6021033.lua

card "Doomkaiser Dragon" {
    id: 6021033
    type: Synchro Monster
    attribute: FIRE
    race: Zombie
    level: 6
    atk: 2400
    def: 1500

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        timing: when
        damage_step: false
        trigger: when_summoned by_special_summon
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single + Continuous
        code: ChainNegated
        on_resolve {
            destroy (1+, card, either_player controls)
        }
    }

}
