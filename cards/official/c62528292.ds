card "Ancient Warriors Saga - East-by-South Winds" {
    id: 62528292
    type: Continuous Spell

    effect "Effect 1" {
        speed: 1
        mandatory
        resolve {
            send self to gy
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        mandatory
        resolve {
            send (all, card, either controls) to gy
        }
    }

    effect "Effect 3" {
        speed: 1
        timing: if
        trigger: custom "chain_end"
        condition: previous_location == spell_trap_zone
        resolve {
            install_watcher "desop" { event: attack_declared duration: end_of_turn check { destroy (1, card, opponent controls, from field) } }
        }
    }
}
