card "Nemleria Louve" {
    id: 57296396
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        on_resolve {
            special_summon (1, monster) from gy
            add_to_hand (1+, card, you controls) from hand
            destroy (1+, monster, opponent controls)
        }
