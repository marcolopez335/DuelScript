card "T.G. Recipro Dragonfly" {
    id: 62560742
    type: Synchro Monster
    attribute: WIND
    race: Insect
    level: 2
    atk: 300
    def: 300

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            send (1+, card, either_player controls) to gy
            special_summon (1, monster) from gy
        }
    }

}
