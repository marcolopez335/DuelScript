// グリフォンの翼
// Gryphon Wing
// Transpiled from c55608151.lua

card "Gryphon Wing" {
    id: 55608151
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            negate effect
            destroy (1+, spell, opponent controls, where { is_spell })
        }
    }

}
