// Vanquish Soul Rocks
// Transpiled from c77894049.lua

card "Vanquish Soul Rocks" {
    id: 77894049
    type: Xyz Monster
    attribute: DARK
    race: Pyro
    rank: 4
    atk: 2000
    def: 2500

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        same_level: true
        method: xyz
    }

    raw_effect "Effect 1" {
        effect_type: Field
        code: UpdateAttack
        range: MonsterZone
        on_resolve {
            modifier: atk - 800
        }
    }

    raw_effect "Effect 2" {
        effect_type: Field
        code: UpdateAttack
        range: MonsterZone
        on_resolve {
            modifier: atk + 1000
        }
    }

    raw_effect "Effect 3" {
        effect_type: Ignition
        category: Destroy
        range: MonsterZone
        cost {
            detach 1 overlay_unit from self
        }
        on_resolve {
            destroy (1+, card, either_player controls)
        }
    }

    raw_effect "Effect 4" {
        effect_type: Field + Continuous
        code: BattleEnd
        on_resolve {
            set_flag "tracked" on self
        }
    }

}
