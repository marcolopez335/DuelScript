// 聖蔓の癒し手
// Sunvine Healer
// Transpiled from c65563871.lua

card "Sunvine Healer" {
    id: 65563871
    type: Link Monster
    attribute: EARTH
    race: Plant
    link: 1
    link_arrows: [top]
    atk: 600

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ effect monster
        method: link
    }

    raw_effect "Effect 1" {
        effect_type: Field + MandatoryTrigger
        category: Destroy
        code: ChainNegated
        range: MonsterZone
        on_resolve {
            destroy (1+, card, either_player controls, where { is_link and race == Plant })
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        optional: true
        timing: if
        damage_step: false
        trigger: when_summoned by_special_summon
        on_activate {
            select (1+, card, either_player controls, where { is_link and race == Plant }) as target
        }
        on_resolve {
            gain_lp: 1000
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        optional: true
        timing: when
        trigger: when_battle_destroyed
        on_resolve {
            gain_lp: 1000
        }
    }

}
