// ファーニマル・エンジェル
// Fluffal Angel
// Transpiled from c45215225.lua

card "Fluffal Angel" {
    id: 45215225
    type: Effect Monster | Pendulum Monster
    attribute: LIGHT
    race: Fairy
    level: 2
    scale: 8
    atk: 600
    def: 1200

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_activate {
            select (1+, card, either_player controls) as target
        }
        cost {
            tribute self
        }
        on_resolve {
            discard (1, card)
            special_summon (1, monster) from gy
        }
    }

}
