card "Tearlaments Grief" {
    id: 33878367
    type: Normal Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        on_resolve {
            special_summon (1, monster) from gy
            send (1+, trap, you controls, gy) to gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        damage_step: false
        trigger: on_custom_event "chain_end"
        on_activate {
            select (1+, trap, you controls, where { is_face_up }) as target
        }
        on_resolve {
            add_to_hand (1+, trap, you controls, where { is_face_up }) from gy
        }
    }

}
