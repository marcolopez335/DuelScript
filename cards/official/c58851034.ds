// 封魔の呪印
// Cursed Seal of the Forbidden Spell
// Transpiled from c58851034.lua

card "Cursed Seal of the Forbidden Spell" {
    id: 58851034
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            negate activation
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
