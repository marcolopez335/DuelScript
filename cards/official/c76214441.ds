card "Lifeforce Harmonizer" {
    id: 76214441
    type: Effect Monster
    attribute: WIND
    race: Psychic
    level: 2
    atk: 800
    def: 400

    effect "Effect 1" {
        speed: spell_speed_2
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        activate_from: [hand]
        cost {
            discard (1, card, you controls)
        }
        on_resolve {
            negate activation
            destroy (1+, card, either_player controls)
        }
    }

