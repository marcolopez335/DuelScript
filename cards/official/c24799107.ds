// ドラゴンメイド・シュトラール
// Dragonmaid Sheou
// Transpiled from c24799107.lua

card "Dragonmaid Sheou" {
    id: 24799107
    type: Fusion Monster
    attribute: LIGHT
    race: Dragon
    level: 10
    atk: 3500
    def: 2000

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        method: fusion
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: when
        trigger: during_standby_phase
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            negate activation
            destroy (1+, card, you controls, gy)
            return (1+, card, you controls) to deck shuffle
            special_summon (1, monster) from gy
        }
    }

}
