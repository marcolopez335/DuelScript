// Performapal Pendulum Sorcerer
// Transpiled from c47075569.lua

card "Performapal Pendulum Sorcerer" {
    id: 47075569
    type: Effect Monster | Pendulum Monster
    attribute: EARTH
    race: Spellcaster
    level: 4
    scale: 2
    atk: 1500
    def: 800

    effect "Effect 1" {
        speed: spell_speed_1
        trigger: when_summoned by_special_summon
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        damage_step: false
        trigger: when_summoned by_special_summon
        on_activate {
            select (1+, monster, you controls) as target
        }
        on_resolve {
            destroy (1+, monster, you controls)
            return (1+, monster, you controls) to hand
            reveal (1+, card, opponent controls)
        }
    }

}
