// サイバース・ビーコン
// Cyberse Beacon
// Transpiled from c91269402.lua

card "Cyberse Beacon" {
    id: 91269402
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        on_resolve {
            add_to_hand (1+, card, you controls, where { race == Cyberse and level <= 4 }) from deck
            reveal (1+, card, opponent controls)
        }
    }

    raw_effect "Effect 2" {
        effect_type: Field + Continuous
        code: 1111
        on_resolve {
            set_flag "tracked" on self
        }
    }

}
