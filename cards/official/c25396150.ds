// アマゾネス拝謁の間
// Amazoness Hall
// Transpiled from c25396150.lua

card "Amazoness Hall" {
    id: 25396150
    type: Continuous Trap

    effect "Effect 1" {
        speed: spell_speed_2
        on_resolve {
            add_to_hand (1, card, you controls) from gy
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        timing: if
        damage_step: false
        trigger: when_summoned by_special_summon
        activate_from: [spell_trap_zone]
        on_activate {
            select (1+, monster, you controls) as target
        }
        on_resolve {
            gain_lp: 1000
        }
    }

}
