card "Queen of the Blazing Domain" {
    id: 72162751
    type: Effect Monster
    attribute: DARK
    race: Pyro
    level: 9
    atk: 3000
    def: 2500

    summon_condition {
        tributes_required: 2
    }

    raw_effect "Effect 1" {
        effect_type: Single
