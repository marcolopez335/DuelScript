// 陽炎殿の君主
// Queen of the Blazing Domain
// Transpiled from c72162751.lua

card "Queen of the Blazing Domain" {
    id: 72162751
    type: Effect Monster
    attribute: DARK
    race: Pyro
    level: 9
    atk: 3000
    def: 2500

    summon_condition {
        tributes_required: 2
    }

    continuous_effect "Effect 1" {
        scope: self
        grant: cannot_be_destroyed_by_effect
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        activate_from: [hand]
        on_activate {
            select (1+, spell, you controls) as target
        }
        on_resolve {
            destroy (1+, spell, you controls)
            special_summon (1, monster) from gy
            destroy (1+, monster, opponent controls)
            return (1+, spell, you controls) to hand
        }
    }

}
