// キラー・ラブカ
// Friller Rabca
// Transpiled from c93830681.lua

card "Friller Rabca" {
    id: 93830681
    type: Effect Monster
    attribute: WATER
    race: Fish
    level: 3
    atk: 700
    def: 1500

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: when
        damage_step: false
        trigger: when_attacked
        activate_from: [gy]
        on_activate {
            select (1+, card, either_player controls) as target
        }
        cost {
            banish self
        }
        on_resolve {
            negate attack
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
