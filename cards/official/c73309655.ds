// 清冽の水霊使いエリア
// Eria the Water Charmer, Gentle
// Transpiled from c73309655.lua

card "Eria the Water Charmer, Gentle" {
    id: 73309655
    type: Link Monster
    attribute: WATER
    race: Spellcaster
    link: 2
    link_arrows: [bottom_left, bottom_right]
    atk: 1850

    materials {
        require: 2+ effect monster
        method: link
    }

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, monster, you controls, where { is_monster and attribute == WATER }) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        trigger: when_destroyed
        on_resolve {
            add_to_hand (1+, monster, you controls, where { is_monster and attribute == WATER }) from deck
            reveal (1+, card, opponent controls)
        }
    }

}
