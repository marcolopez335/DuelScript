// クラリアの蟲惑魔
// Traptrix Cularia
// Transpiled from c952523.lua

card "Traptrix Cularia" {
    id: 952523
    type: Link Monster
    attribute: EARTH
    race: Plant
    link: 2
    link_arrows: [right, bottom]
    atk: 1800

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ effect monster
        method: link
    }

    continuous_effect "Effect 1" {
        scope: self
        grant: unaffected_by_card_effects
    }

    raw_effect "Effect 2" {
        effect_type: Field + Continuous
        code: MoveCard
        range: MonsterZone
        on_resolve {
            set_flag "tracked" on self
            change_battle_position (1, monster)
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: when
        damage_step: false
        trigger: during_end_phase
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
