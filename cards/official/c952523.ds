// クラリアの蟲惑魔
// Traptrix Cularia
// Transpiled from c952523.lua

card "Traptrix Cularia" {
    id: 952523
    type: Link Monster
    attribute: EARTH
    race: Plant
    link: 2
    link_arrows: [right, bottom]
    atk: 1800

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ effect monster
        method: link
    }

    raw_effect "Effect 1" {
        effect_type: Single
        code: ImmuneEffect
        property: SingleRange
        range: MonsterZone
        on_resolve {
            register_effect on self { grant: unaffected_by_card_effects duration: until_end_of_turn }
        }
    }

    raw_effect "Effect 2" {
        effect_type: Field + Continuous
        code: MoveCard
        range: MonsterZone
        on_resolve {
            set_flag "tracked" on self
            change_battle_position (1, monster)
        }
    }

    raw_effect "Effect 3" {
        effect_type: Field + Trigger
        category: SpecialSummon
        code: PhaseEnd
        property: CardTarget
        range: MonsterZone
        count_limit: (1, 952523)
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
