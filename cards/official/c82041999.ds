card "Joruri-P.U.N.K. Madame Spider" {
    id: 82041999
    type: Effect Monster | Tuner
    attribute: EARTH
    race: Psychic
    level: 3
    atk: 900
    def: 600

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        cost {
            pay_lp 600
        }
        on_resolve {
            add_to_hand (1+, trap, you controls) from deck
            reveal (1+, card, opponent controls)
        }
    }

    raw_effect "Effect 2" {
        effect_type: QuickEffect
        category: AtkChange
        code: BecomeTarget
        property: CardTarget
        range: MonsterZone
        count_limit: (1, 0)
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
