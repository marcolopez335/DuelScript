card "Glacial Beast Iceberg Narwhal" {
    id: 6568731
    type: Synchro Monster
    attribute: WATER
    race: Aqua
    level: 7
    atk: 2700
    def: 1600

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    effect "Effect 1" {
        speed: spell_speed_1
        trigger: when_destroyed
        on_resolve {
            deal_damage to opponent: 1000
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            negate effect
            destroy (1+, monster, you controls)
        }
    }

