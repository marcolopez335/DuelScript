// 聖なる薊花
// The Hallowed Azamina
// Transpiled from c94845588.lua

card "The Hallowed Azamina" {
    id: 94845588
    type: Normal Spell

    effect "Effect 1" {
        speed: spell_speed_1
        on_resolve {
            reveal (1+, card, opponent controls)
            reveal (1+, card, opponent controls)
            send (1+, monster, you controls, hand) to gy
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        activate_from: [gy]
        on_activate {
            select (1+, monster, you controls) as target
        }
        on_resolve {
            return (1+, monster, you controls) to deck shuffle
            add_to_hand (1+, monster, you controls) from hand
        }
    }

}
