// 捕食原生
// Predaprimitive
// Transpiled from c89176044.lua

card "Predaprimitive" {
    id: 89176044
    // FIXME: card not found in CDB — type/stats are placeholders
    type: Effect Monster
    attribute: DARK
    race: Fiend
    level: 1
    atk: 0
    def: 0

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        cost {
            send self to gy
        }
        on_resolve {
            add_to_hand (1+, spell, you controls, where { is_face_up }) from deck
            reveal (1+, card, opponent controls)
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        optional: true
        timing: if
        damage_step: false
        trigger: when_summoned by_special_summon
        activate_from: [gy]
        on_activate {
            select (1+, spell, you controls, where { is_face_up }) as target
        }
        cost {
            banish self
        }
        on_resolve {
            destroy (1+, spell, you controls, deck)
        }
    }

}
