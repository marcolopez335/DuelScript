// 妖魔ヌリカベ
// Nurikabe
// Transpiled from c60681372.lua

card "Nurikabe" {
    id: 60681372
    type: Effect Monster
    attribute: EARTH
    race: Zombie
    level: 4
    atk: 900
    def: 2000

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        activate_from: [gy]
        on_activate {
            select (1+, card, either_player controls) as target
        }
        cost {
            pay_lp 1000
        }
        on_resolve {
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
