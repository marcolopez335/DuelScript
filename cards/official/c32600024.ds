card "Chamber Dragonmaid" {
    id: 32600024
    type: Effect Monster
    attribute: DARK
    race: Dragon
    level: 4
    atk: 500
    def: 1800

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned
        resolve {
            add_to_hand (1, card, where archetype == "Dragonmaid" and not is_monster) from deck
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            add_to_hand (1, card, where archetype == "Dragonmaid" and not is_monster) from deck
        }
    }
}
