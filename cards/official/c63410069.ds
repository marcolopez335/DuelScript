// 砂漠の飛蝗賊
// Desert Locusts
// Transpiled from c63410069.lua

card "Desert Locusts" {
    id: 63410069
    type: Synchro Monster | Tuner
    attribute: EARTH
    race: Insect
    level: 6
    atk: 1500
    def: 2400

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        trigger: when_summoned by_special_summon
        on_resolve {
            send (1+, card, either_player controls) to gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        optional: true
        on_resolve {
            synchro_summon (1, synchro monster) using (1+, monster, you controls)
        }
    }

}
