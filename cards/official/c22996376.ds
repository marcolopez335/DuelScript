card "Behemoth the King of All Animals" {
    id: 22996376
    type: Effect Monster
    attribute: EARTH
    race: Beast
    level: 7
    atk: 2700
    def: 1500

    summon_condition {
        tributes_required: 2
    }

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        timing: when
        damage_step: false
        trigger: when_summoned
        on_activate {
            select (1+, card, either_player controls, where { race == Beast }) as target
        }
        on_resolve {
            add_to_hand (1+, card, either_player controls, where { race == Beast }) from gy
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single
        code: SetBaseAttack
        property: SingleRange
        range: MonsterZone
        on_resolve {
        }
    }

    continuous_effect "Effect 3" {
        scope: self
        grant: cannot_attack
    }

    continuous_effect "Effect 4" {
        scope: self
        grant: cannot_change_battle_position
    }

}
