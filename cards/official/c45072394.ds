card "Iron Cage" {
    id: 45072394
    type: Continuous Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        on_resolve {
            send (1+, monster, you controls) to gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: when
        trigger: during_standby_phase
        activate_from: [spell_trap_zone]
        on_resolve {
            destroy (1+, monster, you controls)
            special_summon (1, monster) from gy
        }
    }

}
