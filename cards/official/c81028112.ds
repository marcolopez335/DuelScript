card "Wattsychic Fighter" {
    id: 81028112
    type: Effect Monster
    attribute: LIGHT
    race: Psychic
    level: 3
    atk: 1500
    def: 300

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: when
        damage_step: false
