// レッド・ロイド・コール
// Emergeroid Call
// Transpiled from c70628672.lua

card "Emergeroid Call" {
    id: 70628672
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            negate activation
            send (1+, monster, you controls, deck) to gy
            send (1+, monster, you controls, deck) to gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        damage_step: false
        activate_from: [gy]
        on_activate {
            select (1+, monster, you controls) as target
        }
        cost {
            banish self
        }
        on_resolve {
            add_to_hand (1+, monster, you controls) from deck
        }
    }

}
