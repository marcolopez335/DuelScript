card "Unchained Soul Lord of Yama" {
    id: 24269961
    type: Link Monster
    attribute: DARK
    race: Fiend
    link: 2
    link_arrows: [bottom_left, bottom_right]
    atk: 2000

    summon {
        cannot_normal_summon
        link materials: (2, monster, where race == Fiend)
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            return (all, card, either controls) to hand
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        timing: when
        trigger: destroyed
        cost {
            banish self
        }
        resolve {
            special_summon (all, card, either controls)
            destroy (all, card, either controls)
        }
    }
}
