// 焔聖騎士-モージ
// Infernoble Knight Maugis
// Transpiled from c94730900.lua

card "Infernoble Knight Maugis" {
    id: 94730900
    type: Effect Monster
    attribute: FIRE
    race: Warrior
    level: 4
    atk: 1500
    def: 1000

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: on_custom_event "chain_end"
        on_resolve {
            draw 1
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        activate_from: [gy]
        on_activate {
            select (1+, card, you controls, where { is_face_up and race == Warrior }) as target
        }
        on_resolve {
            equip (1, card) to (1, monster)
        }
    }

    continuous_effect "Effect 3" {
        scope: self
        grant: cannot_be_destroyed_by_battle
    }

}
