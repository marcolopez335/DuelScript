card "Cyberse Desavewurm" {
    id: 92422871
    type: Fusion Monster
    attribute: DARK
    race: Cyberse
    level: 6
    atk: 2300
    def: 1500

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        method: fusion
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        on_resolve {
