// オルターガイスト・フィジアラート
// Altergeist Fijialert
// Transpiled from c85673903.lua

card "Altergeist Fijialert" {
    id: 85673903
    type: Effect Monster
    attribute: WATER
    race: Spellcaster
    level: 4
    atk: 1400
    def: 1200

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: when
        damage_step: false
        trigger: when_summoned by_special_summon
        activate_from: [hand]
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
