card "Ningirsu the World Chalice Warrior" {
    id: 30194529
    type: Link Monster
    attribute: EARTH
    race: Warrior
    link: 3
    link_arrows: [top, left, right]
    atk: 2500

    summon {
        cannot_normal_summon
        special_summon_procedure {
            from: extra_deck
            to: your_field
        }
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        mandatory
        trigger: summoned by special
        resolve {
            draw 1
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        mandatory
        resolve {
            send (all, card, either controls) to gy
        }
    }

    effect "Effect 3" {
        speed: 1
        timing: if
        trigger: custom "chain_end"
        condition: previous_location == field
        resolve {
            special_summon (all, card, either controls)
        }
    }
}
