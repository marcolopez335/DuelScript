// 天底の使徒
// Nadir Servant
// Transpiled from c1984618.lua

card "Nadir Servant" {
    id: 1984618
    type: Normal Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        on_resolve {
            send (1+, monster, you controls, gy) to gy
            add_to_hand (1+, monster, you controls) from gy
            reveal (1+, card, opponent controls)
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
