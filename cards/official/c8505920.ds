// Gate Guardians Combined
// Transpiled from c8505920.lua

card "Gate Guardians Combined" {
    password: 8505920
    type: Fusion Monster
    attribute: DARK
    race: Warrior
    level: 12
    atk: 3750
    def: 3400

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        trigger: opponent_activates [search | special_summon | send_to_gy | draw]
        on_resolve {
            negate effect
            destroy (1+, card, either_player controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        optional: true
        trigger: when_leaves_field
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
