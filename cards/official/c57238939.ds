// A・ジェネクス・リモート
// Genex Ally Remote
// Transpiled from c57238939.lua

card "Genex Ally Remote" {
    id: 57238939
    type: Effect Monster | Tuner
    attribute: DARK
    race: Machine
    level: 3
    atk: 500
    def: 1800

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_activate {
            select (1+, card, either_player controls, where { is_face_up and is_tuner }) as target
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
