card "Malevolent Nuzzler" {
    id: 99597615
    type: Equip Spell

    effect "Effect 2" {
        speed: 1
        timing: when
        trigger: custom "chain_end"
        cost {
            pay_lp 500
        }
        condition: previous_location == field
        resolve {
            return (all, card, either controls) to deck
        }
    }

    effect "Effect 3" {
        speed: 1
        mandatory
        resolve {
            send target to deck
        }
    }


    passive "Passive 4" {
        target: equipped_card
        modifier: atk + 700
    }
}
