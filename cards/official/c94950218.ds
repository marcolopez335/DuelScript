// リバース・ブレイカー
// Reverse Breaker
// Transpiled from c94950218.lua

card "Reverse Breaker" {
    id: 94950218
    type: Equip Spell

    effect "Effect 1" {
        speed: spell_speed_1
        damage_step: false
        trigger: when attack_declared
        activate_from: [spell_trap_zone]
        on_resolve {
            destroy (1+, spell, either_player controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        on_resolve {
            equip self to (1, monster, you controls)
        }
    }

}
