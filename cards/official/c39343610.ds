card "Darkblaze Dragon" {
    id: 39343610
    type: Effect Monster
    attribute: FIRE
    race: Dragon
    level: 7
    atk: 1200
    def: 1000

    summon {
        tributes: 2
    }

    effect "Effect 1" {
        speed: 1
        mandatory
        trigger: summoned by special
        condition: previous_location == gy
        resolve {
            set_atk self self.base_atk * 2 until end_of_turn
            set_def self self.base_def * 2 until end_of_turn
        }
    }

    effect "Effect 2" {
        speed: 1
        mandatory
        trigger: battle_damage
        resolve {
            damage opponent 1000
        }
    }
}
