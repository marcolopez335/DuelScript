card "Odin, Father of the Aesir" {
    id: 93483212
    type: Synchro Monster
    attribute: LIGHT
    race: Fairy
    level: 10
    atk: 4000
    def: 3500

    summon {
        cannot_normal_summon
        special_summon_procedure {
            from: extra_deck
            to: your_field
        }
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: soft
        mandatory
    }

    effect "Effect 3" {
        speed: 1
        once_per_turn: soft
        timing: when
        trigger: end_phase
        cost {
            banish self
        }
        resolve {
            special_summon (all, card, either controls)
        }
    }

    effect "Effect 4" {
        speed: 1
        timing: when
        trigger: summoned by special
        resolve {
            draw 1
        }
    }
}
