// エンドレス・オブ・ザ・ワールド
// Cycle of the World
// Transpiled from c32828635.lua

card "Cycle of the World" {
    id: 32828635
    type: Ritual Spell

    effect "Effect 1" {
        speed: spell_speed_1
        activate_from: [gy]
        cost {
            send self to deck
        }
        on_resolve {
            add_to_hand (1+, card, you controls) from gy
            reveal (1+, card, opponent controls)
            add_to_hand (1+, card, you controls) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        on_resolve {
            ritual_summon (1, ritual monster) using (1+, monster, you controls)
        }
    }

}
