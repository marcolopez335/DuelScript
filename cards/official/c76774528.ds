card "Scrap Dragon" {
    id: 76774528
    type: Synchro Monster
    attribute: EARTH
    race: Dragon
    level: 8
    atk: 2800
    def: 2000

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    summon_condition {
        cannot_normal_summon: true
    }

    raw_effect "Effect 1" {
        effect_type: Ignition
        category: Destroy
        property: CardTarget
        range: MonsterZone
        count_limit: (1, 0)
        on_resolve {
            destroy (1+, card, either_player controls)
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single + MandatoryTrigger
        category: SpecialSummon
        code: ChainEnd
        property: CardTarget
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
