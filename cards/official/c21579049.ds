// 白の循環礁
// White Circle Reef
// Transpiled from c21579049.lua

card "White Circle Reef" {
    id: 21579049
    type: Normal Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, monster, you controls, where { race == Fish and is_face_up }) as target
        }
        on_resolve {
            destroy (1+, monster, you controls, gy)
            add_to_hand (1, card, you controls) from gy
            special_summon (1, monster) from gy
            add_to_hand (1+, monster, you controls, where { race == Fish and is_face_up }) from gy
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        activate_from: [gy]
        on_activate {
            select (1+, monster, you controls, where { race == Fish and is_face_up }) as target
        }
        cost {
            banish self
        }
        on_resolve {
            return (1+, monster, you controls, where { race == Fish and is_face_up }) to deck shuffle
            special_summon (1, monster) from gy
        }
    }

}
