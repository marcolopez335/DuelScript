// 深海のセントリー
// Deep Sea Sentry
// Transpiled from c45483489.lua

card "Deep Sea Sentry" {
    id: 45483489
    type: Effect Monster
    attribute: WATER
    race: Sea Serpent
    level: 2
    atk: 400
    def: 2000

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: on_custom_event "chain_end"
        on_resolve {
            banish (1+, card, opponent controls, hand)
            shuffle_hand
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        damage_step: false
        trigger: when_summoned by_special_summon
        on_activate {
            select (1+, card, opponent controls) as target
        }
        on_resolve {
            add_to_hand (1+, card, opponent controls) from hand
        }
    }

}
