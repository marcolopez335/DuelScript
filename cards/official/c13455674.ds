card "Crystron Quariongandrax" {
    id: 13455674
    type: Synchro Monster
    attribute: WATER
    race: Machine
    level: 9
    atk: 3000
    def: 3000

    summon {
        cannot_normal_summon
        synchro materials {
            tuner: (2+, tuner monster)
            non_tuner: (1, non-tuner monster)
        }
    }

    effect "Effect 1" {
        speed: 1
        timing: if
        trigger: summoned by special
        resolve {
            banish (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        timing: if
        trigger: destroyed
        resolve {
            special_summon (all, card, either controls)
        }
    }
}
