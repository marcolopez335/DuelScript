// ブラック・ブルドラゴ
// Black Brutdrago
// Transpiled from c96029574.lua

card "Black Brutdrago" {
    id: 96029574
    type: Synchro Monster
    attribute: FIRE
    race: Dragon
    level: 8
    atk: 3000
    def: 2600

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_activate {
            select (1+, spell, you controls, where { is_spell }) as target
        }
        cost {
            send self to gy
        }
        on_resolve {
            destroy (1+, spell, you controls, hand)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        optional: true
        timing: when
        damage_step: false
        trigger: on_custom_event "chain_end"
        on_activate {
            select (1+, spell, you controls, where { is_spell }) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
