// かなり魅湧な受注水産
// Made to Order Mermaid Outfit Outfitter
// Transpiled from c96127902.lua

card "Made to Order Mermaid Outfit Outfitter" {
    id: 96127902
    type: Normal Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, card, you controls) as target
        }
        on_resolve {
            banish (1+, card, you controls, deck)
            add_to_hand (1+, card, you controls) from deck
            reveal (1+, card, opponent controls)
        }
    }

}
