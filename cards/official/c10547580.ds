// 古代の機械弩士
// Ancient Gear Ballista
// Transpiled from c10547580.lua

card "Ancient Gear Ballista" {
    id: 10547580
    type: Link Monster
    attribute: EARTH
    race: Machine
    link: 2
    link_arrows: [right, bottom_left]
    atk: 1500

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ effect monster
        method: link
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        on_resolve {
            add_to_hand (1+, monster, you controls) from deck
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_resolve {
            destroy (1+, monster, you controls, deck)
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    continuous_effect "Effect 3" {
        scope: self
        grant: cannot_be_destroyed_by_battle
    }

    raw_effect "Effect 4" {
        effect_type: Single
        code: SetDefenseFinal
        on_resolve {
            modifier: def + 0
        }
    }

}
