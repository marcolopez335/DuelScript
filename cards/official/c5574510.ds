card "Shateki" {
    id: 5574510
    type: Continuous Spell

    effect "Effect 1" {
        speed: spell_speed_1
        on_resolve {
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        damage_step: false
        activate_from: [spell_trap_zone]
        on_activate {
            select (1+, card, you controls) as target
        }
        cost {
            discard (1, card, you controls)
        }
        on_resolve {
            flip_coin { heads { draw 1 } tails { draw 1 } }
            destroy (1+, card, you controls, deck)
            add_to_hand (1+, card, you controls) from deck
            reveal (1+, card, opponent controls)
            set_flag "tracked" on self
        }
    }

}
