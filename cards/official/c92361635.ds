// アトミック・スクラップ・ドラゴン
// Atomic Scrap Dragon
// Transpiled from c92361635.lua

card "Atomic Scrap Dragon" {
    id: 92361635
    type: Synchro Monster
    attribute: EARTH
    race: Dragon
    level: 10
    atk: 3200
    def: 2400

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_resolve {
            destroy (1+, card, either_player controls)
            return (1+, card, either_player controls) to deck shuffle
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        damage_step: false
        trigger: on_custom_event "chain_end"
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
