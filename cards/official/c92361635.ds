card "Atomic Scrap Dragon" {
    id: 92361635
    type: Synchro Monster
    attribute: EARTH
    race: Dragon
    level: 10
    atk: 3200
    def: 2400

    summon {
        cannot_normal_summon
        synchro materials {
            tuner: (1, tuner monster, where archetype == "Scrap")
            non_tuner: (2+, non-tuner monster)
        }
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: soft
        mandatory
        target (1, card, you control, from field)
        resolve {
            destroy (all, card, either controls)
            return (all, card, either controls) to deck
        }
    }

    effect "Effect 2" {
        speed: 1
        mandatory
        trigger: custom "chain_end"
        resolve {
            special_summon (all, card, either controls)
        }
    }
}
