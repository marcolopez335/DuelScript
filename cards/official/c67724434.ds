// ダブル・ワイルド
// Double Wild
// Transpiled from c67724434.lua

card "Double Wild" {
    id: 67724434
    type: Quick-Play Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, card, you controls, where { level == 10 }) as target
        }
        on_resolve {
            add_to_hand (1+, card, you controls, where { level == 10 }) from hand
            reveal (1+, card, opponent controls)
            shuffle_hand
            discard (1, card)
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
