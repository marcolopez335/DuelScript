card "Parallel Port Armor" {
    id: 879958
    type: Normal Trap

    effect "Effect 1" {
        speed: 2
        mandatory
        resolve {
            equip self to target
            grant equipped_card cannot_be_destroyed by battle until while_equipped
            grant equipped_card cannot_be_targeted until while_equipped
        }
    }

    effect "Effect 2" {
        speed: 2
        cost {
            banish self
        }
        resolve {
            grant target double_attack until end_of_turn
        }
    }
}
