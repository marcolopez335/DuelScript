// オルターガイスト・キードゥルガー
// Altergeist Kidolga
// Transpiled from c76685519.lua

card "Altergeist Kidolga" {
    id: 76685519
    type: Link Monster
    attribute: DARK
    race: Spellcaster
    link: 2
    link_arrows: [left, bottom]
    atk: 1000

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ effect monster
        method: link
    }

    raw_effect "Effect 1" {
        effect_type: Field + Trigger
        category: SpecialSummon
        code: BattleDestroyed
        property: CardTarget
        range: MonsterZone
        on_resolve {
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single + Trigger
        category: ToHand
        code: BattleDamage
        property: CardTarget + Delay
        on_resolve {
            add_to_hand (1+, card, either_player controls) from gy
        }
    }

}
