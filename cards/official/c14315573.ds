// 攻撃の無力化
// Negate Attack
// Transpiled from c14315573.lua

card "Negate Attack" {
    id: 14315573
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        damage_step: false
        trigger: when attack_declared
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            negate attack
        }
    }

}
