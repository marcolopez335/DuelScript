card "U.A. Blockbacker" {
    id: 34614289
    type: Effect Monster
    attribute: EARTH
    race: Warrior
    level: 7
    atk: 1600
    def: 2700

    summon_condition {
        tributes_required: 2
    }

    raw_effect "Effect 1" {
        effect_type: Field
        code: CannotSummon
        property: Uncopyable
        range: Hand
        count_limit: (1, 34614289)
        on_resolve {
            return (1+, monster, you controls) to hand
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: when
        trigger: when_summoned by_special_summon
        on_resolve {
            change_battle_position (1, monster)
            negate effect
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
