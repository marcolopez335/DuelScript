// 灼熱の火霊使いヒータ
// Hiita the Fire Charmer, Ablaze
// Transpiled from c48815792.lua

card "Hiita the Fire Charmer, Ablaze" {
    id: 48815792
    type: Link Monster
    attribute: FIRE
    race: Spellcaster
    link: 2
    link_arrows: [bottom_left, bottom_right]
    atk: 1850

    materials {
        require: 2+ effect monster
        method: link
    }

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, monster, you controls, where { is_monster and attribute == FIRE }) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        trigger: when_destroyed
        on_resolve {
            add_to_hand (1+, monster, you controls, where { is_monster and attribute == FIRE }) from deck
            reveal (1+, card, opponent controls)
        }
    }

}
