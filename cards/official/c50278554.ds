// スクラップ・ツイン・ドラゴン
// Scrap Twin Dragon
// Transpiled from c50278554.lua

card "Scrap Twin Dragon" {
    id: 50278554
    type: Synchro Monster
    attribute: EARTH
    race: Dragon
    level: 9
    atk: 3000
    def: 2200

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    summon_condition {
        cannot_normal_summon: true
    }

    raw_effect "Effect 1" {
        effect_type: Ignition
        category: Destroy + ToHand
        property: CardTarget
        range: MonsterZone
        count_limit: (1, 0)
        on_resolve {
            destroy (1+, card, either_player controls)
            add_to_hand (1+, card, either_player controls) from gy
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single + MandatoryTrigger
        category: SpecialSummon
        code: ChainEnd
        property: CardTarget
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
