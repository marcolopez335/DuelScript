card "Ignis Phoenix, the Dracoslayer" {
    id: 56347375
    type: Effect Monster | Pendulum Monster
    attribute: FIRE
    race: Warrior
    level: 4
    scale: 7
    atk: 1700
    def: 1900

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        on_resolve {
            reveal (1+, card, opponent controls)
            return (1+, monster, either_player controls) to deck shuffle
            add_to_hand (1+, monster, either_player controls) from gy
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        trigger: when_destroyed
        on_resolve {
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
