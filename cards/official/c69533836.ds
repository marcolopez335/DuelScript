// 魂を刻む右
// Soul Fist
// Transpiled from c69533836.lua

card "Soul Fist" {
    id: 69533836
    type: Equip Spell

    continuous_effect "Effect 1" {
        scope: self
        grant: unaffected_by_card_effects
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        activate_from: [spell_trap_zone]
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: when
        damage_step: false
        trigger: when attack_declared
        activate_from: [spell_trap_zone]
        on_activate {
            select (1+, monster, opponent controls) as target
        }
        on_resolve {
            banish (1+, monster, opponent controls)
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    continuous_effect "Effect 4" {
        scope: self
        grant: cannot_be_destroyed_by_battle
    }

    raw_effect "Effect 5" {
        effect_type: Single
        code: UpdateAttack
        property: BothSide
        on_resolve {
            modifier: atk + 0
        }
    }

    effect "Effect 6" {
        speed: spell_speed_1
        on_resolve {
            equip self to (1, monster, you controls)
        }
    }

}
