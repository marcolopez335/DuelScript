card "T.G. Drill Fish" {
    id: 30348744
    type: Effect Monster
    attribute: WATER
    race: Fish
    level: 1
    atk: 100
    def: 800

    continuous_effect "Effect 1" {
        scope: self
        grant: direct_attack
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [hand]
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: when
        damage_step: false
        trigger: when_battle_destroyed
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            destroy (1+, card, either_player controls)
        }
    }

