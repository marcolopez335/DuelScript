// 冥帝エレボス
// Erebus the Underworld Monarch
// Transpiled from c23064604.lua

card "Erebus the Underworld Monarch" {
    id: 23064604
    type: Effect Monster
    attribute: DARK
    race: Zombie
    level: 8
    atk: 2800
    def: 1000

    summon_condition {
        tributes_required: 2
    }

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        timing: if
        trigger: when_summoned
        on_resolve {
            send (1+, spell, you controls, hand) to gy
            return (1+, spell, you controls) to deck shuffle
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        damage_step: false
        activate_from: [gy]
        on_resolve {
            add_to_hand (1+, spell, you controls) from hand
        }
    }

    continuous_effect "Effect 3" {
        scope: self
        grant: cannot_attack
    }

    continuous_effect "Effect 4" {
        scope: self
        grant: cannot_change_battle_position
    }

}
