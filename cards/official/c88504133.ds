// ＲＵＭ－ファントム・フォース
// Phantom Knights' Rank-Up-Magic Force
// Transpiled from c88504133.lua

card "Phantom Knights' Rank-Up-Magic Force" {
    id: 88504133
    type: Quick-Play Spell

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, card, either_player controls, where { attribute == DARK }) as target
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            attach (1, card) to self as_material
            special_summon (1, monster) from gy
        }
    }

}
