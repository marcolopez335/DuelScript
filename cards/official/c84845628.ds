// 獄落鳥
// Bird of Paradise Lost
// Transpiled from c84845628.lua

card "Bird of Paradise Lost" {
    id: 84845628
    type: Effect Monster | Tuner
    attribute: DARK
    race: Wyrm
    level: 8
    atk: 2700
    def: 1500

    summon_condition {
        tributes_required: 2
    }

    raw_effect "Effect 1" {
        effect_type: Single
        code: UpdateAttack
        property: SingleRange
        range: MonsterZone
        on_resolve {
            modifier: atk + count((1+, card, you controls, gy)) * 100
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single
        code: UpdateDefense
        property: SingleRange
        range: MonsterZone
        on_resolve {
            modifier: def + count((1+, card, you controls, gy)) * 100
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_activate {
            select (1+, card, you controls, where { is_tuner }) as target
        }
        on_resolve {
            take_control of (1, monster, opponent controls)
        }
    }

}
