// 不退の荒武者
// Driven Daredevil
// Transpiled from c93353691.lua

card "Driven Daredevil" {
    id: 93353691
    type: Synchro Monster
    attribute: EARTH
    race: Warrior
    level: 7
    atk: 2400
    def: 2100

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    summon_condition {
        cannot_normal_summon: true
    }

    raw_effect "Effect 1" {
        effect_type: Single
        code: CannotBeEffectTarget
        range: MonsterZone
        on_resolve {
            register_effect on self { grant: cannot_be_destroyed_by_battle duration: until_end_of_turn }
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single + MandatoryTrigger
        category: Destroy
        code: BattleEnd
        on_resolve {
            destroy (1+, card, either_player controls)
        }
    }

}
