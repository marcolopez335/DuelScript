card "Guardragon Cataclysm" {
    id: 47393199
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, card, either_player controls, where { race == Dragon }) as target
        }
        on_resolve {
            destroy (1+, card, either_player controls, where { race == Dragon })
        }
    }

}
