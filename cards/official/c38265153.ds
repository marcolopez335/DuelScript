// 電脳エナジーショック
// Cyber Energy Shock
// Transpiled from c38265153.lua

card "Cyber Energy Shock" {
    id: 38265153
    type: Quick-Play Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, trap, you controls) as target
        }
        on_resolve {
            destroy (1+, trap, you controls)
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single
        code: UpdateAttack
        on_resolve {
            modifier: atk + 800
        }
    }

}
