// ギミック・パペット－キメラ・ドール
// Gimmick Puppet Chimera Doll
// Transpiled from c97520532.lua

card "Gimmick Puppet Chimera Doll" {
    id: 97520532
    type: Link Monster
    attribute: DARK
    race: Machine
    link: 2
    link_arrows: [bottom_left, bottom_right]
    atk: 1500

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ effect monster
        method: link
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        on_resolve {
            add_to_hand (1, card, you controls) from gy
            shuffle_hand
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    continuous_effect "Effect 2" {
        scope: field
        grant: cannot_be_used_as_material
    }

}
