// シャイニング・アブソーブ
// Leeching the Light
// Transpiled from c90263923.lua

card "Leeching the Light" {
    id: 90263923
    type: Normal Spell

    effect "Effect 1" {
        speed: spell_speed_1
        damage_step: false
        on_activate {
            select (1+, monster, you controls, where { is_face_up and attribute == LIGHT }) as target
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
