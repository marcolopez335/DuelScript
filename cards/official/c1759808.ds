// 幻魔の肖像
// Fiendish Portrait
// Transpiled from c1759808.lua

card "Fiendish Portrait" {
    id: 1759808
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, card, you controls) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
            destroy (1+, monster, opponent controls)
            return (1+, card, you controls) to deck shuffle
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
