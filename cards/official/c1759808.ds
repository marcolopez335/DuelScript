card "Fiendish Portrait" {
    id: 1759808
    type: Normal Trap

    raw_effect "Effect 1" {
        effect_type: Activate
        category: SpecialSummon
        code: FreeChain
        property: CardTarget
        count_limit: (1, 1759808)
        on_resolve {
            special_summon (1, monster) from gy
            destroy (1+, monster, opponent controls)
            return (1+, card, you controls) to deck shuffle
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
