// 魂の共有－コモンソウル
// Common Soul
// Transpiled from c14772491.lua

card "Common Soul" {
    id: 14772491
    type: Continuous Spell

    effect "Effect 1" {
        speed: spell_speed_1
        damage_step: false
        on_activate {
            select (1+, card, you controls, where { is_face_up }) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single + Continuous
        code: ChainNegated
        on_resolve {
            add_to_hand (1+, card, you controls, where { is_face_up }) from hand
        }
    }

}
