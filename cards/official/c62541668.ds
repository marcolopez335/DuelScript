card "Number 77: The Seven Sins" {
    id: 62541668
    type: Xyz Monster
    attribute: DARK
    race: Fiend
    rank: 12
    atk: 4000
    def: 3000

    materials {
        require: 2+ monster
        same_level: true
        method: xyz
    }

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        cost {
            detach 2 overlay_unit from self
        }
        on_resolve {
            banish (1+, monster, opponent controls, where { is_monster })
            attach (1, card) to self as_material
        }
    }

    replacement_effect "Effect 2" {
        instead_of: destroyed_by_any
        do: {
            banish self
        }
    }

