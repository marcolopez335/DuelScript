card "Dracotail Lukias" {
    id: 75003700
    type: Effect Monster
    attribute: EARTH
    race: Spellcaster
    level: 4
    atk: 1800
    def: 700

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned
        resolve {
            add_to_hand (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            add_to_hand (1, monster, where archetype == "Dracotail") from deck
        }
    }
}
