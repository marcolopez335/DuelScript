card "Indomitable Gladiator Beast" {
    id: 55136228
    type: Quick-Play Spell

    effect "Effect 1" {
        speed: 2
        mandatory
        target (1, card, you control, from monster_zone, where is_face_up and archetype == "Gladiator Beast")
        resolve {
            modify_atk target + 500 until end_of_turn
        }
    }

    effect "Effect 2" {
        speed: 2
        mandatory
        resolve {
            add_to_hand (all, card, either controls)
        }
    }
}
