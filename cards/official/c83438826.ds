// 聖剣アロンダイト
// Noble Arms - Arfeudutyr
// Transpiled from c83438826.lua

card "Noble Arms - Arfeudutyr" {
    id: 83438826
    type: Equip Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        activate_from: [spell_trap_zone]
        on_activate {
            select (1+, card, either_player controls, where { is_face_down }) as target
        }
        on_resolve {
            destroy (1+, card, either_player controls, where { is_face_down })
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        damage_step: false
        trigger: on_custom_event "chain_end"
        on_activate {
            select (1+, card, either_player controls, where { is_face_down }) as target
        }
        on_resolve {
            equip (1, card) to (1, monster)
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        on_resolve {
            equip self to (1, monster, you controls)
        }
    }

}
