// パラメタルフォーゼ・メルキャスター
// Parametalfoes Melcaster
// Transpiled from c10024317.lua

card "Parametalfoes Melcaster" {
    id: 10024317
    type: Effect Monster | Pendulum Monster
    attribute: FIRE
    race: Psychic
    level: 7
    scale: 1
    atk: 2000
    def: 2500

    summon_condition {
        tributes_required: 2
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_activate {
            select (1+, monster, you controls) as target
        }
        on_resolve {
            destroy (1+, monster, you controls, deck)
            set (1, card)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: when_destroyed
        on_resolve {
            add_to_hand (1+, monster, you controls) from deck
            reveal (1+, card, opponent controls)
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
