// 鎖付き爆弾
// Blast with Chain
// Transpiled from c98239899.lua

card "Blast with Chain" {
    id: 98239899
    type: Normal Trap

    raw_effect "Effect 1" {
        effect_type: Activate
        category: EquipAction
        code: FreeChain
        property: CardTarget + Oath
        on_resolve {
            equip (1, card) to (1, monster)
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single + MandatoryTrigger
        code: ChainNegated
        property: CardTarget
        on_resolve {
            destroy (1+, card, either_player controls)
        }
    }

}
