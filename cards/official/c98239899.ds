// 鎖付き爆弾
// Blast with Chain
// Transpiled from c98239899.lua

card "Blast with Chain" {
    id: 98239899
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        damage_step: false
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            equip (1, card) to (1, monster)
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single + MandatoryTrigger
        code: ChainNegated
        property: CardTarget
        on_resolve {
            destroy (1+, card, either_player controls)
        }
    }

}
