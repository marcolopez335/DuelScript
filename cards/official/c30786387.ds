// 花積み
// Flower Stacking
// Transpiled from c30786387.lua

card "Flower Stacking" {
    id: 30786387
    type: Normal Spell

    effect "Effect 1" {
        speed: spell_speed_1
        on_resolve {
            reveal (1+, card, opponent controls)
            shuffle_deck
            send_to_deck (1+, card, you controls) top
            send_to_deck (1+, card, you controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        activate_from: [gy]
        on_activate {
            select (1+, monster, you controls) as target
        }
        cost {
            banish self
        }
        on_resolve {
            add_to_hand (1+, monster, you controls) from deck
        }
    }

}
