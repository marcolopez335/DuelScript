card "Virtual World Beast - Jiujiu" {
    id: 35252119
    type: Synchro Monster
    attribute: WIND
    race: Psychic
    level: 6
    atk: 2400
    def: 1700

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    continuous_effect "Effect 1" {
        scope: self
        grant: cannot_be_destroyed_by_battle
    }

    continuous_effect "Effect 2" {
        scope: self
        grant: cannot_be_destroyed_by_effect
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        cost {
            banish self
        }
        on_resolve {
            send (1+, monster, you controls, gy) to gy
        }
    }

}
