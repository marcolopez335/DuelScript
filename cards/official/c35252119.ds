card "Virtual World Beast - Jiujiu" {
    id: 35252119
    type: Synchro Monster
    attribute: WIND
    race: Psychic
    level: 6
    atk: 2400
    def: 1700

    summon {
        cannot_normal_summon
        synchro materials {
            tuner: (1, tuner monster)
            non_tuner: (1+, non-tuner monster)
        }
    }

    passive "Effect 1" {
        scope: self
        grant: cannot_be_destroyed by battle
    }

    passive "Effect 2" {
        scope: self
        grant: cannot_be_destroyed by effect
    }

    effect "Effect 3" {
        speed: 1
        once_per_turn: hard
        mandatory
        cost {
            banish self
        }
        resolve {
            send (all, card, either controls) to gy
        }
    }
