card "Destrudo the Lost Dragon's Frisson" {
    id: 5560911
    type: Effect Monster | Tuner
    attribute: DARK
    race: Dragon
    level: 7
    atk: 1000
    def: 3000

    summon_condition {
        tributes_required: 2
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        activate_from: [hand, gy]
        on_activate {
            select (1+, card, either_player controls, where { is_face_up and level <= 6 }) as target
        }
        cost {
            pay_lp your_lp / 2
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
