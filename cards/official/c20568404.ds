            }
            destroy (1+, card, you controls)
            send (1+, card, you controls) to gy
            special_summon (1, monster) from gy
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single + Trigger
        category: ToHand
        code: BattleDamage
        on_resolve {
            return (1+, card, you controls) to hand
        }
    }

}
