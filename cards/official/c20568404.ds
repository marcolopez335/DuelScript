card "Jurrac Stego" {
    password: 20568404
    type: Effect Monster
    attribute: FIRE
    race: Dinosaur
    level: 4
    atk: 1700
    def: 900

    raw_effect "Effect 1" {
        effect_type: Ignition
        category: Destroy + ToGrave + SpecialSummon
        range: MonsterZone
        count_limit: (1, 20568404)
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
