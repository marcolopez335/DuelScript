// ジュラック・スティゴ
// Jurrac Stego
// Transpiled from c20568404.lua

card "Jurrac Stego" {
    id: 20568404
    type: Effect Monster
    attribute: FIRE
    race: Dinosaur
    level: 4
    atk: 1700
    def: 900

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            destroy (1+, card, you controls)
            send (1+, card, you controls) to gy
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        optional: true
        timing: when
        trigger: when_battle_damage
        on_resolve {
            return (1+, card, you controls) to hand
        }
    }

}
