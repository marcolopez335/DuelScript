// 闇征竜－ネビュラス
// Nebulus, Dragon Ruler of Mishaps
// Transpiled from c94655777.lua

card "Nebulus, Dragon Ruler of Mishaps" {
    id: 94655777
    type: Effect Monster
    attribute: DARK
    race: Dragon
    level: 2
    atk: 1000
    def: 600

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        activate_from: [hand]
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        activate_from: [gy]
        on_activate {
            select (1+, card, either_player controls) as target
        }
        cost {
            banish self
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
