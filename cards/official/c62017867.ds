card "Superheavy Samurai Gigagloves" {
    id: 62017867
    type: Effect Monster
    attribute: EARTH
    race: Machine
    level: 3
    atk: 100
    def: 1000

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        timing: if
        trigger: on_custom_event "chain_end"
        on_resolve {
            send_to_deck (1+, card, you controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        optional: true
        timing: when
        trigger: when attack_declared
        activate_from: [gy]
        cost {
            banish self
        }
        on_resolve {
            reveal (1, card, opponent controls, deck)
            add_to_hand (1+, spell, you controls) from gy
            shuffle_hand
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            send (1+, spell, you controls, gy) to gy
        }
    }

}
