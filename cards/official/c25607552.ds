// 華信龍－ノウルーズ・エリーズ
// Nowru Aries the Vernal Dragon
// Transpiled from c25607552.lua

card "Nowru Aries the Vernal Dragon" {
    id: 25607552
    type: Effect Monster
    attribute: WIND
    race: Dragon
    level: 7
    atk: 2000
    def: 2500

    summon_condition {
        tributes_required: 2
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [gy]
        cost {
            send self to gy
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        damage_step: false
        trigger: when_destroyed
        on_activate {
            select (1+, monster, you controls, where { is_monster and level >= 5 }) as target
        }
        on_resolve {
            banish (1+, monster, you controls, hand)
        }
    }

}
