// ハイネス・デーモン
// Highness Archfiend
// Transpiled from c11248645.lua

card "Highness Archfiend" {
    id: 11248645
    type: Effect Monster
    attribute: LIGHT
    race: Fiend
    level: 3
    atk: 1000
    def: 800

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: when_summoned
        cost {
            banish self
        }
        on_resolve {
            add_to_hand (1+, card, you controls) from gy
            reveal (1+, card, opponent controls)
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: when
        trigger: when_battle_damage
        activate_from: [gy]
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
