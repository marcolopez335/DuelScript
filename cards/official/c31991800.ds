// マジェスペクター・ラクーン
// Majespecter Raccoon - Bunbuku
// Transpiled from c31991800.lua

card "Majespecter Raccoon - Bunbuku" {
    id: 31991800
    type: Effect Monster | Pendulum Monster
    attribute: WIND
    race: Spellcaster
    level: 3
    scale: 5
    atk: 1200
    def: 900

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: when
        trigger: when_summoned
        on_resolve {
            add_to_hand (1+, monster, you controls) from deck
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: when
        trigger: when_summoned by_special_summon
        on_resolve {
            add_to_hand (1+, monster, you controls) from deck
            reveal (1+, card, opponent controls)
        }
    }

    continuous_effect "Effect 3" {
        scope: self
        grant: cannot_be_targeted_by_card_effects
    }

    continuous_effect "Effect 4" {
        scope: self
        grant: cannot_be_destroyed_by_effect
    }

}
