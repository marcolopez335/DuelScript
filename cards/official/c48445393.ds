card "Scrapstorm" {
    id: 48445393
    type: Quick-Play Spell

    effect "Effect 1" {
        speed: spell_speed_1
        damage_step: false
        on_activate {
            select (1+, monster, you controls) as target
        }
        on_resolve {
            send (1+, monster, you controls, deck) to gy
            shuffle_deck
            draw 1
            destroy (1+, monster, you controls, deck)
        }
    }

}
