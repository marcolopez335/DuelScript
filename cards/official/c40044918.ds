card "Elemental HERO Stratos" {
    id: 40044918
    type: Effect Monster
    attribute: WIND
    race: Warrior
    level: 4
    atk: 1800
    def: 300

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        timing: when
        trigger: when_summoned
        on_resolve {
            destroy (1+, monster, either_player controls)
            return (1+, monster, either_player controls) to hand
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        optional: true
        timing: when
        trigger: when_summoned by_special_summon
        on_resolve {
            destroy (1+, monster, either_player controls)
            return (1+, monster, either_player controls) to hand
            reveal (1+, card, opponent controls)
        }
    }

}
