// The Dragon's Bead
// Transpiled from c92408984.lua

card "The Dragon's Bead" {
    password: 92408984
    type: Continuous Trap

    effect "Effect 1" {
        speed: spell_speed_1
        on_resolve {
            reveal self
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        optional: true
        trigger: opponent_activates [search | special_summon | send_to_gy | draw]
        on_resolve {
            negate effect
            destroy (1+, card, either_player controls)
        }
    }

}
