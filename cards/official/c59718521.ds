// Mind Over Matter
// Transpiled from c59718521.lua

card "Mind Over Matter" {
    password: 59718521
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_1
        trigger: when_summoned
        cost {
            tribute self
        }
        on_resolve {
            negate summon
            destroy (1+, card, either_player controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        trigger: opponent_activates [search | special_summon | send_to_gy | draw]
        cost {
            tribute self
        }
        on_resolve {
            negate activation
            destroy (1+, card, either_player controls)
        }
    }

}
