card "Chaofeng, Phantom of the Yang Zing" {
    id: 19048328
    type: Synchro Monster
    attribute: LIGHT
    race: Wyrm
    level: 9
    atk: 2800
    def: 2200

    summon {
        cannot_normal_summon
    }

    effect "Effect 3" {
        speed: 1
        timing: when
        trigger: custom "chain_end"
        resolve {
            add_to_hand (all, card, either controls)
        }
    }

    effect "Effect 4" {
        speed: 1
        once_per_turn: soft
        timing: when
        trigger: destroyed
        resolve {
            special_summon (all, card, either controls)
        }
    }
}
