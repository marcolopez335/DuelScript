card "Enlightenment Paladin" {
    id: 59123194
    type: Synchro Monster
    attribute: DARK
    race: Spellcaster
    level: 8
    atk: 2500
    def: 2000

    summon {
        cannot_normal_summon
        synchro materials {
            tuner: (1, tuner monster)
            non_tuner: (1+, non-tuner monster)
        }
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            add_to_hand (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        timing: when
        trigger: battle_damage
        resolve {
            damage opponent 1000
        }
    }
}
