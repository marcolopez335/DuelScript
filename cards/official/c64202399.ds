// 深淵の青眼龍
// Blue-Eyes Abyss Dragon
// Transpiled from c64202399.lua

card "Blue-Eyes Abyss Dragon" {
    id: 64202399
    type: Effect Monster
    attribute: LIGHT
    race: Dragon
    level: 8
    atk: 2500
    def: 2500

    summon_condition {
        tributes_required: 2
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        on_resolve {
            return (1+, monster, you controls, where { is_face_up and level >= 8 and race == Dragon }) to hand
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: when
        trigger: during_end_phase
        on_resolve {
            return (1+, monster, you controls, where { is_face_up and level >= 8 and race == Dragon }) to hand
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        activate_from: [gy]
        cost {
            banish self
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
