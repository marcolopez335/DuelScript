// 原罪宝－スネークアイ
// Original Sinful Spoils - Snake-Eye
// Transpiled from c89023486.lua

card "Original Sinful Spoils - Snake-Eye" {
    id: 89023486
    type: Normal Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        cost {
            send self to gy
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        activate_from: [gy]
        on_activate {
            select (1+, monster, you controls, where { level == 1 and attribute == FIRE }) as target
        }
        cost {
            banish self
        }
        on_resolve {
            return (1+, monster, you controls, where { level == 1 and attribute == FIRE }) to hand
            reveal (1+, card, opponent controls)
            shuffle_deck
            return (1+, monster, you controls, where { level == 1 and attribute == FIRE }) to deck shuffle
        }
    }

}
