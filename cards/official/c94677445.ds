card "Ib the World Chalice Justiciar" {
    id: 94677445
    type: Synchro Monster | Tuner
    attribute: WATER
    race: Spellcaster
    level: 5
    atk: 1800
    def: 2100

    summon {
        cannot_normal_summon
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            add_to_hand (1, card, where archetype == "World Legacy") from deck
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: custom "chain_end"
        resolve {
            special_summon (all, card, either controls)
        }
    }
}
