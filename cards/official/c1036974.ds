card "Misfortune" {
    id: 1036974
    type: Normal Spell

    effect "Effect 1" {
        speed: spell_speed_1
        damage_step: false
        on_activate {
            select (1+, card, either_player controls, where { is_face_up }) as target
        }
        on_resolve {
            deal_damage to opponent: 1000
        }
    }

}
