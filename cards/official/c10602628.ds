card "Blackwing - Boreastorm the Wicked Wind" {
    id: 10602628
    type: Synchro Monster | Tuner
    attribute: DARK
    race: Winged Beast
    level: 6
    atk: 2400
    def: 1200

    summon {
        cannot_normal_summon
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            send (1, monster, from deck, where archetype == "Blackwing") to gy
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        timing: when
        trigger: battle_damage
        cost {
            banish self
        }
        resolve {
            special_summon (all, card, either controls)
        }
    }
}
