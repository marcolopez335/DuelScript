// 森羅の守神 アルセイ
// Alsei, the Sylvan High Protector
// Transpiled from c10406322.lua

card "Alsei, the Sylvan High Protector" {
    id: 10406322
    type: Xyz Monster
    attribute: LIGHT
    race: Plant
    rank: 8
    atk: 2300
    def: 3200

    materials {
        require: 2+ monster
        same_level: true
        method: xyz
    }

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        on_resolve {
            reveal (1, card, opponent controls, deck)
            add_to_hand (1+, card, either_player controls) from gy
            shuffle_hand
            send (1+, card, either_player controls) to gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        damage_step: false
        trigger: on_custom_event "chain_end"
        on_activate {
            select (1+, card, either_player controls) as target
        }
        cost {
            detach 1 overlay_unit from self
        }
        on_resolve {
            return (1+, card, either_player controls) to deck shuffle
            return (1+, card, either_player controls) to deck shuffle
        }
    }

}
