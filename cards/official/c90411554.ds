card "Redox, Dragon Ruler of Boulders" {
    id: 90411554
    type: Effect Monster
    attribute: EARTH
    race: Dragon
    level: 7
    atk: 1600
    def: 3000

    summon_condition {
        tributes_required: 2
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [hand, gy]
        cost {
            banish self
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        trigger: during_end_phase
        on_resolve {
            add_to_hand (1+, monster, you controls, where { race == Dragon and attribute == EARTH }) from gy
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        activate_from: [hand]
        on_activate {
            select (1+, monster, you controls, where { race == Dragon and attribute == EARTH }) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    raw_effect "Effect 4" {
        effect_type: Single + Trigger
        category: ToHand + Search
        code: TurnEnd
        property: Delay
        count_limit: (1, 90411554)
        on_resolve {
            add_to_hand (1+, monster, you controls, where { race == Dragon and attribute == EARTH }) from gy
            reveal (1+, card, opponent controls)
        }
