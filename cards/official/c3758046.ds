card "D/D/D Wave King Caesar" {
    id: 3758046
    type: Xyz Monster
    attribute: WATER
    race: Fiend
    rank: 4
    atk: 2400
    def: 1200

    summon {
        cannot_normal_summon
        xyz materials: (2, monster, where level == 4 and race == Fiend)
    }

    effect "Effect 1" {
        speed: 2
        once_per_turn: hard
        cost {
            detach 1 from self
        }
        resolve {
            add_to_hand target
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: custom "chain_end"
        resolve {
            add_to_hand (all, card, either controls)
        }
    }
}
