card "Rebirth of the Seventh Emperors" {
    id: 83888009
    type: Normal Trap

    raw_effect "Effect 1" {
        effect_type: Activate
        category: SpecialSummon + Damage + LeaveGrave
        code: FreeChain
        property: CardTarget
        cost {
            tribute self
        }
        on_resolve {
            special_summon (1, monster) from gy
            attach (1, card) to self as_material
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
