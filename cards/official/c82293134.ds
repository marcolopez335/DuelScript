// 紋章獣レオ
// Heraldic Beast Leo
// Transpiled from c82293134.lua

card "Heraldic Beast Leo" {
    id: 82293134
    type: Effect Monster
    attribute: EARTH
    race: Beast
    level: 4
    atk: 2000
    def: 1000

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        trigger: during_end_phase
        on_resolve {
            destroy (1+, monster, opponent controls, deck)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        trigger: on_custom_event "chain_end"
        on_resolve {
            add_to_hand (1+, monster, opponent controls) from deck
            reveal (1+, card, opponent controls)
        }
    }

}
