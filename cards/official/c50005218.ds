card "Sky Striker Airspace - Area Zero" {
    id: 50005218
    type: Field Spell

    effect "Effect 1" {
        speed: 1
        mandatory
        target (1, card, you control, from field)
        resolve {
            add_to_hand target
            shuffle_hand yours
            shuffle_deck yours
            send target to gy
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        mandatory
        resolve {
            add_to_hand (all, card, either controls)
            send (all, card, either controls) to gy
        }
    }

    effect "Effect 3" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: custom "chain_end"
        resolve {
            special_summon (all, card, either controls)
        }
    }
}
