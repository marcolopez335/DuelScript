// ハイパーサイコライダー
// Hyper Psychic Riser
// Transpiled from c99115354.lua

card "Hyper Psychic Riser" {
    id: 99115354
    type: Synchro Monster
    attribute: EARTH
    race: Psychic
    level: 6
    atk: 2000
    def: 600

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    summon_condition {
        cannot_normal_summon: true
    }

    continuous_effect "Effect 1" {
        scope: field
        grant: cannot_attack
    }

    continuous_effect "Effect 2" {
        scope: field
        grant: cannot_activate_effects
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        damage_step: false
        trigger: on_custom_event "chain_end"
        on_activate {
            select (1+, monster, you controls) as target
        }
        on_resolve {
            add_to_hand (1+, monster, you controls) from gy
        }
    }

}
