card "Lavalval Salamander" {
    id: 67797569
    type: Synchro Monster
    attribute: FIRE
    race: Dragon
    level: 7
    atk: 2600
    def: 200

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        on_resolve {
            draw 1
            shuffle_hand
            send (1+, monster, opponent controls) to gy
            reveal (1+, card, opponent controls)
            return (1+, monster, opponent controls) to deck shuffle
            shuffle_deck
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        cost {
            banish self
        }
        on_resolve {
            change_battle_position (1, monster)
        }
    }

