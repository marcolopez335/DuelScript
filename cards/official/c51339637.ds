// サラマングレイト・ロアー
// Salamangreat Roar
// Transpiled from c51339637.lua

card "Salamangreat Roar" {
    id: 51339637
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            negate activation
            destroy (1+, monster, you controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        activate_from: [gy]
        on_resolve {
            set (1, card)
        }
    }

}
