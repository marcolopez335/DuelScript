card "Sky Striker Maneuver - Jamming Waves!" {
    id: 25955749
    type: Normal Spell

    effect "Effect 1" {
        speed: spell_speed_1
        damage_step: false
        on_activate {
            select (1+, spell, either_player controls, where { is_face_down and is_spell }) as target
        }
        on_resolve {
            destroy (1+, spell, either_player controls, where { is_face_down and is_spell })
            destroy (1+, spell, either_player controls, where { is_face_down and is_spell })
        }
    }

}
