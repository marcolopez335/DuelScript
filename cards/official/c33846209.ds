// デュアルスパーク
// Gemini Spark
// Transpiled from c33846209.lua

card "Gemini Spark" {
    id: 33846209
    type: Quick-Play Spell

    effect "Effect 1" {
        speed: spell_speed_2
        damage_step: false
        on_activate {
            select (1+, card, either_player controls, where { is_face_up and level == 4 }) as target
        }
        on_resolve {
            destroy (1+, card, either_player controls, where { is_face_up and level == 4 })
            draw 1
        }
    }

}
