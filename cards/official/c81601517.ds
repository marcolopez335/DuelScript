// ヴィクティム・カウンター
// Gemini Counter
// Transpiled from c81601517.lua

card "Gemini Counter" {
    id: 81601517
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        damage_step: false
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            change_battle_position (1, monster)
            negate activation
            destroy (1+, card, either_player controls)
        }
    }

}
