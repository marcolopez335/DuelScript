card "Arcanite Magician" {
    id: 31924889
    type: Synchro Monster
    attribute: LIGHT
    race: Spellcaster
    level: 7
    atk: 400
    def: 1800

    summon {
        cannot_normal_summon
        synchro materials {
            tuner: (1, tuner monster)
            non_tuner: (1+, non-tuner monster, where race == Spellcaster)
        }
    }

    effect "Effect 1" {
        speed: 1
        mandatory
        trigger: summoned by special
    }

    effect "Effect 3" {
        speed: 1
        mandatory
        target (1, card, opponent controls, from field)
        resolve {
            destroy (all, card, either controls)
        }
    }
}
