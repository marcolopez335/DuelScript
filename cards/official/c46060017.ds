// 十二獣の会局
// Zoodiac Barrage
// Transpiled from c46060017.lua

card "Zoodiac Barrage" {
    id: 46060017
    type: Continuous Spell

    effect "Effect 1" {
        speed: spell_speed_1
        on_resolve {
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        activate_from: [spell_trap_zone]
        on_activate {
            select (1+, card, you controls, where { is_face_up }) as target
        }
        on_resolve {
            destroy (1+, card, you controls, deck)
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        optional: true
        timing: if
        damage_step: false
        trigger: on_custom_event "chain_end"
        on_activate {
            select (1+, card, you controls, where { is_face_up }) as target
        }
        on_resolve {
            attach (1, card) to self as_material
        }
    }

}
