// ワルキューレ・ドリット
// Valkyrie Dritte
// Transpiled from c3026686.lua

card "Valkyrie Dritte" {
    id: 3026686
    type: Effect Monster
    attribute: LIGHT
    race: Fairy
    level: 4
    atk: 1000
    def: 1600

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: when_summoned
        on_resolve {
            add_to_hand (1+, monster, you controls, where { is_face_up and is_monster }) from deck
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        on_resolve {
            add_to_hand (1+, monster, you controls, where { is_face_up and is_monster }) from deck
            reveal (1+, card, opponent controls)
        }
    }

    raw_effect "Effect 3" {
        effect_type: Single
        code: UpdateAttack
        property: SingleRange
        range: MonsterZone
        on_resolve {
            modifier: atk + count((1+, card, you controls, banished)) * 200
        }
    }

}
