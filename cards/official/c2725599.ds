card "Rescue-ACE Arbitrator" {
    id: 2725599
    type: Link Monster
    attribute: FIRE
    race: Machine
    link: 4
    link_arrows: [left, right, bottom_left, bottom_right]
    atk: 3000

    summon {
        cannot_normal_summon
    }

    effect "Effect 1" {
        speed: 1
        timing: if
        trigger: summoned by special
        resolve {
            add_to_hand (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        twice_per_turn
        timing: if
        trigger: opponent_activates [activate_spell, activate_trap, activate_spell]
        resolve {
            destroy (all, card, either controls)
        }
    }
}
