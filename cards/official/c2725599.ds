// Ｒ－ＡＣＥアビトレイター
// Rescue-ACE Arbitrator
// Transpiled from c2725599.lua

card "Rescue-ACE Arbitrator" {
    id: 2725599
    type: Link Monster
    attribute: FIRE
    race: Machine
    link: 4
    link_arrows: [left, right, bottom_left, bottom_right]
    atk: 3000

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ effect monster
        method: link
    }

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        on_resolve {
            add_to_hand (1+, card, you controls) from gy
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        twice_per_turn
        optional: true
        timing: if
        damage_step: false
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            destroy (1+, card, you controls, gy)
        }
    }

}
