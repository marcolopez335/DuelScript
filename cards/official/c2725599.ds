// Rescue-ACE Arbitrator
// Transpiled from c2725599.lua

card "Rescue-ACE Arbitrator" {
    password: 2725599
    type: Link Monster
    attribute: FIRE
    race: Machine
    link: 4
    atk: 3000

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        trigger: when_summoned by_special_summon
        on_resolve {
            add_to_hand (1, card) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        trigger: opponent_activates [search | special_summon | send_to_gy | draw]
        on_resolve {
            destroy (1+, card, either_player controls)
        }
    }

}
