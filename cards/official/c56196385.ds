card "Tri-Brigade Kitt" {
    id: 56196385
    type: Effect Monster
    attribute: FIRE
    race: Beast
    level: 2
    atk: 700
    def: 1000

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        cost {
            banish self
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        trigger: on_custom_event "chain_end"
        on_resolve {
            send (1+, monster, you controls, gy) to gy
        }
    }

}
