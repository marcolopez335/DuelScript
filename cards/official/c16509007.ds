card "Kewl Tune Mix" {
    id: 16509007
    type: Effect Monster | Tuner
    attribute: WIND
    race: Warrior
    level: 2
    atk: 100
    def: 2000

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned
        resolve {
            add_to_hand (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            add_to_hand (1, monster, where archetype == "Kewl Tune") from deck
        }
    }
}
