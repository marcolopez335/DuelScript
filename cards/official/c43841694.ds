// 魔導書の奇跡
// Spellbook of Miracles
// Transpiled from c43841694.lua

card "Spellbook of Miracles" {
    id: 43841694
    type: Normal Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, spell, either_player controls) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
            attach (1, card) to self as_material
        }
    }

}
