    id: 81191584
    type: Normal Spell

    effect "Effect 1" {
        speed: spell_speed_1
        damage_step: false
        on_activate {
            select (1+, card, either_player controls, where { attribute == DARK }) as target
        }
        on_resolve {
            add_to_hand (1+, card, either_player controls, where { attribute == DARK }) from gy
        }
    }

