card "Prank-Kids Dodo-Doodle-Doo" {
    id: 17382973
    type: Link Monster
    attribute: WIND
    race: Thunder
    link: 2
    link_arrows: [left, bottom]
    atk: 2000

    summon {
        cannot_normal_summon
        link materials: (2, monster, where archetype == "Prank Kids")
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            add_to_hand (1, card, where archetype == "Prank-Kids" and not is_monster) from deck
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        mandatory
        cost {
            tribute self
        }
        resolve {
            add_to_hand (all, card, either controls)
        }
    }
}
