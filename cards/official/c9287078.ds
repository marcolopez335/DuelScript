// 黒魔族復活の棺
// Dark Renewal
// Transpiled from c9287078.lua

card "Dark Renewal" {
    id: 9287078
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        damage_step: false
        trigger: when_summoned
        on_activate {
            select (1+, card, you controls) as target
        }
        on_resolve {
            send (1+, card, you controls, gy) to gy
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        damage_step: false
        trigger: when_summoned by_special_summon
        on_activate {
            select (1+, card, you controls) as target
        }
        on_resolve {
            send (1+, card, you controls, gy) to gy
            special_summon (1, monster) from gy
        }
    }

}
