// 氷結界の鏡魔師
// Mirror Mage of the Ice Barrier
// Transpiled from c9396662.lua

card "Mirror Mage of the Ice Barrier" {
    id: 9396662
    type: Effect Monster | Tuner
    attribute: WATER
    race: Aqua
    level: 2
    atk: 1000
    def: 400

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        cost {
            tribute self
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            create_token { atk: 0 def: 0 }
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        trigger: on_custom_event "chain_end"
        on_resolve {
            add_to_hand (1+, card, you controls) from deck
            reveal (1+, card, opponent controls)
        }
    }

}
