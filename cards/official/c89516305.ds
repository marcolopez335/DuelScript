card "Number 87: Queen of the Night" {
    id: 89516305
    type: Xyz Monster
    attribute: WATER
    race: Plant
    rank: 8
    atk: 3200
    def: 2800

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        same_level: true
        method: xyz
    }

    raw_effect "Effect 1" {
        effect_type: QuickEffect
        code: FreeChain
