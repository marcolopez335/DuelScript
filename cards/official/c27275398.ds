card "Gold Pride - Pedal to the Metal!" {
    id: 27275398
    type: Quick-Play Spell

    passive "Effect 5" {
        scope: self
        grant: cannot_be_destroyed by battle
    }

    passive "Effect 6" {
        scope: self
        grant: cannot_be_destroyed by effect
    }

    passive "Effect 7" {
        scope: self
        grant: cannot_activate effects
    }

    effect "Effect 1" {
        speed: 2
        mandatory
        resolve {
            modify_atk target + 500 until end_of_turn
            grant target cannot_be_destroyed by battle until end_of_turn
            grant target cannot_be_destroyed by effect until end_of_turn
        }
    }

    effect "Effect 2" {
        speed: 2
        once_per_turn: hard
        timing: when
        trigger: end_phase
        resolve {
            set self
        }
    }
}
