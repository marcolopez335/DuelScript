    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: when
        trigger: when_summoned by_special_summon
        on_resolve {
            add_to_hand (1+, spell, you controls, where { race == Spellcaster and attribute == DARK and level >= 5 }) from gy
            reveal (1+, card, opponent controls)
            special_summon (1, monster) from gy
        }
