card "Keaf, Murk of the Ghoti" {
    id: 99529628
    type: Effect Monster
    attribute: WATER
    race: Fish
    level: 2
    atk: 0
    def: 1500

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [hand]
        on_resolve {
            special_summon (1, monster) from gy
        }
