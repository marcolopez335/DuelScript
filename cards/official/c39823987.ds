// 太陽龍インティ
// Sun Dragon Inti
// Transpiled from c39823987.lua

card "Sun Dragon Inti" {
    id: 39823987
    type: Synchro Monster
    attribute: LIGHT
    race: Dragon
    level: 8
    atk: 3000
    def: 2800

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        trigger: when_battle_damage
        on_resolve {
            destroy (1+, card, either_player controls)
            deal_damage to opponent: 1000
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single + Continuous
        code: Destroyed
        property: BothSide
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
