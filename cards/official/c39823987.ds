card "Sun Dragon Inti" {
    password: 39823987
    type: Synchro Monster
    attribute: LIGHT
    race: Dragon
    level: 8
    atk: 3000
    def: 2800

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
