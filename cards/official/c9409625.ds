card "Empty Machine" {
    id: 9409625
    type: Continuous Trap

    effect "Effect 1" {
        speed: spell_speed_2
        on_resolve {
        }
    }

    replacement_effect "Effect 2" {
        instead_of: destroyed_by_any
        do: {
            banish self
        }
    }

    continuous_effect "Effect 3" {
        scope: self
        grant: cannot_be_destroyed
    }

    effect "Effect 4" {
        speed: spell_speed_2
        optional: true
        activate_from: [spell_trap_zone]
        on_resolve {
            draw 1
        }
    }

    effect "Effect 5" {
        speed: spell_speed_2
        optional: true
        damage_step: false
        activate_from: [spell_trap_zone]
        on_activate {
            select (1+, monster, you controls) as target
        }
        on_resolve {
            return (1+, monster, you controls) to deck shuffle
            set (1, card)
        }
    }

}
