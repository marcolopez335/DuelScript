        on_resolve {
            register_effect on self { grant: cannot_be_destroyed duration: until_end_of_turn }
        }
    }

    effect "Effect 4" {
        speed: spell_speed_2
        optional: true
        activate_from: [spell_trap_zone]
        on_resolve {
            draw 1
        }
    }

    effect "Effect 5" {
        speed: spell_speed_2
        optional: true
        damage_step: false
        activate_from: [spell_trap_zone]
        on_resolve {
            return (1+, monster, you controls) to deck shuffle
            set (1, card)
        }
    }

