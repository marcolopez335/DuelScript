card "Spiritual Whisper" {
    id: 50155385
    type: Effect Monster
    attribute: WIND
    race: Winged Beast
    level: 4
    atk: 200
    def: 2000

    continuous_effect "Effect 1" {
        scope: self
        grant: cannot_be_destroyed
    }

    effect "Effect 2" {
        speed: spell_speed_1
        optional: true
        timing: when
        trigger: when_summoned by_special_summon
        on_resolve {
            add_to_hand (1+, card, you controls) from deck
            reveal (1+, card, opponent controls)
        }
    }

}
