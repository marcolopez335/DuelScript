card "Performapal Celestial Magician" {
    id: 58092907
    type: Effect Monster | Pendulum Monster
    attribute: DARK
    race: Spellcaster
    level: 4
    scale: 8
    atk: 1500
    def: 1000

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        timing: when
        trigger: destroyed
        resolve {
            destroy (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        mandatory
        resolve {
            grant self direct_attack until end_of_turn
            set_atk self self.base_atk * 2 until end_of_turn
            install_watcher "thop" { event: end_phase duration: end_of_turn check { add_to_hand (1, card, you control, from deck) } }
        }
    }
}
