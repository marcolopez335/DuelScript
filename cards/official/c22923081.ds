card "Breaker the Dark Magical Warrior" {
    id: 22923081
    type: Effect Monster
    attribute: DARK
    race: Spellcaster
    level: 6
    atk: 1600
    def: 1000

    summon_condition {
        tributes_required: 1
    }

    effect "Effect 1" {
        speed: spell_speed_1
        trigger: when_summoned
        on_resolve {
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        trigger: when_summoned by_special_summon
        on_resolve {
        }
    }

    raw_effect "Effect 3" {
        effect_type: Single
        code: UpdateAttack
        property: SingleRange
        range: MonsterZone
        on_resolve {
            modifier: atk + self.level * 400
        }
    }

    effect "Effect 4" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, spell, either_player controls, where { is_spell }) as target
        }
        on_resolve {
            destroy (1+, spell, either_player controls, where { is_spell })
        }
    }

}
