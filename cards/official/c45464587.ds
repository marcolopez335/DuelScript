card "Gold Pride - Eradicator" {
    id: 45464587
    type: Synchro Monster
    attribute: DARK
    race: Warrior
    level: 8
    atk: 2700
    def: 1700

    summon {
        cannot_normal_summon
    }

    effect "Effect 1" {
        speed: 2
        once_per_turn: hard
        resolve {
            destroy (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        mandatory
        trigger: end_phase
        resolve {
            return (all, card, either controls) to deck
            special_summon (all, card, either controls)
        }
    }
}
