card "Overdone Burial" {
    id: 65993085
    type: Equip Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        on_activate {
            select (1+, monster, you controls) as target
        }
        on_resolve {
            special_summon (1, monster) from gy
            equip (1, card) to (1, monster)
        }
    }

    continuous_effect "Effect 2" {
        scope: self
        grant: cannot_activate_effects
    }

}
