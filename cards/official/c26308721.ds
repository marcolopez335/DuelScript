// 捕食植物プテロペンテス
// Predaplant Pterapenthes
// Transpiled from c26308721.lua

card "Predaplant Pterapenthes" {
    id: 26308721
    type: Effect Monster
    attribute: DARK
    race: Plant
    level: 3
    atk: 300
    def: 2100

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        timing: when
        damage_step: false
        trigger: when_battle_destroyed
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            take_control of (1, monster, opponent controls)
        }
    }

}
