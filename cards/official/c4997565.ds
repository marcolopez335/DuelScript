    }

    raw_effect "Effect 2" {
        effect_type: QuickEffect
        category: Disable
        code: Chaining
        property: CardTarget
        range: MonsterZone
        count_limit: (1, 0)
        cost {
            detach 1 overlay_unit from self
        }
        on_resolve {
            negate effect
            register_effect on self {
