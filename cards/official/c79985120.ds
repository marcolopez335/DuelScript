card "Raidraptor - Revolution Falcon - Air Raid" {
    id: 79985120
    type: Xyz Monster
    attribute: DARK
    race: Winged Beast
    rank: 6
    atk: 2000
    def: 3000

    materials {
        require: 2+ monster
        same_level: true
        method: xyz
    }

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        timing: if
        damage_step: false
        trigger: when_summoned by_special_summon
        on_activate {
            select (1+, spell, you controls) as target
        }
        on_resolve {
            destroy (1+, spell, you controls, hand)
            deal_damage to opponent: 1000
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        optional: true
        timing: if
        trigger: on_custom_event "chain_end"
        on_resolve {
            special_summon (1, monster) from gy
            attach (1, card) to self as_material
        }
    }

}
