card "Raidraptor - Revolution Falcon - Air Raid" {
    id: 79985120
    type: Xyz Monster
    attribute: DARK
    race: Winged Beast
    rank: 6
    atk: 2000
    def: 3000

    summon {
        cannot_normal_summon
        special_summon_procedure {
            from: extra_deck
            to: your_field
        }
    }

    effect "Effect 1" {
        speed: 1
        timing: if
        trigger: summoned by special
        target (1, card, opponent controls, from monster_zone)
        resolve {
            destroy (all, card, either controls)
            damage opponent 1000
        }
    }

    effect "Effect 2" {
        speed: 1
        timing: if
        trigger: custom "chain_end"
        resolve {
            special_summon (all, card, either controls)
        }
    }
}
