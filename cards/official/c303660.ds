// 電脳増幅器
// Amplifier
// Transpiled from c303660.lua

card "Amplifier" {
    id: 303660
    type: Equip Spell

    raw_effect "Effect 1" {
        effect_type: Field
        code: ImmuneEffect
        property: IgnoreRange
        range: SpellTrapZone
        on_resolve {
            register_effect on self { grant: unaffected_by_card_effects duration: until_end_of_turn }
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single + Continuous
        code: ChainNegated
        on_resolve {
            destroy (1+, trap, either_player controls)
        }
    }

    raw_effect "Effect 3" {
        effect_type: Single
        code: CannotChangeControl
        on_resolve {
        }
    }

    effect "Effect 4" {
        speed: spell_speed_1
        on_resolve {
            equip self to (1, monster, you controls)
        }
    }

}
