card "Mitsu the Insect Ninja" {
    id: 67282505
    type: Effect Monster
    attribute: WATER
    race: Insect
    level: 2
    atk: 200
    def: 2100

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [hand]
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        timing: when
        damage_step: false
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            change_battle_position (1, monster)
            change_battle_position (1, monster)
            negate effect
        }
    }

}
