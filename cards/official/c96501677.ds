// またたびキャット
// Catnipped Kitty
// Transpiled from c96501677.lua

card "Catnipped Kitty" {
    id: 96501677
    type: Effect Monster
    attribute: EARTH
    race: Beast
    level: 2
    atk: 0
    def: 500

    continuous_effect "Effect 1" {
        scope: self
        grant: cannot_be_targeted_by_card_effects
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_activate {
            select (1+, monster, you controls) as target
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
