// クロス・デバッガー
// Cross Debug
// Transpiled from c9097866.lua

card "Cross Debug" {
    id: 9097866
    type: Effect Monster
    attribute: DARK
    race: Cyberse
    level: 2
    atk: 900
    def: 600

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [hand]
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: when
        damage_step: false
        trigger: when attack_declared
        activate_from: [gy]
        on_activate {
            select (1+, card, either_player controls, where { is_face_up }) as target
        }
        cost {
            banish self
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
