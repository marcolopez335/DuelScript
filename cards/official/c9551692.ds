card "Master of Ham" {
    id: 9551692
    type: Fusion Monster
    attribute: EARTH
    race: Beast
    level: 5
    atk: 2100
    def: 1850

    summon {
        cannot_normal_summon
        fusion materials: (2, monster, where race == Beast)
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: custom "chain_active"
        resolve {
            special_summon (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            special_summon (all, card, either controls)
        }
    }

    effect "Effect 3" {
        speed: 1
        once_per_turn: soft
        mandatory
        cost {
            banish self
        }
        resolve {
            special_summon (all, card, either controls)
        }
    }
}
