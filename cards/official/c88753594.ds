// 月光舞剣虎姫
// Lunalight Sabre Dancer
// Transpiled from c88753594.lua

card "Lunalight Sabre Dancer" {
    id: 88753594
    type: Fusion Monster
    attribute: DARK
    race: Beast-Warrior
    level: 9
    atk: 3000
    def: 2600

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        method: fusion
    }

    raw_effect "Effect 1" {
        effect_type: Single
        code: SpsummonCondition
        property: BothSide + Uncopyable
        on_resolve {
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single
        code: UpdateAttack
        property: SingleRange
        range: MonsterZone
        on_resolve {
            modifier: atk + count((1+, card, you controls, gy)) * 200
        }
    }

    continuous_effect "Effect 3" {
        scope: self
        grant: cannot_be_targeted_by_card_effects
    }

    effect "Effect 4" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        activate_from: [gy]
        on_activate {
            select (1+, card, either_player controls, where { is_face_up and race == Beast-Warrior }) as target
        }
        cost {
            banish self
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
