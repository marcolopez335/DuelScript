    type: Effect Monster | Pendulum Monster
    attribute: EARTH
    race: Machine
    level: 5
    scale: 10
    atk: 500
    def: 500

    summon_condition {
        tributes_required: 1
    }

    raw_effect "Effect 1" {
        effect_type: Field
        code: CannotDisable
        property: IgnoreImmune + BothSide + InitialValue
        range: PendulumZone
        on_resolve {
            register_effect on self { grant: cannot_be_used_as_material duration: until_end_of_turn }
        }
