// エクシーズ・オーバーディレイ
// Xyz Encore
// Transpiled from c78610936.lua

card "Xyz Encore" {
    id: 78610936
    type: Quick-Play Spell

    effect "Effect 1" {
        speed: spell_speed_1
        damage_step: false
        on_resolve {
            send (1+, card, either_player controls, where { is_face_up and is_xyz }) to gy
            return (1+, card, either_player controls, where { is_face_up and is_xyz }) to deck shuffle
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
