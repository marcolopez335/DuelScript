// エクシーズ・オーバーディレイ
// Xyz Encore
// Transpiled from c78610936.lua

card "Xyz Encore" {
    id: 78610936
    type: Quick-Play Spell

    raw_effect "Effect 1" {
        effect_type: Activate
        category: ToDeck + SpecialSummon
        code: FreeChain
        property: CardTarget
        on_resolve {
            send (1+, card, either_player controls) to gy
            return (1+, card, either_player controls) to deck shuffle
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
