card "Colossal Fighter/Assault Mode" {
    id: 38898779
    type: Effect Monster | Effect Monster
    attribute: DARK
    race: Warrior
    level: 10
    atk: 3300
    def: 1500

    summon {
        cannot_normal_summon
    }

    effect "Effect 2" {
        speed: 1
        timing: when
        trigger: summoned by special
        resolve {
            send (all, card, either controls) to gy
        }
    }

    effect "Effect 4" {
        speed: 1
        timing: when
        trigger: destroyed
        condition: previous_location == field
        resolve {
            special_summon (all, card, either controls)
        }
    }
}
