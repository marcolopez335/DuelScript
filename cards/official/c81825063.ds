card "General Wayne of the Ice Barrier" {
    id: 81825063
    type: Effect Monster
    attribute: WATER
    race: Warrior
    level: 5
    atk: 2100
    def: 400

    summon {
        tributes: 1
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        mandatory
        resolve {
            special_summon (all, card, either controls)
        }
    }

    effect "Effect 3" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: summoned
        resolve {
            add_to_hand (1, card, where archetype == "Ice Barrier" and not is_monster) from deck
        }
    }

    effect "Effect 4" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: summoned by special
        resolve {
            add_to_hand (1, card, where archetype == "Ice Barrier" and not is_monster) from deck
        }
    }
}
