card "A Wild Monster Appears!" {
    id: 23587624
    type: Normal Spell

    passive "Effect 2" {
        scope: self
        grant: unaffected_by effects
    }

    passive "Effect 3" {
        scope: self
        grant: cannot_attack
    }

    passive "Effect 4" {
        scope: self
        grant: cannot_change_position
    }

    passive "Effect 5" {
        scope: self
        grant: cannot_attack
    }

    effect "Effect 1" {
        speed: 1
        mandatory
        resolve {
            special_summon (all, card, either controls)
