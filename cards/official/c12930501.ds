// 暗黒の魔再生
// Dark Spell Regeneration
// Transpiled from c12930501.lua

card "Dark Spell Regeneration" {
    id: 12930501
    type: Normal Trap

    raw_effect "Effect 1" {
        effect_type: Activate
        category: LeaveGrave
        code: AttackAnnounce
        property: CardTarget
        on_resolve {
            set (1, card)
        }
    }

    raw_effect "Effect 2" {
        effect_type: QuickEffect
        category: ToGrave + SpecialSummon
        code: FreeChain
        range: Graveyard
        cost {
            send self to gy
        }
        on_resolve {
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            send (1+, spell, you controls, hand) to gy
        }
    }

}
