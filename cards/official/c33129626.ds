// ケンタウルミナ
// Centaur Mina
// Transpiled from c33129626.lua

card "Centaur Mina" {
    id: 33129626
    type: Fusion Monster
    attribute: LIGHT
    race: Beast-Warrior
    level: 6
    atk: 2200
    def: 1600

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        method: fusion
    }

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            negate activation
            change_battle_position (1, monster)
            emit_event "custom"
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        trigger: when_flipped
        on_resolve {
            destroy (1+, monster, either_player controls)
        }
    }

}
