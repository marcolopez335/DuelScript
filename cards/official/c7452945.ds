// 天命の聖剣
// Noble Arms of Destiny
// Transpiled from c7452945.lua

card "Noble Arms of Destiny" {
    id: 7452945
    type: Equip Spell

    raw_effect "Effect 1" {
        effect_type: Equip
        code: CannotHandReturn
        on_resolve {
            register_effect on self { grant: cannot_be_destroyed duration: until_end_of_turn }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        damage_step: false
        trigger: on_custom_event "chain_end"
        on_resolve {
            equip (1, card) to (1, monster)
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        on_resolve {
            equip self to (1, monster, you controls)
        }
    }

}
