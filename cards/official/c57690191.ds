    raw_effect "Effect 3" {
        effect_type: Ignition
        category: ToDeck + Draw
        property: 16
        range: MonsterZone
        count_limit: (1, 0)
        on_resolve {
            return (1+, card, you controls) to deck shuffle
            shuffle_deck
            draw 1
        }
    }

