// ミラー ソードナイト
// Mirror Swordknight
// Transpiled from c28954097.lua

card "Mirror Swordknight" {
    id: 28954097
    type: Effect Monster
    attribute: LIGHT
    race: Unknown
    level: 4
    atk: 1900
    def: 300

    raw_effect "Effect 1" {
        effect_type: Field
        code: CannotBeEffectTarget
        range: MonsterZone
        on_resolve {
            register_effect on self { grant: cannot_be_destroyed_by_battle duration: until_end_of_turn }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        cost {
            tribute self
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 3" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        activate_from: [monster_zone, gy]
        cost {
            banish self
        }
        on_resolve {
            negate effect
        }
    }

}
