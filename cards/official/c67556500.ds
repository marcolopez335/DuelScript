card "Phonon Pulse Dragon" {
    password: 67556500
    type: Synchro Monster | Tuner
    attribute: DARK
    race: Dragon
    level: 4
    atk: 1900
    def: 800

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    summon_condition {
        cannot_normal_summon: true
