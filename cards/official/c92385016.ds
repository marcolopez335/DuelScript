card "Munin the Runick Wings" {
    id: 92385016
    type: Fusion Monster
    attribute: LIGHT
    race: Fairy
    level: 3
    atk: 0
    def: 2000

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        method: fusion
    }

    effect "Effect 1" {
        speed: spell_speed_1
