card "Junk Connector" {
    id: 37337327
    type: Link Monster
    attribute: DARK
    race: Warrior
    link: 2
    link_arrows: [bottom_left, bottom_right]
    atk: 1700

    summon {
        cannot_normal_summon
        special_summon_procedure {
            from: extra_deck
            to: your_field
        }
    }

    effect "Effect 1" {
        speed: 2
        once_per_turn: soft
        resolve {
            special_summon target
        }
    }

    effect "Effect 2" {
        speed: 1
        timing: if
        trigger: custom "chain_end"
        resolve {
            special_summon (all, card, either controls)
        }
    }
}
