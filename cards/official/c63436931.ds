// 赤き龍
// Crimson Dragon
// Transpiled from c63436931.lua

card "Crimson Dragon" {
    id: 63436931
    type: Synchro Monster
    attribute: LIGHT
    race: Dragon
    level: 12
    atk: 0
    def: 0

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        on_resolve {
            add_to_hand (1+, spell, you controls, where { is_spell }) from deck
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        damage_step: false
        on_activate {
            select (1+, spell, you controls, where { is_spell }) as target
        }
        on_resolve {
            return (1+, spell, you controls, where { is_spell }) to deck shuffle
            special_summon (1, monster) from gy
        }
    }

}
