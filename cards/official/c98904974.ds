card "Magikey Unlocking" {
    id: 98904974
    type: Normal Trap

    raw_effect "Effect 1" {
        effect_type: Activate
        category: Destroy + Negate
        code: Chaining
        count_limit: (1, 98904974)
        on_resolve {
            negate activation
            destroy (1+, monster, you controls)
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
