// 運命湾曲
// Bending Destiny
// Transpiled from c94662235.lua

card "Bending Destiny" {
    id: 94662235
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        on_resolve {
            negate summon
            banish (1+, monster, you controls)
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            negate activation
            banish (1+, monster, you controls)
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
