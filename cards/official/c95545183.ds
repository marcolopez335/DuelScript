// 異譚の忍法帖
// Ninjitsu Art Notebook of Mystery
// Transpiled from c95545183.lua

card "Ninjitsu Art Notebook of Mystery" {
    id: 95545183
    type: Quick-Play Spell

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        on_resolve {
            set (1, card)
            special_summon (1, monster) from gy
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        timing: if
        damage_step: false
        trigger: on_custom_event "chain_end"
        on_activate {
            select (1+, spell, you controls) as target
        }
        on_resolve {
            change_battle_position (1, monster)
        }
    }

}
