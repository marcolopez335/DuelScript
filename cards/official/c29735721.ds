card "Spell Vanishing" {
    password: 29735721
    type: Normal Trap

    raw_effect "Effect 1" {
        effect_type: Activate
        category: Destroy + AtkChange + DefChange + Negate
        code: Chaining
        on_resolve {
            negate activation
            destroy (1+, card, you controls, hand)
            reveal (1+, card, opponent controls)
