card "Dicelops" {
    id: 62893810
    type: Effect Monster
    attribute: FIRE
    race: Machine
    level: 4
    atk: 1800
    def: 200

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        on_resolve {
            flip_coin { heads { draw 1 } tails { draw 1 } }
            reveal (1+, card, opponent controls)
            send (1+, card, either_player controls) to gy
            shuffle_hand
            send (1+, card, either_player controls) to gy
            send (1+, card, either_player controls) to gy
            shuffle_hand
        }
    }

