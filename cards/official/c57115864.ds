// 光子化
// Lumenize
// Transpiled from c57115864.lua

card "Lumenize" {
    id: 57115864
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        damage_step: false
        trigger: when attack_declared
        on_activate {
            select (1+, monster, you controls, where { is_face_up and attribute == LIGHT }) as target
        }
        on_resolve {
            negate attack
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
