card "Light of Judgment" {
    id: 44595286
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        on_resolve {
            send (1+, card, either_player controls, where { attribute == LIGHT }) to gy
            reveal (1+, card, opponent controls)
            send (1+, card, either_player controls, where { attribute == LIGHT }) to gy
            shuffle_hand
        }
    }

}
