// レベル・マイスター
// Level Lifter
// Transpiled from c37198732.lua

card "Level Lifter" {
    id: 37198732
    type: Normal Spell

    effect "Effect 1" {
        speed: spell_speed_1
        damage_step: false
        on_activate {
            select (1+, monster, you controls, where { is_face_up and level >= 1 }) as target
        }
        cost {
            send self to gy
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
