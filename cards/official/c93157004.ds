card "Vylon Omega" {
    id: 93157004
    type: Synchro Monster
    attribute: LIGHT
    race: Fairy
    level: 10
    atk: 3200
    def: 1900

    summon {
        cannot_normal_summon
    }

    passive "Effect 6" {
        scope: self
        grant: cannot_be_targeted by effects
    }

    passive "Effect 7" {
        scope: self
        grant: cannot_be_destroyed by effect
    }

    passive "Effect 8" {
        scope: self
        grant: cannot_be_destroyed by battle
    }

    effect "Effect 1" {
        speed: 1
        mandatory
        trigger: summoned by special
        resolve {
            destroy (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        mandatory
    }

    effect "Effect 3" {
        speed: 2
        timing: when
        trigger: opponent_activates [activate_spell, activate_trap, activate_spell]
        cost {
            send self to gy
        }
        resolve {
            negate
            destroy (all, card, either controls)
        }
    }
}
