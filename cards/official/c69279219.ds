// 我が身を盾に
// My Body as a Shield
// Transpiled from c69279219.lua

card "My Body as a Shield" {
    id: 69279219
    type: Quick-Play Spell

    effect "Effect 1" {
        speed: spell_speed_1
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        cost {
            pay_lp 1500
        }
        on_resolve {
            negate activation
            destroy (1+, monster, either_player controls, where { is_monster })
        }
    }

}
