// 硫酸のたまった落とし穴
// Acid Trap Hole
// Transpiled from c41356845.lua

card "Acid Trap Hole" {
    id: 41356845
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        damage_step: false
        on_activate {
            select (1+, card, either_player controls, where { is_face_down }) as target
        }
        on_resolve {
            change_battle_position (1, monster)
            destroy (1+, card, either_player controls, where { is_face_down })
            reveal (1+, card, opponent controls)
            change_battle_position (1, monster)
        }
    }

}
