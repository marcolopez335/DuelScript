card "Beetrooper Cruel Saturnas" {
    id: 91300233
    type: Fusion Monster
    attribute: DARK
    race: Insect
    level: 5
    atk: 2400
    def: 2000

    summon {
        cannot_normal_summon
        special_summon_procedure {
            from: extra_deck
            to: your_field
        }
    }

    passive "Effect 1" {
        scope: self
        grant: cannot_attack
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            add_to_hand (1, card, where archetype == "Beetrooper") from deck
        }
    }
}
