// 猛吹雪
// Driving Snow
// Transpiled from c473469.lua

card "Driving Snow" {
    id: 473469
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        damage_step: false
        trigger: on_custom_event "chain_end"
        on_activate {
            select (1+, trap, either_player controls, where { is_trap }) as target
        }
        on_resolve {
            destroy (1+, trap, either_player controls, where { is_trap })
        }
    }

}
