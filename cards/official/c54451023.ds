// 植物連鎖
// Plant Food Chain
// Transpiled from c54451023.lua

card "Plant Food Chain" {
    id: 54451023
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        damage_step: false
        on_activate {
            select (1+, card, either_player controls, where { is_face_up and race == Plant }) as target
        }
        on_resolve {
            equip (1, card) to (1, monster)
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single + Trigger
        category: SpecialSummon
        code: ChainNegated
        property: CardTarget + Oath + Delay
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
