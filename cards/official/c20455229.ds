// ファイアウォール・ディフェンサー
// Firewall Defenser
// Transpiled from c20455229.lua

card "Firewall Defenser" {
    id: 20455229
    type: Effect Monster
    attribute: DARK
    race: Cyberse
    level: 4
    atk: 1200
    def: 1500

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: when_flipped
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    replacement_effect "Effect 2" {
        instead_of: destroyed_by_any
        do: {
            banish self
        }
    }

    raw_effect "Effect 3" {
        effect_type: Field
        code: CannotDisable
        property: InitialValue + CannotDisable + IgnoreRange2
        on_resolve {
            register_effect on self { grant: cannot_be_used_as_material duration: until_end_of_turn }
        }
    }

}
