card "Desrook Archfiend" {
    id: 72192100
    type: Effect Monster
    attribute: LIGHT
    race: Fiend
    level: 3
    atk: 1100
    def: 1800

    raw_effect "Effect 1" {
        effect_type: Field + Continuous
        code: PhaseStandby
        property: BothSide + Uncopyable
        range: MonsterZone
        count_limit: (1, 0)
        on_resolve {
            destroy (1+, card, either_player controls, where { card_id == 35975813 })
        }
    }

    raw_effect "Effect 2" {
        effect_type: Field + Continuous
        code: 1020
        range: MonsterZone
        on_resolve {
            flip_coin { heads { draw 1 } tails { draw 1 } }
            negate effect
            destroy (1+, card, either_player controls, where { card_id == 35975813 })
        }
    }

    effect "Effect 3" {
        speed: spell_speed_2
        optional: true
        timing: when
        damage_step: false
        trigger: on_custom_event "chain_end"
        activate_from: [hand]
        cost {
            send self to gy
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
