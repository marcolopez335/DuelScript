card "Desrook Archfiend" {
    password: 72192100
    type: Effect Monster
    attribute: LIGHT
    race: Fiend
    level: 3
    atk: 1100
    def: 1800

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        trigger: during_standby_phase
        on_resolve {
            destroy (1+, card, either_player controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        on_resolve {
            negate effect
            destroy (1+, card, either_player controls)
        }
    }

    effect "Effect 3" {
        speed: spell_speed_2
        optional: true
        damage_step: true
        trigger: when_sent_to gy
        cost {
            send self to gy
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
