// ヴァイロン・セグメント
// Vylon Segment
// Transpiled from c1644289.lua

card "Vylon Segment" {
    id: 1644289
    type: Equip Spell

    raw_effect "Effect 1" {
        effect_type: Equip
        code: CannotDirectAttack2
        property: SetAvailable
        on_resolve {
            register_effect on self { grant: cannot_be_targeted_by_card_effects duration: until_end_of_turn }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        optional: true
        timing: if
        trigger: on_custom_event "chain_end"
        on_resolve {
            add_to_hand (1+, spell, you controls) from deck
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        on_resolve {
            equip self to (1, monster, you controls)
        }
    }

}
