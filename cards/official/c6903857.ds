card "Power Breaker" {
    id: 6903857
    type: Effect Monster
    attribute: EARTH
    race: Warrior
    level: 4
    atk: 1900
    def: 0

    effect "Effect 1" {
        speed: spell_speed_1
        damage_step: false
        trigger: on_custom_event "chain_end"
        on_activate {
            select (1+, spell, either_player controls) as target
        }
        on_resolve {
            destroy (1+, spell, either_player controls)
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single + MandatoryTrigger
        code: BattleDestroyed
        on_resolve {
            change_battle_position (1, monster)
        }
    }

}
