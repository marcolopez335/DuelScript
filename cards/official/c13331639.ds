card "Supreme King Z-ARC" {
    id: 13331639
    type: Fusion Monster | Pendulum Monster
    attribute: DARK
    race: Dragon
    level: 12
    scale: 1
    atk: 4000
    def: 4000

    summon {
        cannot_normal_summon
    }

    passive "Effect 2" {
        scope: self
        grant: cannot_activate effects
    }

    passive "Effect 5" {
        scope: self
        grant: cannot_be_targeted by effects
    }

    passive "Effect 6" {
        scope: self
        grant: cannot_be_destroyed by effect
    }

    effect "Effect 4" {
        speed: 1
        mandatory
        trigger: summoned by special
        resolve {
            destroy (all, card, either controls)
        }
    }

    effect "Effect 7" {
        speed: 1
        timing: when
        trigger: battle_damage
        resolve {
            special_summon (1, monster, where archetype == "Supreme King Dragon") from deck in attack_position
        }
    }

    effect "Effect 8" {
        speed: 1
        timing: if
        trigger: destroyed
        resolve {
            special_summon (all, card, either controls)
        }
    }
}
