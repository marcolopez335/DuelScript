card "Capricious Darklord" {
    id: 55289183
    type: Effect Monster
    attribute: DARK
    race: Fairy
    level: 4
    atk: 0
    def: 1600

    effect "Effect 1" {
        speed: 2
        once_per_turn: hard
        resolve {
            normal_summon (1, card, you control, from hand)
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: custom "chain_end"
        resolve {
            modify_atk (all, card, opponent controls, from monster_zone, where is_face_up) - 500 * count((all, card, either controls, from monster_zone, where is_face_up and race == Fairy)) until end_of_turn
            modify_def (all, card, opponent controls, from monster_zone, where is_face_up) - 500 * count((all, card, either controls, from monster_zone, where is_face_up and race == Fairy)) until end_of_turn
        }
    }
}
