// 星痕の機界騎士
// Mekk-Knight Spectrum Supreme
// Transpiled from c38502358.lua

card "Mekk-Knight Spectrum Supreme" {
    id: 38502358
    type: Link Monster
    attribute: LIGHT
    race: Cyberse
    link: 3
    link_arrows: [bottom_left, bottom, bottom_right]
    atk: 3000

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ effect monster
        method: link
    }

    continuous_effect "Effect 1" {
        scope: self
        grant: direct_attack
    }

    continuous_effect "Effect 2" {
        scope: self
        grant: cannot_be_destroyed_by_effect
    }

    continuous_effect "Effect 3" {
        scope: self
        grant: cannot_be_targeted_by_card_effects
    }

    effect "Effect 4" {
        speed: spell_speed_1
        once_per_turn: hard
        cost {
            send self to gy
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
