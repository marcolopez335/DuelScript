card "Millennium Seeker" {
    id: 5130393
    type: Effect Monster
    attribute: DARK
    race: Spellcaster
    level: 4
    atk: 1000
    def: 1000

    raw_effect "Effect 1" {
        effect_type: Field + Trigger
        category: SpecialSummon
        code: 1111
        property: Oath
        range: Hand
        count_limit: (1, 5130393)
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_activate {
            select (1+, monster, opponent controls, where { is_monster }) as target
        }
        on_resolve {
            reveal (1+, card, opponent controls)
            shuffle_deck
            special_summon (1, monster) from gy
            add_to_hand (1+, monster, opponent controls, where { is_monster }) from deck
            reveal (1+, card, opponent controls)
            shuffle_hand
            special_summon (1, monster) from gy
        }
    }

}
