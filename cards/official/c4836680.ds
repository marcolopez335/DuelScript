card "Performapal Odd-Eyes Seer" {
    id: 4836680
    type: Effect Monster | Pendulum Monster
    attribute: DARK
    race: Spellcaster
    level: 6
    scale: 1
    atk: 100
    def: 1800

    summon_condition {
        tributes_required: 1
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_activate {
            select (1+, card, you controls) as target
        }
        on_resolve {
            add_to_hand (1+, card, you controls) from deck
            destroy (1+, card, you controls, deck)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_activate {
            select (1+, card, you controls) as target
        }
        cost {
            banish self
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        on_resolve {
            send (1+, card, you controls) to extra_deck
            send (1+, card, you controls, deck) to gy
        }
    }

