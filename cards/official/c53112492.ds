// 対抗魔術
// Anti-Spell
// Transpiled from c53112492.lua

card "Anti-Spell" {
    id: 53112492
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            negate activation
            destroy (1+, card, either_player controls)
        }
    }

}
