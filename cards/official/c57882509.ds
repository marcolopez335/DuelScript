// 弱体化の仮面
// Mask of Weakness
// Transpiled from c57882509.lua

card "Mask of Weakness" {
    id: 57882509
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        damage_step: false
        on_activate {
            select (1+, card, either_player controls) as target
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
