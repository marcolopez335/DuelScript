// 深海姫プリマドーナ
// Deep Sea Prima Donna
// Transpiled from c50793215.lua

card "Deep Sea Prima Donna" {
    id: 50793215
    type: Synchro Monster | Tuner
    attribute: WATER
    race: Sea Serpent
    level: 7
    atk: 1500
    def: 2700

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    raw_effect "Effect 1" {
        effect_type: Single + Continuous
        code: FlipSuccess
        property: SetAvailable
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: hard
        damage_step: false
        on_resolve {
            add_to_hand (1, card, you controls) from gy
            special_summon (1, monster) from gy
            add_to_hand (1+, card, you controls) from deck
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        damage_step: false
        trigger: on_custom_event "chain_end"
        on_resolve {
            return (1+, card, you controls) to deck shuffle
        }
    }

    continuous_effect "Effect 4" {
        scope: self
        grant: cannot_be_targeted_by_card_effects
    }

}
