card "Pollinosis" {
    password: 91078716
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_1
        trigger: when_summoned
        cost {
            tribute self
        }
        on_resolve {
            negate summon
            destroy (1+, card, either_player controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        trigger: opponent_activates [search | special_summon | send_to_gy | draw]
