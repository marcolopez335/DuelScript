// 超魔導師－ブラック・マジシャンズ
// The Dark Magicians
// Transpiled from c50237654.lua

card "The Dark Magicians" {
    id: 50237654
    type: Fusion Monster
    attribute: DARK
    race: Spellcaster
    level: 8
    atk: 2800
    def: 2300

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        method: fusion
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            draw 1
            set (1, card)
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        optional: true
        timing: if
        trigger: when_destroyed
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
