card "Magician's Rod" {
    id: 7084129
    type: Effect Monster
    attribute: DARK
    race: Spellcaster
    level: 3
    atk: 1600
    def: 100

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        timing: when
        trigger: summoned
        resolve {
            add_to_hand (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: opponent_activates [activate_spell, activate_trap, activate_spell]
        cost {
            tribute self
        }
        resolve {
            add_to_hand (all, card, either controls)
        }
    }
}
