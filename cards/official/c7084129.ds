// マジシャンズ・ロッド
// Magician's Rod
// Transpiled from c7084129.lua

card "Magician's Rod" {
    id: 7084129
    type: Effect Monster
    attribute: DARK
    race: Spellcaster
    level: 3
    atk: 1600
    def: 100

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: when
        trigger: when_summoned
        on_resolve {
            add_to_hand (1+, spell, you controls) from deck
            reveal (1+, card, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        activate_from: [gy]
        cost {
            tribute self
        }
        on_resolve {
            add_to_hand (1+, spell, you controls) from deck
        }
    }

}
