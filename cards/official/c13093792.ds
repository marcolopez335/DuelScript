card "Destiny HERO - Diamond Dude" {
    id: 13093792
    type: Effect Monster
    attribute: DARK
    race: Warrior
    level: 4
    atk: 1400
    def: 1600

    raw_effect "Effect 1" {
        effect_type: Ignition
        category: AtkChange
        range: MonsterZone
        count_limit: (1, 0)
        on_resolve {
            reveal (1, card, opponent controls, deck)
            send (1+, card, either_player controls) to gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            send_to_deck (1+, card, you controls) bottom
        }
    }

}
