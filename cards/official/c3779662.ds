card "Gladiator Beast Andabata" {
    id: 3779662
    type: Fusion Monster
    attribute: DARK
    race: Beast-Warrior
    level: 8
    atk: 1000
    def: 2800

    summon {
        cannot_normal_summon
        special_summon_procedure {
            from: extra_deck
            to: your_field
        }
    }

    effect "Effect 1" {
        speed: 1
        timing: if
        trigger: summoned by special
        resolve {
            special_summon (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        timing: when
        trigger: standby_phase
        resolve {
            special_summon (all, card, either controls)
