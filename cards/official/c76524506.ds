            }
            destroy (1+, spell, either_player controls)
            create_token { atk: 0 def: 0 }
            special_summon (1, monster) from gy
        }
    }

    raw_effect "Effect 2" {
        effect_type: QuickEffect
        category: SpecialSummon
        code: FreeChain
        range: MonsterZone
        on_resolve {
            synchro_summon (1, synchro monster) using (1+, monster, you controls)
        }
