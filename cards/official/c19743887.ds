// 蹴神－ＶＡＲｅｆａｒ
// VARefar, the Judge of Ball
// Transpiled from c19743887.lua

card "VARefar, the Judge of Ball" {
    id: 19743887
    type: Effect Monster
    attribute: EARTH
    race: Fiend
    level: 11
    atk: 2100
    def: 800

    summon_condition {
        tributes_required: 2
    }

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        activate_from: [hand]
        on_resolve {
            special_summon (1, monster) from gy
            reveal (1+, card, opponent controls)
            shuffle_hand
            change_battle_position (1, monster)
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            banish (1+, card, you controls, hand)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        timing: when
        trigger: when_attacked
        activate_from: [hand]
        on_resolve {
            special_summon (1, monster) from gy
            reveal (1+, card, opponent controls)
            shuffle_hand
            change_battle_position (1, monster)
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
            banish (1+, card, you controls, hand)
        }
    }

}
