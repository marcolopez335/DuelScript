// プルーフ・プルフラス
// Proof of Pruflas
// Transpiled from c85847157.lua

card "Proof of Pruflas" {
    id: 85847157
    type: Effect Monster
    attribute: DARK
    race: Fiend
    level: 3
    atk: 100
    def: 100

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [hand]
        on_resolve {
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        optional: true
        timing: if
        trigger: when_summoned
        on_resolve {
            normal_summon (1, monster, you controls)
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        optional: true
        timing: if
        trigger: when_summoned by_special_summon
        on_resolve {
            normal_summon (1, monster, you controls)
        }
    }

}
