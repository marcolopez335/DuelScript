card "Dark Angel" {
    id: 28593329
    type: Effect Monster
    attribute: DARK
    race: Fairy
    level: 5
    atk: 0
    def: 0

    summon_condition {
        tributes_required: 1
    }

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        timing: when
        damage_step: false
        trigger: when_attacked
        activate_from: [hand]
        on_activate {
            select (1+, card, either_player controls) as target
        }
        cost {
            tribute self
            send self to gy
        }
        on_resolve {
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
