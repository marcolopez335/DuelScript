// 森羅の姫芽宮
// Sylvan Princessprite
// Transpiled from c33909817.lua

card "Sylvan Princessprite" {
    id: 33909817
    type: Xyz Monster
    attribute: LIGHT
    race: Plant
    rank: 1
    atk: 1800
    def: 100

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        same_level: true
        method: xyz
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        cost {
            detach 1 overlay_unit from self
        }
        on_resolve {
            reveal (1, card, opponent controls, deck)
            add_to_hand (1+, spell, you controls, where { is_face_up and race == Plant }) from deck
            shuffle_hand
            send (1+, spell, you controls, deck) to gy
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_activate {
            select (1+, spell, you controls, where { is_face_up and race == Plant }) as target
        }
        cost {
            send self to gy
        }
        on_resolve {
            special_summon (1, monster) from gy
        }
    }

}
