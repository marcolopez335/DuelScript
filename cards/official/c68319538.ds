// 宇宙砦ゴルガー
// Cosmic Fortress Gol'gar
// Transpiled from c68319538.lua

card "Cosmic Fortress Gol'gar" {
    id: 68319538
    type: Synchro Monster
    attribute: LIGHT
    race: Reptile
    level: 5
    atk: 2600
    def: 1800

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    summon_condition {
        cannot_normal_summon: true
    }

    raw_effect "Effect 1" {
        effect_type: Ignition
        category: ToHand + LinkSummon
        property: CardTarget
        range: MonsterZone
        count_limit: (1, 0)
        on_resolve {
            return (1+, spell, either_player controls) to hand
        }
    }

    raw_effect "Effect 2" {
        effect_type: Ignition
        category: Destroy
        property: CardTarget
        range: MonsterZone
        count_limit: (1, 0)
        on_resolve {
            destroy (1+, spell, either_player controls)
        }
    }

}
