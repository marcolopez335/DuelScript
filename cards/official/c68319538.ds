card "Cosmic Fortress Gol'gar" {
    id: 68319538
    type: Synchro Monster
    attribute: LIGHT
    race: Reptile
    level: 5
    atk: 2600
    def: 1800

    summon {
        cannot_normal_summon
        special_summon_procedure {
            from: extra_deck
            to: your_field
        }
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: soft
        mandatory
        resolve {
            return (all, card, either controls) to hand
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        mandatory
        resolve {
            destroy (all, card, either controls)
        }
    }
}
