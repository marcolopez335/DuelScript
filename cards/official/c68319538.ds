// 宇宙砦ゴルガー
// Cosmic Fortress Gol'gar
// Transpiled from c68319538.lua

card "Cosmic Fortress Gol'gar" {
    id: 68319538
    type: Synchro Monster
    attribute: LIGHT
    race: Reptile
    level: 5
    atk: 2600
    def: 1800

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    summon_condition {
        cannot_normal_summon: true
    }

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_activate {
            select (1+, spell, either_player controls, where { is_face_up and is_spell }) as target
        }
        on_resolve {
            return (1+, spell, either_player controls, where { is_face_up and is_spell }) to hand
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        damage_step: false
        on_activate {
            select (1+, spell, either_player controls, where { is_face_up and is_spell }) as target
        }
        on_resolve {
            destroy (1+, spell, either_player controls, where { is_face_up and is_spell })
        }
    }

}
