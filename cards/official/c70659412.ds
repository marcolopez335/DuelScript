card "Psychic Omnibuster" {
    id: 70659412
    type: Synchro Monster
    attribute: WIND
    race: Psychic
    level: 7
    atk: 2500
    def: 2000

    summon {
        cannot_normal_summon
    }

    passive "Effect 2" {
        scope: self
        grant: cannot_be_destroyed by effect
    }

    effect "Effect 1" {
        speed: 1
        timing: if
        trigger: opponent_activates [activate_spell, activate_trap, activate_spell]
        cost {
            pay_lp 2000
        }
        resolve {
            add_to_hand (all, card, either controls)
            banish (all, card, either controls)
        }
    }
}
