// サイコ・オムニバスター
// Psychic Omnibuster
// Transpiled from c70659412.lua

card "Psychic Omnibuster" {
    id: 70659412
    type: Synchro Monster
    attribute: WIND
    race: Psychic
    level: 7
    atk: 2500
    def: 2000

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 1 tuner monster
        require: 1+ non-tuner monster
        method: synchro
    }

    effect "Effect 1" {
        speed: spell_speed_1
        optional: true
        timing: if
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        cost {
            pay_lp 2000
        }
        on_resolve {
            reveal (1+, card, opponent controls)
            shuffle_hand
            add_to_hand (1+, card, either_player controls) from gy
            banish (1+, monster, opponent controls)
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single
        code: IndestructableEffect
        property: BothSide + IgnoreRange2
        on_resolve {
            register_effect on self { grant: cannot_be_destroyed_by_effect duration: until_end_of_turn }
        }
    }

}
