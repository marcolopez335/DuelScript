// 雷龍融合
// Thunder Dragon Fusion
// Transpiled from c95238394.lua

card "Thunder Dragon Fusion" {
    id: 95238394
    type: Normal Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        on_resolve {
            fusion_summon (1, fusion monster) using (1+, monster, you controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        activate_from: [gy]
        cost {
            banish self
        }
        on_resolve {
            add_to_hand (1+, card, you controls, where { race == Thunder }) from gy
            reveal (1+, card, opponent controls)
        }
    }

}
