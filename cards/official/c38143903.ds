// Head Judging
// Transpiled from c38143903.lua

card "Head Judging" {
    password: 38143903
    type: Continuous Trap

    effect "Effect 1" {
        speed: spell_speed_1
        on_resolve {
            reveal self
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        damage_step: true
        trigger: opponent_activates [search | special_summon | send_to_gy | draw]
        on_resolve {
            send (1, card) to gy
            negate activation
            take_control of (1, monster, opponent controls)
        }
    }

}
