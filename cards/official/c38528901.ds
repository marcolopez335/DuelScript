card "Shock Troops of the Ice Barrier" {
    id: 38528901
    type: Effect Monster
    attribute: WATER
    race: Spellcaster
    level: 3
    atk: 1500
    def: 800

    effect "Effect 1" {
        speed: spell_speed_1
        damage_step: false
        on_activate {
            select (1+, monster, you controls) as target
        }
        cost {
            tribute self
        }
        on_resolve {
            destroy (1+, monster, you controls, deck)
            add_to_hand (1+, monster, you controls) from deck
            reveal (1+, card, opponent controls)
        }
    }

}
