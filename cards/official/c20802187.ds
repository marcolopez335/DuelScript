card "Spirit Converter" {
    id: 20802187
    type: Continuous Spell

    effect "Effect 1" {
        speed: 1
        mandatory
        resolve {
            attach (1, card, you control, from monster_zone) to target as_material
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        mandatory
        condition: previous_location == field
        resolve {
            add_to_hand target
        }
    }

    effect "Effect 3" {
        speed: 1
        mandatory
        trigger: custom "chain_end"
        resolve {
            add_to_hand (all, card, either controls)
        }
    }
}
