card "Rciela, Sinister Soul of the White Forest" {
    id: 77313225
    type: Synchro Monster | Tuner
    attribute: LIGHT
    race: Spellcaster
    level: 6
    atk: 2000
    def: 1500

    summon {
        cannot_normal_summon
        synchro materials {
            tuner: (1, tuner monster)
            non_tuner: (1+, non-tuner monster)
        }
    }

    passive "Effect 3" {
        scope: self
        grant: cannot_be_destroyed by effect
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        cost {
            send self to gy
        }
        resolve {
            add_to_hand (all, card, either controls)
        }
    }
}
