// ネフティスの護り手
// Defender of Nephthys
// Transpiled from c51782995.lua

card "Defender of Nephthys" {
    id: 51782995
    type: Effect Monster
    attribute: WIND
    race: Spellcaster
    level: 2
    atk: 1400
    def: 200

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        on_resolve {
            destroy (1+, monster, you controls, hand)
            special_summon (1, monster) from gy
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single + Continuous
        code: Destroyed
        property: BothSide
        on_resolve {
            set_flag "tracked" on self
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: when
        trigger: during_standby_phase
        activate_from: [gy]
        on_resolve {
            destroy (1+, monster, you controls, hand)
        }
    }

}
