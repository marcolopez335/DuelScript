// 怒りの業火 エクゾード・フレイム
// Exxod Fires of Rage
// Transpiled from c23617756.lua

card "Exxod Fires of Rage" {
    id: 23617756
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        on_resolve {
            destroy (1+, monster, opponent controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        activate_from: [gy]
        cost {
            banish self
        }
        on_resolve {
            return (1+, monster, opponent controls) to hand
            reveal (1+, card, opponent controls)
            return (1+, monster, opponent controls) to deck shuffle
        }
    }

}
