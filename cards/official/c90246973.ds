card "Power Pickaxe" {
    id: 90246973
    type: Equip Spell

    raw_effect "Effect 1" {
        effect_type: Ignition
        category: Banish + SynchroSummon
        property: CardTarget
        range: SpellTrapZone
        count_limit: (1, 0)
        on_resolve {
            banish (1+, card, either_player controls)
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    raw_effect "Effect 2" {
        effect_type: Activate
        category: EquipAction
        code: FreeChain
        on_resolve {
            equip self to (1, monster, you controls)
        }
    }

