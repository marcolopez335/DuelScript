card "Battlin' Boxer Rib Gardna" {
    id: 24184846
    type: Effect Monster
    attribute: FIRE
    race: Warrior
    level: 3
    atk: 100
    def: 1400

    effect "Effect 1" {
        speed: spell_speed_2
        optional: true
        damage_step: false
        activate_from: [hand, gy]
        on_activate {
            select (1+, card, either_player controls) as target
        }
        cost {
            banish self
