// バージェストマ・アノマロカリス
// Paleozoic Anomalocaris
// Transpiled from c61307542.lua

card "Paleozoic Anomalocaris" {
    id: 61307542
    type: Xyz Monster
    attribute: WATER
    race: Aqua
    rank: 2
    atk: 2400
    def: 0

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ monster
        same_level: true
        method: xyz
    }

    continuous_effect "Effect 1" {
        scope: self
        grant: unaffected_by_card_effects
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        trigger: on_custom_event "chain_end"
        on_resolve {
            reveal (1, card, opponent controls, deck)
            add_to_hand (1+, trap, either_player controls, where { is_trap }) from gy
            shuffle_hand
            send (1+, trap, either_player controls, where { is_trap }) to gy
        }
    }

    effect "Effect 3" {
        speed: spell_speed_2
        once_per_turn: soft
        optional: true
        damage_step: false
        on_activate {
            select (1+, trap, either_player controls, where { is_trap }) as target
        }
        cost {
            detach 1 overlay_unit from self
        }
        on_resolve {
            destroy (1+, trap, either_player controls, where { is_trap })
        }
    }

}
