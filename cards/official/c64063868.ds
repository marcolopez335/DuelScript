// Kozmo－ダークエクリプサー
// Kozmo Dark Eclipser
// Transpiled from c64063868.lua

card "Kozmo Dark Eclipser" {
    id: 64063868
    type: Effect Monster
    attribute: DARK
    race: Machine
    level: 9
    atk: 3000
    def: 2600

    summon_condition {
        tributes_required: 2
    }

    continuous_effect "Effect 1" {
        scope: self
        grant: cannot_be_targeted_by_card_effects
    }

    effect "Effect 2" {
        speed: spell_speed_2
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        cost {
            banish self
        }
        on_resolve {
            negate activation
            destroy (1+, monster, you controls, gy)
        }
    }

    effect "Effect 3" {
        speed: spell_speed_1
        optional: true
        timing: if
        trigger: on_custom_event "chain_end"
        cost {
            banish self
        }
        on_resolve {
            add_to_hand (1+, monster, you controls) from gy
            reveal (1+, card, opponent controls)
        }
    }

}
