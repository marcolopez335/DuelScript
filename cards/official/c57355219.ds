// パラドックス・フュージョン
// Paradox Fusion
// Transpiled from c57355219.lua

card "Paradox Fusion" {
    id: 57355219
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        cost {
            banish self
        }
        on_resolve {
            negate summon
            destroy (1+, monster, you controls)
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    effect "Effect 2" {
        speed: spell_speed_2
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        cost {
            banish self
        }
        on_resolve {
            negate activation
            destroy (1+, monster, you controls)
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

}
