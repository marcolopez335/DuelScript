// 粉砕せし破壊神
// The Breaking Ruin God
// Transpiled from c85182315.lua

card "The Breaking Ruin God" {
    id: 85182315
    type: Quick-Play Spell

    raw_effect "Effect 1" {
        effect_type: Activate
        category: SpecialSummon
        code: FreeChain
        count_limit: (1, 0)
        on_resolve {
            special_summon (1, monster) from gy
            register_effect on self {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }

    raw_effect "Effect 2" {
        effect_type: Field + Trigger
        category: Banish + Damage
        code: Released
        property: Delay
        range: Graveyard
        count_limit: (1, 0)
        cost {
            banish self
        }
        on_resolve {
            banish (1+, monster, opponent controls, gy)
            deal_damage to opponent: 1000
        }
    }

}
