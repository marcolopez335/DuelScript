card "Melodious Concerto" {
    id: 31458630
    type: Normal Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        on_resolve {
            fusion_summon (1, fusion monster) using (1+, monster, you controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        optional: true
        timing: if
        trigger: on_custom_event "chain_end"
        activate_from: [gy]
        on_resolve {
            return (1+, card, either_player controls) to deck shuffle
            draw 1
        }
    }

}
