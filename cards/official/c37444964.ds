// 夢魔鏡の夢物語
// Dream Mirror Fantasy
// Transpiled from c37444964.lua

card "Dream Mirror Fantasy" {
    id: 37444964
    type: Normal Trap

    effect "Effect 1" {
        speed: spell_speed_2
        once_per_turn: hard
        damage_step: false
        on_resolve {
            return (1+, card, either_player controls, where { is_face_up }) to deck shuffle
            banish (1+, card, either_player controls, where { is_face_up })
        }
    }

    replacement_effect "Effect 2" {
        instead_of: destroyed_by_any
        do: {
            banish self
        }
    }

}
