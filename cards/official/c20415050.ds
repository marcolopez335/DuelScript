// 神の見えざる手
// The Hidden Hecahands
// Transpiled from c20415050.lua

card "The Hidden Hecahands" {
    id: 20415050
    type: Normal Spell

    effect "Effect 1" {
        speed: spell_speed_1
        once_per_turn: hard
        cost {
            send self to gy
        }
        on_resolve {
            return (1+, monster, you controls) to hand
            reveal (1+, card, opponent controls)
            shuffle_hand
            set (1, card)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        once_per_turn: soft
        activate_from: [gy]
        cost {
            banish self
        }
        on_resolve {
            draw 1
            shuffle_hand
            discard (1, card)
        }
    }

}
