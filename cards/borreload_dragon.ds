// ============================================================
// borreload_dragon.ds — Link Monster, restrictions, take_control
// ============================================================

card "Borreload Dragon" {
  type: Link Monster
  attribute: DARK
  race: Dragon
  link: 4
  atk: 3000

  link_arrows: [top_left, left, bottom_right, bottom]

  materials {
    require: 3+ effect monster
    cannot_use: token
  }

  // Passive — opponent cannot target this card
  continuous_effect "Untargetable" {
    while: on_field
    apply_to: self
    grant: immune_to_targeting
  }

  // Effect 1 — Quick effect: reduce one monster's ATK/DEF by 500
  effect "Borrelsword Burst" {
    speed: spell_speed_2
    once_per_turn: true

    on_resolve {
      modifier: atk -500 on (1, monster, either_player controls) until_end_of_turn
      modifier: def -500 on (1, monster, either_player controls) until_end_of_turn
    }
  }

  // Effect 2 — Take control of opponent's monster with 0 ATK after it attacks
  effect "Borrel Seizure" {
    speed: spell_speed_2
    once_per_turn: true
    timing: when

    trigger: when_attacked

    on_resolve {
      take_control of (1, monster, opponent controls, with_atk == 0) until end_of_turn
    }
  }
}
