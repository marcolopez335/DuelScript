// 八式対魔法多重結界
// Spell Shield Type-8
// Negate the activation of a Spell Card and destroy it.

card "Spell Shield Type-8" {
    id: 38275183
    type: Counter Trap

    effect "Negate Spell" {
        speed: 3
        trigger: opponent_activates [activate_spell]
        resolve {
            negate and destroy
        }
    }
}
