// 威嚇する咆哮
// Threatening Roar
// Your opponent cannot declare an attack this turn.

card "Threatening Roar" {
    id: 36361633
    type: Normal Trap

    effect "No Attacks" {
        speed: 2
        resolve {
            grant (all, monster, opponent controls) cannot_attack until end_of_turn
        }
    }
}
