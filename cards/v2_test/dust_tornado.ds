// 砂塵の大竜巻
// Dust Tornado
// Target 1 Spell/Trap opponent controls; destroy it.

card "Dust Tornado" {
    id: 60082869
    type: Normal Trap

    effect "Destroy Spell/Trap" {
        speed: 2
        target (1, card, opponent controls)
        resolve {
            destroy target
        }
    }
}
