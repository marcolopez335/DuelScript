// 攻撃の無力化
// Negate Attack
// When an opponent's monster declares an attack: Negate the attack,
// then end the Battle Phase.

card "Negate Attack" {
    id: 14315573
    type: Counter Trap

    effect "Negate and End Battle" {
        speed: 3
        trigger: opponent_attack_declared
        resolve {
            negate
        }
    }
}
