// 心変わり
// Change of Heart
// Target 1 opponent's monster; take control of it until the End Phase.

card "Change of Heart" {
    id: 4031928
    type: Normal Spell

    effect "Take Control" {
        speed: 1
        target (1, monster, opponent controls)
        resolve {
            take_control target until end_phase
        }
    }
}
