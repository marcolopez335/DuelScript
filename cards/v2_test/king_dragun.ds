// 竜魔人 キングドラグーン
// King Dragun
// "Lord of D." + "Divine Dragon Ragnarok"
// Opponent cannot target Dragon monsters you control with effects.
// Once per turn: Special Summon 1 Dragon from your hand.

card "King Dragun" {
    id: 13756293
    type: Fusion Monster
    attribute: DARK
    race: Dragon
    level: 7
    atk: 2400
    def: 1100

    summon {
        cannot_normal_summon
        fusion materials: "Lord of D." + "Divine Dragon Ragnarok"
    }

    passive "Dragon Protection" {
        scope: field
        target: (all, monster, you control, where race == Dragon)
        grant: cannot_be_targeted by opponent
    }

    effect "Summon Dragon" {
        speed: 1
        once_per_turn: soft
        resolve {
            special_summon (1, monster, where race == Dragon) from hand
        }
    }
}
