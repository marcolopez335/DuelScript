// 大嵐
// Heavy Storm
// Destroy all Spell and Trap Cards on the field.

card "Heavy Storm" {
    id: 19613556
    type: Normal Spell

    effect "Destroy All Spells and Traps" {
        speed: 1
        resolve {
            destroy (all, spell, either controls)
            destroy (all, trap, either controls)
        }
    }
}
