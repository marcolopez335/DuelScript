// 盗賊の七つ道具
// Seven Tools of the Bandit
// When a Trap is activated: Pay 1000 LP; negate and destroy it.

card "Seven Tools of the Bandit" {
    id: 3819470
    type: Counter Trap

    effect "Negate Trap" {
        speed: 3
        trigger: opponent_activates [activate_trap]
        cost {
            pay_lp 1000
        }
        resolve {
            negate and destroy
        }
    }
}
