// 降霊の儀式
// Rite of Spirit
// Target 1 "Gravekeeper's" monster in your GY; Special Summon it.

card "Rite of Spirit" {
    id: 30450531
    type: Normal Trap

    effect "Revive Gravekeeper" {
        speed: 2
        resolve {
            special_summon (1, "Gravekeeper's" monster) from gy
        }
    }
}
