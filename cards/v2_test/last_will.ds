// 遺言状
// Last Will
// If a monster you control is sent to your GY this turn: You can
// Special Summon 1 monster with 1500 or less ATK from your Deck.

card "Last Will" {
    id: 85602018
    type: Normal Spell

    effect "Recruit on Death" {
        speed: 1
        resolve {
            special_summon (1, monster, you control, from deck, where atk <= 1500)
        }
    }
}
