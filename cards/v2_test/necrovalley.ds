// 王家の眠る谷－ネクロバレー
// Necrovalley
// All "Gravekeeper's" monsters gain 500 ATK and DEF.
// Cards in the GY cannot be banished or moved.

card "Necrovalley" {
    id: 47355498
    type: Field Spell

    passive "Gravekeeper Boost" {
        scope: field
        target: (all, "Gravekeeper's" monster, either controls)
        modifier: atk + 500
    }
}
