// 抹殺の使徒
// Nobleman of Crossout
// Target 1 face-down monster; destroy and banish it. If it was a
// Flip monster, both players banish all copies from their Decks.

card "Nobleman of Crossout" {
    id: 71044499
    type: Normal Spell

    effect "Destroy and Banish" {
        speed: 1
        target (1, monster, either controls, face_down)
        resolve {
            destroy target
            banish target
        }
    }
}
