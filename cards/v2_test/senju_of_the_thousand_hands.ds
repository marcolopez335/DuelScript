// センジュ・ゴッド
// Senju of the Thousand Hands
// When Normal or Flip Summoned: Add 1 Ritual Monster from Deck to hand.

card "Senju of the Thousand Hands" {
    id: 23401839
    type: Effect Monster
    attribute: LIGHT
    race: Fairy
    level: 4
    atk: 1400
    def: 1000

    effect "Search Ritual" {
        speed: 1
        trigger: normal_summoned
        resolve {
            search (1, ritual monster) from deck
            add_to_hand searched
        }
    }
}
