// ヒーロー見参
// A Hero Emerges
// When opponent attacks: opponent picks 1 random card from your
// hand; if it is a Monster Card, Special Summon it.

card "A Hero Emerges" {
    id: 21597117
    type: Normal Trap

    effect "Random Summon" {
        speed: 2
        trigger: opponent_attack_declared
        resolve {
            special_summon (1, monster) from hand
        }
    }
}
