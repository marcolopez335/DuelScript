// レベル制限B地区
// Level Limit - Area B
// All face-up Level 4 or higher monsters are changed to Defense Position.

card "Level Limit - Area B" {
    id: 3136426
    type: Continuous Spell

    passive "Force Defense" {
        scope: field
        target: (all, monster, either controls, face_up, where level >= 4)
        grant: cannot_change_position
    }
}
