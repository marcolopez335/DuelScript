// 次元融合
// Dimension Fusion
// Pay 2000 Life Points; both players Special Summon as many of
// their removed from play monsters as possible.

card "Dimension Fusion" {
    id: 23557835
    type: Normal Spell

    effect "Mass Return" {
        speed: 1
        cost {
            pay_lp 2000
        }
        resolve {
            special_summon (all, monster, you control) from banished
            special_summon (all, monster, opponent controls) from banished
        }
    }
}
