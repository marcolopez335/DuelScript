// 異次元の女戦士
// D.D. Warrior Lady
// After damage calculation, if this card battled an opponent's
// monster: Banish both this card and that monster.

card "D.D. Warrior Lady" {
    id: 7572887
    type: Effect Monster
    attribute: LIGHT
    race: Warrior
    level: 4
    atk: 1500
    def: 1600

    effect "Mutual Banish" {
        speed: 1
        trigger: damage_calculation
        resolve {
            banish self
            banish (1, monster, opponent controls)
        }
    }
}
