// 月の書
// Book of Moon
// Target 1 face-up monster on the field; change that target to
// face-down Defense Position.

card "Book of Moon" {
    id: 14087893
    type: Quick-Play Spell

    effect "Set Face-Down" {
        speed: 2
        target (1, monster, either controls, face_up)
        resolve {
            flip_down target
        }
    }
}
