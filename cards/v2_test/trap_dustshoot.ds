// ダスト・シュート
// Trap Dustshoot
// Activate only if your opponent has 4 or more cards in their hand.
// Look at your opponent's hand, select 1 Monster Card, and return
// it to the Deck.

card "Trap Dustshoot" {
    type: Normal Trap
    id: 64697231

    effect "Hand Peek and Return" {
        speed: 2
        condition: hand_size >= 4

        resolve {
            look_at (all, card, opponent controls) from hand
            return (1, monster, opponent controls) to deck shuffle
        }
    }
}
