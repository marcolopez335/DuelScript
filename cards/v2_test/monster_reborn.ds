// Monster Reborn
// Normal Spell -- Target 1 monster in either GY; Special Summon it.

card "Monster Reborn" {
    id: 83764718
    type: Normal Spell

    effect "Revive" {
        speed: 1
        target (1, monster, either controls, in gy)
        resolve {
            special_summon target from gy in attack_position
        }
    }
}
