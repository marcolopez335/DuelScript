// ならず者傭兵部隊
// Exiled Force
// Tribute this card, then target 1 monster on the field; destroy
// that target.

card "Exiled Force" {
    id: 74131780
    type: Effect Monster
    attribute: EARTH
    race: Warrior
    level: 4
    atk: 1000
    def: 1000

    effect "Destroy by Tribute" {
        speed: 1
        cost {
            tribute self
        }
        target (1, monster, either controls)
        resolve {
            destroy target
        }
    }
}
