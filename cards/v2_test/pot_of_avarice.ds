// 貪欲な壺
// Pot of Avarice
// Target 5 monsters in your GY; shuffle them into the Deck, then draw 2.

card "Pot of Avarice" {
    id: 67169062
    type: Normal Spell

    effect "Recycle and Draw" {
        speed: 1
        resolve {
            return (5, monster, in gy) to deck shuffle
            draw 2
        }
    }
}
