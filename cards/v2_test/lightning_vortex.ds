// ライトニング・ボルテックス
// Lightning Vortex
// Discard 1 card; destroy all face-up monsters opponent controls.

card "Lightning Vortex" {
    id: 69162969
    type: Normal Spell

    effect "Destroy Face-Up Monsters" {
        speed: 1
        cost {
            discard (1, card)
        }
        resolve {
            destroy (all, monster, opponent controls, face_up)
        }
    }
}
