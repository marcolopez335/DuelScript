// ============================================================
// limiter_removal.ds — ATK modifier with duration + drawback
// ============================================================

card "Limiter Removal" {
  type: Quick-Play Spell

  effect {
    speed: spell_speed_2

    cost {
      none
    }

    on_resolve {
      // Double ATK of all Machine monsters you control this turn
      for_each (1, "Machine" monster, you controls) in monster_zone {
        double_atk self until_end_of_turn
      }
    }
  }

  // Drawback — destroy all machines that were affected at end phase
  replacement_effect "Limiter Burnout" {
    instead_of: sent_to_gy

    do: {
      destroy (1, "Machine" monster, you controls)
    }
  }
}
