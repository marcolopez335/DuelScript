// ============================================================
// thestalos_mega_monarch.ds — Tribute filter: must tribute
// an "Tribute Summoned" or "Special Summoned" monster
// ============================================================

card "Thestalos the Mega Monarch" {
  type: Effect Monster
  attribute: FIRE
  race: Pyro
  level: 8
  atk: 2400
  def: 1000

  archetype: ["Monarch"]

  summon_condition {
    tributes_required: 2
    // The second tribute must be a Tribute Summoned or Special Summoned monster
    tribute_material: monster
  }

  // Effect 1 — On Tribute Summon using a Tribute Summoned monster:
  // make opponent discard a random card, then burn for its level x 200
  effect "Mega Fire King" {
    speed: spell_speed_1
    timing: when
    once_per_turn: true

    trigger: when_tribute_summoned

    on_resolve {
      // Discard random card from opponent's hand
      discard (1, card, opponent controls)

      // Deal damage equal to the discarded card's level * 200
      // (engine resolves the dynamic damage via card reference)
      deal_damage to opponent: 800
    }
  }

  // Effect 2 (standard Monarch) — smaller burn on standard tribute summon
  effect "Fire King's Tribute" {
    speed: spell_speed_1
    timing: when

    trigger: when_tribute_summoned

    cost {
      none
    }

    on_resolve {
      discard (1, card, opponent controls)
      deal_damage to opponent: 400
    }
  }
}
