// ============================================================
// odd_eyes_pendulum_dragon.ds — Pendulum card stress test
// ============================================================

card "Odd-Eyes Pendulum Dragon" {
  type: Pendulum Monster | Effect Monster
  attribute: DARK
  race: Dragon
  level: 7
  scale: 4
  atk: 2500
  def: 2000

  archetype: ["Odd-Eyes", "Pendulum Dragon"]

  // ── Pendulum Effect ───────────────────────────────────────
  pendulum_effect {
    speed: spell_speed_1
    once_per_turn: true

    condition: in_spell_trap_zone

    trigger: during_standby_phase of yours

    on_resolve {
      // Search for another Pendulum monster with 1500 or less ATK
      search (1, monster, with_atk <= 1500, that_was_special_summoned) from deck
    }
  }

  // ── Monster Effect ────────────────────────────────────────
  effect "Piercing Pendulum" {
    speed: spell_speed_1
    timing: when

    // Double battle damage when attacking a special summoned monster
    trigger: when_attacked

    on_resolve {
      double_atk self until_end_of_damage_step
    }
  }

  // Replace destruction with search from extra deck
  replacement_effect "Pendulum Return" {
    instead_of: destroyed_by_any

    do: {
      return self to extra_deck
    }
  }
}
