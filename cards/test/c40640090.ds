// Xyz detach reference: Number 101 style.
// "Detach 1 material; take control of 1 opponent's monster."

card "Void Leviathan" {
    type: Xyz Monster | Effect Monster
    id: 40640090
    attribute: WATER
    race: Sea Serpent
    rank: 4
    atk: 2500
    def: 1500

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2 monster level 4
        same_level: true
        method: xyz
    }

    effect "Absorb Monster" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true

        cost {
            detach 1 overlay_unit from self
        }

        on_resolve {
            take_control of (1, monster, opponent controls) until end_phase
        }
    }
}
