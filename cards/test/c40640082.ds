// Choose-action reference: Magi-Magi-Magician-Gal-style.
//
// "When this card is Special Summoned, choose one:
//   - Add 1 Spell Counter to a face-up monster you control;
//   - Take control of 1 monster your opponent controls until
//     the End Phase;
//   - Special Summon 1 Spellcaster monster from your GY."
//
// Demonstrates the `choose` action with three named option branches,
// each containing a different game_action sequence. Useful as a
// proof-of-grammar for player-resolution forks.

card "Trifold Magician" {
    type: Effect Monster
    password: 40640082
    attribute: DARK
    race: Spellcaster
    level: 6
    atk: 2400
    def: 1000
    archetype: ["Magician"]

    summon_condition {
        tributes_required: 1
    }

    effect "Triple Choice" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: when
        trigger: when_summoned by_special_summon

        on_resolve {
            choose {
                option "Charge a Spell Counter" {
                    place_counter 1 "Spell Counter" on (1, monster, you controls)
                }
                option "Take Control" {
                    take_control of (1, monster, opponent controls) until end_phase
                }
                option "Revive a Spellcaster" {
                    special_summon (1, "Spellcaster" monster) from gy
                }
            }
        }
    }
}
