// Pattern: when_leaves_field trigger
// "When this card leaves the field: destroy 1 Spell/Trap your
//  opponent controls."

card "Departing Phantom" {
    type: Effect Monster
    id: 40640104
    attribute: WIND
    race: Winged Beast
    level: 4
    atk: 1600
    def: 900

    effect "Parting Shot" {
        speed: spell_speed_1
        optional: true
        timing: when
        trigger: when_leaves_field

        on_resolve {
            destroy (1, spell, opponent controls)
        }
    }
}
