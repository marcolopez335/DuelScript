// Pattern: condition: opponent_lp <= 3000
// "If your opponent's LP are 3000 or less: this card gains 1000 ATK."

card "Finishing Blow Dragon" {
    type: Effect Monster
    id: 40640113
    attribute: FIRE
    race: Dragon
    level: 6
    atk: 2000
    def: 1500

    summon_condition {
        tributes_required: 1
    }

    continuous_effect "Bloodlust" {
        scope: self
        while: opponent_lp <= 3000
        modifier: atk + 1000
    }
}
