// Forbidden Chalice — canonical hand-written version.
// Quick-Play Spell — Target 1 face-up monster on the field; until the end
// of this turn, that target gains 400 ATK, but its effects are negated.
//
// We exercise the +400 ATK part. The negate-effects-until-end-of-turn
// piece needs the apply_until / continuous wiring path which is a
// future sprint.

card "Forbidden Chalice" {
    type: Normal Spell
    password: 24286941

    effect "Boost ATK" {
        speed: spell_speed_1

        on_resolve {
            modifier: atk + 400 on (1, monster, either_player controls) until_end_of_turn
        }
    }
}
