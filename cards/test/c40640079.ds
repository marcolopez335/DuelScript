// Flag-with-value reference: set_flag .. value: expr lifecycle.
//
// "When this card is summoned, place a 'memory' flag on it whose
//  value equals its current ATK times 2. The flag survives leaving
//  the field and going to the GY. When this card is sent to the GY,
//  if it has the memory flag, gain LP equal to its base ATK and
//  clear the flag."
//
// Demonstrates:
//   - set_flag with `value: expr` (computed flag payload)
//   - flag survives mask covering both leave_field and to_gy
//   - has_flag condition guarding a downstream trigger
//   - clear_flag explicit teardown

card "Memory Sentinel" {
    type: Effect Monster
    password: 40640079
    attribute: EARTH
    race: Warrior
    level: 4
    atk: 1600
    def: 1200

    effect "Imprint Memory" {
        speed: spell_speed_1
        trigger: when_summoned
        on_resolve {
            set_flag "memory" on self {
                value: self.atk * 2
                survives: [leave_field, to_gy]
                resets_on: [end_of_duel]
            }
        }
    }

    effect "Recall Memory" {
        speed: spell_speed_1
        optional: true
        timing: when
        trigger: when_sent_to gy
        condition: has_flag "memory" on self

        on_resolve {
            gain_lp: self.base_atk
            clear_flag "memory" on self
        }
    }
}
