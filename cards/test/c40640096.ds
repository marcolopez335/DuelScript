// Field spell with continuous ATK boost reference.
// "All Warrior monsters gain 500 ATK."

card "Warrior's Sanctum" {
    type: Field Spell
    id: 40640096

    continuous_effect "Warrior Power" {
        scope: field
        apply_to: (1+, "Warrior" monster, either_player controls)
        modifier: atk + 500
    }
}
