// Pattern: set_scale action
// "Target 1 Pendulum Monster you control; change its Pendulum
//  Scale to 1."

card "Scale Tuner" {
    type: Quick-Play Spell
    id: 40640131

    effect "Adjust Scale" {
        speed: spell_speed_2
        once_per_turn: hard

        on_resolve {
            set_scale (1, monster, you controls, pendulum_zone) to 1
        }
    }
}
