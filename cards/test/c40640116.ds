// Pattern: 4-effect monster (ignition + quick + trigger mandatory + continuous)
// Ignition: discard 1; search a "Storm" card from Deck.
// Quick: banish 1 card from GY; negate 1 opponent's effect.
// Trigger (mandatory): when destroyed, Special Summon 1 "Storm" from GY.
// Continuous: "Storm" monsters you control cannot be targeted by opponent's effects.

card "Storm General" {
    type: Effect Monster
    id: 40640116
    attribute: WIND
    race: Warrior
    level: 6
    atk: 2300
    def: 1800

    summon_condition {
        tributes_required: 1
    }

    archetype: ["Storm"]

    effect "Storm Requisition" {
        speed: spell_speed_1
        once_per_turn: hard

        cost {
            discard (1, card, you controls, hand)
        }

        on_resolve {
            add_to_hand (1, "Storm" card) from deck
        }
    }

    effect "Storm Negation" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]

        cost {
            banish (1, card, you controls, gy) from gy
        }

        on_resolve {
            negate effect
        }
    }

    effect "Storm Succession" {
        speed: spell_speed_1
        optional: false
        timing: when
        trigger: when_destroyed by any

        on_resolve {
            special_summon (1, "Storm" monster) from gy
        }
    }

    continuous_effect "Storm Barrier" {
        scope: field
        apply_to: (1+, "Storm" monster, you controls)
        grant: cannot_be_targeted_by_opponent
    }
}
