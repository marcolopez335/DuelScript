// Heavy Storm — canonical hand-written version.
// Normal Spell — Destroy all Spells and Traps on the field.

card "Heavy Storm" {
    type: Normal Spell
    password: 19613556

    effect "Destroy All Spells and Traps" {
        speed: spell_speed_1

        on_resolve {
            destroy (1+, spell, either_player controls)
        }
    }
}
