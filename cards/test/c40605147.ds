// Solemn Strike — counter trap test card.
// Pay 1500 LP; negate the activation/summon and destroy that card.
// We exercise: cost (pay_lp) + negate.

card "Solemn Strike" {
    type: Counter Trap
    password: 40605147

    effect "Negate" {
        speed: spell_speed_3

        cost {
            pay_lp 1500
        }

        on_resolve {
            negate activation
        }
    }
}
