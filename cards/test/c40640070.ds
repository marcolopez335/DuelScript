// Dynamic modifier test: "this monster gains 200 ATK for each
// Dragon in your graveyard" — the modifier expression includes
// a count() that resolves at runtime.
//
// Verifies that the DSL's `expr` atoms compose into a working
// continuous modifier without hand-coding the value.

card "Dragon Lord" {
    type: Effect Monster
    password: 40640070
    attribute: DARK
    race: Dragon
    level: 7
    atk: 2400
    def: 1500

    continuous_effect "Dragon Power" {
        scope: self
        modifier: atk + count((1+, "Dragon" monster, you controls, gy)) * 200
    }
}
