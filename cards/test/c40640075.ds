// Damage-step effect reference: Honest-style.
// "When your monster battles, send this card to the GY; the
//  attacking monster gains ATK equal to the opponent's monster's
//  ATK."
//
// Demonstrates: when_attacked trigger + damage step + dynamic stat
// computation via target.atk in the modifier expression.

card "Honest" {
    type: Effect Monster
    password: 40640075
    attribute: LIGHT
    race: Fairy
    level: 4
    atk: 1100
    def: 1900
    archetype: ["Honest"]

    effect "Boost on Battle" {
        speed: spell_speed_2
        damage_step: true
        trigger: when_attacked
        optional: true

        cost {
            send self to gy
        }

        on_resolve {
            modifier: atk + target.atk on (1, monster, you controls) until_end_of_turn
        }
    }
}
