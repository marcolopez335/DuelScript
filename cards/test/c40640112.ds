// Pattern: condition: cards_in_gy >= 10
// "If you have 10 or more cards in your GY: banish 5 cards from
//  your GY; Special Summon this card from your hand."

card "Gravekeeper Colossus" {
    type: Effect Monster
    id: 40640112
    attribute: DARK
    race: Zombie
    level: 7
    atk: 2800
    def: 2000

    summon_condition {
        tributes_required: 2
    }

    effect "GY Mass Summon" {
        speed: spell_speed_1
        once_per_turn: hard
        activate_from: [hand]
        condition: cards_in_gy >= 10

        cost {
            banish (5, card, you controls, gy) from gy
        }

        on_resolve {
            special_summon self from hand
        }
    }
}
