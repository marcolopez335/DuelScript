// Pattern: change_level action
// "Target 1 monster you control; change its Level to 4."

card "Level Adjuster" {
    type: Quick-Play Spell
    id: 40640126

    effect "Force Level" {
        speed: spell_speed_2
        once_per_turn: hard

        on_resolve {
            change_level (1, monster, you controls) to 4
        }
    }
}
