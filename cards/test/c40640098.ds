// Hand trap reference: Ash Blossom pattern.
// "When opponent searches/summons/sends from deck: discard;
//  negate that effect."

card "Bloom Stopper" {
    type: Effect Monster | Tuner
    id: 40640098
    attribute: FIRE
    race: Zombie
    level: 3
    atk: 0
    def: 1800

    effect "Negate Deck Interaction" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true
        activate_from: [hand]
        condition: chain_link_includes [search, special_summon, send_to_gy]
        trigger: opponent_activates [search | special_summon | send_to_gy]

        cost {
            discard self
        }

        on_resolve {
            negate effect
        }
    }
}
