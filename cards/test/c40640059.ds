// Sprint 23 test card — Card-query predicates.
// Targets opponent monsters of level 4 or lower with ATK >= 1500.
//
// This is the language feature that unlocks ~50K Lua call sites
// across the 13K corpus where cards branch on Card.IsLevelBelow,
// Card.IsAttackAbove, Card.IsType, etc.

card "Predicate Test Spell" {
    type: Normal Spell
    password: 40640059

    effect "Selective Destroy" {
        speed: spell_speed_1

        on_resolve {
            destroy (1+, monster, opponent controls, where {
                level <= 4 and atk >= 1500
            })
        }
    }
}
