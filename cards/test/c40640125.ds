// Pattern: create_token action
// "Special Summon 2 'Mecha Token' tokens (Machine/EARTH/ATK 0/DEF 0)
//  in Defense Position."

card "Token Factory" {
    type: Normal Spell
    id: 40640125

    effect "Mass Production" {
        speed: spell_speed_1
        once_per_turn: hard

        on_resolve {
            create_token {
                name: "Mecha Token"
                attribute: EARTH
                race: Machine
                atk: 0
                def: 0
                count: 2
                position: defense_position
            }
        }
    }
}
