// Counter trap with LP cost: Solemn Judgment style.
// "Pay half your LP; negate a summon or activation, and destroy it."

card "Divine Denial" {
    type: Counter Trap
    id: 40640093

    effect "Negate Everything" {
        speed: spell_speed_3
        trigger: opponent_activates [activate_spell | activate_trap | normal_summon | special_summon]

        cost {
            pay_lp your_lp / 2
        }

        on_resolve {
            negate activation and destroy
        }
    }
}
