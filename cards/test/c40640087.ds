// Redirect effect reference: Dimensional Fissure style.
// "Any monster sent to the GY is banished instead."

card "Void Rift" {
    type: Continuous Spell
    id: 40640087

    redirect_effect "Banish Instead" {
        when_going_to: gy
        redirect_to: banished
        apply_to: (1+, monster, either_player controls)
    }
}
