// Multi-effect test monster.
// Effect 0: when summoned → draw 1
// Effect 1: when destroyed by battle → draw 2
//
// Used to verify Sprint 12: the engine fires the right effect_index
// based on which event triggered.

card "Test Multi Effect Monster" {
    type: Effect Monster
    password: 40640058
    attribute: DARK
    race: Fiend
    level: 4
    atk: 1500
    def: 1000

    effect "Draw on Summon" {
        speed: spell_speed_1
        trigger: when_summoned
        on_resolve {
            draw 1
        }
    }

    effect "Draw on Destroy" {
        speed: spell_speed_1
        trigger: when_destroyed by battle
        on_resolve {
            draw 2
        }
    }
}
