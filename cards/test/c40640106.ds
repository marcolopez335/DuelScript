// Pattern: when_battle_damage trigger
// "When this card inflicts battle damage to your opponent:
//  send the top 2 cards of your opponent's Deck to the GY."

card "Erosion Striker" {
    type: Effect Monster
    id: 40640106
    attribute: WATER
    race: Sea Serpent
    level: 4
    atk: 1800
    def: 800

    effect "Mill on Damage" {
        speed: spell_speed_1
        optional: false
        timing: when
        trigger: when_battle_damage to opponent

        on_resolve {
            mill 2 from opponent_deck
        }
    }
}
