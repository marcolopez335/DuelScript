// Sprint 25 test card — predicate filters by race.
// "Destroy all opponent monsters that are Warriors of level 4 or less."
//
// This card requires the runtime to actually answer race queries —
// the predicate language existed before, but Race always returned a
// sentinel value so race == X never matched anything.

card "Warrior Hunter" {
    type: Normal Spell
    password: 40640060

    effect "Hunt Warriors" {
        speed: spell_speed_1

        on_resolve {
            destroy (1+, monster, opponent controls, where {
                level <= 4 and race == Warrior
            })
        }
    }
}
