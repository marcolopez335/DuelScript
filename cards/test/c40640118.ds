// Pattern: and_if_you_do sequential resolution
// "Destroy 1 monster your opponent controls, and if you do,
//  gain LP equal to that monster's ATK."

card "Smiting Light" {
    type: Normal Spell
    id: 40640118

    effect "Holy Smite" {
        speed: spell_speed_1

        on_resolve {
            select (1, monster, opponent controls) as target
            destroy (1, monster, opponent controls)
            and_if_you_do {
                gain_lp: target.atk
            }
        }
    }
}
