// Pattern: template-using card (define template + use it)
// Defines a "thorn" template that damages the opponent when the
// monster is destroyed, then uses it in a card with its own effect.

template thorn_revenge {
    effect "Thorn Retaliation" {
        speed: spell_speed_1
        optional: false
        timing: when
        trigger: when_destroyed by any

        on_resolve {
            deal_damage to opponent: 500
        }
    }
}

card "Thorn Beast" {
    type: Effect Monster
    id: 40640134
    attribute: EARTH
    race: Plant
    level: 4
    atk: 1600
    def: 1200

    archetype: ["Thorn"]

    use thorn_revenge

    effect "Thorn Growth" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: when_summoned

        on_resolve {
            special_summon (1, "Thorn" monster) from deck in defense_position
        }
    }
}
