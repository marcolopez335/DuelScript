// Pattern: when_sent_to gy trigger
// "When this card is sent to the GY: add 1 'Sentry' card from
//  your Deck to your hand."

card "Sentry Courier" {
    type: Effect Monster
    id: 40640102
    attribute: EARTH
    race: Warrior
    level: 3
    atk: 1000
    def: 1000

    archetype: ["Sentry"]

    effect "GY Search" {
        speed: spell_speed_1
        optional: true
        timing: if
        trigger: when_sent_to gy

        on_resolve {
            add_to_hand (1, "Sentry" card) from deck
        }
    }
}
