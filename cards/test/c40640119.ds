// Pattern: then { } unconditional follow-up
// "Send 1 monster from your Deck to the GY; then draw 1 card."

card "Burial Dividend" {
    type: Normal Spell
    id: 40640119

    effect "Bury and Draw" {
        speed: spell_speed_1
        once_per_turn: hard

        on_resolve {
            send (1, monster, you controls, deck) to gy
            then {
                draw 1
            }
        }
    }
}
