// Pattern: change_attribute action
// "Target 1 face-up monster on the field; change its Attribute
//  to DARK."

card "Shadow Infusion" {
    type: Normal Spell
    id: 40640127

    effect "Corrupt Attribute" {
        speed: spell_speed_1

        on_resolve {
            change_attribute (1, monster, you controls, field, face_up) to DARK
        }
    }
}
