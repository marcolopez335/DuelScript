// Pattern: if (condition) { } conditional action in on_resolve
// "Draw 1 card. If you control a Spellcaster monster, draw 1
//  more card."

card "Scholar's Insight" {
    type: Normal Spell
    id: 40640122

    effect "Conditional Draw" {
        speed: spell_speed_1
        once_per_turn: hard

        on_resolve {
            draw 1
            if (you_control (1, "Spellcaster" monster)) {
                draw 1
            }
        }
    }
}
