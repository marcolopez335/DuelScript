// Compulsory Evacuation Device — canonical hand-written version.
// Normal Trap — Target 1 monster on the field; return that target to its
// owner's hand.

card "Compulsory Evacuation Device" {
    type: Normal Trap
    password: 94192409

    effect "Bounce Target" {
        speed: spell_speed_2

        on_resolve {
            return (1, monster, either_player controls) to hand
        }
    }
}
