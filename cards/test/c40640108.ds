// Pattern: on_nth_summon: 3 (3rd summon this turn)
// "When the 3rd monster is Summoned this turn: destroy all
//  monsters your opponent controls."

card "Triad Enforcer" {
    type: Effect Monster
    id: 40640108
    attribute: DARK
    race: Machine
    level: 4
    atk: 1500
    def: 1500

    effect "Third Summon Wipe" {
        speed: spell_speed_1
        optional: false
        timing: when
        trigger: on_nth_summon: 3

        on_resolve {
            destroy (1+, monster, opponent controls)
        }
    }
}
