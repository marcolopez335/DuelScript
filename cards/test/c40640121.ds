// Pattern: for_each loop action
// "For each Dragon monster in your GY: gain 300 LP."

card "Dragon Shrine Priest" {
    type: Effect Monster
    id: 40640121
    attribute: LIGHT
    race: Fairy
    level: 4
    atk: 1100
    def: 1800

    effect "Dragon Blessing" {
        speed: spell_speed_1
        once_per_turn: hard
        trigger: during_standby_phase of yours

        on_resolve {
            for_each (1+, "Dragon" monster) in gy {
                gain_lp: 300
            }
        }
    }
}
