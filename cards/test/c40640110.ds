// Pattern: condition: you_control (1, "Dragon" monster)
// "You can activate this effect only if you control a Dragon
//  monster. Tribute 1 monster; Special Summon 1 Level 7 or higher
//  Dragon from your Deck."

card "Dragon Herald" {
    type: Effect Monster
    id: 40640110
    attribute: FIRE
    race: Dragon
    level: 4
    atk: 1300
    def: 1100

    effect "Summon Elder Dragon" {
        speed: spell_speed_1
        once_per_turn: hard
        condition: you_control (1, "Dragon" monster)

        cost {
            tribute (1, monster, you controls)
        }

        on_resolve {
            special_summon (1, "Dragon" monster) from deck
        }
    }
}
