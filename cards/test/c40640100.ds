// Pattern: when_destroyed by battle trigger
// "When this card is destroyed by battle: Special Summon 1 Level 4
//  or lower DARK monster from your Deck."

card "Abyssal Avenger" {
    type: Effect Monster
    id: 40640100
    attribute: DARK
    race: Fiend
    level: 4
    atk: 1200
    def: 1600

    effect "Revenge Summon" {
        speed: spell_speed_1
        optional: true
        timing: when
        trigger: when_destroyed by battle

        on_resolve {
            special_summon (1, "DARK" monster) from deck in defense_position
        }
    }
}
