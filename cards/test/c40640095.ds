// Flip effect monster reference.
// "When flipped face-up: destroy 1 monster your opponent controls."

card "Shadow Lurker" {
    type: Effect Monster | Flip
    id: 40640095
    attribute: DARK
    race: Fiend
    level: 2
    atk: 450
    def: 500

    flip_effect "Destroy on Flip" {
        on_resolve {
            destroy (1, monster, opponent controls)
        }
    }
}
