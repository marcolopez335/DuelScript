// Equip-lifecycle reference: Axe of Despair-style.
// "Equip only to a monster you control. The equipped monster gains
//  1000 ATK. When this card is sent to the GY, you can put it on
//  top of the deck."
//
// Demonstrates: equip_effect block, while_equipped modifier,
// on_equipped_destroyed action.

card "Axe of Despair" {
    type: Equip Spell
    password: 40640072

    equip_effect {
        target: (1, monster, you controls)
        while_equipped {
            modifier: atk + 1000
        }
        on_equipped_destroyed {
            return self to deck
        }
    }
}
