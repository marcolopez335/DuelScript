// Counter-system reference: Pendulum-Of-Souls.
//
// "Each time a monster is sent to the GY, place a 'Soul Counter'
//  on this card (max 5). Once per turn, you can remove 3 Soul
//  Counters from this card to Special Summon 1 Level 4 or lower
//  monster from your GY."
//
// Demonstrates:
//   - counter_system block with name + placed_when + max
//   - cost { remove_counter N "name" from self }
//   - effect that consumes counters this card itself maintains

card "Pendulum of Souls" {
    type: Continuous Trap
    password: 40640081

    counter_system {
        name: "Soul Counter"
        placed_when: when send_to_gy
        max: 5
    }

    effect "Soul Reaping Revival" {
        speed: spell_speed_2
        once_per_turn: hard
        optional: true

        cost {
            remove_counter 3 "Soul Counter" from self
        }

        on_resolve {
            special_summon (1, monster) from gy
        }
    }
}
