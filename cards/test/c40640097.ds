// Link monster reference: requires 2+ Effect Monsters.
// "When this card is Link Summoned: draw 1 card."

card "Circuit Serpent" {
    type: Link Monster | Effect Monster
    id: 40640097
    attribute: DARK
    race: Cyberse
    link: 2
    atk: 1600
    link_arrows: [bottom_left, bottom_right]

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: 2+ effect monster
        method: link
    }

    effect "Link Draw" {
        speed: spell_speed_1
        once_per_turn: hard
        trigger: when_summoned by_link_summon

        on_resolve {
            draw 1
        }
    }
}
