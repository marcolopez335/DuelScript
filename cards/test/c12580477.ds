// Raigeki — canonical hand-written version.
// Normal Spell — Destroy all monsters your opponent controls.

card "Raigeki" {
    type: Normal Spell
    password: 12580477

    effect "Destroy Opponent's Monsters" {
        speed: spell_speed_1

        on_resolve {
            destroy (1+, monster, opponent controls)
        }
    }
}
