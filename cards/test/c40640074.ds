// Replacement-effect reference: "If this card would be destroyed,
//  banish 1 card from your hand instead."
//
// Demonstrates the replacement_effect block with a real `do { ... }`
// body — the kind of effect Sprint 29's migrator pattern emits but
// with a hand-written, semantically-precise body.

card "Phantom Aegis" {
    type: Effect Monster
    password: 40640074
    attribute: LIGHT
    race: Fairy
    level: 4
    atk: 1500
    def: 1500

    replacement_effect "Banish Instead" {
        instead_of: destroyed_by_any
        do: {
            banish (1, card, you controls, hand)
        }
    }
}
