// Lightning Vortex — canonical hand-written version.
// Normal Spell — Discard 1 card; destroy all face-up monsters
// your opponent controls.

card "Lightning Vortex" {
    type: Normal Spell
    password: 69162969

    effect "Discard and Destroy" {
        speed: spell_speed_1

        cost {
            discard (1, card, you controls)
        }

        on_resolve {
            destroy (1+, monster, opponent controls)
        }
    }
}
