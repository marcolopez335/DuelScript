// Pattern: when_destroys_by_battle trigger
// "When this card destroys a monster by battle: gain LP equal
//  to the destroyed monster's original ATK."

card "War Harvester" {
    type: Effect Monster
    id: 40640107
    attribute: EARTH
    race: Warrior
    level: 4
    atk: 1700
    def: 1000

    effect "Battle Reap" {
        speed: spell_speed_1
        optional: false
        timing: when
        trigger: when_destroys_by_battle

        on_resolve {
            gain_lp: target.original_atk
        }
    }
}
