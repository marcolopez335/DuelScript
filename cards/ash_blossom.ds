// ============================================================
// ash_blossom.ds — DuelScript Example (Complex Hand Trap)
// ============================================================

card "Ash Blossom & Joyous Spring" {
  type: Effect Monster | Tuner
  attribute: FIRE
  race: Zombie
  level: 3
  atk: 0
  def: 1800

  // Hand trap — negates opponent's key actions from hand
  effect "Hand Trap" {
    speed: spell_speed_2
    once_per_turn: true
    condition: in_hand

    trigger: opponent_activates [
      search
      | special_summon
      | send_to_gy
    ]

    cost {
      discard self
    }

    on_resolve {
      negate effect
    }
  }
}
