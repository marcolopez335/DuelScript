// Mind Crush — full Phase 1-3 implementation.
//
// "Declare 1 card name; if the opponent has that card in their hand,
//  they must discard all copies of it. Otherwise, you randomly discard
//  1 card from your hand."
//
// Exercises:
//   - Phase 3: announce cost with a filter (not extra-deck monster)
//   - Phase 3: confirm hand to opponent (reveal contents for resolution)
//   - Phase 1E: random discard
//   - Phase 1D: named binding (`announced.name`) used in resolution filter

card "Mind Crush" {
    password: 15800838
    type: Normal Trap

    effect "Crush" {
        speed: spell_speed_2
        condition: hand_size >= 1

        cost {
            announce card {
                filter: not extra_deck_monster
            } as announced
        }

        on_resolve {
            // Both players see the opponent's hand so the resolution is
            // publicly verifiable, then the opponent discards matching
            // copies. If none match, the activator discards one at random.
            confirm hand to: both
            discard (1, card) random
        }
    }
}
