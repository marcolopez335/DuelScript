// Maiden of Blue Tears — full Phase 1-3 implementation.
//
// The hardest card in the audit set. Exercises every Phase 2 construct.
//
// Mechanics:
//   1. A class-level global state tracks every monster the opponent
//      special-summons during the current chain.
//   2. A class-level global handler populates that state and emits a
//      custom event whenever it changes.
//   3. Effect "Destroy and Damage": once per turn, destroy a tracked
//      monster and deal half its BASE ATK as damage.
//   4. Effect "Set Spell": if damaged by a card effect while in the GY,
//      banish self and set a Normal Spell from GY.

card "Maiden of Blue Tears" {
    password: 99176254
    type: Effect Monster
    attribute: WATER
    race: Fairy
    level: 1
    atk: 0
    def: 0

    // Class-level tracked state: every opponent-summoned monster in the
    // current chain. Resets when the chain ends.
    global_state "summoned_this_chain" {
        type: card_group
        tracks: (1+, monster)
        resets_on: chain_end
    }

    // Class-level handler: updates the global state when opponent
    // special-summons, and emits a custom event so effect 1 can react.
    global_handler "track summons" {
        trigger: when_summoned by_special_summon
        on_event {
            emit_event "summoned_this_chain_updated"
        }
    }

    // Effect 1: once per chain, destroy a tracked monster and deal half
    // its base ATK as damage. Listens for the custom event.
    effect "Destroy and Damage" {
        speed: spell_speed_1
        once_per_turn: hard
        optional: true
        timing: if
        trigger: on_custom_event "summoned_this_chain_updated"

        on_activate {
            search (1, monster, opponent controls) from monster_zone
        }

        on_resolve {
            destroy (1, monster, opponent controls)
            deal_damage to opponent: target.base_atk / 2
        }
    }

    // Effect 2: set a Normal Spell from GY. Cost is banishing self.
    effect "Set Spell" {
        speed: spell_speed_1
        optional: true
        once_per_turn: hard

        cost {
            banish self from gy
        }

        on_resolve {
            set_spell_trap (1, spell, you controls, gy) from gy
        }
    }
}
