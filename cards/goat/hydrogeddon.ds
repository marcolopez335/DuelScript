// ハイドロゲドン
// Hydrogeddon
// When this card destroys an opponent's monster by battle: You can
// Special Summon 1 "Hydrogeddon" from your Deck.

card "Hydrogeddon" {
    id: 22587018
    type: Effect Monster
    attribute: WATER
    race: Dinosaur
    level: 4
    atk: 1600
    def: 1000

    effect "Summon Copy" {
        speed: 1
        timing: when
        trigger: destroys_by_battle
        resolve {
            special_summon (1, "Hydrogeddon" monster) from deck
        }
    }
}
