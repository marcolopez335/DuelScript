// カオスの儀式
// Black Luster Ritual
// Ritual Spell that summons "Black Luster Soldier".
// Tribute monsters whose total Levels equal 8 or more.

card "Black Luster Ritual" {
    type: Ritual Spell
    id: 55761792

    effect "Ritual Summon" {
        speed: spell_speed_1

        on_resolve {
            ritual_summon (1, ritual monster)
                using (1+, monster, you controls)
                where total_level >= 8
        }
    }
}
