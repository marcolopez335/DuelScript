// お注射天使リリー
// Injection Fairy Lily
// If this card attacks or is attacked, during damage calculation:
// You can pay 2000 LP once per battle; this card gains 3000 ATK
// during that damage calculation only.

card "Injection Fairy Lily" {
    id: 79575620
    type: Effect Monster
    attribute: EARTH
    race: Spellcaster
    level: 3
    atk: 400
    def: 1500

    effect "ATK Boost" {
        speed: spell_speed_2
        optional: true
        trigger: when attack_declared
        cost {
            pay_lp 2000
        }
        on_resolve {
            modifier: atk + 3000 on (1, monster, you controls) until_end_of_turn
        }
    }
}
