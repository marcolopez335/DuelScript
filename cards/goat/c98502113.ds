// 超魔導剣士－ブラック・パラディン
// Dark Paladin
// "Dark Magician" + "Buster Blader"
// Negate Spell activation by discarding 1 card.
// Gains 500 ATK for each Dragon on field and in GYs.

card "Dark Paladin" {
    type: Fusion Monster | Effect Monster
    id: 98502113
    attribute: DARK
    race: Spellcaster
    level: 8
    atk: 2900
    def: 2400

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: "Dark Magician" + "Buster Blader"
        method: fusion
    }

    effect "Effect 1" {
        speed: spell_speed_2
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        on_resolve {
            negate activation
            destroy (1+, card, you controls, hand)
        }
    }

    raw_effect "Effect 2" {
        effect_type: Single
        code: UpdateAttack
        property: SingleRange
        range: MonsterZone
        on_resolve {
            modifier: atk + count((1+, card, you controls, gy)) * 500
        }
    }

    raw_effect "Effect 3" {
        effect_type: Single
        code: SpsummonCondition
        property: BothSide + Uncopyable
        on_resolve {
        }
    }

}
