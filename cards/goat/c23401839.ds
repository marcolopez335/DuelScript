// センジュ・ゴッド
// Senju of the Thousand Hands
// LIGHT Fairy / Level 4 / ATK 1400 / DEF 1000
// When this card is Normal or Flip Summoned: You can add 1 Ritual Monster
// from your Deck to your hand.

card "Senju of the Thousand Hands" {
    id: 23401839
    type: Effect Monster
    attribute: LIGHT
    race: Fairy
    level: 4
    atk: 1400
    def: 1000

    effect "Search Ritual Monster" {
        speed: spell_speed_1
        optional: true
        timing: when
        trigger: when_summoned by_normal_summon

        on_resolve {
            add_to_hand (1, monster, you controls, where { is_ritual }) from deck
        }
    }

    effect "Search Ritual Monster on Flip" {
        speed: spell_speed_1
        optional: true
        timing: when
        trigger: when_summoned by_flip_summon

        on_resolve {
            add_to_hand (1, monster, you controls, where { is_ritual }) from deck
        }
    }
}
