// 「A」細胞培養装置
// 'A' Cell Incubator
// Each time an A-Counter is removed from play, place 1 A-Counter on
// this card. When this card is destroyed, distribute the A-Counters
// on this card among face-up monsters.

card "'A' Cell Incubator" {
    id: 64163367
    type: Continuous Spell

    counter_system {
        name: "A-Counter"
        max: none
    }

    effect "Collect Counters" {
        speed: spell_speed_1
        trigger: when_sent_to gy
        on_resolve {
            place_counter 1 "A-Counter" on self
        }
    }

    effect "Distribute on Destroy" {
        speed: spell_speed_1
        trigger: when_destroyed by any
        on_resolve {
            place_counter 1 "A-Counter" on (1+, monster, either_player controls, face_up)
        }
    }
}
