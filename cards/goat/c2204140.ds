// 生者の書－禁断の呪術－
// Book of Life
// Target 1 Zombie-Type monster in your GY and 1 monster in your
// opponent's GY; Special Summon the first target, and banish the
// second target.

card "Book of Life" {
    id: 2204140
    type: Normal Spell

    effect "Revive Zombie and Banish" {
        speed: spell_speed_1
        on_activate {
            select (1, monster, you controls, gy, where { race == Zombie }) as target
            select (1, monster, opponent controls, gy) as target
        }
        on_resolve {
            special_summon (1, monster, you controls, gy, where { race == Zombie }) from gy
            banish (1, monster, opponent controls) from gy
        }
    }
}
