// 早すぎた埋葬
// Premature Burial
// Pay 800 LP; target 1 monster in your GY; Special Summon it
// in Attack Position and equip this card to it.

card "Premature Burial" {
    id: 70828912
    type: Equip Spell

    effect "Revive" {
        speed: 1
        cost {
            pay_lp 800
        }
        resolve {
            special_summon (1, monster) from gy in attack_position
        }
    }
}
