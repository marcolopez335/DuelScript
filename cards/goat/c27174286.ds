// 異次元からの帰還
// Return from the Different Dimension
// Pay half LP; Special Summon as many banished monsters as possible.
// Banish them during End Phase.

card "Return from the Different Dimension" {
    type: Normal Trap
    id: 27174286

    effect "Mass Return" {
        speed: spell_speed_2
        cost {
            pay_lp your_lp / 2
        }
        on_resolve {
            special_summon (1+, monster, you controls) from banished
        }
    }
}
