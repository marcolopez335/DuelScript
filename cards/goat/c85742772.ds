// グラヴィティ・バインド－超重力の網－
// Gravity Bind
// Level 4 or higher monsters cannot attack.

card "Gravity Bind" {
    id: 85742772
    type: Continuous Trap

    continuous_effect "Lock High-Level Monsters" {
        scope: field
        apply_to: (1+, monster, either_player controls, where { level >= 4 })
        grant: cannot_attack
    }
}
