// Shining Angel
card "Shining Angel" {
    id: 95956346
    type: Effect Monster
    attribute: LIGHT
    race: Fairy
    level: 4
    atk: 1400
    def: 800

    effect "Recruit LIGHT Monster" {
        speed: 1
        timing: when
        trigger: destroyed_by_battle
        resolve {
            special_summon (1, monster, you control, where atk <= 1500) from deck in attack_position
        }
    }
}
