// リビングデッドの呼び声
// Call of the Haunted
// Activate this card by targeting 1 monster in your GY; Special
// Summon that target in Attack Position. When this card leaves the
// field, destroy that monster. When that monster is destroyed,
// destroy this card.

card "Call of the Haunted" {
    type: Continuous Trap
    id: 97077563

    effect "Revive from GY" {
        speed: spell_speed_2

        on_activate {
            select (1, monster, you controls, gy) as target
        }

        on_resolve {
            special_summon (1, monster) from gy in attack_position
        }
    }

    effect "Destroy Monster if This Leaves" {
        speed: spell_speed_2
        trigger: when_leaves_field

        on_resolve {
            destroy (1, monster, you controls)
        }
    }

    effect "Destroy Self if Monster Dies" {
        speed: spell_speed_2
        trigger: when_destroyed

        on_resolve {
            destroy self
        }
    }
}
