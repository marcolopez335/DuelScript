// ダーク・バルター
// Dark Balter the Terrible
// "Possessed Dark Soul" + "Frontier Wiseman"
// Negate Normal Spell effects that target this card. Can negate
// monster effects by discarding 1 card.

card "Dark Balter the Terrible" {
    id: 80071763
    type: Fusion Monster
    attribute: DARK
    race: Fiend
    level: 5
    atk: 2000
    def: 1200

    summon {
        cannot_normal_summon
        fusion materials: "Possessed Dark Soul" + "Frontier Wiseman"
    }

    passive "Spell Immunity" {
        scope: self
        grant: unaffected_by spells
    }
}
