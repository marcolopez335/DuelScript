// 補充要員
// Backup Soldier
// If 5+ monsters in GY: add up to 3 Normal Monsters with 1500
// or less ATK from GY to hand.

card "Backup Soldier" {
    type: Normal Trap
    id: 36280194

    effect "Recover Normals" {
        speed: spell_speed_2
        condition: cards_in_gy >= 5
        on_resolve {
            add_to_hand (1+, monster, you controls, with_atk <= 1500) from gy
        }
    }
}
