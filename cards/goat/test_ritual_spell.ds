// Integration test fixture: ritual summon action
// Exercises ritual_summon with material selector and total_level constraint.

card "Test Ritual Spell" {
    id: 99999997
    type: Ritual Spell

    effect "Ritual Summon" {
        speed: 1
        resolve {
            ritual_summon (1, ritual monster) using (1+, monster, you control) where total_level >= 8
        }
    }
}
