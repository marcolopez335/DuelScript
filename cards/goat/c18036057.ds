// 天空騎士パーシアス
// Airknight Parshath
// If this card attacks a Defense Position monster, inflict piercing
// battle damage. When this card inflicts battle damage to your
// opponent: Draw 1 card.

card "Airknight Parshath" {
    id: 18036057
    type: Effect Monster
    attribute: LIGHT
    race: Fairy
    level: 5
    atk: 1900
    def: 1400

    summon_condition {
        tributes_required: 1
    }

    continuous_effect "Piercing" {
        scope: self
        grant: piercing
    }

    effect "Draw on Battle Damage" {
        speed: spell_speed_1
        trigger: when_battle_damage to opponent
        on_resolve {
            draw 1
        }
    }
}
