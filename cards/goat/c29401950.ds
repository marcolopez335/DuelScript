// 奈落の落とし穴
// Bottomless Trap Hole
// When your opponent Summons a monster(s) with 1500 or more ATK:
// Destroy that monster(s), and if you do, banish it.

card "Bottomless Trap Hole" {
    type: Normal Trap
    id: 29401950

    effect "Destroy and Banish" {
        speed: spell_speed_2
        timing: when
        trigger: when_summoned

        on_resolve {
            destroy (1+, monster, opponent controls, with_atk >= 1500)
            and_if_you_do {
                banish (1+, monster, opponent controls)
            }
        }
    }
}
