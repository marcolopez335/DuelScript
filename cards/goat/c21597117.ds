// ヒーロー見参
// A Hero Emerges
// When opponent attacks: opponent picks 1 random card from your
// hand; if it's a Monster, Special Summon it.

card "A Hero Emerges" {
    type: Normal Trap
    id: 21597117

    effect "Random Summon" {
        speed: spell_speed_2
        trigger: when attack_declared
        on_resolve {
            special_summon (1, monster) from hand
        }
    }
}
