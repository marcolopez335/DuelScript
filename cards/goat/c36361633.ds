// 威嚇する咆哮
// Threatening Roar
// Your opponent cannot declare an attack this turn.

card "Threatening Roar" {
    type: Normal Trap
    id: 36361633

    effect "No Attacks" {
        speed: spell_speed_2
        on_resolve {
            register_effect on (1+, monster, opponent controls) {
                grant: cannot_attack
                duration: until_end_of_turn
            }
        }
    }
}
