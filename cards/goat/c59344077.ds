// マジック・ドレイン
// Magic Drain
// When a Spell Card is activated: Your opponent can discard 1 Spell;
// otherwise negate the activation of that Spell Card, and if you do,
// destroy it.

card "Magic Drain" {
    id: 59344077
    type: Counter Trap

    effect "Negate Spell" {
        speed: spell_speed_3
        trigger: opponent_activates [activate_spell]
        on_resolve {
            negate activation and destroy
        }
    }
}
