// 人造人間－サイコ・ショッカー
// Jinzo
// Trap Cards cannot be activated. Negate all Trap effects on the field.

card "Jinzo" {
    type: Effect Monster
    id: 77585513
    attribute: DARK
    race: Machine
    level: 6
    atk: 2400
    def: 1500

    summon_condition {
        tributes_required: 1
    }

    continuous_effect "Trap Lockdown" {
        scope: field
        apply_to: (1+, trap, either_player controls)
        grant: cannot_activate_effects
    }
}
