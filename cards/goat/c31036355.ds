// 強制転移
// Creature Swap
// Each player chooses 1 monster they control and switches control
// of those monsters with each other. Those monsters cannot change
// their battle positions for the rest of this turn.

card "Creature Swap" {
    type: Normal Spell
    id: 31036355

    effect "Swap Monsters" {
        speed: spell_speed_1

        on_resolve {
            select (1, monster, you controls) as yours
            select (1, monster, opponent controls) as theirs
            take_control of (1, monster, opponent controls)
        }
    }
}
