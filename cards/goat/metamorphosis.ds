// 突然変異
// Metamorphosis
// Tribute 1 monster; Special Summon 1 Fusion Monster from Extra
// Deck with the same Level as the Tributed monster.

card "Metamorphosis" {
    id: 46411259
    type: Normal Spell

    effect "Tribute for Fusion" {
        speed: 1
        cost {
            tribute (1, monster, you control)
        }
        resolve {
            special_summon (1, fusion monster) from extra_deck
        }
    }
}
