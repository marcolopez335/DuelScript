// キラー・トマト
// Mystic Tomato
// When this card is destroyed by battle and sent to the GY:
// You can Special Summon 1 DARK monster with 1500 or less ATK
// from your Deck in face-up Attack Position.

card "Mystic Tomato" {
    id: 83011277
    type: Effect Monster
    attribute: DARK
    race: Plant
    level: 4
    atk: 1400
    def: 1100

    effect "Recruit DARK Monster" {
        speed: spell_speed_1
        optional: true
        timing: when
        trigger: when_destroyed by battle

        on_resolve {
            special_summon (1, monster, you controls, where { attribute == DARK and atk <= 1500 }) from deck in attack_position
        }
    }
}
