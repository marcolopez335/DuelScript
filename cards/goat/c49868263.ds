// ドラゴン・ウォリアー
// Ryu Senshi
// "Warrior Dai Grepher" + "Spirit Ryu"
// Negate the effect of a Normal Trap that targets this card and destroy
// it. This card is unaffected by Normal Spell effects.

card "Ryu Senshi" {
    id: 49868263
    type: Fusion Monster
    attribute: EARTH
    race: Warrior
    level: 6
    atk: 2000
    def: 1200

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: "Warrior Dai Grepher" + "Spirit Ryu"
        method: fusion
    }

    continuous_effect "Unaffected by Normal Spells" {
        scope: self
        grant: unaffected_by_spell_effects
    }

    effect "Negate Targeting Trap" {
        speed: spell_speed_2
        trigger: opponent_activates [activate_trap]
        on_resolve {
            negate activation and destroy
        }
    }
}
