card "Ryu Senshi" {
    id: 49868263
    type: Fusion Monster
    attribute: EARTH
    race: Warrior
    level: 6
    atk: 2000
    def: 1200

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: "Warrior Dai Grepher" + "Spirit Ryu"
        method: fusion
    }

    effect "Effect 1" {
        speed: spell_speed_2
        optional: true
        timing: when
        trigger: opponent_activates [activate_spell | activate_trap | activate_monster_effect]
        cost {
            pay_lp 1000
        }
        on_resolve {
            negate effect
        }
    }

    raw_effect "Effect 2" {
        effect_type: Field + Continuous
        code: 1020
        range: MonsterZone
        on_resolve {
            negate effect
            destroy (1+, spell, either_player controls)
        }
    }

    continuous_effect "Effect 3" {
        scope: field
        grant: cannot_activate_effects
    }

    raw_effect "Effect 4" {
        effect_type: Field
        code: 141
        on_resolve {
            destroy self
        }
    }

