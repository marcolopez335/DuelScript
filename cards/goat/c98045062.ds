// エネミーコントローラー
// Enemy Controller
// Activate 1 of these effects:
// - Target 1 face-up monster your opponent controls; change its
//   battle position.
// - Tribute 1 monster, then target 1 face-up monster your opponent
//   controls; take control of it until the End Phase.

card "Enemy Controller" {
    type: Quick-Play Spell
    id: 98045062

    effect "Change Position" {
        speed: spell_speed_2

        on_activate {
            select (1, monster, opponent controls, face_up) as target
        }

        on_resolve {
            change_position (1, monster, opponent controls)
        }
    }

    effect "Take Control" {
        speed: spell_speed_2

        cost {
            tribute (1, monster, you controls)
        }

        on_activate {
            select (1, monster, opponent controls, face_up) as target
        }

        on_resolve {
            take_control of (1, monster, opponent controls) until end_phase
        }
    }
}
