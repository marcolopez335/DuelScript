// 激流葬
// Torrential Tribute
// When a monster(s) is Summoned: Destroy all monsters on the field.

card "Torrential Tribute" {
    type: Normal Trap
    id: 53582587

    effect "Destroy All Monsters" {
        speed: spell_speed_2
        timing: when
        trigger: when_summoned

        on_resolve {
            destroy (1+, monster, either_player controls)
        }
    }
}
