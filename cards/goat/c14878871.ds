// レスキューキャット
// Rescue Cat
// Send this card to the Graveyard; Special Summon 2 Level 3 or
// lower Beast-Type monsters from your Deck. Those monsters are
// destroyed during the End Phase.

card "Rescue Cat" {
    id: 14878871
    type: Effect Monster
    attribute: EARTH
    race: Beast
    level: 4
    atk: 300
    def: 100

    effect "Summon Beasts from Deck" {
        speed: spell_speed_1
        cost {
            send self to gy
        }
        on_resolve {
            special_summon (2, monster, you controls, where { race == Beast and level <= 3 }) from deck
            delayed until end_phase {
                destroy (1+, monster, you controls, that_was_special_summoned)
            }
        }
    }
}
