// 黒き森のウィッチ
// Witch of the Black Forest
// When this card is sent from the field to the GY: Add 1 monster
// with 1500 or less DEF from your Deck to your hand.

card "Witch of the Black Forest" {
    id: 78010363
    type: Effect Monster
    attribute: DARK
    race: Spellcaster
    level: 4
    atk: 1100
    def: 1200

    effect "Search Low DEF Monster" {
        speed: spell_speed_1
        trigger: when_sent_to gy
        condition: previous_location: field
        on_resolve {
            add_to_hand (1, monster, you controls, with_def <= 1500) from deck
        }
    }
}
