// 人喰い虫
// Man-Eater Bug
// FLIP: Target 1 monster on the field; destroy that target.

card "Man-Eater Bug" {
    id: 54652250
    type: Effect Monster | Flip
    attribute: EARTH
    race: Insect
    level: 2
    atk: 450
    def: 600

    flip_effect "Destroy Monster" {
        on_activate {
            select (1, monster, either_player controls) as target
        }
        on_resolve {
            destroy (1, monster, either_player controls)
        }
    }
}
