// ラストバトル！
// Last Turn
// Activate only when your LP is 1000 or less. Each player picks
// 1 monster; destroy all others. Those monsters battle.

card "Last Turn" {
    id: 28566710
    type: Normal Trap

    effect "Last Stand" {
        speed: 2
        condition: lp <= 1000
        resolve {
            destroy (all, card, either controls)
        }
    }
}
