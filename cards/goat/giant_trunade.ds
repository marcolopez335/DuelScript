// ハリケーン
// Giant Trunade
// Return all Spell and Trap Cards on the field to the hand.

card "Giant Trunade" {
    id: 42703248
    type: Normal Spell

    effect "Bounce All" {
        speed: 1
        resolve {
            return (all, spell, either controls) to hand
            return (all, trap, either controls) to hand
        }
    }
}
