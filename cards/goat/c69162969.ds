// ライトニング・ボルテックス
// Lightning Vortex
// Discard 1 card; destroy all face-up monsters your opponent controls.

card "Lightning Vortex" {
    id: 69162969
    type: Normal Spell

    effect "Destroy Face-Up Monsters" {
        speed: spell_speed_1
        cost {
            discard (1, card, you controls)
        }
        on_resolve {
            destroy (1+, monster, opponent controls, face_up)
        }
    }
}
