// 心変わり
// Change of Heart
// Target 1 opponent monster; take control until End Phase.

card "Change of Heart" {
    type: Normal Spell
    id: 4031928

    effect "Take Control" {
        speed: spell_speed_1
        on_activate {
            select (1, monster, opponent controls) as target
        }
        on_resolve {
            take_control of (1, monster, opponent controls) until end_phase
        }
    }
}
