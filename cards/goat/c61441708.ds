// ネフティスの鳳凰神
// Sacred Phoenix of Nephthys
// If this card is destroyed by a card effect: Special Summon it during
// your next Standby Phase. When this card is Special Summoned this way:
// Destroy all Spell and Trap Cards on the field.

card "Sacred Phoenix of Nephthys" {
    id: 61441708
    type: Effect Monster
    attribute: FIRE
    race: Winged Beast
    level: 8
    atk: 2400
    def: 1600

    summon_condition {
        tributes_required: 2
    }

    effect "Revive from Destruction" {
        speed: spell_speed_1
        trigger: during_standby_phase of yours
        condition: sent_by_reason: [card_effect]
        activate_from: [gy]
        on_resolve {
            special_summon self from gy
        }
    }

    effect "Destroy All Spells and Traps" {
        speed: spell_speed_1
        trigger: when_summoned by_special_summon
        on_resolve {
            destroy (1+, spell, either_player controls)
            destroy (1+, trap, either_player controls)
        }
    }
}
