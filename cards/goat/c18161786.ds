// ダークゾーン
// Mystic Plasma Zone
// All DARK monsters gain 500 ATK and lose 400 DEF.

card "Mystic Plasma Zone" {
    id: 18161786
    type: Field Spell

    continuous_effect "DARK Power Boost" {
        scope: field
        apply_to: (1+, monster, either_player controls, where { attribute == DARK })
        modifier: atk + 500
        modifier: def - 400
    }
}
