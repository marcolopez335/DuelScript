// スケープ・ゴート
// Scapegoat
// Special Summon 4 "Sheep Tokens" (0/0, EARTH, Beast) in
// Defense Position. You cannot Summon other monsters the turn
// you activate this card.

card "Scapegoat" {
    type: Quick-Play Spell
    id: 73915051

    effect "Summon Sheep" {
        speed: spell_speed_2

        on_resolve {
            create_token {
                name: "Sheep Token"
                attribute: EARTH
                race: Beast
                atk: 0
                def: 0
                count: 4
                position: defense_position
            }
        }
    }
}
