// ガトリング・ドラゴン
// Gatling Dragon
// "Barrel Dragon" + "Blowback Dragon"
// Once per turn: You can toss a coin 3 times. Destroy monsters on
// the field up to the number of heads.

card "Gatling Dragon" {
    id: 87751584
    type: Fusion Monster
    attribute: DARK
    race: Machine
    level: 8
    atk: 2600
    def: 1200

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: "Barrel Dragon" + "Blowback Dragon"
        method: fusion
    }

    effect "Coin Flip Destruction" {
        speed: spell_speed_1
        once_per_turn: soft
        on_resolve {
            flip_coin {
                heads {
                    destroy (1+, monster, either_player controls)
                }
                tails {
                    destroy (1, monster, either_player controls)
                }
            }
        }
    }
}
