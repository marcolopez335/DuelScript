// 執念深き老魔術師
// Old Vindictive Magician
// FLIP: Target 1 monster your opponent controls; destroy that target.

card "Old Vindictive Magician" {
    id: 45141844
    type: Effect Monster | Flip
    attribute: DARK
    race: Spellcaster
    level: 2
    atk: 450
    def: 600

    flip_effect "Destroy Opponent Monster" {
        on_activate {
            select (1, monster, opponent controls) as target
        }
        on_resolve {
            destroy (1, monster, opponent controls)
        }
    }
}
