// 貪欲な壺
// Pot of Avarice
// Target 5 monsters in your GY; shuffle all 5 into the Deck,
// then draw 2 cards.

card "Pot of Avarice" {
    id: 67169062
    type: Normal Spell

    effect "Recycle and Draw" {
        speed: spell_speed_1
        on_activate {
            select (1+, monster, you controls) as target
        }
        on_resolve {
            return (1+, monster, you controls) to deck shuffle
            then {
                draw 2
            }
        }
    }
}
