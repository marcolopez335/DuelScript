// 増援
// Reinforcement of the Army
// Normal Spell
// Add 1 Level 4 or lower Warrior-Type monster from your Deck to your hand.

card "Reinforcement of the Army" {
    id: 32807846
    type: Normal Spell

    effect "Search Warrior" {
        speed: spell_speed_1

        on_resolve {
            add_to_hand (1, monster, you controls, where { level <= 4 and race == Warrior }) from deck
        }
    }
}
