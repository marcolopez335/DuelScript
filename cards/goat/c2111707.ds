// XY－ドラゴン・キャノン
// XY-Dragon Cannon
// "X-Head Cannon" + "Y-Dragon Head"
// Discard 1 card; destroy 1 face-up Spell or Trap Card on the field.

card "XY-Dragon Cannon" {
    id: 2111707
    type: Fusion Monster
    attribute: LIGHT
    race: Machine
    level: 6
    atk: 2200
    def: 1900

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: "X-Head Cannon" + "Y-Dragon Head"
        method: fusion
    }

    effect "Destroy Spell or Trap" {
        speed: spell_speed_1
        cost {
            discard (1, card, you controls)
        }
        on_activate {
            select (1, spell, either_player controls, face_up) as target
        }
        on_resolve {
            destroy (1, spell, either_player controls)
        }
    }
}
