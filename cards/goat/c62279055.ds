// 魔法の筒
// Magic Cylinder
// When an opponent's monster declares an attack: Target the attacking
// monster; negate the attack, and if you do, inflict damage to your
// opponent equal to its ATK.

card "Magic Cylinder" {
    id: 62279055
    type: Normal Trap

    effect "Negate and Burn" {
        speed: spell_speed_2
        trigger: when attack_declared
        on_activate {
            select (1, monster, opponent controls) as target
        }
        on_resolve {
            negate attack
            and_if_you_do {
                deal_damage to opponent: target.atk
            }
        }
    }
}
