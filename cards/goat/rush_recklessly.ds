// 突進
// Rush Recklessly
// Target 1 face-up monster; it gains 700 ATK until end of turn.

card "Rush Recklessly" {
    id: 70046172
    type: Quick-Play Spell

    effect "ATK Boost" {
        speed: 2
        target (1, monster, either controls, face_up)
        resolve {
            modify_atk target + 700 until end_of_turn
        }
    }
}
