// 墓守の番兵
// Gravekeeper's Guard
// DARK Spellcaster / Level 4 / ATK 1000 / DEF 1900
// FLIP: Target 1 monster your opponent controls; return it to the hand.

card "Gravekeeper's Guard" {
    id: 37101832
    type: Effect Monster | Flip
    attribute: DARK
    race: Spellcaster
    level: 4
    atk: 1000
    def: 1900

    archetype: ["Gravekeeper's"]

    flip_effect "Bounce Opponent Monster" {
        on_resolve {
            return (1, monster, opponent controls) to hand
        }
    }
}
