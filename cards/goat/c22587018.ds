// ハイドロゲドン
// Hydrogeddon
// WATER Dinosaur / Level 4 / ATK 1600 / DEF 1000
// When this card destroys an opponent's monster by battle and sends it to the
// GY: You can Special Summon 1 "Hydrogeddon" from your Deck.

card "Hydrogeddon" {
    id: 22587018
    type: Effect Monster
    attribute: WATER
    race: Dinosaur
    level: 4
    atk: 1600
    def: 1000

    effect "Summon Copy on Battle Destroy" {
        speed: spell_speed_1
        optional: true
        timing: when
        trigger: when_destroys_by_battle

        on_resolve {
            special_summon (1, monster, you controls, where { name == "Hydrogeddon" }) from deck in attack_position
        }
    }
}
