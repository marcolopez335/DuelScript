// レベル制限B地区
// Level Limit - Area B
// Continuous Spell
// All face-up Level 4 or higher monsters are changed to Defense Position.

card "Level Limit - Area B" {
    id: 3136426
    type: Continuous Spell

    continuous_effect "Force High-Level to Defense" {
        scope: field
        apply_to: (1+, monster, either_player controls, where { is_face_up and level >= 4 })
        grant: cannot_change_battle_position
    }

    effect "Switch to Defense" {
        speed: spell_speed_1
        trigger: when_summoned

        on_resolve {
            change_position (1+, monster, either_player controls, where { is_face_up and level >= 4 }) to defense_position
        }
    }
}
