// 魂を喰らう者 バズー
// Bazoo the Soul-Eater
// Once per turn: banish up to 3 monsters from GY; gain 300 ATK each until end of opponent turn.

card "Bazoo the Soul-Eater" {
    type: Effect Monster
    id: 40133511
    attribute: DARK
    race: Beast
    level: 4
    atk: 1600
    def: 900

    effect "ATK Boost" {
        speed: spell_speed_1
        once_per_turn: soft
        on_resolve {
            banish (1+, monster, you controls, gy)
            modifier: atk + 300 on self until_end_of_turn
        }
    }
}
