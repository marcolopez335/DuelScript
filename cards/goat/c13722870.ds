// 黒炎の騎士－ブラック・フレア・ナイト－
// Dark Flare Knight
// "Dark Magician" + "Flame Swordsman"
// The controller of this card takes no Battle Damage from any
// battle involving this card. When this card is destroyed by
// battle: Special Summon 1 "Mirage Knight" from your hand or Deck.

card "Dark Flare Knight" {
    id: 13722870
    type: Fusion Monster
    attribute: DARK
    race: Warrior
    level: 6
    atk: 2200
    def: 800

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: "Dark Magician" + "Flame Swordsman"
        method: fusion
    }

    // Note: "no battle damage from battles involving this card" is
    // a damage-zeroing continuous effect; engine handles via SetDamage(0).
    continuous_effect "No Battle Damage" {
        scope: self
        grant: cannot_be_destroyed_by_battle
    }

    effect "Summon Mirage Knight" {
        speed: spell_speed_1
        trigger: when_destroyed by battle
        on_resolve {
            special_summon (1, "Mirage Knight") from deck
        }
    }
}
