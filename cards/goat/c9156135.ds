// 見習い魔術師
// Apprentice Magician
// When this card is destroyed by battle and sent to the GY:
// You can Set 1 Level 2 or lower Spellcaster-Type monster from
// your Deck face-down.

card "Apprentice Magician" {
    id: 9156135
    type: Effect Monster
    attribute: DARK
    race: Spellcaster
    level: 2
    atk: 400
    def: 800

    effect "Set Spellcaster from Deck" {
        speed: spell_speed_1
        optional: true
        timing: when
        trigger: when_destroyed by battle

        on_resolve {
            search (1, monster, you controls, where { level <= 2 and race == Spellcaster }) from deck
            set (1, monster, you controls)
        }
    }
}
