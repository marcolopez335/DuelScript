// 聖なるバリア－ミラーフォース－
// Mirror Force
// When an opponent's monster declares an attack: Destroy all your
// opponent's Attack Position monsters.

card "Mirror Force" {
    id: 44095762
    type: Normal Trap

    effect "Destroy Attacking Monsters" {
        speed: spell_speed_2
        trigger: when attack_declared
        on_resolve {
            destroy (1+, monster, opponent controls, in_attack_position)
        }
    }
}
