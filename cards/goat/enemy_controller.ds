// エネミーコントローラー
// Enemy Controller
// Choose: Change 1 opponent's monster to Defense Position, OR
// Tribute 1 monster; take control of 1 opponent's monster.

card "Enemy Controller" {
    id: 98045062
    type: Quick-Play Spell

    effect "Switch Position" {
        speed: 2
        target (1, monster, opponent controls)
        resolve {
            change_position target to defense_position
        }
    }
}
