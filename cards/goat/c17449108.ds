// 撲滅の使徒
// Nobleman of Extermination
// Target 1 face-down Spell/Trap Card on the field; destroy that
// target, and if it is a Trap Card, banish it, then both players
// check their Decks and banish all copies of it.

card "Nobleman of Extermination" {
    id: 17449108
    type: Normal Spell

    effect "Destroy Face-Down Spell/Trap" {
        speed: spell_speed_1
        on_activate {
            select (1, card, either_player controls, face_down, where { is_spell or is_trap }) as target
        }
        on_resolve {
            destroy (1, card, either_player controls)
            if (sent_by_reason: [card_effect]) {
                banish (1+, trap, either_player controls) from deck
            }
        }
    }
}
