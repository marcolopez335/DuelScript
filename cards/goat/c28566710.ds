// ラストバトル！
// Last Turn
// Activate when LP <= 1000. Select 1 monster each; destroy all
// other cards. Those monsters battle. Winner wins the duel.

card "Last Turn" {
    type: Normal Trap
    id: 28566710

    effect "Last Stand" {
        speed: spell_speed_2
        condition: your_lp <= 1000
        on_resolve {
            destroy (1+, card, either_player controls)
        }
    }
}
