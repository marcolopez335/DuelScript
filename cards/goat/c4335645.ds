// ニュードリュア
// Newdoria
// Destroyed by battle: target 1 monster on field; destroy it.

card "Newdoria" {
    type: Effect Monster
    id: 4335645
    attribute: DARK
    race: Fiend
    level: 4
    atk: 1200
    def: 800

    effect "Destroy on Death" {
        speed: spell_speed_1
        trigger: when_destroyed by battle
        on_activate {
            select (1, monster, either_player controls) as target
        }
        on_resolve {
            destroy (1, monster, either_player controls)
        }
    }
}
