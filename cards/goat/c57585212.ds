// 自爆スイッチ
// Self-Destruct Button
// You can only activate this card when the difference between both
// players' Life Points is 7000 or more. Both players' Life Points
// become 0.

card "Self-Destruct Button" {
    id: 57585212
    type: Normal Trap

    effect "Mutual Destruction" {
        speed: spell_speed_2
        on_resolve {
            deal_damage to both_players: your_lp
        }
    }
}
