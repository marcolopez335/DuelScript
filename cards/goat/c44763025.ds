// いたずら好きな双子悪魔
// Delinquent Duo
// Pay 1000 LP; discard 1 random card from your opponent's hand,
// then they choose and discard 1 more card.

card "Delinquent Duo" {
    type: Normal Spell
    id: 44763025

    effect "Hand Rip" {
        speed: spell_speed_1

        cost {
            pay_lp 1000
        }

        on_resolve {
            discard (1, card, opponent controls) random
            then {
                discard (1, card, opponent controls)
            }
        }
    }
}
