// 混沌の黒魔術師
// Dark Magician of Chaos
// When this card is Normal or Special Summoned: You can add 1 Spell
// from your GY to your hand. A monster destroyed by battle with this
// card is banished instead of going to the GY. When this card is
// removed from the field, banish it.

card "Dark Magician of Chaos" {
    id: 40737112
    type: Effect Monster
    attribute: DARK
    race: Spellcaster
    level: 8
    atk: 2800
    def: 2600

    summon_condition {
        tributes_required: 2
    }

    effect "Recover Spell" {
        speed: spell_speed_1
        optional: true
        trigger: when_summoned
        on_resolve {
            add_to_hand (1, spell, you controls) from gy
        }
    }

    effect "Banish Destroyed Monster" {
        speed: spell_speed_1
        trigger: when_destroys_by_battle
        on_resolve {
            banish (1, monster, opponent controls)
        }
    }

    effect "Banish Self When Removed" {
        speed: spell_speed_1
        trigger: when_leaves_field
        on_resolve {
            banish self
        }
    }
}
