// 攻撃の無力化
// Negate Attack
// When an opponent's monster declares an attack: Target the
// attacking monster; negate the attack, then end the Battle Phase.

card "Negate Attack" {
    id: 14315573
    type: Counter Trap

    effect "Negate and End Battle" {
        speed: spell_speed_3
        trigger: when attack_declared
        on_resolve {
            negate attack
        }
    }
}
