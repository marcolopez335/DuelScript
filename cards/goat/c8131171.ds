// キラー・スネーク
// Sinister Serpent
// During your Standby Phase, if this card is in your GY: You can
// add this card to your hand.

card "Sinister Serpent" {
    id: 8131171
    type: Effect Monster
    attribute: WATER
    race: Reptile
    level: 1
    atk: 300
    def: 250

    effect "Recover from GY" {
        speed: spell_speed_1
        optional: true
        trigger: during_standby_phase of yours
        activate_from: [gy]
        on_resolve {
            add_to_hand self from gy
        }
    }
}
