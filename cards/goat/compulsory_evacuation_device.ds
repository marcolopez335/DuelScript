// 強制脱出装置
// Compulsory Evacuation Device
// Target 1 monster on the field; return that target to the hand.

card "Compulsory Evacuation Device" {
    id: 94192409
    type: Normal Trap

    effect "Bounce Monster" {
        speed: 2
        target (1, monster, either controls)
        resolve {
            return target to hand
        }
    }
}
