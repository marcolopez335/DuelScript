// 和睦の使者
// Waboku
// You take no battle damage this turn. Your monsters cannot be
// destroyed by battle this turn.

card "Waboku" {
    type: Normal Trap
    id: 12607053

    effect "Battle Protection" {
        speed: spell_speed_2

        on_resolve {
            register_effect on (1+, monster, you controls) {
                grant: cannot_be_destroyed_by_battle
                duration: until_end_of_turn
            }
        }
    }
}
