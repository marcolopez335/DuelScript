// ゾンビ・マスター
// Zombie Master
// Once per turn: You can send 1 monster from your hand to the GY,
// then target 1 Level 4 or lower Zombie-Type monster in either
// player's GY; Special Summon that target.

card "Zombie Master" {
    id: 17259470
    type: Effect Monster
    attribute: DARK
    race: Zombie
    level: 4
    atk: 1800
    def: 0

    effect "Revive Zombie" {
        speed: spell_speed_1
        once_per_turn: soft
        cost {
            send (1, monster, you controls, hand) to gy
        }
        on_activate {
            select (1, monster, either_player controls, gy, where { race == Zombie and level <= 4 }) as target
        }
        on_resolve {
            special_summon (1, monster, either_player controls, gy) from gy
        }
    }
}
