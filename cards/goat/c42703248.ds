// ハリケーン
// Giant Trunade
// Return all Spells and Traps on field to hand.

card "Giant Trunade" {
    type: Normal Spell
    id: 42703248

    effect "Bounce All S/T" {
        speed: spell_speed_1
        on_resolve {
            return (1+, spell, either_player controls) to hand
        }
    }
}
