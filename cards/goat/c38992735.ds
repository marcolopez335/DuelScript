// 波動キャノン
// Wave-Motion Cannon
// Send this card to GY; deal 1000 damage per Standby Phase that
// passed since activation.

card "Wave-Motion Cannon" {
    type: Continuous Spell
    id: 38992735

    effect "Fire" {
        speed: spell_speed_1
        cost {
            send self to gy
        }
        on_resolve {
            deal_damage to opponent: 1000
        }
    }
}
