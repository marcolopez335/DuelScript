// マジック・ドレイン
// Magic Drain
// When a Spell Card is activated: Opponent can discard 1 Spell to
// negate this. Otherwise, negate and destroy the Spell.

card "Magic Drain" {
    id: 59344077
    type: Counter Trap

    effect "Negate Spell" {
        speed: 3
        trigger: opponent_activates [activate_spell]
        resolve {
            negate and destroy
        }
    }
}
