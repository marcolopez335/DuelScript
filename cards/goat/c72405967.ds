// 王家の生け贄
// Royal Tribute
// You can only activate this card when "Necrovalley" is on your side
// of the field. Both players discard all Monster Cards from their hand.

card "Royal Tribute" {
    id: 72405967
    type: Normal Spell

    effect "Discard All Monsters" {
        speed: spell_speed_1
        condition: on_field
        on_resolve {
            discard (1+, monster, you controls)
            discard (1+, monster, opponent controls)
        }
    }
}
