// サイバーポッド
// Cyber Jar
// FLIP: Destroy all monsters on the field, then both players reveal
// the top 5 cards of their Decks. Special Summon any Level 4 or
// lower monsters among them in face-up Attack or face-down Defense
// Position, and add the rest to their hands.

card "Cyber Jar" {
    id: 34124316
    type: Effect Monster | Flip
    attribute: DARK
    race: Rock
    level: 3
    atk: 900
    def: 900

    flip_effect "Mass Destroy and Reveal" {
        on_resolve {
            destroy (1+, monster, either_player controls)
            excavate 5 from your_deck
            excavate 5 from opponent_deck
            special_summon (1+, monster, you controls, where { level <= 4 }) from deck
            special_summon (1+, monster, opponent controls, where { level <= 4 }) from deck
            add_to_hand (1+, card, you controls) from deck
            add_to_hand (1+, card, opponent controls) from deck
        }
    }
}
