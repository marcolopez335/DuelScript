// 魔導雑貨商人
// Magical Merchant
// FLIP: Excavate cards from top of Deck until you find a
// Spell/Trap; add it to hand, send rest to GY.

card "Magical Merchant" {
    type: Effect Monster | Flip
    id: 32362575
    attribute: LIGHT
    race: Insect
    level: 1
    atk: 200
    def: 700

    flip_effect "Dig for Spell" {
        on_resolve {
            excavate 5 from your_deck
            add_to_hand (1, spell, you controls) from deck
        }
    }
}
