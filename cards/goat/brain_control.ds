// 洗脳－ブレインコントロール
// Brain Control
// Pay 800 LP; take control of 1 opponent's monster until End Phase.

card "Brain Control" {
    id: 87910978
    type: Normal Spell

    effect "Take Control" {
        speed: 1
        cost {
            pay_lp 800
        }
        target (1, monster, opponent controls, face_up)
        resolve {
            take_control target until end_phase
        }
    }
}
