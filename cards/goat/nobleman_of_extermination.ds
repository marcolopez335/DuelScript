// 撲滅の使徒
// Nobleman of Extermination
// Target 1 face-down Spell/Trap Card on the field; destroy that target.

card "Nobleman of Extermination" {
    id: 17449108
    type: Normal Spell

    effect "Destroy Face-Down" {
        speed: 1
        target (1, card, either controls, face_down)
        resolve {
            destroy target
        }
    }
}
