// 魔人 ダーク・バルター
// Dark Balter the Terrible
// "Possessed Dark Soul" + "Frontier Wiseman"
// When a Normal Spell Card is activated: You can pay 1000 LP; negate
// the activation, and if you do, destroy it. Negate the effects of
// an Effect Monster destroyed by battle with this card.

card "Dark Balter the Terrible" {
    id: 80071763
    type: Fusion Monster
    attribute: DARK
    race: Fiend
    level: 5
    atk: 2000
    def: 1200

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: "Possessed Dark Soul" + "Frontier Wiseman"
        method: fusion
    }

    effect "Negate Normal Spell" {
        speed: spell_speed_2
        trigger: opponent_activates [activate_spell]
        cost {
            pay_lp 1000
        }
        on_resolve {
            negate activation and destroy
        }
    }

    effect "Negate Destroyed Monster Effects" {
        speed: spell_speed_1
        trigger: when_destroys_by_battle
        on_resolve {
            negate effect
        }
    }
}
