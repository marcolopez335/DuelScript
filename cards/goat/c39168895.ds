// 氷帝メビウス
// Mobius the Frost Monarch
// WATER Aqua / Level 6 / ATK 2400 / DEF 1000
// When this card is Tribute Summoned: You can target up to 2 Spell/Trap
// Cards on the field; destroy those targets.

card "Mobius the Frost Monarch" {
    id: 39168895
    type: Effect Monster
    attribute: WATER
    race: Aqua
    level: 6
    atk: 2400
    def: 1000

    summon_condition {
        tributes_required: 1
    }

    effect "Destroy Spells and Traps" {
        speed: spell_speed_1
        optional: true
        trigger: when_tribute_summoned

        on_activate {
            select (1+, spell, either_player controls, where { is_spell or is_trap }) as target
        }

        on_resolve {
            destroy (1+, spell, either_player controls)
        }
    }
}
