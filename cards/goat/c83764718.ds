// Monster Reborn
// Normal Spell — Target 1 monster in either GY; Special Summon it.

card "Monster Reborn" {
    type: Normal Spell
    password: 83764718

    effect "Revive" {
        speed: spell_speed_1

        on_activate {
            // Target 1 monster in either player's GY
            search (1, monster, either_player controls, gy) from gy
        }

        on_resolve {
            special_summon (1, monster, either_player controls, gy) from gy in attack_position
        }
    }
}
