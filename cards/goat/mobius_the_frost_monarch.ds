// 氷帝メビウス
// Mobius the Frost Monarch
// When this card is Tribute Summoned: Target up to 2 Spell/Trap
// Cards on the field; destroy those targets.
card "Mobius the Frost Monarch" {
    id: 4929256
    type: Effect Monster
    attribute: WATER
    race: Aqua
    level: 6
    atk: 2400
    def: 1000

    summon {
        tributes: 1
    }

    effect "Destroy Spells and Traps" {
        speed: 1
        timing: when
        trigger: tribute_summoned

        target (all, spell, either controls, where is_spell or is_trap)

        resolve {
            destroy (all, spell, either controls)
        }
    }
}
