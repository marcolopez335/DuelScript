// サイクロン
// Mystical Space Typhoon
// Target 1 Spell/Trap on the field; destroy that target.

card "Mystical Space Typhoon" {
    id: 5318639
    type: Quick-Play Spell

    effect "Destroy Spell/Trap" {
        speed: 2
        target (1, card, either controls)
        resolve {
            destroy target
        }
    }
}
