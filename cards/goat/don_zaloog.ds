// 首領・ザルーグ
// Don Zaloog
// When this card inflicts battle damage: Choose 1 — opponent
// discards 1 card, or send top 2 cards of opponent's Deck to GY.

card "Don Zaloog" {
    id: 76922029
    type: Effect Monster
    attribute: DARK
    race: Warrior
    level: 4
    atk: 1400
    def: 1500

    effect "Hand Rip" {
        speed: 1
        trigger: battle_damage to opponent
        resolve {
            discard (1, card, opponent controls)
        }
    }
}
