// マハー・ヴァイロ
// Maha Vailo
// This card gains 500 ATK for each Equip Card equipped to it.

card "Maha Vailo" {
    id: 93013676
    type: Effect Monster
    attribute: LIGHT
    race: Spellcaster
    level: 4
    atk: 1550
    def: 1400

    continuous_effect "Equip ATK Boost" {
        scope: self
        modifier: atk + 500
    }
}
