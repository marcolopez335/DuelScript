// 異次元の女戦士
// D.D. Warrior Lady
// After damage calculation, when this card battles an opponent's
// monster: You can banish that monster, and also banish this card.

card "D.D. Warrior Lady" {
    id: 7572887
    type: Effect Monster
    attribute: LIGHT
    race: Warrior
    level: 4
    atk: 1500
    def: 1600

    effect "Mutual Banish" {
        speed: spell_speed_1
        optional: true
        trigger: when_battle_damage
        on_resolve {
            banish self
            banish (1, monster, opponent controls)
        }
    }
}
