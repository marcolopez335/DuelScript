// 強奪
// Snatch Steal
// Equip to opponent's monster. Take control of it.
// Opponent gains 1000 LP each Standby Phase.

card "Snatch Steal" {
    id: 45986603
    type: Equip Spell

    effect "Take Control" {
        speed: 1
        target (1, monster, opponent controls)
        resolve {
            take_control target
        }
    }
}
