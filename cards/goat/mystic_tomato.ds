// キラー・トマト
// Mystic Tomato
// When destroyed by battle: Special Summon 1 DARK monster with
// 1500 or less ATK from your Deck in Attack Position.

card "Mystic Tomato" {
    id: 83011277
    type: Effect Monster
    attribute: DARK
    race: Plant
    level: 4
    atk: 1400
    def: 1100

    effect "Recruit DARK" {
        speed: 1
        timing: when
        trigger: destroyed_by_battle
        resolve {
            special_summon (1, monster, where attribute == DARK and atk <= 1500) from deck in attack_position
        }
    }
}
