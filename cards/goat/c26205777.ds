// 炎帝テスタロス
// Thestalos the Firestorm Monarch
// When Tribute Summoned: discard 1 random card from opponent's
// hand. If it was a Monster, deal damage equal to its Level x 100.

card "Thestalos the Firestorm Monarch" {
    type: Effect Monster
    id: 26205777
    attribute: FIRE
    race: Pyro
    level: 6
    atk: 2400
    def: 1000

    summon_condition {
        tributes_required: 1
    }

    effect "Discard and Burn" {
        speed: spell_speed_1
        trigger: when_tribute_summoned
        on_resolve {
            discard (1, card, opponent controls) random
        }
    }
}
