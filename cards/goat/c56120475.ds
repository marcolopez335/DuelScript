// 炸裂装甲
// Sakuretsu Armor
// When an opponent's monster declares an attack: Target the attacking
// monster; destroy that target.

card "Sakuretsu Armor" {
    id: 56120475
    type: Normal Trap

    effect "Destroy Attacker" {
        speed: spell_speed_2
        trigger: when attack_declared
        on_activate {
            select (1, monster, opponent controls) as target
        }
        on_resolve {
            destroy (1, monster, opponent controls)
        }
    }
}
