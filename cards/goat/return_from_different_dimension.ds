// 異次元からの帰還
// Return from the Different Dimension
// Pay half your LP; Special Summon as many of your banished
// monsters as possible. Banish them during the End Phase.

card "Return from the Different Dimension" {
    id: 27174286
    type: Normal Trap

    effect "Mass Return" {
        speed: 2
        cost {
            pay_lp half
        }
        resolve {
            special_summon (all, monster, you control) from banished
        }
    }
}
