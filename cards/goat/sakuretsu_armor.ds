// 炸裂装甲
// Sakuretsu Armor
// When an opponent's monster declares an attack: Target the attacking
// monster; destroy that target.

card "Sakuretsu Armor" {
    id: 56120475
    type: Normal Trap

    effect "Destroy Attacker" {
        speed: 2
        trigger: opponent_attack_declared
        target (1, monster, opponent controls)
        resolve {
            destroy target
        }
    }
}
