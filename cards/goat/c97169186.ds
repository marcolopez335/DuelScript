// 地砕き
// Smashing Ground
// Destroy the 1 face-up monster your opponent controls that has
// the highest DEF (your choice, if tied).

card "Smashing Ground" {
    type: Normal Spell
    id: 97169186

    effect "Destroy Highest DEF" {
        speed: spell_speed_1

        on_resolve {
            destroy (1, monster, opponent controls, face_up)
        }
    }
}
