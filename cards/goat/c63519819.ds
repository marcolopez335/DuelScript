// サウザンド・アイズ・サクリファイス
// Thousand-Eyes Restrict
// "Relinquished" + "Thousand-Eyes Idol"
// Other monsters cannot change positions or attack. Once per turn:
// equip 1 opponent's monster. ATK/DEF become the equipped monster's.
// If destroyed by battle, destroy equipped monster instead.

card "Thousand-Eyes Restrict" {
    type: Fusion Monster | Effect Monster
    id: 63519819
    attribute: DARK
    race: Spellcaster
    level: 1
    atk: 0
    def: 0

    summon_condition {
        cannot_normal_summon: true
    }

    materials {
        require: "Relinquished" + "Thousand-Eyes Idol"
        method: fusion
    }

    continuous_effect "Lock Field" {
        scope: field
        apply_to: (1+, monster, either_player controls, other_than_self)
        grant: cannot_attack
        grant: cannot_change_battle_position
    }

    effect "Absorb Monster" {
        speed: spell_speed_1
        once_per_turn: soft

        on_activate {
            select (1, monster, opponent controls) as target
        }

        on_resolve {
            equip (1, monster, opponent controls) to self
        }
    }

    replacement_effect "Shield" {
        instead_of: destroyed_by_battle
        do: {
            destroy (1, monster, you controls)
        }
    }
}
