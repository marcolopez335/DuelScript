// メタモルポット
// Morphing Jar
// FLIP: Both players discard their entire hands, then draw 5 cards.

card "Morphing Jar" {
    type: Effect Monster | Flip
    id: 33508719
    attribute: EARTH
    race: Rock
    level: 2
    atk: 700
    def: 600

    flip_effect "Refresh Hands" {
        on_resolve {
            discard_all your_hand
            discard_all opponent_hand
            draw 5
        }
    }
}
