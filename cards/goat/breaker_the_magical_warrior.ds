// 魔導戦士 ブレイカー
// Breaker the Magical Warrior
// Gains 300 ATK from Spell Counter. Remove counter to destroy 1
// Spell/Trap.

card "Breaker the Magical Warrior" {
    id: 71413901
    type: Effect Monster
    attribute: DARK
    race: Spellcaster
    level: 4
    atk: 1600
    def: 1000

    effect "Destroy Spell/Trap" {
        speed: 1
        target (1, card, either controls)
        resolve {
            destroy target
        }
    }
}
