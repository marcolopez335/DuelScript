// 月の書
// Book of Moon
// Target 1 face-up monster on the field; change that target to
// face-down Defense Position.

card "Book of Moon" {
    type: Quick-Play Spell
    id: 14087893

    effect "Set Face-Down" {
        speed: spell_speed_2

        on_activate {
            select (1, monster, either_player controls, face_up) as target
        }

        on_resolve {
            flip_face_down (1, monster, either_player controls)
        }
    }
}
