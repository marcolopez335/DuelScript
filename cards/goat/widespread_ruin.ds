// 万能地雷グレイモヤ
// Widespread Ruin
// When opponent's monster attacks: Destroy the opponent's monster
// with the highest ATK.

card "Widespread Ruin" {
    id: 77754944
    type: Normal Trap

    effect "Destroy Strongest" {
        speed: 2
        trigger: opponent_attack_declared
        resolve {
            destroy (1, monster, opponent controls)
        }
    }
}
