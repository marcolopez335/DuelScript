// 降霊の儀式
// Rite of Spirit
// Target 1 "Gravekeeper's" monster in GY; Special Summon it.
// Unaffected by Necrovalley.

card "Rite of Spirit" {
    type: Normal Trap
    id: 30450531

    effect "Revive Gravekeeper" {
        speed: spell_speed_2
        on_resolve {
            special_summon (1, "Gravekeeper" monster) from gy
        }
    }
}
