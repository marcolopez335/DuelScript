// 盗賊の七つ道具
// Seven Tools of the Bandit
// When a Trap is activated: Pay 1000 LP; negate and destroy.

card "Seven Tools of the Bandit" {
    type: Counter Trap
    id: 3819470

    effect "Negate Trap" {
        speed: spell_speed_3
        trigger: opponent_activates [activate_trap]
        cost {
            pay_lp 1000
        }
        on_resolve {
            negate activation and destroy
        }
    }
}
