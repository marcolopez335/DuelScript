// 万能地雷グレイモヤ
// Widespread Ruin
// When an opponent's monster declares an attack: Destroy the 1
// Attack Position monster your opponent controls that has the highest
// ATK (your choice, if tied).

card "Widespread Ruin" {
    id: 77754944
    type: Normal Trap

    effect "Destroy Strongest Attacker" {
        speed: spell_speed_2
        trigger: when attack_declared
        on_resolve {
            destroy (1, monster, opponent controls, in_attack_position)
        }
    }
}
