// 突進
// Rush Recklessly
// Target 1 face-up monster on the field; it gains 700 ATK until the
// end of this turn.

card "Rush Recklessly" {
    id: 70046172
    type: Quick-Play Spell

    effect "ATK Boost" {
        speed: spell_speed_2
        on_activate {
            select (1, monster, either_player controls, face_up) as target
        }
        on_resolve {
            modifier: atk + 700 on (1, monster, either_player controls) until_end_of_turn
        }
    }
}
