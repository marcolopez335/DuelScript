// グラヴィティ・バインド－超重力の網－
// Gravity Bind
// Level 4 or higher monsters cannot attack.

card "Gravity Bind" {
    id: 85742772
    type: Continuous Trap

    passive "Attack Lock" {
        scope: field
        target: (all, monster, either controls, where level >= 4)
        grant: cannot_attack
    }
}
