// グリズリーマザー
// Mother Grizzly
// When this card is destroyed by battle and sent to the GY: You can
// Special Summon 1 WATER monster with 1500 or less ATK from your Deck
// in Attack Position.

card "Mother Grizzly" {
    id: 57839750
    type: Effect Monster
    attribute: WATER
    race: Beast-Warrior
    level: 4
    atk: 1400
    def: 1000

    effect "Recruit WATER Monster" {
        speed: spell_speed_1
        optional: true
        trigger: when_destroyed by battle
        on_resolve {
            special_summon (1, monster, you controls, with_atk <= 1500) from deck in attack_position
        }
    }
}
