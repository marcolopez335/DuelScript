// 巨大ネズミ
// Giant Rat
// When this card is destroyed by battle and sent to the GY: You can
// Special Summon 1 EARTH monster with 1500 or less ATK from your Deck
// in Attack Position.

card "Giant Rat" {
    id: 97017120
    type: Effect Monster
    attribute: EARTH
    race: Beast
    level: 4
    atk: 1400
    def: 1450

    effect "Recruit EARTH Monster" {
        speed: spell_speed_1
        optional: true
        trigger: when_destroyed by battle
        on_resolve {
            special_summon (1, monster, you controls, with_atk <= 1500) from deck in attack_position
        }
    }
}
