// 魔導戦士 ブレイカー
// Breaker the Magical Warrior
// When this card is Normal Summoned: Place 1 Spell Counter on it
// (max. 1). This card gains 300 ATK for each Spell Counter on it.
// You can remove 1 Spell Counter from this card, then target 1
// Spell/Trap on the field; destroy that target.

card "Breaker the Magical Warrior" {
    id: 71413901
    type: Effect Monster
    attribute: DARK
    race: Spellcaster
    level: 4
    atk: 1600
    def: 1000

    counter_system {
        name: "Spell Counter"
        placed_when: when_summoned by_normal_summon
        max: 1

        effect "Destroy Spell or Trap" {
            speed: spell_speed_1
            cost {
                remove_counter 1 "Spell Counter" from self
            }
            on_activate {
                select (1, spell, either_player controls) as target
            }
            on_resolve {
                destroy (1, spell, either_player controls)
            }
        }
    }

    continuous_effect "ATK Boost per Counter" {
        scope: self
        modifier: atk + 300
    }
}
