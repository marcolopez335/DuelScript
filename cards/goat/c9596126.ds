// カオス・ソーサラー
// Chaos Sorcerer
// Cannot be Normal Summoned/Set. Must be Special Summoned by banishing
// 1 LIGHT and 1 DARK monster from your GY. Once per turn: You can
// target 1 face-up monster on the field; banish that target. This
// card cannot attack the turn you activate this effect.

card "Chaos Sorcerer" {
    id: 9596126
    type: Effect Monster
    attribute: DARK
    race: Spellcaster
    level: 6
    atk: 2300
    def: 2000

    summon_condition {
        cannot_normal_summon: true
        special_summon_only: true
    }

    effect "Banish Monster" {
        speed: spell_speed_1
        once_per_turn: soft
        on_activate {
            select (1, monster, either_player controls, face_up) as target
        }
        on_resolve {
            banish (1, monster, either_player controls)
        }
    }
}
