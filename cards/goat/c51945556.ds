// 雷帝ザボルグ
// Zaborg the Thunder Monarch
// When this card is Tribute Summoned: Target 1 monster on the field;
// destroy that target.

card "Zaborg the Thunder Monarch" {
    id: 51945556
    type: Effect Monster
    attribute: LIGHT
    race: Thunder
    level: 5
    atk: 2400
    def: 1000

    summon_condition {
        tributes_required: 1
    }

    effect "Destroy Monster on Tribute Summon" {
        speed: spell_speed_1
        trigger: when_tribute_summoned
        on_activate {
            select (1, monster, either_player controls) as target
        }
        on_resolve {
            destroy (1, monster, either_player controls)
        }
    }
}
