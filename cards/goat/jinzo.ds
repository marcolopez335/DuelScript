// Jinzo
// Trap Cards cannot be activated. Negate all Trap effects on the field.

card "Jinzo" {
    id: 77585513
    type: Effect Monster
    attribute: DARK
    race: Machine
    level: 6
    atk: 2400
    def: 1500

    summon {
        tributes: 1
