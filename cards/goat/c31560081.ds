// 聖なる魔術師
// Magician of Faith
// FLIP: Target 1 Spell in your GY; add that target to your hand.

card "Magician of Faith" {
    type: Effect Monster | Flip
    id: 31560081
    attribute: LIGHT
    race: Spellcaster
    level: 1
    atk: 300
    def: 400

    flip_effect "Recover Spell" {
        on_resolve {
            add_to_hand (1, spell, you controls) from gy
        }
    }
}
