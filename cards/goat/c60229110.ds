// 地帝グランマーグ
// Granmarg the Rock Monarch
// When this card is Tribute Summoned: Target 1 Set card on the field;
// destroy that target.

card "Granmarg the Rock Monarch" {
    id: 60229110
    type: Effect Monster
    attribute: EARTH
    race: Rock
    level: 6
    atk: 2400
    def: 1000

    summon_condition {
        tributes_required: 1
    }

    effect "Destroy Set Card" {
        speed: spell_speed_1
        trigger: when_tribute_summoned
        on_activate {
            select (1, card, either_player controls, face_down) as target
        }
        on_resolve {
            destroy (1, card, either_player controls)
        }
    }
}
