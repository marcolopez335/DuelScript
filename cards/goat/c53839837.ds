// ヴァンパイア・ロード
// Vampire Lord
// When this card inflicts Battle Damage to your opponent: Declare 1 card
// type (Monster, Spell, or Trap); your opponent sends 1 card of that type
// from their Deck to the GY. If this card is destroyed by a card effect
// and is in the GY during your next Standby Phase: Special Summon it.

card "Vampire Lord" {
    id: 53839837
    type: Effect Monster
    attribute: DARK
    race: Zombie
    level: 5
    atk: 2000
    def: 1500

    summon_condition {
        tributes_required: 1
    }

    effect "Force Opponent Mill" {
        speed: spell_speed_1
        trigger: when_battle_damage to opponent
        on_resolve {
            send (1, card, opponent controls, deck) to gy
        }
    }

    effect "Revive from GY" {
        speed: spell_speed_1
        trigger: during_standby_phase of yours
        condition: previous_location: gy
        activate_from: [gy]
        on_resolve {
            special_summon self from gy
        }
    }
}
