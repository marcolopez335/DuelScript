// 王宮のお触れ
// Royal Decree
// Negate all other Trap effects on the field.

card "Royal Decree" {
    type: Continuous Trap
    id: 51452091

    continuous_effect "Negate All Traps" {
        scope: field
        apply_to: (1+, trap, either_player controls, other_than_self)
        grant: cannot_activate_effects
    }
}
