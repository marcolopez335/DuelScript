// 押収
// Confiscation
// Pay 1000 LP. Look at your opponent's hand, then discard 1 card
// from their hand.

card "Confiscation" {
    id: 17375316
    type: Normal Spell

    effect "View and Discard" {
        speed: spell_speed_1
        cost {
            pay_lp 1000
        }
        on_resolve {
            look_at (1+, card, opponent controls) from hand
            discard (1, card, opponent controls)
        }
    }
}
