// ペンギン・ソルジャー
// Penguin Soldier
// FLIP: You can target up to 2 monsters on the field;
// return those targets to the hand.

card "Penguin Soldier" {
    id: 93920745
    type: Effect Monster | Flip
    attribute: WATER
    race: Aqua
    level: 2
    atk: 750
    def: 500

    flip_effect "Bounce Monsters" {
        optional: true

        on_activate {
            select (1+, monster, either_player controls) as target
        }
        on_resolve {
            return (1+, monster, either_player controls) to hand
        }
    }
}
