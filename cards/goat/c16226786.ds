// 深淵の暗殺者
// Night Assailant
// FLIP: Target 1 monster your opponent controls; destroy that target.
// If this card is sent from your hand to the GY: Target 1 Flip
// monster in your GY; add that target to your hand.

card "Night Assailant" {
    type: Effect Monster | Flip
    id: 16226786
    attribute: DARK
    race: Fiend
    level: 3
    atk: 200
    def: 500

    flip_effect "Destroy Opponent Monster" {
        on_resolve {
            destroy (1, monster, opponent controls)
        }
    }

    effect "Recover Flip Monster" {
        speed: spell_speed_1
        trigger: when_sent_to gy

        on_resolve {
            add_to_hand (1, monster, you controls) from gy
        }
    }
}
