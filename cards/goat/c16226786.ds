// 深淵の暗殺者
// Night Assailant
// Transpiled from c16226786.lua

card "Night Assailant" {
    id: 16226786
    type: Effect Monster
    attribute: DARK
    race: Fiend
    level: 3
    atk: 200
    def: 500

    raw_effect "Effect 1" {
        effect_type: Single + Flip
        category: Destroy
        property: CardTarget
        on_resolve {
            destroy (1+, monster, either_player controls)
        }
    }

    effect "Effect 2" {
        speed: spell_speed_1
        damage_step: false
        trigger: on_custom_event "chain_end"
        on_activate {
            select (1+, monster, either_player controls) as target
        }
        on_resolve {
            add_to_hand (1+, monster, either_player controls) from gy
            reveal (1+, card, opponent controls)
        }
    }

}
