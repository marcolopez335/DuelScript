// 地割れ
// Fissure
// Destroy the 1 face-up monster your opponent controls that has the
// lowest ATK (your choice, if tied).

card "Fissure" {
    id: 66788016
    type: Normal Spell

    effect "Destroy Weakest Monster" {
        speed: spell_speed_1
        on_resolve {
            destroy (1, monster, opponent controls, face_up)
        }
    }
}
