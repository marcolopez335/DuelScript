// 和睦の使者
// Waboku
// You take no battle damage this turn. Your monsters cannot be
// destroyed by battle this turn.

card "Waboku" {
    id: 12607053
    type: Normal Trap

    effect "Battle Protection" {
        speed: 2
        resolve {
            grant (all, monster, you control) cannot_be_destroyed by battle until end_of_turn
        }
    }
}
