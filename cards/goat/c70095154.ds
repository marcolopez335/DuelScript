// サイバー・ドラゴン
// Cyber Dragon
// If only your opponent controls a monster, you can Special Summon
// this card (from your hand).

card "Cyber Dragon" {
    type: Effect Monster
    id: 70095154
    attribute: LIGHT
    race: Machine
    level: 5
    atk: 2100
    def: 1600

    summon_condition {
        tributes_required: 1
        special_summon_from: [hand]
    }

    effect "Self Special Summon" {
        speed: spell_speed_1
        condition: you_control_no_monsters and opponent_controls (1+, monster)

        on_resolve {
            special_summon self from hand
        }
    }
}
