// 洗脳－ブレインコントロール
// Brain Control
// Pay 800 LP, then target 1 face-up monster your opponent controls;
// take control of that target until the End Phase.

card "Brain Control" {
    type: Normal Spell
    id: 87910978

    effect "Take Control" {
        speed: spell_speed_1

        cost {
            pay_lp 800
        }

        on_activate {
            select (1, monster, opponent controls, face_up) as target
        }

        on_resolve {
            take_control of (1, monster, opponent controls) until end_phase
        }
    }
}
