// 自爆スイッチ
// Self-Destruct Button
// When your LP difference with opponent is 7000+: Both players LP
// become 0 (draw).

card "Self-Destruct Button" {
    id: 57585212
    type: Normal Trap

    effect "Mutual Destruction" {
        speed: 2
        resolve {
            damage you 8000
            damage opponent 8000
        }
    }
}
