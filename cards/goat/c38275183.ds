// 八式対魔法多重結界
// Spell Shield Type-8
// Counter Trap
// When a Spell Card that targets is activated: Negate the activation, and
// if you do, destroy it. OR: When a Spell Card is activated: You can discard
// 1 Spell; negate the activation, and if you do, destroy it.

card "Spell Shield Type-8" {
    id: 38275183
    type: Counter Trap

    effect "Negate Targeting Spell" {
        speed: spell_speed_3
        trigger: opponent_activates [activate_spell]

        on_resolve {
            negate activation and destroy
        }
    }

    effect "Negate Any Spell by Discarding" {
        speed: spell_speed_3
        trigger: opponent_activates [activate_spell]

        cost {
            discard (1, spell, you controls)
        }

        on_resolve {
            negate activation and destroy
        }
    }
}
