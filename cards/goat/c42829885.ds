// 強引な番兵
// The Forceful Sentry
// Look at opponent hand, return 1 card to Deck.

card "The Forceful Sentry" {
    type: Normal Spell
    id: 42829885

    effect "Peek and Return" {
        speed: spell_speed_1
        on_resolve {
            look_at (1+, card, opponent controls) from hand
            return (1, card, opponent controls) to deck shuffle
        }
    }
}
