// 抹殺の使徒
// Nobleman of Crossout
// Target 1 face-down monster on the field; destroy that target,
// and if it was a Flip monster, banish it, then both players
// banish all copies of that card from their Decks.

card "Nobleman of Crossout" {
    type: Normal Spell
    id: 71044499

    effect "Destroy Face-Down" {
        speed: spell_speed_1

        on_activate {
            select (1, monster, either_player controls, face_down) as target
        }

        on_resolve {
            destroy (1, monster, either_player controls)
            banish (1+, card, either_player controls, deck)
        }
    }
}
