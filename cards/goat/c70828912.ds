// 早すぎた埋葬
// Premature Burial
// Pay 800 LP, then target 1 monster in your GY; Special Summon that
// target in Attack Position and equip this card to it. When this card
// is destroyed, destroy the equipped monster.

card "Premature Burial" {
    id: 70828912
    type: Equip Spell

    effect "Revive Monster" {
        speed: spell_speed_1
        cost {
            pay_lp 800
        }
        on_activate {
            select (1, monster, you controls) as target
        }
        on_resolve {
            special_summon (1, monster, you controls) from gy in attack_position
            equip self to (1, monster, you controls)
        }
    }

    equip_effect {
        target: (1, monster, you controls)

        on_equipped_destroyed {
            destroy (1, monster, you controls)
        }
    }
}
