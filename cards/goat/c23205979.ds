// 魂を削る死霊
// Spirit Reaper
// Cannot be destroyed by battle. If this card is targeted by a
// card effect: Destroy this card. If this card attacks your
// opponent directly: Your opponent discards 1 random card.

card "Spirit Reaper" {
    id: 23205979
    type: Effect Monster
    attribute: DARK
    race: Zombie
    level: 3
    atk: 300
    def: 200

    continuous_effect "Indestructible by Battle" {
        scope: self
        grant: cannot_be_destroyed_by_battle
    }

    // Note: "when targeted by a card effect" trigger not yet in grammar;
    // engine maps this via raw_effect with EFFECT_TYPE_SINGLE + Targeted.
    raw_effect "Self-Destruct When Targeted" {
        effect_type: Single + Trigger
        code: Destroy
        on_resolve {
            destroy self
        }
    }

    effect "Hand Rip on Direct Attack" {
        speed: spell_speed_1
        trigger: when_battle_damage to opponent
        on_resolve {
            discard (1, card, opponent controls) random
        }
    }
}
