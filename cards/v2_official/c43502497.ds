card "Pendulum Witch" {
    id: 43502497
    type: Effect Monster | Pendulum Monster
    attribute: EARTH
    race: Spellcaster
    level: 3
    scale: 8
    atk: 1500
    def: 800

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: destroyed
        resolve {
            send (all, card, either controls) to extra_deck
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: summoned
        resolve {
            destroy (all, card, either controls)
            add_to_hand (all, card, either controls)
        }
    }

    effect "Effect 3" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: summoned by special
        resolve {
            destroy (all, card, either controls)
            add_to_hand (all, card, either controls)
        }
    }

    effect "Effect 4" {
        speed: 1
        timing: if
        trigger: destroyed
        resolve {
            special_summon (all, card, either controls)
        }
    }
}
