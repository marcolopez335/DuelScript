card "Hyper Psychic Riser" {
    id: 99115354
    type: Synchro Monster
    attribute: EARTH
    race: Psychic
    level: 6
    atk: 2000
    def: 600

    summon {
        cannot_normal_summon
    }

    passive "Effect 1" {
        scope: self
        grant: cannot_attack
    }

    passive "Effect 2" {
        scope: self
        grant: cannot_activate effects
    }

    effect "Effect 3" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: custom "chain_end"
        resolve {
            add_to_hand (all, card, either controls)
        }
    }
}
