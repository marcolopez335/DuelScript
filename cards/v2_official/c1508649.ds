card "Altergeist Hexstia" {
    id: 1508649
    type: Link Monster
    attribute: FIRE
    race: Spellcaster
    link: 2
    atk: 1500

    summon {
        cannot_normal_summon
    }

    effect "Effect 2" {
        speed: 2
        timing: when
        trigger: opponent_activates [activate_spell, activate_trap, activate_spell]
        cost {
            tribute self
        }
        resolve {
            negate
            destroy (all, card, either controls)
        }
    }

    effect "Effect 3" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: custom "chain_end"
        resolve {
            add_to_hand (all, card, either controls)
        }
    }
}
