card "Baromet the Sacred Sheep Shrub" {
    id: 62967433
    type: Xyz Monster
    attribute: EARTH
    race: Plant
    rank: 4
    atk: 1900
    def: 2000

    summon {
        cannot_normal_summon
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: soft
        mandatory
        cost {
            detach 1 from self
        }
        resolve {
            return (all, card, either controls) to deck
            draw 1
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: opponent_activates [activate_spell, activate_trap, activate_spell]
        resolve {
            special_summon (all, card, either controls)
        }
    }
}
