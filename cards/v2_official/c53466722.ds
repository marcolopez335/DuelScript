card "First of the Dragonlords" {
    id: 53466722
    type: Fusion Monster
    attribute: DARK
    race: Dragon
    level: 11
    atk: 3700
    def: 3000

    summon {
        cannot_normal_summon
    }

    passive "Effect 1" {
        scope: self
        grant: cannot_be_destroyed by battle
    }

    passive "Effect 2" {
        scope: self
        grant: unaffected_by effects
    }

    effect "Effect 3" {
        speed: 2
        once_per_turn: hard
        timing: when
        trigger: opponent_activates [activate_spell, activate_trap, activate_spell]
        resolve {
            destroy (all, card, either controls)
        }
    }
}
