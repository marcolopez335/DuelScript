card "Wightbaking" {
    id: 6128460
    type: Effect Monster
    attribute: DARK
    race: Zombie
    level: 1
    atk: 300
    def: 200

    effect "Effect 3" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: custom "chain_end"
        resolve {
            add_to_hand (all, card, either controls)
            discard (all, card, either controls)
        }
    }

    replacement "Effect 2" {
        instead_of: destroyed
        do {
            banish self
        }
    }
}
