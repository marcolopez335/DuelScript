card "P.U.N.K. JAM Dragon Drive" {
    id: 28403802
    type: Synchro Monster
    attribute: EARTH
    race: Psychic
    level: 8
    atk: 2700
    def: 2400

    summon {
        cannot_normal_summon
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: summoned by special
        cost {
            pay_lp 600
        }
        resolve {
            add_to_hand (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: opponent_activates [activate_spell, activate_trap, activate_spell]
        resolve {
            special_summon (all, card, either controls)
        }
    }
}
