card "Dawn Knight" {
    id: 6351548
    type: Effect Monster
    attribute: LIGHT
    race: Warrior
    level: 4
    atk: 1400
    def: 1200

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: custom "chain_end"
        resolve {
            send (all, card, either controls) to gy
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        mandatory
        trigger: custom "chain_end"
        resolve {
            return (all, card, either controls) to deck
        }
    }
}
