card "Mecha Phantom Beast Megaraptor" {
    id: 31533704
    type: Effect Monster
    attribute: WIND
    race: Machine
    level: 4
    atk: 1900
    def: 1000

    passive "Effect 2" {
        scope: self
        grant: cannot_be_destroyed by battle
    }

    passive "Effect 3" {
        scope: self
        grant: cannot_be_destroyed by effect
    }

    effect "Effect 4" {
        speed: 1
        once_per_turn: hard
        mandatory
        trigger: summoned by special
        resolve {
            create_token {
                name: "Token"
                count: 1
            }
            special_summon (all, card, either controls)
        }
    }

    effect "Effect 5" {
        speed: 1
        once_per_turn: soft
        mandatory
        cost {
            tribute self
        }
        resolve {
            return (all, card, either controls) to hand
        }
    }
}
