card "Number 90: Galaxy-Eyes Photon Lord" {
    id: 8165596
    type: Xyz Monster
    attribute: LIGHT
    race: Warrior
    rank: 8
    atk: 2500
    def: 3000

    summon {
        cannot_normal_summon
    }

    passive "Effect 1" {
        scope: self
        grant: cannot_be_destroyed by effect
    }

    effect "Effect 2" {
        speed: 2
        once_per_turn: hard
        timing: when
        trigger: opponent_activates [activate_spell, activate_trap, activate_spell]
        cost {
            detach 1 from self
        }
        resolve {
            negate
            destroy (all, card, either controls)
        }
    }

    effect "Effect 3" {
        speed: 2
        once_per_turn: soft
        resolve {
            add_to_hand (all, card, either controls)
        }
    }
}
