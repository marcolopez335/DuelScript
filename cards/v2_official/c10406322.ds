card "Alsei, the Sylvan High Protector" {
    id: 10406322
    type: Xyz Monster
    attribute: LIGHT
    race: Plant
    rank: 8
    atk: 2300
    def: 3200

    summon {
        cannot_normal_summon
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: soft
        mandatory
        resolve {
            add_to_hand (all, card, either controls)
            send (all, card, either controls) to gy
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: custom "chain_end"
        cost {
            detach 1 from self
        }
        resolve {
            return (all, card, either controls) to deck
            return (all, card, either controls) to deck
        }
    }
}
