card "Cyberse Gadget" {
    id: 645087
    type: Effect Monster
    attribute: LIGHT
    race: Cyberse
    level: 4
    atk: 1400
    def: 300

    effect "Effect 1" {
        speed: 1
        timing: when
        trigger: summoned
        resolve {
            special_summon (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: custom "chain_end"
        resolve {
            create_token {
                name: "Token"
                count: 1
            }
            special_summon (all, card, either controls)
        }
    }
}
