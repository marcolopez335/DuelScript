card "Nekroz of Trishula" {
    id: 52068432
    type: Ritual Monster
    attribute: WATER
    race: Warrior
    level: 9
    atk: 2700
    def: 2000

    summon {
        cannot_normal_summon
    }

    effect "Effect 2" {
        speed: 2
        once_per_turn: hard
        timing: when
        trigger: opponent_activates [activate_spell, activate_trap, activate_spell]
        cost {
            discard (all, card, either controls)
        }
        resolve {
            negate
            send (all, card, either controls) to gy
        }
    }

    effect "Effect 3" {
        speed: 1
        once_per_turn: soft
        timing: when
        trigger: summoned by special
        resolve {
            banish (all, card, either controls)
        }
    }
