card "Doom Kraken" {
    id: 69436288
    type: Effect Monster
    attribute: WATER
    race: Aqua
    level: 4
    atk: 1400
    def: 1600

    effect "Effect 1" {
        speed: 2
        once_per_turn: hard
        resolve {
            special_summon (all, card, either controls)
            return (all, card, either controls) to hand
            destroy (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        timing: when
        trigger: summoned
        resolve {
            return (all, card, either controls) to hand
            negate
        }
    }
}
