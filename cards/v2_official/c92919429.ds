card "Diviner of the Herald" {
    id: 92919429
    type: Effect Monster | Tuner
    attribute: LIGHT
    race: Fairy
    level: 2
    atk: 500
    def: 300

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned
        resolve {
            send (all, card, either controls) to gy
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            send (all, card, either controls) to gy
        }
    }

    effect "Effect 3" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: sent_to gy
        resolve {
            special_summon (all, card, either controls)
        }
    }
}
