card "Moremarshmallon" {
    id: 38505587
    type: Effect Monster
    attribute: LIGHT
    race: Fairy
    level: 3
    atk: 300
    def: 500

    passive "Effect 1" {
        scope: self
        grant: cannot_be_destroyed by battle
    }

    passive "Effect 2" {
        scope: self
        grant: cannot_be_targeted by effects
    }

    effect "Effect 3" {
        speed: 2
        once_per_turn: hard
        resolve {
            special_summon (all, card, either controls)
        }
    }

    effect "Effect 4" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: destroyed
        resolve {
            special_summon (all, card, either controls)
            damage opponent 1000
        }
    }
}
