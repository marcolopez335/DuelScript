card "Centur-Ion Legatia" {
    id: 15982593
    type: Synchro Monster
    attribute: LIGHT
    race: Machine
    level: 12
    atk: 3500
    def: 2000

    summon {
        cannot_normal_summon
    }

    passive "Effect 1" {
        scope: self
        grant: cannot_be_destroyed by battle
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            draw 1
            destroy (all, card, either controls)
            destroy (all, card, either controls)
        }
    }

    effect "Effect 3" {
        speed: 1
        once_per_turn: soft
        timing: when
        trigger: end_phase
        resolve {
            special_summon (all, card, either controls)
        }
    }
