card "Cyberse Integrator" {
    id: 25200959
    type: Synchro Monster
    attribute: LIGHT
    race: Cyberse
    level: 3
    atk: 1000
    def: 1000

    summon {
        cannot_normal_summon
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            special_summon (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: custom "chain_end"
        resolve {
            draw 1
        }
    }
}
