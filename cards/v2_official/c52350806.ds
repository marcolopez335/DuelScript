card "Danger! Mothman!" {
    id: 52350806
    type: Effect Monster
    attribute: DARK
    race: Insect
    level: 4
    atk: 1800
    def: 400

    effect "Effect 1" {
        speed: 1
        mandatory
        resolve {
            send (all, card, either controls) to gy
            special_summon (all, card, either controls)
            draw 1
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: custom "chain_end"
        resolve {
            draw 1
            draw 1
            discard (all, card, either controls)
            discard (all, card, either controls)
        }
    }
}
