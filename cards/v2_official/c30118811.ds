card "Backup @Ignister" {
    id: 30118811
    type: Effect Monster | Tuner
    attribute: DARK
    race: Cyberse
    level: 3
    atk: 1200
    def: 800

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        mandatory
        resolve {
            special_summon (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: summoned
        resolve {
            return (all, card, either controls) to hand
            discard (all, card, either controls)
        }
    }

    effect "Effect 3" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: summoned by special
        resolve {
            return (all, card, either controls) to hand
            discard (all, card, either controls)
        }
    }
}
