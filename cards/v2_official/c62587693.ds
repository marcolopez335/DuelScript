card "Deus X-Krawler" {
    id: 62587693
    type: Effect Monster
    attribute: EARTH
    race: Insect
    level: 9
    atk: 2000
    def: 3000

    summon {
        tributes: 2
    }

    effect "Effect 1" {
        speed: 2
        timing: when
        trigger: opponent_activates [activate_spell, activate_trap, activate_spell]
        resolve {
            negate
            destroy (all, card, either controls)
        }
    }

    effect "Effect 4" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: destroyed
        resolve {
            add_to_hand (all, card, either controls)
        }
    }
}
