card "Krishnerd Witch" {
    id: 37006702
    type: Effect Monster
    attribute: LIGHT
    race: Spellcaster
    level: 4
    atk: 1800
    def: 700

    passive "Effect 1" {
        scope: self
        grant: cannot_be_destroyed by effect
    }

    effect "Effect 3" {
        speed: 2
        once_per_turn: soft
        timing: when
        trigger: opponent_activates [activate_spell, activate_trap, activate_spell]
        resolve {
            return (all, card, either controls) to deck
            special_summon (all, card, either controls)
        }
    }
}
