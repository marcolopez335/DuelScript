card "Overtex Qoatlus" {
    id: 41782653
    type: Effect Monster | Effect Monster
    attribute: DARK
    race: Dinosaur
    level: 7
    atk: 2700
    def: 2100

    summon {
        cannot_normal_summon
    }

    effect "Effect 3" {
        speed: 2
        once_per_turn: soft
        timing: when
        trigger: opponent_activates [activate_spell, activate_trap, activate_spell]
        resolve {
            destroy (all, card, either controls)
            negate
            destroy (all, card, either controls)
        }
    }

    effect "Effect 4" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: custom "chain_end"
        resolve {
            add_to_hand (all, card, either controls)
        }
    }
}
