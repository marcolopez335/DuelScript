card "Jade Dragon Mech" {
    id: 69191257
    type: Synchro Monster
    attribute: WIND
    race: Machine
    level: 9
    atk: 2700
    def: 1800

    summon {
        cannot_normal_summon
    }

    effect "Effect 1" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            send (all, card, either controls) to gy
            special_summon (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        timing: if
        trigger: custom "chain_end"
        cost {
            banish self
        }
        resolve {
            destroy (all, card, either controls)
        }
    }
}
