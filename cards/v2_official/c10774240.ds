card "Skull Guardian, Protector of the Voiceless Voice" {
    id: 10774240
    type: Ritual Monster
    attribute: LIGHT
    race: Warrior
    level: 7
    atk: 2050
    def: 2500

    summon {
        cannot_normal_summon
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            add_to_hand (all, card, either controls)
        }
    }

    effect "Effect 3" {
        speed: 2
        once_per_turn: soft
        timing: when
        trigger: opponent_activates [activate_spell, activate_trap, activate_spell]
        resolve {
            negate
            destroy (all, card, either controls)
        }
    }
}
