    type: Xyz Monster
    attribute: LIGHT
    race: Psychic
    rank: 4
    atk: 2800
    def: 1600

    summon {
        cannot_normal_summon
    }

    effect "Effect 1" {
        speed: 2
        once_per_turn: hard
