card "Foie Glasya de Nouvelles" {
    id: 15001940
    type: Ritual Monster
    attribute: DARK
    race: Warrior
    level: 4
    atk: 1600
    def: 1850

    summon {
        cannot_normal_summon
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            return (all, card, either controls) to deck
        }
    }

    effect "Effect 3" {
        speed: 2
        once_per_turn: soft
        timing: when
        trigger: attacked
        resolve {
            special_summon (all, card, either controls)
        }
    }
}
