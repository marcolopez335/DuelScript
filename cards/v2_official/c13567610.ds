card "Carnot the Eternal Machine" {
    id: 13567610
    type: Effect Monster | Effect Monster
    attribute: LIGHT
    race: Machine
    level: 10
    atk: 3000
    def: 2500

    summon {
        cannot_normal_summon
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: opponent_activates [activate_spell, activate_trap, activate_spell]
    }

    effect "Effect 3" {
        speed: 1
        mandatory
        trigger: custom "chain_end"
        resolve {
            return (all, card, either controls) to deck
        }
    }
}
