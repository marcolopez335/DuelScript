card "Infinite Machine" {
    id: 36894320
    type: Continuous Trap

    effect "Effect 1" {
        speed: 2
        mandatory
        cost {
            send self to gy
        }
    }

    effect "Effect 3" {
        speed: 2
        resolve {
            special_summon (all, card, either controls)
        }
    }

    effect "Effect 4" {
        speed: 2
        resolve {
            return (all, card, either controls) to deck
        }
    }

    replacement "Effect 2" {
        instead_of: destroyed
        do {
            banish self
        }
    }
}
