card "Fiendsmith's Rextremende" {
    id: 11464648
    type: Fusion Monster
    attribute: LIGHT
    race: Fiend
    level: 9
    atk: 3000
    def: 3600

    summon {
        cannot_normal_summon
    }

    passive "Effect 1" {
        scope: self
        grant: unaffected_by effects
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: summoned by special
        resolve {
            send (all, card, either controls) to gy
        }
    }

    effect "Effect 3" {
        speed: 1
        once_per_turn: soft
        timing: if
        trigger: custom "chain_end"
        resolve {
            add_to_hand (all, card, either controls)
        }
    }
}
