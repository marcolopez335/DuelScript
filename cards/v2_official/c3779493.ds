card "Night's End Administrator" {
    id: 3779493
    type: Synchro Monster
    attribute: LIGHT
    race: Spellcaster
    level: 6
    atk: 2300
    def: 1400

    summon {
        cannot_normal_summon
    }

    effect "Effect 1" {
        speed: 1
        timing: if
        trigger: summoned by special
        resolve {
            banish (all, card, either controls)
        }
    }

    effect "Effect 2" {
        speed: 1
        once_per_turn: hard
        timing: if
        trigger: destroyed
        resolve {
            special_summon (all, card, either controls)
        }
    }
}
