card "Ojama Pajama" {
    id: 75884822
    type: Continuous Trap

    effect "Effect 1" {
        speed: 2
        mandatory
    }

    effect "Effect 2" {
        speed: 2
        once_per_turn: hard
        resolve {
            add_to_hand (all, card, either controls)
            discard (all, card, either controls)
        }
    }

    effect "Effect 4" {
        speed: 2
        once_per_turn: soft
        timing: if
        trigger: custom "chain_end"
        resolve {
            special_summon (all, card, either controls)
        }
    }

    replacement "Effect 3" {
        instead_of: destroyed
        do {
            banish self
        }
    }
}
