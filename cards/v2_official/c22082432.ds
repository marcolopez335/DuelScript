card "Dangers of the Divine" {
    id: 22082432
    type: Quick-Play Spell

    passive "Effect 5" {
        scope: self
        grant: cannot_attack
    }

    effect "Effect 1" {
        speed: 2
        once_per_turn: hard
        mandatory
        cost {
            pay_lp 1000
        }
        resolve {
            special_summon (all, card, either controls)
            destroy (all, card, either controls)
            return (all, card, either controls) to hand
        }
    }

    effect "Effect 2" {
        speed: 2
        once_per_turn: soft
        mandatory
        trigger: custom "chain_end"
        resolve {
            send (all, card, either controls) to gy
        }
    }
}
