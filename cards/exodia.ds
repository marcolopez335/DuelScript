// ============================================================
// exodia.ds — Win condition declaration
// ============================================================

card "Exodia the Forbidden One" {
  type: Effect Monster
  attribute: DARK
  race: Spellcaster
  level: 3
  atk: 1000
  def: 1000

  archetype: ["Forbidden One"]

  // Automatic win when all five Forbidden One pieces are in hand
  win_condition {
    when: all_pieces_in_hand
    result: win_duel
  }
}

// ── The four remaining pieces ─────────────────────────────────

