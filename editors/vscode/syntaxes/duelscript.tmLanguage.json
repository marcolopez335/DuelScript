{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "DuelScript",
  "scopeName": "source.duelscript",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#card-definition" },
    { "include": "#block-keywords" },
    { "include": "#field-keywords" },
    { "include": "#action-keywords" },
    { "include": "#type-keywords" },
    { "include": "#attribute-keywords" },
    { "include": "#race-keywords" },
    { "include": "#zone-keywords" },
    { "include": "#effect-keywords" },
    { "include": "#cost-keywords" },
    { "include": "#trigger-keywords" },
    { "include": "#condition-keywords" },
    { "include": "#modifier-keywords" },
    { "include": "#raw-effect-fields" },
    { "include": "#constants" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.duelscript",
          "match": "//.*$"
        },
        {
          "name": "comment.block.duelscript",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.duelscript",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.duelscript", "match": "\\\\." }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.duelscript",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "card-definition": {
      "patterns": []
    },
    "block-keywords": {
      "patterns": [
        {
          "comment": "Named block: effect \"Name\" { ... } — the name gets entity.name.section so it stands out as a definition title in most themes.",
          "match": "\\b(effect|continuous_effect|replacement_effect|equip_effect|pendulum_effect|flip_effect|raw_effect|global_state|global_handler|option)\\b\\s*(\"[^\"]*\")?",
          "captures": {
            "1": { "name": "keyword.control.block.duelscript" },
            "2": { "name": "entity.name.section.duelscript" }
          }
        },
        {
          "comment": "Card definition: card \"Name\" { ... }",
          "match": "\\b(card)\\b\\s*(\"[^\"]*\")?",
          "captures": {
            "1": { "name": "keyword.control.card.duelscript" },
            "2": { "name": "entity.name.type.duelscript" }
          }
        },
        {
          "name": "keyword.control.block.duelscript",
          "match": "\\b(materials|summon_condition|counter_system|win_condition|restriction|on_activate|on_resolve|on_event|on_equipped_destroyed|on_unequipped|while_equipped|cost|alternative|choose|delayed|register_effect|and_if_you_do|then|also|for_each|apply|if_player_chooses|store|recall)\\b"
        }
      ]
    },
    "field-keywords": {
      "patterns": [
        {
          "name": "support.type.field.duelscript",
          "match": "\\b(type|attribute|race|level|rank|link|scale|atk|def|password|flavor|archetype|link_arrows|method|require|same_level|same_attribute|same_race|must_include|cannot_use|name|max|placed_when|result|instead_of|target|while|apply_to|modifier|grant|duration|count|speed|optional|timing|condition|trigger|scope|activate_from|damage_step|frequency|tracks|resets_on|survives|value|tributes_required|cannot_normal_summon|cannot_special_summon|special_summon_only|must_be_summoned_by|summon_once_per_turn|tribute_material|special_summon_from|once_per_turn|once_per_duel|twice_per_turn|each_turn|position|filter)\\b"
        }
      ]
    },
    "action-keywords": {
      "patterns": [
        {
          "name": "entity.name.function.action.duelscript",
          "match": "\\b(draw|special_summon|destroy|negate|search|add_to_hand|send|banish|return|set|flip_face_down|change_battle_position|take_control|place_counter|remove_counter|look_at|reveal|copy_effect|equip|detach|attach|fusion_summon|synchro_summon|xyz_summon|ritual_summon|pendulum_summon|create_token|deal_damage|gain_lp|shuffle|mill|discard|tribute|set_scale|double_atk|halve_atk|set_atk|set_def|select|emit_event|set_flag|clear_flag|change_level|change_attribute|change_race|change_name|change_code|normal_summon|negate_effects|excavate|confirm|send_to_deck|release|discard_all|shuffle_hand|shuffle_deck|change_position|set_spell_trap|equip_to|overlay|move_to_field|flip_coin|pay_lp)\\b"
        }
      ]
    },
    "type-keywords": {
      "patterns": [
        {
          "name": "storage.type.card.duelscript",
          "match": "\\b(Normal Monster|Effect Monster|Ritual Monster|Fusion Monster|Synchro Monster|Xyz Monster|Link Monster|Pendulum Monster|Tuner|Synchro Tuner|Gemini|Union|Spirit|Flip|Toon|Normal Spell|Quick-Play Spell|Continuous Spell|Equip Spell|Field Spell|Ritual Spell|Normal Trap|Counter Trap|Continuous Trap)\\b"
        }
      ]
    },
    "attribute-keywords": {
      "patterns": [
        {
          "name": "constant.language.attribute.duelscript",
          "match": "\\b(LIGHT|DARK|FIRE|WATER|EARTH|WIND|DIVINE)\\b"
        }
      ]
    },
    "race-keywords": {
      "patterns": [
        {
          "name": "constant.language.race.duelscript",
          "match": "\\b(Dragon|Spellcaster|Zombie|Warrior|Beast-Warrior|Beast|Winged Beast|Fiend|Fairy|Insect|Dinosaur|Reptile|Fish|Sea Serpent|Aqua|Pyro|Thunder|Rock|Plant|Machine|Psychic|Divine-Beast|Creator-God|Wyrm|Cyberse|Illusion|Cyborg|Magical Knight|High Dragon|Omega Psychic)\\b"
        }
      ]
    },
    "zone-keywords": {
      "patterns": [
        {
          "name": "variable.language.zone.duelscript",
          "match": "\\b(hand|field|graveyard|gy|banished|exile|deck|extra_deck|extra_deck_face_up|monster_zone|spell_trap_zone|extra_monster_zone|field_zone|pendulum_zone|top_of_deck|bottom_of_deck)\\b"
        }
      ]
    },
    "effect-keywords": {
      "patterns": [
        {
          "name": "keyword.other.effect.duelscript",
          "match": "\\b(spell_speed_1|spell_speed_2|spell_speed_3|soft|hard|attack_position|defense_position|face_down_defense|until_end_of_turn|until_end_phase|until_end_of_damage_step|until_next_turn|permanently|this_turn|as_material)\\b"
        }
      ]
    },
    "cost-keywords": {
      "patterns": [
        {
          "name": "keyword.operator.cost.duelscript",
          "match": "\\b(pay_lp|overlay_unit|none|announce|must_be)\\b"
        }
      ]
    },
    "trigger-keywords": {
      "patterns": [
        {
          "name": "keyword.control.trigger.duelscript",
          "match": "\\b(when_summoned|when_destroyed|when_battle_destroyed|when_destroys_by_battle|when_leaves_field|when_used_as_material|when_battle_damage|when_banished|when_sent_to|when_flipped|when_attacked|when_tributed|when_tribute_summoned|during_standby_phase|during_end_phase|during|opponent_activates|on_nth_summon|on_custom_event|when_action|attack_declared|by_normal_summon|by_special_summon|by_flip_summon|by_ritual_summon|by_fusion_summon|by_synchro_summon|by_xyz_summon|by_link_summon)\\b"
        }
      ]
    },
    "condition-keywords": {
      "patterns": [
        {
          "name": "keyword.control.condition.duelscript",
          "match": "\\b(chain_link_includes|has_flag|you_control_no_monsters|opponent_controls_no_monsters|field_is_empty|you_control|opponent_controls|you_control_count|your_lp|opponent_lp|hand_size|cards_in_gy|banished_count|on_field|previous_location|previous_position|sent_by_reason|this_effect_activated_this_turn|this_card_was_flipped_this_turn)\\b"
        }
      ]
    },
    "modifier-keywords": {
      "patterns": [
        {
          "name": "support.function.modifier.duelscript",
          "match": "\\b(piercing|double_attack|triple_attack|direct_attack|cannot_be_destroyed_by_battle|cannot_be_destroyed_by_effect|cannot_be_destroyed|cannot_be_targeted_by_spell_effects|cannot_be_targeted_by_trap_effects|cannot_be_targeted_by_monster_effects|cannot_be_targeted_by_card_effects|cannot_be_targeted_by_opponent|unaffected_by_spell_effects|unaffected_by_trap_effects|unaffected_by_monster_effects|unaffected_by_card_effects|unaffected_by_opponent_effects|immune_to_targeting|cannot_activate_effects|cannot_attack_directly|cannot_attack|must_attack_if_able|cannot_be_tributed|cannot_be_used_as_material|cannot_change_battle_position|attack_all_opponent_monsters|attack_twice|second_attack_this_turn|ignores_battle_position|pierces_defense|cannot_be_negated|cannot|must|limit)\\b"
        }
      ]
    },
    "raw-effect-fields": {
      "patterns": [
        {
          "name": "support.type.raw.duelscript",
          "match": "\\b(effect_type|category|code|property|range|count_limit)\\b"
        },
        {
          "comment": "Sprint 56: PascalCase named constants for raw_effect fields",
          "name": "constant.language.named.duelscript",
          "match": "\\b(Single|Field|Equip|Activate|Flip|Ignition|Trigger|OptionalTrigger|QuickEffect|MandatoryTrigger|MandatoryQuick|Continuous|Grant|Destroy|Release|Banish|ToHand|ToDeck|ToGrave|AtkChange|DefChange|Counter|CoinToss|SpecialSummon|Token|PositionChange|LevelChange|FusionSummon|SynchroSummon|XyzSummon|LinkSummon|RitualSummon|Negate|Disable|Draw|Search|EquipAction|Damage|Recover|DiceRoll|Summon|FreeChain|Chaining|Destroyed|SummonSuccess|FlipSummonSuccess|SpecialSummonSuccess|AttackAnnounce|BattleTarget|DamageCalculation|BattleDamage|PhaseStandby|PhaseMain1|PhaseBattle|PhaseMain2|PhaseEnd|CardTarget|Delay|CannotDisable|Uncopyable|PlayerTarget|ClientHint|SingleRange|Hand|MonsterZone|SpellTrapZone|Graveyard|Deck|ExtraDeck|FieldZone|PendulumZone)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.duelscript",
          "match": "\\b(true|false|self|from|to|in|of|by|on|and|or|not|if|else|using|controls|when|until|as|for|either_player|opponent|you|both|both_players|face_up|face_down|random|at_random|top|bottom|shuffle|heads|tails|yours|opponents|either|any|battle|card_effect|your_effect|opponent_effect|selected_targets|where|with_level|own_effect|ritual_spell|fusion_spell|specific_card|your_deck|opponent_deck|your_hand|opponent_hand)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.duelscript",
          "match": "(>=|<=|==|!=|>|<|\\+|\\-|\\*|/|\\|)"
        }
      ]
    }
  }
}
